<%- include('./partials/header') %>
<style>
tr.mail-item { display: table-row; padding: 0; }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Kotak Masuk</div>
    <h1 class="page-title">Kotak Masuk</h1>
    <p class="page-subtitle"><%= mails.filter(m => !m.read).length %> surat belum dibaca dari <%= mails.length %> total</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div id="bulkBar" style="display:none;position:sticky;top:0;z-index:50;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:10px 16px;margin-bottom:12px;display:none;align-items:center;gap:12px;">
  <span id="bulkCount" style="font-size:13px;font-weight:600;color:#b91c1c;"></span>
  <button onclick="bulkDelete()" class="btn" style="background:#ef4444;color:#fff;font-size:12px;padding:5px 14px;border:none;">
    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" style="margin-right:4px"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Hapus Dipilih
  </button>
  <button onclick="clearSelection()" class="btn btn-secondary" style="font-size:12px;padding:5px 12px;">Batal</button>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Kotak Masuk</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Belum Dibaca</div><div class="stat-value"><%= mails.filter(m => !m.read).length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 9v4M10 7h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Mendesak</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Mendesak' || m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Sudah Dibaca</div><div class="stat-value"><%= mails.filter(m => m.read).length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <!-- TABS -->
  <div class="dok-tabs" style="padding:0 16px;">
    <a href="#" class="dok-tab active" id="tab-all" onclick="filterTab('all',this)">Semua <span class="tab-count"><%= mails.length %></span></a>
    <a href="#" class="dok-tab" id="tab-unread" onclick="filterTab('unread',this)">Belum Dibaca <span class="tab-count"><%= mails.filter(m=>!m.read).length %></span></a>
    <a href="#" class="dok-tab" id="tab-mendesak" onclick="filterTab('mendesak',this)">Mendesak <span class="tab-count"><%= mails.filter(m=>m.tag==='Mendesak'||m.tag==='Urgent').length %></span></a>
    <a href="#" class="dok-tab" id="tab-internal" onclick="filterTab('internal',this)">Internal <span class="tab-count"><%= mails.filter(m=>m.jenis==='internal').length %></span></a>
    <a href="#" class="dok-tab" id="tab-eksternal" onclick="filterTab('eksternal',this)">Eksternal <span class="tab-count"><%= mails.filter(m=>m.jenis==='eksternal').length %></span></a>
  </div>
  <!-- SEARCH -->
  <div class="dok-search">
    <input type="text" id="searchBox" class="form-control" style="font-size:13px;" placeholder="Cari subjek, pengirim, nomor surat..." oninput="filterSearch()">
  </div>

  <% if (mails.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M6 10h36a2 2 0 012 2v24a2 2 0 01-2 2H6a2 2 0 01-2-2V12a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M4 14l20 14L44 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Kotak masuk kosong.</p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table class="dok-table" id="mailTable">
      <thead>
        <tr>
          <th style="width:32px;"><input type="checkbox" id="checkAll" onchange="toggleAll(this)" style="cursor:pointer;"></th>
          <th style="width:120px;">Jenis</th>
          <th>Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:130px;">Dari</th>
          <th style="width:90px;">Prioritas</th>
          <th style="width:80px;">Status</th>
          <th style="width:100px;">Tanggal</th>
          <th style="width:50px;"></th>
        </tr>
      </thead>
      <tbody>
      <% const tagCls = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' }; %>
      <% mails.forEach(function(m) { %>
      <tr class="mail-item <%= m.read ? '' : 'unread' %>"
          id="row-<%= m._id %>"
          data-id="<%= m._id %>"
          data-tag="<%= (m.tag||'biasa').toLowerCase() %>"
          data-read="<%= m.read %>"
          data-jenis="<%= (m.jenis||'internal').toLowerCase() %>"
          data-date="<%= m.dateISO||'' %>"
          data-search="<%= (m.subject+' '+m.from+' '+(m.nomorSurat||'')).toLowerCase() %>">
        <td onclick="event.stopPropagation()"><input type="checkbox" class="row-check" value="<%= m._id %>" onchange="updateBulkBar()" style="cursor:pointer;"></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;"><span class="dok-tipe-badge <%= m.tipeSurat==='Nota Dinas'?'tipe-nota':m.tipeSurat==='Surat Dinas'?'tipe-surat':'tipe-lain' %>"><%= m.tipeSurat||'—' %></span></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;"><% if (!m.read) { %><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--brand-500);margin-right:5px;vertical-align:middle;"></span><% } %><%= m.nomorSurat||'—' %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:<%= m.read?'400':'600' %>;"><%= m.subject %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-size:12px;color:var(--gray-500);"><%= m.from||'—' %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;"><span class="mail-tag <%= tagCls[m.tag]||'tag-normal' %>" style="font-size:11px;"><%= m.tag||'Biasa' %></span></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;"><% if(m.read){%><span style="font-size:11px;font-weight:600;color:var(--green-600);">Dibaca</span><%}else{%><span style="font-size:11px;font-weight:600;color:var(--brand-600);">Baru</span><%}%></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-size:12px;color:var(--gray-400);white-space:nowrap;"><%= m.date %></td>
        <td onclick="event.stopPropagation()">
          <button onclick="deleteSingle('<%= m._id %>')" title="Hapus" style="background:none;border:none;cursor:pointer;padding:4px;color:var(--gray-400);border-radius:4px;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--gray-400)'">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </td>
      </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
let activeTab = 'all';
function filterTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.dok-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  filterSearch();
  return false;
}
function filterSearch() {
  const q = (document.getElementById('searchBox').value || '').toLowerCase();
  document.querySelectorAll('#mailTable tbody tr').forEach(row => {
    const search = (row.dataset.search || '');
    const tag    = (row.dataset.tag || '');
    const read   = row.dataset.read === 'true';

    const jenis  = (row.dataset.jenis || '');
    let show = true;
    if (activeTab === 'unread') show = !read;
    else if (activeTab === 'mendesak') show = tag === 'mendesak';
    else if (activeTab === 'internal') show = jenis === 'internal';
    else if (activeTab === 'eksternal') show = jenis === 'eksternal';
    if (show && q) show = search.includes(q);
    row.style.display = show ? '' : 'none';
  });
}

function toggleAll(cb) {
  document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
  updateBulkBar();
}
function updateBulkBar() {
  const checked = document.querySelectorAll('.row-check:checked');
  const bar = document.getElementById('bulkBar');
  if (checked.length > 0) {
    bar.style.display = 'flex';
    document.getElementById('bulkCount').textContent = checked.length + ' surat dipilih';
  } else {
    bar.style.display = 'none';
    document.getElementById('checkAll').checked = false;
  }
}
function clearSelection() {
  document.querySelectorAll('.row-check').forEach(c => c.checked = false);
  document.getElementById('checkAll').checked = false;
  updateBulkBar();
}
async function deleteSingle(id) {
  if (!confirm('Hapus surat ini dari kotak masuk?')) return;
  const res = await fetch('/inbox/' + id, { method: 'DELETE' });
  const data = await res.json();
  if (data.ok) {
    document.getElementById('row-' + id)?.remove();
  } else alert('Gagal menghapus.');
}
async function bulkDelete() {
  const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(c => c.value);
  if (!ids.length) return;
  if (!confirm('Hapus ' + ids.length + ' surat dari kotak masuk?')) return;
  const res = await fetch('/inbox/bulk-delete', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids })
  });
  const data = await res.json();
  if (data.ok) {
    ids.forEach(id => document.getElementById('row-' + id)?.remove());
    clearSelection();
  } else alert('Gagal menghapus.');
}
</script>

<%- include('./partials/footer') %>
