<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Kotak Masuk</div>
    <h1 class="page-title">Kotak Masuk</h1>
    <p class="page-subtitle"><%= mails.filter(m => !m.read).length %> surat belum dibaca dari <%= mails.length %> total</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Kotak Masuk</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Belum Dibaca</div><div class="stat-value"><%= mails.filter(m => !m.read).length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 9v4M10 7h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Urgent</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Sudah Dibaca</div><div class="stat-value"><%= mails.filter(m => m.read).length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
    <span class="mail-list-title" id="listCount"><%= mails.length %> surat masuk</span>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <input type="text" id="searchBox" class="search-input" placeholder="Cari subjek, pengirim..." style="width:220px;padding:7px 12px;" oninput="applyFilters()">
      <div id="activeChips" class="filter-active-chips"></div>
      <div class="filter-wrap">
        <button class="filter-btn" id="filterBtn" onclick="toggleFilterDropdown()">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M6 10h8M9 15h2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          Filter
          <span class="filter-badge" id="filterBadge" style="display:none;">0</span>
        </button>
        <div class="filter-dropdown" id="filterDropdown">
          <div class="filter-section">
            <div class="filter-section-label">Status Baca</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="read" data-val="all" onclick="pickChip(this)">Semua</button>
              <button class="filter-chip" data-group="read" data-val="unread" onclick="pickChip(this)">Belum Dibaca</button>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Prioritas</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="tag" data-val="all" onclick="pickChip(this)">Semua</button>
              <button class="filter-chip" data-group="tag" data-val="penting" onclick="pickChip(this)">Penting</button>
              <button class="filter-chip" data-group="tag" data-val="urgent" onclick="pickChip(this)">Urgent</button>
              <button class="filter-chip" data-group="tag" data-val="normal" onclick="pickChip(this)">Normal</button>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Tipe Surat</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="jenis" data-val="all" onclick="pickChip(this)">Semua</button>
              <button class="filter-chip" data-group="jenis" data-val="internal" onclick="pickChip(this)">Internal</button>
              <button class="filter-chip" data-group="jenis" data-val="eksternal" onclick="pickChip(this)">Eksternal</button>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Tanggal</div>
            <div class="filter-chips" style="margin-bottom:8px;">
              <button class="filter-chip active" data-group="datemode" data-val="all" onclick="pickChip(this);toggleDateMode('all')">Semua</button>
              <button class="filter-chip" data-group="datemode" data-val="single" onclick="pickChip(this);toggleDateMode('single')">Tanggal</button>
              <button class="filter-chip" data-group="datemode" data-val="range" onclick="pickChip(this);toggleDateMode('range')">Rentang</button>
              <button class="filter-chip" data-group="datemode" data-val="month" onclick="pickChip(this);toggleDateMode('month')">Bulan/Tahun</button>
            </div>
            <div id="dateInputSingle" style="display:none;"><div class="filter-date-row"><input type="date" id="dateSingle" oninput="applyFilters()"></div></div>
            <div id="dateInputRange" style="display:none;"><div class="filter-date-row"><input type="date" id="dateFrom" oninput="applyFilters()"><span class="filter-date-sep">s/d</span><input type="date" id="dateTo" oninput="applyFilters()"></div></div>
            <div id="dateInputMonth" style="display:none;"><div class="filter-date-row">
              <select id="dateMonth" onchange="applyFilters()"><option value="">-- Bulan --</option><option value="01">Januari</option><option value="02">Februari</option><option value="03">Maret</option><option value="04">April</option><option value="05">Mei</option><option value="06">Juni</option><option value="07">Juli</option><option value="08">Agustus</option><option value="09">September</option><option value="10">Oktober</option><option value="11">November</option><option value="12">Desember</option></select>
              <select id="dateYear" onchange="applyFilters()"><option value="">-- Tahun --</option><% for(let y=new Date().getFullYear();y>=2020;y--){%><option value="<%=y%>"><%=y%></option><%}%></select>
            </div></div>
          </div>
          <div class="filter-actions">
            <button class="btn btn-ghost" style="font-size:12.5px;padding:6px 14px;" onclick="resetAllFilters()">Reset</button>
            <button class="btn btn-primary" style="font-size:12.5px;padding:6px 14px;" onclick="toggleFilterDropdown()">Tutup</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% mails.forEach(function(m) {
    var initials = m.from.split(' ').slice(0,2).map(function(w){ return w[0]; }).join('').toUpperCase();
    var tagClass = { Penting: 'tag-penting', Urgent: 'tag-urgent', Info: 'tag-info', Normal: 'tag-normal', Draft: 'tag-draft' }[m.tag] || 'tag-normal';
    var avatarColors = ['av-green','av-teal','av-blue','av-amber','av-purple'];
    var avColor = avatarColors[m.id % avatarColors.length];
  %>
  <a href="/email/<%= m.id %>" class="mail-item <%= m.read ? '' : 'unread' %>"
     data-tag="<%= m.tag.toLowerCase() %>" data-read="<%= m.read %>"
     data-jenis="<%= (m.jenis || 'internal').toLowerCase() %>"
     data-date="<%= m.dateISO || '' %>"
     data-search="<%= (m.subject + ' ' + m.from).toLowerCase() %>">
    <div class="mail-avatar <%= avColor %>"><%= initials %></div>
    <div class="mail-body">
      <div class="mail-from"><%= m.from %></div>
      <div class="mail-subject"><%= m.subject %></div>
      <div class="mail-berkas"><%= m.berkas %></div>
    </div>
    <div class="mail-meta">
      <span class="mail-date"><%= m.date %></span>
      <span class="mail-tag <%= tagClass %>"><%= m.tag %></span>
    </div>
  </a>
  <% }); %>
</div>

<script>
window._countSuffix = ' surat masuk';
<%- include('./partials/filter-script') %>
</script>

<%- include('./partials/footer') %>
