<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Buku Panduan — <%= ss.siteName %></title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Times+New+Roman&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Times New Roman', Times, serif;
    font-size: 12pt;
    color: #000;
    background: #fff;
    line-height: 1.8;
  }

  /* ── PRINT LAYOUT ── */
  @page {
    size: A4;
    margin: 2.5cm 3cm 2.5cm 3cm;
  }
  @page :first { margin-top: 0; margin-bottom: 0; }

  .page-break { page-break-before: always; break-before: page; }
  .no-break    { page-break-inside: avoid; break-inside: avoid; }

  /* ── COVER ── */
  .cover {
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 40px;
    border: 3px double #000;
    page-break-after: always;
    break-after: page;
  }
  .cover-logo {
    width: 90px;
    height: 90px;
    object-fit: contain;
    margin-bottom: 32px;
  }
  .cover-org {
    font-size: 11pt;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
    color: #333;
  }
  .cover-title {
    font-size: 22pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .cover-subtitle {
    font-size: 13pt;
    margin-bottom: 40px;
    color: #333;
  }
  .cover-system {
    font-size: 14pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 4px;
  }
  .cover-tagline {
    font-size: 10pt;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 60px;
  }
  .cover-divider {
    width: 80px;
    border: none;
    border-top: 1.5px solid #000;
    margin: 20px auto;
  }
  .cover-year {
    font-size: 11pt;
    color: #444;
    margin-top: 16px;
  }

  /* ── CONTENT ── */
  .doc {
    max-width: 100%;
    padding: 0;
  }

  h1.chapter {
    font-size: 14pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: 16px;
    padding-bottom: 6px;
    border-bottom: 1.5px solid #000;
  }
  h2.section {
    font-size: 12pt;
    font-weight: bold;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  h3.subsection {
    font-size: 12pt;
    font-weight: bold;
    font-style: italic;
    margin-top: 14px;
    margin-bottom: 6px;
  }
  p {
    text-align: justify;
    margin-bottom: 10px;
    text-indent: 2em;
  }
  p.no-indent { text-indent: 0; }
  ul, ol {
    margin: 8px 0 12px 2.5em;
  }
  li {
    margin-bottom: 4px;
    line-height: 1.7;
  }
  table.info-table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 11pt;
  }
  table.info-table th, table.info-table td {
    border: 1px solid #555;
    padding: 6px 10px;
    text-align: left;
    vertical-align: top;
  }
  table.info-table th {
    background: #f0f0f0;
    font-weight: bold;
  }
  .chapter-block {
    margin-bottom: 40px;
  }
  .toc-entry {
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
    font-size: 11.5pt;
  }
  .toc-entry.main { font-weight: bold; margin-top: 10px; }
  .toc-dots {
    flex: 1;
    border-bottom: 1px dotted #555;
    margin: 0 8px 4px;
  }
  .abstract-box {
    border: 1px solid #aaa;
    padding: 20px 24px;
    margin: 20px 0 30px;
    background: #fafafa;
  }
  .abstract-title {
    font-weight: bold;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
    font-size: 11pt;
  }
  .abstract-box p { font-size: 11pt; }

  .print-btn {
    position: fixed;
    top: 20px;
    right: 20px;
    background: #071840;
    color: #fff;
    border: none;
    padding: 10px 22px;
    font-size: 13px;
    font-family: Arial, sans-serif;
    cursor: pointer;
    border-radius: 6px;
    z-index: 999;
  }
  .print-btn:hover { background: #0a2060; }

  @media print {
    .print-btn { display: none; }
    body { background: #fff; }
  }

  .page-num {
    font-size: 10pt;
    text-align: center;
    margin-top: 30px;
    color: #666;
  }
  .header-line {
    display: flex;
    justify-content: space-between;
    font-size: 9pt;
    color: #666;
    border-bottom: 1px solid #ccc;
    padding-bottom: 4px;
    margin-bottom: 24px;
  }
</style>
</head>
<body>

<button class="print-btn" onclick="window.print()">Cetak / Simpan PDF</button>

<!-- ══════════════ COVER ══════════════ -->
<div class="cover">
  <% if (ss.logoBase64) { %>
  <img src="<%= ss.logoBase64 %>" class="cover-logo" alt="Logo">
  <% } else { %>
  <img src="/img/Group 1597880519.png" class="cover-logo" alt="Logo">
  <% } %>
  <div class="cover-org"><%= ss.siteName %> — <%= ss.siteSub || '' %></div>
  <hr class="cover-divider">
  <div class="cover-title">Buku Panduan Pengguna</div>
  <div class="cover-subtitle">Panduan Penggunaan Sistem Pengelolaan Naskah Dinas</div>
  <hr class="cover-divider">
  <div class="cover-system"><%= ss.siteName %></div>
  <div class="cover-tagline"><%= ss.siteTagline || 'Sistem Surat Dinas Digital' %></div>
  <div class="cover-year">Versi 1.0 &nbsp;&middot;&nbsp; <%= new Date().getFullYear() %></div>
</div>

