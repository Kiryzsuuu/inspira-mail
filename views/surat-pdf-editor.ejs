<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Editor PDF — <%= surat.perihal %></title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: #0f172a; color: #1e293b; min-height: 100vh; }

/* ── TOOLBAR ── */
.pdf-toolbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 54px;
  background: #071840;
  display: flex; align-items: center; gap: 12px;
  padding: 0 20px;
  box-shadow: 0 1px 0 rgba(255,255,255,.08);
}
.toolbar-back {
  display: flex; align-items: center; gap: 6px;
  color: rgba(255,255,255,.6); font-size: 13px; text-decoration: none;
  padding: 5px 10px; border-radius: 6px;
  transition: background .15s;
}
.toolbar-back:hover { background: rgba(255,255,255,.08); color: #fff; }
.toolbar-sep { width: 1px; height: 20px; background: rgba(255,255,255,.12); }
.toolbar-title { font-size: 13.5px; font-weight: 500; color: #fff; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.toolbar-hint { font-size: 12px; color: rgba(255,255,255,.4); }
.btn-dl {
  display: flex; align-items: center; gap: 6px;
  background: #1a56a8; color: #fff; border: none; border-radius: 7px;
  padding: 7px 16px; font-size: 13px; font-weight: 500; cursor: pointer;
  transition: background .15s; white-space: nowrap;
}
.btn-dl:hover { background: #1d63c0; }

/* ── LAYOUT ── */
.pdf-shell { display: flex; height: 100vh; padding-top: 54px; }

/* ── CANVAS ── */
.pdf-canvas-area {
  flex: 1; overflow: auto;
  background: #1e293b;
  display: flex; align-items: flex-start; justify-content: center;
  padding: 40px 24px;
}

/* ── A4 PAGE ── */
.a4-page {
  position: relative;
  width: 794px;
  min-height: 1123px;
  background: #fff;
  box-shadow: 0 8px 40px rgba(0,0,0,.5);
  flex-shrink: 0;
  overflow: hidden;
}

/* Document content inside A4 */
.doc-header {
  background: #071840;
  padding: 28px 48px 22px;
  display: flex; align-items: center; gap: 18px;
}
.doc-header-logo {
  width: 40px; height: 40px; object-fit: contain; filter: brightness(10);
}
.doc-header-text { color: #fff; }
.doc-header-org { font-size: 15px; font-weight: 600; letter-spacing: .3px; }
.doc-header-sub { font-size: 11px; color: rgba(255,255,255,.55); margin-top: 1px; }

.doc-divider { height: 4px; background: linear-gradient(90deg,#1a56a8,#0f3270); }

.doc-type-banner {
  background: #f8fafc;
  border-bottom: 1px solid #e2e8f0;
  padding: 14px 48px;
  display: flex; align-items: center; gap: 12px;
}
.doc-type-label {
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: #64748b;
}
.doc-type-pill {
  font-size: 10.5px; font-weight: 600; padding: 3px 10px;
  border-radius: 20px; letter-spacing: .5px;
}
.pill-urgent { background: #fee2e2; color: #991b1b; }
.pill-penting { background: #fef9c3; color: #854d0e; }
.pill-normal  { background: #e0f2fe; color: #075985; }
.pill-info    { background: #f0fdf4; color: #166534; }

.doc-body { padding: 32px 48px 24px; }

.doc-title {
  font-size: 18px; font-weight: 700; color: #0f172a;
  margin-bottom: 24px; line-height: 1.4;
}

.doc-info-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
.doc-info-table td {
  padding: 8px 0; vertical-align: top;
  font-size: 13px; color: #334155;
  border-bottom: 1px solid #f1f5f9;
}
.doc-info-table td:first-child {
  width: 150px; font-weight: 600; color: #64748b;
  font-size: 12px; text-transform: uppercase; letter-spacing: .5px;
  padding-right: 16px;
}
.doc-info-table td .colon { color: #94a3b8; padding-right: 8px; }

.doc-catatan {
  background: #f8fafc; border: 1px solid #e2e8f0;
  border-radius: 8px; padding: 14px 16px; margin-top: 4px;
}
.doc-catatan-label { font-size: 10.5px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #94a3b8; margin-bottom: 6px; }
.doc-catatan-text  { font-size: 13px; color: #475569; line-height: 1.7; }

.doc-sig-area {
  padding: 24px 48px 40px;
  border-top: 1px solid #f1f5f9;
}
.doc-sig-label {
  font-size: 10.5px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: #94a3b8; margin-bottom: 16px;
}
.doc-sig-hint {
  font-size: 12px; color: #94a3b8; font-style: italic;
  text-align: center; padding: 24px 0;
}

/* ── QR STAMP (draggable/resizable) ── */
.qr-stamp {
  position: absolute;
  cursor: move;
  user-select: none;
  border: 2px dashed transparent;
  border-radius: 4px;
  transition: border-color .15s;
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 4px;
}
.qr-stamp:hover, .qr-stamp.active { border-color: #1a56a8; }
.qr-stamp img {
  width: 100%;
  display: block;
  flex-shrink: 0;
}
.qr-stamp-sig {
  width: 100%;
  border-top: 1.5px solid #071840;
  margin-top: 4px;
}
.qr-stamp-name {
  font-size: 8.5px; font-weight: 700; text-align: center;
  color: #071840; padding: 3px 4px 0;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 100%; line-height: 1.3;
}
.qr-stamp-role {
  font-size: 7.5px; color: #475569; text-align: center;
  padding: 1px 4px 2px; white-space: nowrap; overflow: hidden;
  text-overflow: ellipsis; max-width: 100%;
}
.qr-resize {
  position: absolute; bottom: 0; right: 0;
  width: 12px; height: 12px; cursor: se-resize;
  background: #1a56a8; border-radius: 2px 0 0 0; opacity: 0;
  transition: opacity .15s;
}
.qr-stamp:hover .qr-resize, .qr-stamp.active .qr-resize { opacity: 1; }
.qr-delete {
  position: absolute; top: -10px; right: -10px;
  width: 20px; height: 20px; border-radius: 50%;
  background: #ef4444; color: #fff; border: none; cursor: pointer;
  font-size: 12px; line-height: 20px; text-align: center;
  opacity: 0; transition: opacity .15s; display: flex; align-items: center; justify-content: center;
}
.qr-stamp:hover .qr-delete, .qr-stamp.active .qr-delete { opacity: 1; }

/* ── RIGHT PANEL ── */
.pdf-panel {
  width: 280px; flex-shrink: 0;
  background: #0f172a; border-left: 1px solid rgba(255,255,255,.06);
  overflow-y: auto; display: flex; flex-direction: column;
}
.panel-section { padding: 20px; border-bottom: 1px solid rgba(255,255,255,.06); }
.panel-title { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.35); margin-bottom: 14px; }
.panel-hint { font-size: 12px; color: rgba(255,255,255,.4); line-height: 1.6; margin-bottom: 14px; }

.btn-add-self {
  width: 100%; padding: 9px; border-radius: 8px;
  background: #1a56a8; color: #fff; border: none; cursor: pointer;
  font-size: 13px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 6px;
  transition: background .15s;
}
.btn-add-self:hover { background: #1d63c0; }
.btn-add-self:disabled { background: #334155; color: rgba(255,255,255,.35); cursor: not-allowed; }

.cosign-toggle {
  display: flex; align-items: center; gap: 10px; cursor: pointer;
  padding: 10px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.04); color: rgba(255,255,255,.75); font-size: 13px;
  transition: background .15s, border-color .15s;
}
.cosign-toggle input { accent-color: #1a56a8; width: 15px; height: 15px; }
.cosign-toggle:hover { background: rgba(255,255,255,.07); }

.cosign-panel { margin-top: 12px; display: none; }
.cosign-panel.open { display: block; }
.panel-select {
  width: 100%; padding: 8px 10px; border-radius: 6px;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  color: #fff; font-size: 13px; margin-bottom: 8px;
  outline: none;
}
.panel-select option { background: #1e293b; color: #fff; }
.btn-add-cosign {
  width: 100%; padding: 8px; border-radius: 6px;
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.8); font-size: 13px; cursor: pointer;
  transition: background .15s;
}
.btn-add-cosign:hover { background: rgba(255,255,255,.14); }

/* Signer list in panel */
.signer-list { display: flex; flex-direction: column; gap: 8px; }
.signer-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; border-radius: 8px;
  background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08);
}
.signer-av {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg,#0f3270,#1a56a8);
  color: #fff; font-size: 11px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.signer-info { flex: 1; min-width: 0; }
.signer-name { font-size: 12.5px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.signer-role { font-size: 11px; color: rgba(255,255,255,.4); margin-top: 1px; }
.signer-del {
  width: 24px; height: 24px; border-radius: 5px;
  background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.2);
  color: #ef4444; font-size: 13px; cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  transition: background .15s;
}
.signer-del:hover { background: rgba(239,68,68,.3); }

.empty-signers {
  text-align: center; padding: 20px 0;
  color: rgba(255,255,255,.25); font-size: 12px; line-height: 1.7;
}

/* ── PRINT / PDF STYLES ── */
@media print {
  @page { size: A4; margin: 0; }
  html, body { margin: 0; padding: 0; background: #fff !important; }
  .pdf-toolbar, .pdf-panel { display: none !important; }
  .pdf-shell { display: block !important; padding-top: 0 !important; }
  .pdf-canvas-area {
    display: block !important;
    padding: 0 !important;
    background: #fff !important;
    overflow: visible !important;
  }
  .a4-page {
    width: 210mm !important;
    min-height: 297mm !important;
    box-shadow: none !important;
    overflow: hidden !important;
  }
  .qr-resize, .qr-delete { display: none !important; }
  .qr-stamp { border-color: transparent !important; cursor: default !important; }
}
</style>
</head>
<body>

<!-- Toolbar -->
<div class="pdf-toolbar">
  <a href="/surat-masuk/<%= surat._id %>" class="toolbar-back">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M12 4l-8 8 8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Kembali
  </a>
  <div class="toolbar-sep"></div>
  <div class="toolbar-title">Editor PDF — <%= surat.perihal %></div>
  <span class="toolbar-hint">Drag QR untuk memindahkan • Tarik sudut kanan bawah untuk resize</span>
  <button class="btn-dl" onclick="downloadPDF()">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M6 9l4 4 4-4M3 17h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Download PDF (A4)
  </button>
</div>

<div class="pdf-shell">

  <!-- A4 Canvas -->
  <div class="pdf-canvas-area">
    <div class="a4-page" id="a4Page">

      <!-- Header -->
      <div class="doc-header">
        <img src="/img/Group 1597880519.png" class="doc-header-logo" alt="Logo" onerror="this.style.display='none'">
        <div class="doc-header-text">
          <div class="doc-header-org">Inspira Mailer</div>
          <div class="doc-header-sub">Sistem Manajemen Surat & Dokumen Digital</div>
        </div>
      </div>
      <div class="doc-divider"></div>

      <!-- Type banner -->
      <div class="doc-type-banner">
        <div class="doc-type-label">Dokumen Resmi</div>
        <span class="doc-type-pill pill-<%= surat.klasifikasi.toLowerCase() %>"><%= surat.klasifikasi %></span>
      </div>

      <!-- Body -->
      <div class="doc-body">
        <div class="doc-title">SURAT MASUK<% if (surat.nomorSurat) { %> — <%= surat.nomorSurat %><% } %></div>

        <table class="doc-info-table">
          <% if (surat.nomorSurat) { %>
          <tr>
            <td>Nomor Surat<span class="colon">:</span></td>
            <td><strong><%= surat.nomorSurat %></strong></td>
          </tr>
          <% } %>
          <tr>
            <td>Dari<span class="colon">:</span></td>
            <td><strong><%= surat.dariInstansi %></strong></td>
          </tr>
          <tr>
            <td>Perihal<span class="colon">:</span></td>
            <td><%= surat.perihal %></td>
          </tr>
          <tr>
            <td>Tanggal Surat<span class="colon">:</span></td>
            <td><%= surat.tanggalSurat ? new Date(surat.tanggalSurat).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) : '—' %></td>
          </tr>
          <tr>
            <td>Tanggal Diterima<span class="colon">:</span></td>
            <td><%= new Date(surat.tanggalTerima).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) %></td>
          </tr>
          <tr>
            <td>Klasifikasi<span class="colon">:</span></td>
            <td><%= surat.klasifikasi %></td>
          </tr>
          <tr>
            <td>Dicatat oleh<span class="colon">:</span></td>
            <td><%= surat.dicatatOleh?.name || '—' %></td>
          </tr>
          <% if (surat.catatan) { %>
          <tr>
            <td style="padding-top:12px;vertical-align:top;">Catatan<span class="colon">:</span></td>
            <td style="padding-top:12px;">
              <div class="doc-catatan">
                <div class="doc-catatan-label">Disposisi / Catatan</div>
                <div class="doc-catatan-text"><%= surat.catatan %></div>
              </div>
            </td>
          </tr>
          <% } %>
        </table>
      </div>

      <!-- Signature area -->
      <div class="doc-sig-area">
        <div class="doc-sig-label">Area Tanda Tangan Digital</div>
        <div id="sigHint" class="doc-sig-hint" style="<%= docSig.signers.length > 0 ? 'display:none' : '' %>">
          Tambahkan tanda tangan dari panel kanan, lalu seret ke posisi yang diinginkan.
        </div>
      </div>

      <!-- QR stamps rendered from server data -->
      <% docSig.signers.forEach(function(s) {
        const roleLabel = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
      %>
      <div class="qr-stamp" id="stamp-<%= s._id %>"
        data-id="<%= s._id %>"
        style="left:<%= s.position.x %>px;top:<%= s.position.y %>px;width:<%= s.position.width %>px;height:<%= s.position.height %>px;">
        <img src="<%= s.qrDataUrl %>" alt="QR <%= s.userName %>" draggable="false">
        <div class="qr-stamp-sig"></div>
        <div class="qr-stamp-name"><%= s.userName %></div>
        <div class="qr-stamp-role"><%= s.userRole ? roleLabel[s.userRole] || s.userRole : (s.userOrg || '') %></div>
        <div class="qr-resize"></div>
        <button class="qr-delete" onclick="removeSigner('<%= s._id %>', event)" title="Hapus">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>
      <% }) %>

    </div><!-- /a4-page -->
  </div><!-- /canvas-area -->

  <!-- Right Panel -->
  <div class="pdf-panel">

    <!-- Self sign section -->
    <div class="panel-section">
      <div class="panel-title">Tanda Tangan Saya</div>
      <div class="panel-hint">Tambahkan tanda tangan QR Anda ke dokumen ini. Setiap dokumen memiliki QR unik tersendiri.</div>
      <button class="btn-add-self" id="btnAddSelf" onclick="addSelf()"
        <% if (docSig.signers.some(s => s.userId.toString() === currentUser._id.toString())) { %>disabled<% } %>>
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <% if (docSig.signers.some(s => s.userId.toString() === currentUser._id.toString())) { %>
          Sudah Ditambahkan
        <% } else { %>
          Tambah Tanda Tangan Saya
        <% } %>
      </button>
    </div>

    <!-- Co-sign section -->
    <div class="panel-section">
      <div class="panel-title">Co-Sign</div>
      <label class="cosign-toggle">
        <input type="checkbox" id="coSignCheck" onchange="toggleCoSign(this)">
        Aktifkan Multi Penandatangan
      </label>
      <div class="cosign-panel" id="coSignPanel">
        <div style="margin-top:12px;">
          <select class="panel-select" id="coSignSelect">
            <option value="">— Pilih pengguna —</option>
            <% users.forEach(u => { %>
            <% if (u._id.toString() !== currentUser._id.toString()) { %>
            <option value="<%= u._id %>"><%= u.name %> (<%= u.email %>)</option>
            <% } %>
            <% }) %>
          </select>
          <button class="btn-add-cosign" onclick="addCoSigner()">
            + Tambah Penandatangan
          </button>
        </div>
      </div>
    </div>

    <!-- Signer list -->
    <div class="panel-section" style="flex:1;">
      <div class="panel-title">Daftar Penandatangan (<span id="signerCount"><%= docSig.signers.length %></span>)</div>
      <div class="signer-list" id="signerList">
        <% if (docSig.signers.length === 0) { %>
        <div class="empty-signers" id="emptySig">
          Belum ada penandatangan.<br>Tambahkan tanda tangan di atas.
        </div>
        <% } %>
        <% docSig.signers.forEach(function(s) {
          const initials = s.userName.split(' ').slice(0,2).map(w => w[0] || '').join('').toUpperCase();
          const roleLabel = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
        %>
        <div class="signer-item" id="si-<%= s._id %>">
          <div class="signer-av"><%= initials %></div>
          <div class="signer-info">
            <div class="signer-name"><%= s.userName %></div>
            <div class="signer-role"><%= s.userRole ? roleLabel[s.userRole] || s.userRole : s.userOrg || '' %></div>
          </div>
          <button class="signer-del" onclick="removeSigner('<%= s._id %>', event)" title="Hapus">
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </button>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- QR Info -->
    <div class="panel-section" style="border-bottom:none;">
      <div class="panel-title">Info</div>
      <div style="font-size:11.5px;color:rgba(255,255,255,.3);line-height:1.8;">
        • Setiap QR unik per dokumen &amp; penandatangan<br>
        • Scan QR untuk verifikasi keaslian dokumen<br>
        • Seret QR untuk ubah posisi<br>
        • Tarik sudut kanan bawah untuk resize
      </div>
    </div>

  </div><!-- /panel -->

</div><!-- /shell -->

<script>
const SURAT_ID = '<%= surat._id %>';
const CURRENT_USER_ID = '<%= currentUser._id %>';

// ── DRAG & RESIZE ──
let dragState = null;

document.addEventListener('mousemove', onMouseMove);
document.addEventListener('mouseup', onMouseUp);

function onMouseMove(e) {
  if (!dragState) return;
  const { type, el, startX, startY, origX, origY, origW, origH, page } = dragState;
  const dx = e.clientX - startX;
  const dy = e.clientY - startY;
  const rect = page.getBoundingClientRect();

  if (type === 'drag') {
    let nx = origX + dx;
    let ny = origY + dy;
    nx = Math.max(0, Math.min(nx, rect.width - el.offsetWidth));
    ny = Math.max(0, Math.min(ny, page.scrollHeight - el.offsetHeight));
    el.style.left = nx + 'px';
    el.style.top  = ny + 'px';
  } else { // resize
    let nw = Math.max(60, origW + dx);
    let nh = Math.max(60, origH + dy);
    nw = Math.min(nw, rect.width - origX);
    el.style.width  = nw + 'px';
    el.style.height = nh + 'px';
  }
}

function onMouseUp(e) {
  if (!dragState) return;
  const el = dragState.el;
  el.classList.remove('active');
  savePosition(el.dataset.id, el);
  dragState = null;
}

function initStamp(el) {
  const page = document.getElementById('a4Page');

  el.addEventListener('mousedown', function(e) {
    if (e.target.classList.contains('qr-resize') || e.target.closest('.qr-delete')) return;
    e.preventDefault();
    el.classList.add('active');
    dragState = {
      type: 'drag', el,
      startX: e.clientX, startY: e.clientY,
      origX: parseInt(el.style.left) || 0,
      origY: parseInt(el.style.top)  || 0,
      page
    };
  });

  const resizeHandle = el.querySelector('.qr-resize');
  if (resizeHandle) {
    resizeHandle.addEventListener('mousedown', function(e) {
      e.preventDefault(); e.stopPropagation();
      el.classList.add('active');
      dragState = {
        type: 'resize', el,
        startX: e.clientX, startY: e.clientY,
        origX: parseInt(el.style.left) || 0,
        origY: parseInt(el.style.top)  || 0,
        origW: el.offsetWidth,
        origH: el.offsetHeight,
        page
      };
    });
  }
}

// Init all existing stamps
document.querySelectorAll('.qr-stamp').forEach(initStamp);

// ── SAVE POSITION ──
async function savePosition(signerId, el) {
  await fetch(`/surat-masuk/${SURAT_ID}/pdf/update-position`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      signerId,
      x: parseInt(el.style.left) || 0,
      y: parseInt(el.style.top)  || 0,
      width:  el.offsetWidth,
      height: el.offsetHeight
    })
  });
}

// ── ADD SELF ──
async function addSelf() {
  const btn = document.getElementById('btnAddSelf');
  btn.disabled = true;
  btn.textContent = 'Memproses...';

  const res = await fetch(`/surat-masuk/${SURAT_ID}/pdf/add-signer`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId: CURRENT_USER_ID })
  });
  const data = await res.json();

  if (data.ok) {
    addStampToPage(data.signer);
    addSignerToPanel(data.signer);
    btn.textContent = 'Sudah Ditambahkan';
  } else {
    alert(data.message || 'Gagal menambahkan tanda tangan.');
    btn.disabled = false;
    btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Tambah Tanda Tangan Saya`;
  }
}

// ── CO-SIGN TOGGLE ──
function toggleCoSign(cb) {
  document.getElementById('coSignPanel').classList.toggle('open', cb.checked);
}

// ── ADD CO-SIGNER ──
async function addCoSigner() {
  const sel = document.getElementById('coSignSelect');
  const userId = sel.value;
  if (!userId) { alert('Pilih pengguna terlebih dahulu.'); return; }

  const res = await fetch(`/surat-masuk/${SURAT_ID}/pdf/add-signer`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId })
  });
  const data = await res.json();

  if (data.ok) {
    addStampToPage(data.signer);
    addSignerToPanel(data.signer);
    // Remove from dropdown
    sel.querySelector(`option[value="${userId}"]`)?.remove();
    sel.value = '';
  } else {
    alert(data.message || 'Gagal menambahkan penandatangan.');
  }
}

// ── ADD STAMP TO A4 ──
function addStampToPage(signer) {
  const page = document.getElementById('a4Page');
  document.getElementById('sigHint').style.display = 'none';

  const div = document.createElement('div');
  div.className = 'qr-stamp';
  div.id = `stamp-${signer._id}`;
  div.dataset.id = signer._id;
  div.style.cssText = `left:${signer.position.x}px;top:${signer.position.y}px;width:${signer.position.width}px;height:${signer.position.height}px;`;

  const roleLabels = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
  const roleText = signer.userRole ? (roleLabels[signer.userRole] || signer.userRole) : (signer.userOrg || '');

  div.innerHTML = `
    <img src="${signer.qrDataUrl}" alt="QR ${signer.userName}" draggable="false">
    <div class="qr-stamp-sig"></div>
    <div class="qr-stamp-name">${signer.userName}</div>
    <div class="qr-stamp-role">${roleText}</div>
    <div class="qr-resize"></div>
    <button class="qr-delete" onclick="removeSigner('${signer._id}', event)" title="Hapus">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
  `;

  page.appendChild(div);
  initStamp(div);
}

// ── ADD SIGNER TO PANEL LIST ──
function addSignerToPanel(signer) {
  document.getElementById('emptySig')?.remove();
  const roleLabels = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
  const roleText = signer.userRole ? (roleLabels[signer.userRole] || signer.userRole) : (signer.userOrg || '');
  const initials = signer.userName.split(' ').slice(0,2).map(w => w[0] || '').join('').toUpperCase();

  const list = document.getElementById('signerList');
  const item = document.createElement('div');
  item.className = 'signer-item';
  item.id = `si-${signer._id}`;
  item.innerHTML = `
    <div class="signer-av">${initials}</div>
    <div class="signer-info">
      <div class="signer-name">${signer.userName}</div>
      <div class="signer-role">${roleText}</div>
    </div>
    <button class="signer-del" onclick="removeSigner('${signer._id}', event)" title="Hapus">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>
  `;
  list.appendChild(item);
  updateCount(1);
}

// ── REMOVE SIGNER ──
async function removeSigner(signerId, e) {
  if (e) { e.preventDefault(); e.stopPropagation(); }
  if (!confirm('Hapus penandatangan ini dari dokumen?')) return;

  const res = await fetch(`/surat-masuk/${SURAT_ID}/pdf/signers/${signerId}`, { method: 'DELETE' });
  const data = await res.json();

  if (data.ok) {
    document.getElementById(`stamp-${signerId}`)?.remove();
    document.getElementById(`si-${signerId}`)?.remove();
    updateCount(-1);

    const list = document.getElementById('signerList');
    if (!list.querySelector('.signer-item')) {
      const hint = document.createElement('div');
      hint.className = 'empty-signers';
      hint.id = 'emptySig';
      hint.innerHTML = 'Belum ada penandatangan.<br>Tambahkan tanda tangan di atas.';
      list.appendChild(hint);
      document.getElementById('sigHint').style.display = '';
    }

    // Re-enable self button if own signature was removed
    const selfBtn = document.getElementById('btnAddSelf');
    if (data.wasCurrentUser || signerId === data.removedUserId) {
      selfBtn.disabled = false;
      selfBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Tambah Tanda Tangan Saya`;
    }
  }
}

function updateCount(delta) {
  const el = document.getElementById('signerCount');
  el.textContent = parseInt(el.textContent) + delta;
}

// ── DOWNLOAD PDF ──
function downloadPDF() {
  window.print();
}
</script>

