<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= siteSettings && siteSettings.siteName ? siteSettings.siteName : 'Inspira' %> <%= siteSettings && siteSettings.siteSub ? siteSettings.siteSub : 'Mailer' %> — <%= title %></title>
<link rel="icon" type="image/png" href="<%= siteSettings && siteSettings.logoBase64 ? siteSettings.logoBase64 : '/img/Group 1597880519.png' %>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href="/inbox" class="brand">
        <img src="<%= siteSettings && siteSettings.logoBase64 ? siteSettings.logoBase64 : '/img/Group 1597880519.png' %>" alt="Logo" class="brand-logo">
        <div class="brand-text">
          <span class="brand-name"><%= siteSettings && siteSettings.siteName ? siteSettings.siteName : 'Inspira' %></span>
          <span class="brand-sub"><%= siteSettings && siteSettings.siteSub ? siteSettings.siteSub : 'Mailer' %></span>
        </div>
      </a>
      <button class="sidebar-close" id="sidebarClose" aria-label="Tutup">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="compose-btn-wrap">
      <a href="/compose" class="compose-btn">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 2v11M2 7.5h11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Tulis Surat
      </a>
    </div>

    <nav class="sidebar-nav">
      <a href="/inbox" class="nav-item <%= active === 'inbox' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Kotak Masuk
        <% if (inboxCount > 0) { %><span class="badge"><%= inboxCount %></span><% } %>
      </a>
      <a href="/surat-masuk" class="nav-item <%= active === 'surat-masuk' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 11l-5 4M12 11l5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
        Surat Masuk
        <% if (inboxCount > 0) { %><span class="badge"><%= inboxCount %></span><% } %>
      </a>
      <a href="/sent" class="nav-item <%= active === 'sent' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Terkirim
      </a>
      <a href="/compose" class="nav-item <%= active === 'compose' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M4 4h12a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M7 8h6M7 11h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 14l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Manajemen Dokumen
        <% if (draftCount > 0) { %><span class="badge badge-muted"><%= draftCount %></span><% } %>
      </a>
      <div class="nav-divider"></div>
      <a href="/digsig" class="nav-item <%= active === 'digsig' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 17l4-4L14 6l3 3-7 7-4 1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 3l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Digsig
      </a>
      <a href="/log-penomoran" class="nav-item <%= active === 'log-penomoran' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h8M4 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="14" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
        Log Penomoran
      </a>
      <a href="/shorturl" class="nav-item <%= active === 'shorturl' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M8 12l-4 4a5.657 5.657 0 000-8l4-4M12 8l4-4a5.657 5.657 0 010 8l-4 4M8.5 11.5l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Short URL
      </a>
      <a href="/tugas" class="nav-item <%= active === 'tugas' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M9 5H7a2 2 0 00-2 2v8a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h0a2 2 0 002-2M9 5a2 2 0 012-2h0a2 2 0 012 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12l1.5 1.5L13 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Tugas
      </a>
      <% if (user && (user.role === 'admin' || user.role === 'superadmin' || user.role === 'direktur')) { %>
      <div class="nav-divider"></div>
      <% } %>
      <% if (user && user.role === 'direktur') { %>
      <a href="/direktur/overview" class="nav-item <%= active === 'direktur' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Ringkasan Org
      </a>
      <% } %>
      <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
      <a href="/direktur/overview" class="nav-item <%= active === 'direktur' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Ringkasan Org
      </a>
      <a href="/admin" class="nav-item <%= active === 'admin' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
        Admin Dashboard
      </a>
      <a href="/admin/direktorat" class="nav-item <%= active === 'direktorat' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 7h14M3 7V5a1 1 0 011-1h12a1 1 0 011 1v2M3 7v9a1 1 0 001 1h12a1 1 0 001-1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 11h4M10 9v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Direktorat
      </a>
      <a href="/admin/jabatan" class="nav-item <%= active === 'jabatan' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M3 17c0-3.3 3.1-6 7-6s7 2.7 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Jabatan
      </a>
      <a href="/admin/organisasi" class="nav-item <%= active === 'organisasi' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 7h14M3 7V5a1 1 0 011-1h12a1 1 0 011 1v2M3 7v9a1 1 0 001 1h12a1 1 0 001-1V7M8 11h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Organisasi
      </a>
      <a href="/admin/site-settings" class="nav-item <%= active === 'site-settings' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M10 13a3 3 0 100-6 3 3 0 000 6z" stroke="currentColor" stroke-width="1.5"/><path d="M17.66 10a7.58 7.58 0 00-.07-1l1.42-1.11a.34.34 0 00.08-.43l-1.35-2.34a.34.34 0 00-.41-.15l-1.67.67a7.6 7.6 0 00-.87-.5l-.25-1.78A.34.34 0 0014.16 3h-2.7a.34.34 0 00-.34.29l-.25 1.78a7.6 7.6 0 00-.87.5l-1.67-.67a.34.34 0 00-.41.15L6.57 7.46a.34.34 0 00.08.43L8.07 9a7.58 7.58 0 000 2l-1.42 1.11a.34.34 0 00-.08.43l1.35 2.34c.08.15.26.21.41.15l1.67-.67c.28.18.57.34.87.5l.25 1.78c.04.17.19.29.34.29h2.7c.16 0 .3-.12.34-.29l.25-1.78c.3-.16.59-.32.87-.5l1.67.67c.15.06.33 0 .41-.15l1.35-2.34a.34.34 0 00-.08-.43L17.66 11a7.58 7.58 0 00.07-1z" stroke="currentColor" stroke-width="1.5"/></svg>
        Pengaturan Situs
      </a>
      <% } %>
    </nav>

    <div class="sidebar-footer">
      <div class="user-menu-wrap" id="userMenuWrap">
        <div class="user-info" id="userMenuToggle">
          <% if (user && user.avatar) { %>
            <img src="<%= user.avatar %>" class="user-avatar user-avatar-img" alt="">
          <% } else { %>
            <div class="user-avatar"><%= user ? user.getInitials() : 'AZ' %></div>
          <% } %>
          <div class="user-details">
            <span class="user-name"><%= user ? user.name : 'Pengguna' %></span>
            <span class="user-role"><%= user ? user.organization : 'Inspira Tekno' %></span>
          </div>
          <button class="user-menu-btn" type="button" aria-label="Menu pengguna">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
        <div class="user-dropdown" id="userDropdown">
          <a href="/profile" class="user-dropdown-item">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Profil Saya
          </a>
          <% if (user && (user.role === 'direktur' || user.role === 'admin' || user.role === 'superadmin')) { %>
          <a href="/direktur/overview" class="user-dropdown-item">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Ringkasan Organisasi
          </a>
          <% } %>
          <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
          <a href="/admin" class="user-dropdown-item">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
            Admin Dashboard
          </a>
          <% } %>
          <div class="user-dropdown-divider"></div>
          <a href="/logout" class="user-dropdown-item user-dropdown-danger">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M13 3h4v14h-4M9 14l4-4-4-4M3 10h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Keluar
          </a>
        </div>
      </div>
    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <main class="main-content">
    <header class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
      <div class="topbar-search">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10.5 10.5L13 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" placeholder="Cari naskah dinas..." class="search-input" id="searchInput">
        <kbd class="search-kbd">⌘K</kbd>
      </div>
      <div class="topbar-actions">
        <a href="/profile" class="topbar-avatar" title="Profil Saya">
          <% if (user && user.avatar) { %>
            <img src="<%= user.avatar %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" alt="">
          <% } else { %>
            <%= user ? user.getInitials() : 'AZ' %>
          <% } %>
        </a>
      </div>
    </header>
    <div class="page-body">
