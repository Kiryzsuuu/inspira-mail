<%# Shared filter dropdown JS — include inside <script> block on any mail-list page %>
const AF = { tag:'all', jenis:'all', datemode:'all', read:'all', sort:'newest' };
const ITEM_SEL = '.draft-item, .mail-item';
const COUNT_EL = document.getElementById('draftCount') || document.getElementById('listCount');
const COUNT_SUFFIX = COUNT_EL ? (COUNT_EL.id === 'draftCount' ? ' draf' : (window._countSuffix||' surat')) : '';

function pickChip(btn) {
  const group = btn.dataset.group, val = btn.dataset.val;
  AF[group] = val;
  btn.closest('.filter-chips').querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function toggleDateMode(mode) {
  ['single','range','month'].forEach(m => {
    const el = document.getElementById('dateInput' + m.charAt(0).toUpperCase() + m.slice(1));
    if (el) el.style.display = (m === mode) ? '' : 'none';
  });
  if (mode === 'all') applyFilters();
}

function applyFilters() {
  const kw     = (document.getElementById('searchBox').value||'').toLowerCase().trim();
  const dmode  = AF.datemode;
  const dSingle = (document.getElementById('dateSingle')||{}).value||'';
  const dFrom   = (document.getElementById('dateFrom')||{}).value||'';
  const dTo     = (document.getElementById('dateTo')||{}).value||'';
  const dMonth  = (document.getElementById('dateMonth')||{}).value||'';
  const dYear   = (document.getElementById('dateYear')||{}).value||'';

  const container = document.querySelector('.mail-list-wrap');
  const items = [...document.querySelectorAll(ITEM_SEL)];

  let n = 0;
  items.forEach(el => {
    const d = el.dataset.date || '';
    let matchDate = true;
    if (dmode === 'single' && dSingle) matchDate = d === dSingle;
    else if (dmode === 'range') {
      if (dFrom && dTo) matchDate = d >= dFrom && d <= dTo;
      else if (dFrom)   matchDate = d >= dFrom;
      else if (dTo)     matchDate = d <= dTo;
    } else if (dmode === 'month') {
      if (dMonth && dYear) matchDate = d.startsWith(dYear + '-' + dMonth);
      else if (dYear)      matchDate = d.startsWith(dYear + '-');
      else if (dMonth)     matchDate = d.slice(5,7) === dMonth;
    }
    const matchSearch = !kw || (el.dataset.search||'').includes(kw);
    const matchTag    = AF.tag   === 'all' || (el.dataset.tag||'')   === AF.tag;
    const matchJenis  = AF.jenis === 'all' || (el.dataset.jenis||'') === AF.jenis;
    const matchRead   = AF.read  === 'all' || (AF.read === 'unread' && el.dataset.read === 'false');
    const show = matchSearch && matchTag && matchJenis && matchDate && matchRead;
    el.style.display = show ? '' : 'none';
    if (show) n++;
  });

  // Sort visible items by date
  const visible = items.filter(el => el.style.display !== 'none');
  visible.sort((a, b) => {
    const da = a.dataset.date || '', db = b.dataset.date || '';
    return AF.sort === 'oldest' ? da.localeCompare(db) : db.localeCompare(da);
  });
  visible.forEach(el => el.parentNode.appendChild(el));

  if (COUNT_EL) COUNT_EL.textContent = n + COUNT_SUFFIX;
  updateFilterBadge();
  renderActiveChips();
}

function updateFilterBadge() {
  let count = 0;
  if (AF.tag !== 'all')      count++;
  if (AF.jenis !== 'all')    count++;
  if (AF.datemode !== 'all') count++;
  if (AF.read !== 'all')     count++;
  if (AF.sort !== 'newest')  count++;
  const badge = document.getElementById('filterBadge');
  const btn   = document.getElementById('filterBtn');
  if (badge) { badge.textContent = count; badge.style.display = count ? '' : 'none'; }
  if (btn)   btn.classList.toggle('has-filter', count > 0);
}

function renderActiveChips() {
  const wrap = document.getElementById('activeChips');
  if (!wrap) return;
  wrap.innerHTML = '';
  const labels = {
    tag:  { penting:'Penting', urgent:'Urgent', normal:'Normal', info:'Info' },
    jenis:{ internal:'Internal', eksternal:'Eksternal' },
    read: { unread:'Belum Dibaca' },
    sort: { oldest:'Terlama' }
  };
  const removeChip = (group, def) => {
    AF[group] = def;
    document.querySelectorAll(`.filter-chip[data-group="${group}"][data-val="${def}"]`).forEach(c => {
      c.closest('.filter-chips').querySelectorAll('.filter-chip').forEach(x=>x.classList.remove('active'));
      c.classList.add('active');
    });
    applyFilters();
  };
  ['tag','jenis','read'].forEach(g => {
    if (AF[g] !== 'all') {
      const chip = document.createElement('div');
      chip.className = 'filter-active-chip';
      chip.innerHTML = `${labels[g][AF[g]]||AF[g]}<button onclick="removeChip_${g}()">×</button>`;
      wrap.appendChild(chip);
    }
  });
  if (AF.sort !== 'newest') {
    const chip = document.createElement('div');
    chip.className = 'filter-active-chip';
    chip.innerHTML = `${labels.sort[AF.sort]||AF.sort}<button onclick="removeChip_sort()">×</button>`;
    wrap.appendChild(chip);
  }
  window.removeChip_tag   = () => removeChip('tag','all');
  window.removeChip_jenis = () => removeChip('jenis','all');
  window.removeChip_read  = () => removeChip('read','all');
  window.removeChip_sort  = () => removeChip('sort','newest');

  if (AF.datemode !== 'all') {
    const chip = document.createElement('div');
    chip.className = 'filter-active-chip';
    const dmode = AF.datemode;
    let label = '';
    if (dmode==='single') { const v=(document.getElementById('dateSingle')||{}).value; label=v?'Tgl: '+v:'Pilih tanggal'; }
    else if (dmode==='range') { const f=(document.getElementById('dateFrom')||{}).value,t=(document.getElementById('dateTo')||{}).value; label=`${f||'?'} s/d ${t||'?'}`; }
    else if (dmode==='month') { const m=(document.getElementById('dateMonth')||{}).value,y=(document.getElementById('dateYear')||{}).value; label=[m,y].filter(Boolean).join('/'); }
    chip.innerHTML = `${label}<button onclick="resetDate()">×</button>`;
    wrap.appendChild(chip);
  }
}

function resetDate() {
  AF.datemode = 'all';
  document.querySelectorAll('.filter-chip[data-group="datemode"]').forEach(c=>c.classList.remove('active'));
  const allChip = document.querySelector('.filter-chip[data-group="datemode"][data-val="all"]');
  if (allChip) allChip.classList.add('active');
  toggleDateMode('all');
  applyFilters();
}

function resetAllFilters() {
  AF.tag='all'; AF.jenis='all'; AF.datemode='all'; AF.read='all'; AF.sort='newest';
  document.getElementById('searchBox').value='';
  document.querySelectorAll('.filter-chip').forEach(c=>{
    c.classList.toggle('active', c.dataset.val==='all' || c.dataset.val==='newest');
  });
  toggleDateMode('all');
  applyFilters();
}

function toggleFilterDropdown() {
  document.getElementById('filterDropdown').classList.toggle('open');
}

document.addEventListener('click', e => {
  const wrap = document.querySelector('.filter-wrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('filterDropdown')?.classList.remove('open');
  }
});

function liveSearch() { applyFilters(); }
