<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Terkirim</div>
    <h1 class="page-title">Terkirim</h1>
    <p class="page-subtitle"><%= mails.length %> surat telah dikirim</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Total Terkirim</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Mendesak</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Mendesak' || m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 8v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Penting</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Penting').length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <!-- TABS -->
  <div class="dok-tabs" style="padding:0 16px;">
    <a href="#" class="dok-tab active" onclick="filterTab('all',this)">Semua <span class="tab-count"><%= mails.length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('internal',this)">Internal <span class="tab-count"><%= mails.filter(m=>m.jenis==='internal').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('eksternal',this)">Eksternal <span class="tab-count"><%= mails.filter(m=>m.jenis==='eksternal').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('penting',this)">Penting <span class="tab-count"><%= mails.filter(m=>m.tag==='Penting').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('mendesak',this)">Mendesak <span class="tab-count"><%= mails.filter(m=>m.tag==='Mendesak'||m.tag==='Urgent').length %></span></a>
  </div>
  <!-- SEARCH -->
  <div class="dok-search">
    <input type="text" id="searchBox" class="form-control" style="font-size:13px;" placeholder="Cari subjek, penerima, nomor surat..." oninput="filterSearch()">
  </div>

  <% if (mails.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M40 8L21 27M40 8l-12 34-7-17-17-7 36-10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p>Belum ada surat yang dikirim.</p>
    <a href="/compose/new" class="btn btn-primary" style="margin-top:12px;">Tulis Surat Pertama</a>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table class="dok-table" id="mailTable" style="table-layout:fixed;">
      <colgroup>
        <col style="width:110px;">
        <col style="width:185px;">
        <col>
        <col style="width:150px;">
        <col style="width:85px;">
        <col style="width:105px;">
      </colgroup>
      <thead>
        <tr>
          <th>Jenis</th>
          <th>Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th>Penerima</th>
          <th>Prioritas</th>
          <th>Tanggal</th>
        </tr>
      </thead>
      <tbody>
      <% const tagCls = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
         const TIPE_KHUSUS_S = ['MoU','MoA','Contract','IA','PKS','SPK'];
         function tipeCls(t) {
           if(t==='Nota Dinas') return 'tipe-nota';
           if(t==='Surat Dinas') return 'tipe-surat';
           if(t==='MoU'||t==='MoA') return 'tipe-mou';
           if(t==='Contract'||t==='IA') return 'tipe-contract';
           if(t==='PKS'||t==='SPK') return 'tipe-pks';
           return 'tipe-lain';
         }
      %>
      <% mails.forEach(function(m) { %>
      <tr class="mail-item"
          data-tag="<%= (m.tag||'biasa').toLowerCase() %>"
          data-jenis="<%= (m.jenis||'internal').toLowerCase() %>"
          data-date="<%= m.dateISO||'' %>"
          data-search="<%= (m.subject+' '+(m.to||'')+' '+(m.nomorSurat||'')).toLowerCase() %>"
          onclick="window.location='/email/<%= m._id %>'"
          style="cursor:pointer;">
        <td style="white-space:nowrap;overflow:hidden;"><span class="dok-tipe-badge <%= tipeCls(m.tipeSurat) %>" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100px;display:inline-block;"><%= m.tipeSurat %></span></td>
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= m.nomorSurat||'—' %></td>
        <td style="overflow:hidden;">
          <div style="font-weight:500;color:var(--gray-900);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= m.subject %></div>
        </td>
        <td style="color:var(--gray-600);font-size:12.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="<%= m.to %>"><%= m.to %></td>
        <td><span class="mail-tag <%= tagCls[m.tag]||'tag-normal' %>" style="font-size:11px;white-space:nowrap;"><%= m.tag||'Biasa' %></span></td>
        <td style="font-size:12.5px;color:var(--gray-500);white-space:nowrap;"><%= m.date %></td>
      </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
let activeTab = 'all';
function filterTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.dok-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  filterSearch();
  return false;
}
function filterSearch() {
  const q = (document.getElementById('searchBox').value || '').toLowerCase();
  document.querySelectorAll('#mailTable tbody tr').forEach(row => {
    const search = (row.dataset.search || '');
    const tag    = (row.dataset.tag || '');
    const jenis  = (row.dataset.jenis || '');
    let show = true;
    if (activeTab === 'internal')  show = jenis === 'internal';
    else if (activeTab === 'eksternal') show = jenis === 'eksternal';
    else if (activeTab === 'penting')   show = tag === 'penting';
    else if (activeTab === 'mendesak')  show = tag === 'mendesak';
    if (show && q) show = search.includes(q);
    row.style.display = show ? '' : 'none';
  });
}
</script>

<%- include('./partials/footer') %>
