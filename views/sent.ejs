<%- include('./partials/header') %>
<style>
.dok-table { width:100%; border-collapse:collapse; font-size:13px; }
.dok-table th { padding:10px 14px; text-align:left; font-size:11.5px; font-weight:600; color:var(--gray-500); background:var(--gray-50); border-bottom:1px solid var(--gray-200); text-transform:uppercase; letter-spacing:.4px; }
.dok-table td { padding:11px 14px; border-bottom:1px solid var(--gray-100); color:var(--gray-700); vertical-align:middle; }
.dok-table tr:last-child td { border-bottom:none; }
.dok-table tbody tr:hover { background:var(--gray-50); }
.dok-tipe-badge { font-size:11px; font-weight:600; padding:2px 8px; border-radius:4px; white-space:nowrap; }
.tipe-nota { background:#f0fdf4; color:#15803d; }
.tipe-surat { background:#eff6ff; color:#1d4ed8; }
.tipe-mou,.tipe-moa { background:#fdf4ff; color:#7e22ce; }
.tipe-contract,.tipe-ia { background:#fff7ed; color:#c2410c; }
.tipe-pks,.tipe-spk { background:#fef3c7; color:#92400e; }
.tipe-lain { background:var(--gray-100); color:var(--gray-600); }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Terkirim</div>
    <h1 class="page-title">Terkirim</h1>
    <p class="page-subtitle"><%= mails.length %> surat telah dikirim</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Total Terkirim</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Mendesak</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Mendesak' || m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 8v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Penting</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Penting').length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
    <span class="mail-list-title" id="listCount"><%= mails.length %> surat terkirim</span>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <input type="text" id="searchBox" class="search-input" placeholder="Cari subjek, penerima..." style="width:220px;padding:7px 12px;" oninput="applyFilters()">
      <div id="activeChips" class="filter-active-chips"></div>
      <div class="filter-wrap">
        <button class="filter-btn" id="filterBtn" onclick="toggleFilterDropdown()">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M6 10h8M9 15h2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          Filter
          <span class="filter-badge" id="filterBadge" style="display:none;">0</span>
        </button>
        <div class="filter-dropdown" id="filterDropdown">
          <div class="filter-section">
            <div class="filter-section-label">Prioritas</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="tag" data-val="all" onclick="pickChip(this)">Semua</button>
              <button class="filter-chip" data-group="tag" data-val="penting" onclick="pickChip(this)">Penting</button>
              <button class="filter-chip" data-group="tag" data-val="segera" onclick="pickChip(this)">Segera</button>
              <button class="filter-chip" data-group="tag" data-val="mendesak" onclick="pickChip(this)">Mendesak</button>
              <button class="filter-chip" data-group="tag" data-val="biasa" onclick="pickChip(this)">Biasa</button>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Tipe Surat</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="jenis" data-val="all" onclick="pickChip(this)">Semua</button>
              <button class="filter-chip" data-group="jenis" data-val="internal" onclick="pickChip(this)">Internal</button>
              <button class="filter-chip" data-group="jenis" data-val="eksternal" onclick="pickChip(this)">Eksternal</button>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Tanggal</div>
            <div class="filter-chips" style="margin-bottom:8px;">
              <button class="filter-chip active" data-group="datemode" data-val="all" onclick="pickChip(this);toggleDateMode('all')">Semua</button>
              <button class="filter-chip" data-group="datemode" data-val="single" onclick="pickChip(this);toggleDateMode('single')">Tanggal</button>
              <button class="filter-chip" data-group="datemode" data-val="range" onclick="pickChip(this);toggleDateMode('range')">Rentang</button>
              <button class="filter-chip" data-group="datemode" data-val="month" onclick="pickChip(this);toggleDateMode('month')">Bulan/Tahun</button>
            </div>
            <div id="dateInputSingle" style="display:none;"><div class="filter-date-row"><input type="date" id="dateSingle" oninput="applyFilters()"></div></div>
            <div id="dateInputRange" style="display:none;"><div class="filter-date-row"><input type="date" id="dateFrom" oninput="applyFilters()"><span class="filter-date-sep">s/d</span><input type="date" id="dateTo" oninput="applyFilters()"></div></div>
            <div id="dateInputMonth" style="display:none;"><div class="filter-date-row">
              <select id="dateMonth" onchange="applyFilters()"><option value="">-- Bulan --</option><option value="01">Januari</option><option value="02">Februari</option><option value="03">Maret</option><option value="04">April</option><option value="05">Mei</option><option value="06">Juni</option><option value="07">Juli</option><option value="08">Agustus</option><option value="09">September</option><option value="10">Oktober</option><option value="11">November</option><option value="12">Desember</option></select>
              <select id="dateYear" onchange="applyFilters()"><option value="">-- Tahun --</option><% for(let y=new Date().getFullYear();y>=2020;y--){%><option value="<%=y%>"><%=y%></option><%}%></select>
            </div></div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Urutan</div>
            <div class="filter-chips">
              <button class="filter-chip active" data-group="sort" data-val="newest" onclick="pickChip(this)">Terbaru</button>
              <button class="filter-chip" data-group="sort" data-val="oldest" onclick="pickChip(this)">Terlama</button>
            </div>
          </div>
          <div class="filter-actions">
            <button class="btn btn-ghost" style="font-size:12.5px;padding:6px 14px;" onclick="resetAllFilters()">Reset</button>
            <button class="btn btn-primary" style="font-size:12.5px;padding:6px 14px;" onclick="toggleFilterDropdown()">Tutup</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (mails.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M40 8L21 27M40 8l-12 34-7-17-17-7 36-10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p>Belum ada surat yang dikirim.</p>
    <a href="/compose/new" class="btn btn-primary" style="margin-top:12px;">Tulis Surat Pertama</a>
  </div>
  <% } else { %>
  <div class="admin-table-wrap" style="overflow-x:auto;">
    <table class="dok-table">
      <thead>
        <tr>
          <th style="width:100px;">Jenis</th>
          <th style="width:190px;">Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:160px;">Penerima</th>
          <th style="width:90px;">Prioritas</th>
          <th style="width:110px;">Tanggal</th>
        </tr>
      </thead>
      <tbody>
      <% const tagCls = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
         const TIPE_KHUSUS_S = ['MoU','MoA','Contract','IA','PKS','SPK'];
         function tipeCls(t) {
           if(t==='Nota Dinas') return 'tipe-nota';
           if(t==='Surat Dinas') return 'tipe-surat';
           if(t==='MoU'||t==='MoA') return 'tipe-mou';
           if(t==='Contract'||t==='IA') return 'tipe-contract';
           if(t==='PKS'||t==='SPK') return 'tipe-pks';
           return 'tipe-lain';
         }
      %>
      <% mails.forEach(function(m) { %>
      <tr class="mail-item"
          data-tag="<%= (m.tag||'biasa').toLowerCase() %>"
          data-jenis="<%= (m.jenis||'internal').toLowerCase() %>"
          data-date="<%= m.dateISO||'' %>"
          data-search="<%= (m.subject+' '+(m.to||'')+' '+(m.nomorSurat||'')).toLowerCase() %>"
          onclick="window.location='/email/<%= m._id %>'"
          style="cursor:pointer;">
        <td><span class="dok-tipe-badge <%= tipeCls(m.tipeSurat) %>"><%= m.tipeSurat %></span></td>
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;"><%= m.nomorSurat %></td>
        <td>
          <div style="font-weight:500;color:var(--gray-900);"><%= m.subject %></div>
          <% if (m.berkas) { %><div style="font-size:11.5px;color:var(--gray-400);margin-top:2px;"><%= m.berkas %></div><% } %>
        </td>
        <td style="color:var(--gray-600);font-size:12.5px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= m.to %>"><%= m.to %></td>
        <td><span class="mail-tag <%= tagCls[m.tag]||'tag-normal' %>" style="font-size:11px;"><%= m.tag||'Biasa' %></span></td>
        <td style="font-size:12.5px;color:var(--gray-500);white-space:nowrap;"><%= m.date %></td>
      </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
window._countSuffix = ' surat terkirim';
<%- include('./partials/filter-script') %>
</script>

<%- include('./partials/footer') %>
