<%- include('./partials/header') %>
<style>
.dok-tabs { display:flex; gap:0; border-bottom:2px solid var(--gray-100); margin-bottom:0; overflow-x:auto; overflow-y:hidden; scrollbar-width:none; }
.dok-tabs::-webkit-scrollbar { display:none; }
.dok-tab { padding:12px 18px; font-size:13px; font-weight:500; color:var(--gray-500); cursor:pointer; white-space:nowrap; border-bottom:2px solid transparent; margin-bottom:-2px; text-decoration:none; transition:color .15s; display:inline-flex; align-items:center; }
.dok-tab:hover { color:var(--gray-700); }
.dok-tab.active { color:var(--brand-600); border-bottom-color:var(--brand-600); font-weight:600; }
.dok-tab .tab-count { display:inline-block; background:var(--gray-100); color:var(--gray-500); font-size:10.5px; font-weight:600; padding:1px 6px; border-radius:10px; margin-left:5px; }
.dok-tab.active .tab-count { background:#dbeafe; color:#1d4ed8; }
.dok-table { width:100%; border-collapse:collapse; font-size:13px; }
.dok-table th { padding:10px 14px; text-align:left; font-size:11.5px; font-weight:600; color:var(--gray-500); background:var(--gray-50); border-bottom:1px solid var(--gray-200); text-transform:uppercase; letter-spacing:.4px; }
.dok-table td { padding:11px 14px; border-bottom:1px solid var(--gray-100); color:var(--gray-700); vertical-align:middle; }
.dok-table tr:last-child td { border-bottom:none; }
.dok-table tbody tr { cursor:pointer; transition:background .1s; }
.dok-table tbody tr:hover { background:var(--gray-50); }
.dok-tipe-badge { font-size:11px; font-weight:600; padding:2px 8px; border-radius:4px; white-space:nowrap; }
.tipe-nota { background:#f0fdf4; color:#15803d; }
.tipe-surat { background:#eff6ff; color:#1d4ed8; }
.tipe-mou,.tipe-moa { background:#fdf4ff; color:#7e22ce; }
.tipe-contract,.tipe-ia { background:#fff7ed; color:#c2410c; }
.tipe-pks,.tipe-spk { background:#fef3c7; color:#92400e; }
.tipe-lain { background:var(--gray-100); color:var(--gray-600); }
.dok-search { display:flex; gap:8px; padding:12px 16px; border-bottom:1px solid var(--gray-100); }
.dok-search input { flex:1; }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Terkirim</div>
    <h1 class="page-title">Terkirim</h1>
    <p class="page-subtitle"><%= mails.length %> surat telah dikirim</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div id="bulkBar" style="display:none;position:sticky;top:0;z-index:50;background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:10px 16px;margin-bottom:12px;align-items:center;gap:12px;">
  <span id="bulkCount" style="font-size:13px;font-weight:600;color:#b91c1c;"></span>
  <button onclick="bulkDelete()" class="btn" style="background:#ef4444;color:#fff;font-size:12px;padding:5px 14px;border:none;">
    <svg width="13" height="13" viewBox="0 0 20 20" fill="none" style="margin-right:4px"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Hapus Dipilih
  </button>
  <button onclick="clearSelection()" class="btn btn-secondary" style="font-size:12px;padding:5px 12px;">Batal</button>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Total Terkirim</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Mendesak</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Mendesak' || m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 8v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Penting</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Penting').length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <!-- TABS -->
  <div class="dok-tabs" style="padding:0 16px;">
    <a href="#" class="dok-tab active" onclick="filterTab('all',this)">Semua <span class="tab-count"><%= mails.length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('internal',this)">Internal <span class="tab-count"><%= mails.filter(m=>m.jenis==='internal').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('eksternal',this)">Eksternal <span class="tab-count"><%= mails.filter(m=>m.jenis==='eksternal').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('penting',this)">Penting <span class="tab-count"><%= mails.filter(m=>m.tag==='Penting').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('mendesak',this)">Mendesak <span class="tab-count"><%= mails.filter(m=>m.tag==='Mendesak'||m.tag==='Urgent').length %></span></a>
  </div>
  <!-- SEARCH -->
  <div class="dok-search">
    <input type="text" id="searchBox" class="form-control" style="font-size:13px;" placeholder="Cari subjek, penerima, nomor surat..." oninput="filterSearch()">
  </div>

  <% if (mails.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M40 8L21 27M40 8l-12 34-7-17-17-7 36-10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p>Belum ada surat yang dikirim.</p>
    <a href="/compose/new" class="btn btn-primary" style="margin-top:12px;">Tulis Surat Pertama</a>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table class="dok-table" id="mailTable">
      <thead>
        <tr>
          <th style="width:32px;"><input type="checkbox" id="checkAll" onchange="toggleAll(this)" style="cursor:pointer;"></th>
          <th style="width:120px;">Jenis</th>
          <th>Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:130px;">Penerima</th>
          <th style="width:90px;">Prioritas</th>
          <th style="width:100px;">Tanggal</th>
          <th style="width:50px;"></th>
        </tr>
      </thead>
      <tbody>
      <% const tagCls = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
         function tipeCls(t) {
           if(t==='Nota Dinas') return 'tipe-nota';
           if(t==='Surat Dinas') return 'tipe-surat';
           if(['MoU','MoA'].includes(t)) return 'tipe-mou';
           if(['Contract','IA'].includes(t)) return 'tipe-contract';
           if(['PKS','SPK'].includes(t)) return 'tipe-pks';
           return 'tipe-lain';
         }
      %>
      <% mails.forEach(function(m) { %>
      <tr id="row-<%= m._id %>"
          data-id="<%= m._id %>"
          data-tag="<%= (m.tag||'biasa').toLowerCase() %>"
          data-jenis="<%= (m.jenis||'internal').toLowerCase() %>"
          data-date="<%= m.dateISO||'' %>"
          data-search="<%= (m.subject+' '+(m.to||'')+' '+(m.nomorSurat||'')).toLowerCase() %>">
        <td onclick="event.stopPropagation()"><input type="checkbox" class="row-check" value="<%= m._id %>" onchange="updateBulkBar()" style="cursor:pointer;"></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;"><span class="dok-tipe-badge <%= tipeCls(m.tipeSurat) %>"><%= m.tipeSurat||'—' %></span></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;"><%= m.nomorSurat||'—' %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500;"><%= m.subject %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-size:12px;color:var(--gray-500);"><%= m.to||'—' %></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;"><span class="mail-tag <%= tagCls[m.tag]||'tag-normal' %>" style="font-size:11px;"><%= m.tag||'Biasa' %></span></td>
        <td onclick="window.location='/email/<%= m._id %>'" style="cursor:pointer;font-size:12px;color:var(--gray-400);white-space:nowrap;"><%= m.date %></td>
        <td onclick="event.stopPropagation()">
          <button onclick="deleteSingle('<%= m._id %>')" title="Hapus" style="background:none;border:none;cursor:pointer;padding:4px;color:var(--gray-400);border-radius:4px;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--gray-400)'">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </td>
      </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
let activeTab = 'all';
function filterTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.dok-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  filterSearch();
  return false;
}
function filterSearch() {
  const q = (document.getElementById('searchBox').value || '').toLowerCase();
  document.querySelectorAll('#mailTable tbody tr').forEach(row => {
    const search = (row.dataset.search || '');
    const tag    = (row.dataset.tag || '');
    const jenis  = (row.dataset.jenis || '');
    let show = true;
    if (activeTab === 'internal')  show = jenis === 'internal';
    else if (activeTab === 'eksternal') show = jenis === 'eksternal';
    else if (activeTab === 'penting')   show = tag === 'penting';
    else if (activeTab === 'mendesak')  show = tag === 'mendesak';
    if (show && q) show = search.includes(q);
    row.style.display = show ? '' : 'none';
  });
}

function toggleAll(cb) {
  document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
  updateBulkBar();
}
function updateBulkBar() {
  const checked = document.querySelectorAll('.row-check:checked');
  const bar = document.getElementById('bulkBar');
  if (checked.length > 0) {
    bar.style.display = 'flex';
    document.getElementById('bulkCount').textContent = checked.length + ' surat dipilih';
  } else {
    bar.style.display = 'none';
    document.getElementById('checkAll').checked = false;
  }
}
function clearSelection() {
  document.querySelectorAll('.row-check').forEach(c => c.checked = false);
  document.getElementById('checkAll').checked = false;
  updateBulkBar();
}
async function deleteSingle(id) {
  if (!confirm('Hapus surat ini dari Terkirim?')) return;
  const res = await fetch('/sent/' + id, { method: 'DELETE' });
  const data = await res.json();
  if (data.ok) {
    document.getElementById('row-' + id)?.remove();
  } else alert('Gagal menghapus.');
}
async function bulkDelete() {
  const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(c => c.value);
  if (!ids.length) return;
  if (!confirm('Hapus ' + ids.length + ' surat dari Terkirim?')) return;
  const res = await fetch('/sent/bulk-delete', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids })
  });
  const data = await res.json();
  if (data.ok) {
    ids.forEach(id => document.getElementById('row-' + id)?.remove());
    clearSelection();
  } else alert('Gagal menghapus.');
}
</script>

<%- include('./partials/footer') %>
