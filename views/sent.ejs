<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/">Dashboard</a> / Terkirim</div>
    <h1 class="page-title">Terkirim</h1>
    <p class="page-subtitle"><%= mails.length %> surat telah dikirim</p>
  </div>
  <div class="page-actions">
    <a href="/compose" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <span>Tulis Surat</span>
    </a>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Total Terkirim</div><div class="stat-value"><%= mails.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Urgent</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Urgent').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 8v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Penting</div><div class="stat-value"><%= mails.filter(m => m.tag === 'Penting').length %></div></div>
  </div>
</div>

<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
    <span class="mail-list-title" id="listCount"><%= mails.length %> surat terkirim</span>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="text" id="searchBox" class="search-input" placeholder="Cari subjek, penerima..." style="width:240px;padding:7px 12px;" oninput="liveSearch(this.value)">
        <button class="btn btn-ghost" style="padding:7px 10px;" onclick="document.getElementById('searchBox').value='';liveSearch('');" title="Reset">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>
      <div class="filter-tabs">
        <button class="filter-tab active" onclick="filterMails(this,'all')">Semua</button>
        <button class="filter-tab" onclick="filterMails(this,'penting')">Penting</button>
        <button class="filter-tab" onclick="filterMails(this,'urgent')">Urgent</button>
      </div>
    </div>
  </div>

  <% if (mails.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M40 8L21 27M40 8l-12 34-7-17-17-7 36-10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p>Belum ada surat yang dikirim.</p>
    <a href="/compose" class="btn btn-primary" style="margin-top:12px;">Tulis Surat Pertama</a>
  </div>
  <% } %>

  <% mails.forEach(function(m, i) {
    const toStr = m.to || '-';
    const initials = toStr.split(' ').slice(0,2).map(function(w){ return w && w[0] ? w[0] : ''; }).join('').toUpperCase() || 'TO';
    const tagClass = { Penting: 'tag-penting', Urgent: 'tag-urgent', Info: 'tag-info', Normal: 'tag-normal' }[m.tag] || 'tag-normal';
    const avColors = ['av-teal','av-blue','av-green','av-purple','av-amber'];
    const avColor = avColors[i % avColors.length];
  %>
  <a href="/email/<%= m._id %>" class="mail-item" data-tag="<%= (m.tag || 'normal').toLowerCase() %>"
     data-search="<%= (m.subject + ' ' + (m.to||'-')).toLowerCase() %>">
    <div class="mail-avatar <%= avColor %>"><%= initials %></div>
    <div class="mail-body">
      <div class="mail-from">Kepada: <%= toStr %></div>
      <div class="mail-subject"><%= m.subject %></div>
      <% if (m.berkas) { %><div class="mail-berkas"><%= m.berkas %></div><% } %>
    </div>
    <div class="mail-meta">
      <span class="mail-date"><%= m.date %></span>
      <span class="mail-tag <%= tagClass %>"><%= m.tag || 'Normal' %></span>
    </div>
  </a>
  <% }); %>
</div>

<script>
let currentFilter = 'all';

function liveSearch(q) {
  const kw = q.toLowerCase().trim();
  let visible = 0;
  document.querySelectorAll('.mail-item').forEach(el => {
    const s = el.dataset.search || '';
    const tag = el.dataset.tag || '';
    const matchSearch = !kw || s.includes(kw);
    const matchFilter = currentFilter === 'all' || tag === currentFilter;
    const show = matchSearch && matchFilter;
    el.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('listCount').textContent = visible + ' surat terkirim';
}

function filterMails(btn, tag) {
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  currentFilter = tag;
  liveSearch(document.getElementById('searchBox').value);
}
</script>

<%- include('./partials/footer') %>
