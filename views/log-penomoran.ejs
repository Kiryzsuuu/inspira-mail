<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Log Penomoran</div>
    <h1 class="page-title">Log Penomoran Surat</h1>
    <p class="page-subtitle">Riwayat semua nomor surat yang telah di-generate sistem</p>
  </div>
</div>

<div class="mail-list-wrap">
  <div class="mail-list-header" style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
    <span class="mail-list-title"><%= docs.length %> dokumen</span>
    <form method="GET" action="/log-penomoran" style="display:flex;gap:8px;">
      <input type="text" name="q" value="<%= q %>" class="form-control" style="width:240px;padding:7px 12px;font-size:13px;" placeholder="Cari nomor, perihal, jenis...">
      <button type="submit" class="btn btn-secondary" style="padding:7px 16px;font-size:13px;">Cari</button>
      <% if (q) { %><a href="/log-penomoran" class="btn btn-ghost" style="padding:7px 14px;font-size:13px;">Reset</a><% } %>
    </form>
  </div>

  <% if (docs.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M12 8h24l8 8v28H4V8h8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M28 8v8h8M16 22h16M16 30h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Belum ada dokumen yang ternomor<%= q ? ' dengan kata kunci "' + q + '"' : '' %>.</p>
  </div>
  <% } else { %>

  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:2px solid var(--gray-200);background:var(--gray-50);">
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;width:40px;">No.</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Nomor Surat</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Jenis Dokumen</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Perihal</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Pengirim</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Status</th>
          <th style="padding:10px 14px;text-align:left;color:var(--gray-600);font-weight:600;">Tanggal</th>
        </tr>
      </thead>
      <tbody>
      <% docs.forEach((d, i) => { %>
      <tr style="border-bottom:1px solid var(--gray-100);transition:background .1s;" onmouseover="this.style.background='var(--gray-50)'" onmouseout="this.style.background=''">
        <td style="padding:10px 14px;color:var(--gray-400);"><%= i+1 %></td>
        <td style="padding:10px 14px;">
          <a href="/email/<%= d._id %>" style="font-family:monospace;font-weight:700;color:var(--brand-700);font-size:12.5px;text-decoration:none;"><%= d.nomorSurat %></a>
        </td>
        <td style="padding:10px 14px;">
          <span style="font-size:11.5px;font-weight:600;padding:2px 8px;border-radius:4px;background:#eff6ff;color:#1d4ed8;"><%= d.tipeSurat || '—' %></span>
        </td>
        <td style="padding:10px 14px;color:var(--gray-700);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= d.subject %></td>
        <td style="padding:10px 14px;color:var(--gray-600);">
          <div style="font-size:12.5px;font-weight:500;"><%= d.from?.name || '—' %></div>
          <% if (d.pengirimResmi && d.pengirimResmi !== d.from?.name) { %>
            <div style="font-size:11px;color:var(--gray-400);">atas nama: <%= d.pengirimResmi %></div>
          <% } %>
        </td>
        <td style="padding:10px 14px;">
          <span class="admin-status-badge admin-status-<%= d.status === 'sent' ? 'active' : 'inactive' %>">
            <span class="admin-status-dot"></span>
            <%= d.status === 'sent' ? 'Terkirim' : 'Draf' %>
          </span>
        </td>
        <td style="padding:10px 14px;color:var(--gray-500);white-space:nowrap;font-size:12px;"><%= formatDate(d.createdAt) %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('./partials/footer') %>
