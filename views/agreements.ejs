<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Dokumen & Penomoran</div>
    <h1 class="page-title">Dokumen & Penomoran</h1>
    <p class="page-subtitle">MOU, PKS, SPK, dan Kontrak dengan penomoran otomatis</p>
  </div>
  <div class="page-actions">
    <a href="/agreements/new" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      Buat Dokumen
    </a>
  </div>
</div>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M6 2h8l4 4v12H2V2h4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v4h4M6 9h8M6 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Total Dokumen</div><div class="stat-value"><%= stats.total %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Aktif</div><div class="stat-value"><%= stats.aktif %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Draft</div><div class="stat-value"><%= stats.draft %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Berakhir</div><div class="stat-value"><%= stats.berakhir %></div></div>
  </div>
</div>

<!-- Filter -->
<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
    <span class="mail-list-title"><%= docs.length %> dokumen</span>
    <form method="GET" action="/agreements" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <select name="type" class="admin-role-select" onchange="this.form.submit()" style="padding:7px 28px 7px 10px;">
        <option value="">Semua Jenis</option>
        <% ['MOU','PKS','SPK','KONTRAK'].forEach(t => { %>
        <option value="<%= t %>" <%= filter.type === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <select name="status" class="admin-role-select" onchange="this.form.submit()" style="padding:7px 28px 7px 10px;">
        <option value="">Semua Status</option>
        <% ['draft','review','aktif','berakhir','dibatalkan'].forEach(s => { %>
        <option value="<%= s %>" <%= filter.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
        <% }) %>
      </select>
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="text" name="q" class="search-input" placeholder="Cari judul..." value="<%= filter.q || '' %>" style="width:200px;padding:7px 12px;">
        <button type="submit" class="btn btn-secondary" style="padding:7px 14px;font-size:13px;white-space:nowrap;">Cari</button>
        <% if (filter.type || filter.status || filter.q) { %>
        <a href="/agreements" class="btn btn-ghost" style="padding:7px 12px;font-size:13px;white-space:nowrap;">Reset</a>
        <% } %>
      </div>
    </form>
  </div>

  <% if (docs.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M12 6h18l10 10v26H8V6h4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M30 6v10h10M16 22h16M16 30h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Belum ada dokumen.<br>Klik "Buat Dokumen" untuk memulai.</p>
    <a href="/agreements/new" class="btn btn-primary" style="margin-top:12px;">Buat Dokumen Pertama</a>
  </div>
  <% } %>

  <% const statusColor = { draft:'tag-draft', review:'tag-penting', aktif:'tag-info', berakhir:'tag-normal', dibatalkan:'tag-urgent' }; %>
  <% const typeColor = { MOU:'ag-mou', PKS:'ag-pks', SPK:'ag-spk', KONTRAK:'ag-kontrak' }; %>

  <% docs.forEach(function(d) { %>
  <a href="/agreements/<%= d._id %>" class="ag-item">
    <div class="ag-type-badge <%= typeColor[d.type] %>"><%= d.type %></div>
    <div class="ag-body">
      <div class="ag-nomor"><%= d.nomor %></div>
      <div class="ag-judul"><%= d.judul %></div>
      <div class="ag-meta">
        <% if (d.pihakKedua) { %>
        <span class="ag-pihak">
          <svg width="11" height="11" viewBox="0 0 20 20" fill="none"><path d="M3 18V8l7-5 7 5v10M8 18v-5h4v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <%= d.pihakKedua %>
        </span>
        <% } %>
        <% if (d.nilaiKontrak) { %>
        <span class="ag-nilai"><%= formatRupiah(d.nilaiKontrak) %></span>
        <% } %>
        <% if (d.tanggalBerakhir) { %>
        <span class="ag-tanggal">
          <svg width="11" height="11" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Berakhir: <%= new Date(d.tanggalBerakhir).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}) %>
        </span>
        <% } %>
      </div>
    </div>
    <div class="ag-right">
      <span class="mail-tag <%= statusColor[d.status] || 'tag-normal' %>">
        <%= d.status.charAt(0).toUpperCase() + d.status.slice(1) %>
      </span>
      <span class="mail-date"><%= new Date(d.createdAt).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}) %></span>
    </div>
  </a>
  <% }) %>
</div>

<%- include('./partials/footer') %>
