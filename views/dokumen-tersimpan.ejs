<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Dokumen Tersimpan</div>
    <h1 class="page-title">Dokumen Tersimpan</h1>
    <p class="page-subtitle">Dokumen yang dibuatkan oleh admin untuk Anda</p>
  </div>
</div>

<% if (docs.length === 0) { %>
<div class="compose-card" style="padding:48px;text-align:center;">
  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="margin:0 auto 16px;display:block;color:var(--gray-300)"><path d="M12 6h18l8 8v28a2 2 0 01-2 2H12a2 2 0 01-2-2V8a2 2 0 012-2z" stroke="currentColor" stroke-width="2"/><path d="M30 6v10h8" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
  <p style="color:var(--gray-400);font-size:14px;">Belum ada dokumen tersimpan untuk Anda.</p>
</div>
<% } else { %>
<div class="compose-card">
  <div style="overflow-x:auto;">
    <table class="dok-table">
      <thead>
        <tr>
          <th>Nomor Surat</th>
          <th>Perihal</th>
          <th style="width:90px;">Tujuan</th>
          <th style="width:120px;">Jenis</th>
          <th style="width:100px;">Status</th>
          <th style="width:120px;">Dibuatkan oleh</th>
          <th style="width:110px;">Tanggal</th>
          <th style="width:80px;">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% docs.forEach(function(doc) { %>
        <tr>
          <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;white-space:nowrap;"><%= doc.nomorSurat || '—' %></td>
          <td style="max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= doc.subject %></td>
          <td><span style="font-size:11px;font-weight:500;padding:2px 7px;border-radius:10px;<%= doc.jenis==='eksternal'?'background:#fff7ed;color:#c2410c;':'background:#eff6ff;color:#1d4ed8;' %>"><%= doc.jenis==='eksternal'?'Eksternal':'Internal' %></span></td>
          <td style="font-size:12px;"><%= doc.tipeSurat || doc.jenis %></td>
          <td>
            <% if (doc.isLocked) { %>
            <span style="font-size:11px;font-weight:600;color:var(--red-500);display:flex;align-items:center;gap:3px;">
              <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><rect x="4" y="9" width="12" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Terkunci
            </span>
            <% } else if (doc.status === 'sent') { %>
            <span style="font-size:11px;color:var(--green-600);font-weight:500;">Terkirim</span>
            <% } else { %>
            <span style="font-size:11px;color:var(--amber-600);font-weight:500;">Draf</span>
            <% } %>
          </td>
          <td style="font-size:12px;color:var(--gray-500);"><%= doc.builtBy?.name || '—' %></td>
          <td style="font-size:12px;color:var(--gray-400);white-space:nowrap;"><%= formatDate(doc.createdAt) %></td>
          <td>
            <a href="/email/<%= doc._id %>" class="btn btn-secondary" style="padding:3px 10px;font-size:11.5px;">Buka</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<%- include('./partials/footer') %>
