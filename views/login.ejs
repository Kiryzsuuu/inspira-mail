<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Masuk — Inspira Mailer</title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">

<div class="auth-wrap">
  <div class="auth-panel">
    <div class="auth-brand">
      <img src="/img/Group 1597880519.png" alt="Inspira Logo" class="auth-logo">
      <div>
        <div class="auth-brand-name">Inspira Mailer</div>
        <div class="auth-brand-sub">Sistem Surat Dinas Digital</div>
      </div>
    </div>

    <h1 class="auth-title">Selamat Datang</h1>
    <p class="auth-desc">Masuk untuk mengakses sistem surat dinas</p>

    <% if (error) { %>
    <div class="auth-alert auth-alert-error">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <%= error %>
    </div>
    <% } %>

    <form action="/login" method="POST" class="auth-form" autocomplete="on">
      <div class="auth-field">
        <label class="auth-label" for="email">Alamat Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="auth-input"
          placeholder="nama@perusahaan.com"
          value="<%= savedEmail || '' %>"
          required
          autofocus
          autocomplete="email"
        >
      </div>
      <div class="auth-field">
        <label class="auth-label" for="password">
          Kata Sandi
          <a href="/forgot-password" class="auth-link-sm">Lupa kata sandi?</a>
        </label>
        <div class="auth-input-group">
          <input
            type="password"
            id="password"
            name="password"
            class="auth-input"
            placeholder="Minimal 8 karakter"
            required
            autocomplete="current-password"
          >
          <button type="button" class="auth-eye" onclick="toggleVisibility('password','eyeIcon')" tabindex="-1">
            <svg id="eyeIcon" width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="auth-btn">Masuk</button>
    </form>

    <p class="auth-footer-text">
      Belum punya akun?
      <a href="/register" class="auth-link">Daftar sekarang</a>
    </p>
  </div>

  <div class="auth-deco" aria-hidden="true">
    <div class="auth-deco-content">
      <img src="/img/Group 1597880519.png" alt="" class="auth-deco-logo">
      <h2 class="auth-deco-title">Inspira Mailer</h2>
      <p class="auth-deco-sub">Platform surat dinas digital yang aman, cepat, dan terintegrasi untuk kebutuhan korespondensi organisasi Anda.</p>
      <div class="auth-deco-features">
        <div class="auth-deco-feat">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Manajemen surat dinas terpusat
        </div>
        <div class="auth-deco-feat">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Pencarian dan pengarsipan mudah
        </div>
        <div class="auth-deco-feat">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Keamanan data tingkat tinggi
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function toggleVisibility(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M3 3l14 14M9.88 9.88A3 3 0 0110 7a3 3 0 013 3 3 3 0 01-.12.88M10.73 14.95A7 7 0 013 10s2-5 7-5a7 7 0 013.27.79M17 10s-2 5-7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>';
  }
}
</script>
</body>
</html>
