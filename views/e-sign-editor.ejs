<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / <a href="/e-sign">E-Sign PDF</a> / <%= session.title %></div>
    <h1 class="page-title" style="font-size:18px;"><%= session.title %></h1>
    <p class="page-subtitle"><%= session.originalName %></p>
  </div>
  <div class="page-header-actions" style="gap:8px;">
    <a href="/e-sign/<%= session._id %>/download" class="btn btn-secondary" style="font-size:13px;">
      <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v11M6 10l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      Unduh
    </a>
    <% if (currentUserSigner && currentUserSigner.status === 'pending') { %>
    <button id="signBtn" onclick="signDocument()" class="btn btn-primary" style="font-size:13px;">
      <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M3 17l4-4L14 6l3 3-7 7-4 1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Tanda Tangani
    </button>
    <% } %>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 280px;gap:18px;align-items:flex-start;">

  <!-- LEFT: PDF Viewer -->
  <div>
    <!-- Page controls -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius-md);padding:8px 14px;">
      <button onclick="changePage(-1)" id="prevBtn" style="background:none;border:none;cursor:pointer;color:var(--gray-600);padding:2px 6px;border-radius:4px;" title="Halaman sebelumnya">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <span style="font-size:12.5px;color:var(--gray-600);">Halaman <strong id="pageNum">1</strong> / <strong id="totalPages">—</strong></span>
      <button onclick="changePage(1)" id="nextBtn" style="background:none;border:none;cursor:pointer;color:var(--gray-600);padding:2px 6px;border-radius:4px;" title="Halaman berikutnya">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div style="margin-left:auto;font-size:11.5px;color:var(--gray-400);">
        <% if (currentUserSigner && currentUserSigner.status === 'pending') { %>
        <span style="color:#2563eb;">Seret kotak biru untuk memposisikan tanda tangan Anda</span>
        <% } %>
      </div>
    </div>

    <!-- PDF Canvas + Signature boxes -->
    <div id="pdfWrap" style="position:relative;display:inline-block;width:100%;background:#e2e8f0;border-radius:var(--radius-md);overflow:hidden;min-height:400px;line-height:0;">
      <canvas id="pdfCanvas" style="display:block;width:100%;height:auto;"></canvas>
      <!-- Sig boxes injected by JS -->
    </div>
  </div>

  <!-- RIGHT: Panel -->
  <div style="display:flex;flex-direction:column;gap:14px;">

    <!-- Status -->
    <div class="compose-card" style="padding:16px 18px;">
      <div style="font-size:12px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">Status Dokumen</div>
      <% if (session.status === 'signed') { %>
      <div style="display:flex;align-items:center;gap:8px;color:#16a34a;">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="font-size:13.5px;font-weight:600;">Semua sudah tanda tangan</span>
      </div>
      <% } else if (session.status === 'partial') { %>
      <div style="display:flex;align-items:center;gap:8px;color:#b45309;">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span style="font-size:13.5px;font-weight:600;">Sebagian sudah tanda tangan</span>
      </div>
      <% } else { %>
      <div style="display:flex;align-items:center;gap:8px;color:var(--gray-500);">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span style="font-size:13.5px;font-weight:600;">Menunggu tanda tangan</span>
      </div>
      <% } %>
    </div>

    <!-- Signers list -->
    <div class="compose-card" style="padding:16px 18px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div style="font-size:12px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px;">Penandatangan</div>
        <% if (isCreator) { %>
        <button onclick="toggleAddSigner()" style="background:none;border:none;cursor:pointer;color:var(--primary);font-size:11.5px;font-weight:600;display:flex;align-items:center;gap:3px;padding:0;">
          <svg width="11" height="11" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Tambah
        </button>
        <% } %>
      </div>

      <div id="signersList">
        <% session.signers.forEach((signer, i) => {
          const isMe = signer.userId.toString() === currentUser._id.toString();
        %>
        <div class="signer-row" id="sigrow-<%= signer._id %>" style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--gray-100);">
          <div style="width:28px;height:28px;border-radius:50%;background:<%= isMe ? '#eff6ff' : '#f1f5f9' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <span style="font-size:10px;font-weight:700;color:<%= isMe ? '#2563eb' : '#64748b' %>"><%= signer.name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase() %></span>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:12.5px;font-weight:600;color:var(--gray-700);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= signer.name %><%= isMe ? ' (Anda)' : '' %></div>
            <div style="font-size:11px;color:var(--gray-400);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= signer.email %></div>
          </div>
          <div style="flex-shrink:0;">
            <% if (signer.status === 'signed') { %>
            <span style="background:#dcfce7;color:#15803d;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;">✓</span>
            <% } else { %>
            <span style="background:#f1f5f9;color:#94a3b8;font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;">○</span>
            <% } %>
          </div>
          <% if (isCreator && !isMe && signer.status === 'pending') { %>
          <button onclick="removeSigner('<%= session._id %>', '<%= signer._id %>')" style="background:none;border:none;cursor:pointer;color:var(--gray-300);padding:2px;" title="Hapus">
            <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </button>
          <% } %>
        </div>
        <% }) %>
      </div>

      <!-- Add signer form -->
      <% if (isCreator) { %>
      <div id="addSignerForm" style="display:none;margin-top:12px;padding-top:12px;border-top:1px solid var(--gray-100);">
        <div style="font-size:12px;color:var(--gray-600);margin-bottom:8px;font-weight:600;">Pilih pengguna untuk co-sign:</div>
        <select id="coSignerSelect" class="form-control form-select" style="font-size:12.5px;margin-bottom:8px;">
          <option value="">— Pilih pengguna —</option>
          <% users.forEach(u => { %>
          <% const already = session.signers.some(s => s.userId.toString() === u._id.toString()); %>
          <option value="<%= u._id %>" <%= already ? 'disabled' : '' %>><%= u.name %> <%= already ? '(sudah)' : '' %></option>
          <% }) %>
        </select>
        <button onclick="addCoSigner()" class="btn btn-primary" style="font-size:12px;padding:6px 14px;width:100%;">
          <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Tambahkan
        </button>
      </div>
      <% } %>
    </div>

    <!-- Actions -->
    <div class="compose-card" style="padding:16px 18px;">
      <div style="font-size:12px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;">Tindakan</div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% if (currentUserSigner && currentUserSigner.status === 'pending') { %>
        <button id="signBtnPanel" onclick="signDocument()" class="btn btn-primary" style="font-size:12.5px;justify-content:center;">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M3 17l4-4L14 6l3 3-7 7-4 1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Tanda Tangani Dokumen
        </button>
        <% } %>
        <button onclick="saveToPersonalDocs()" class="btn btn-secondary" style="font-size:12.5px;justify-content:center;">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M3 3h14v14H3zM3 8h14M7 3v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Simpan ke Dok. Pribadi
        </button>
        <a href="/e-sign/<%= session._id %>/download" class="btn btn-secondary" style="font-size:12.5px;justify-content:center;text-decoration:none;">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v11M6 10l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Unduh PDF
        </button>
      </div>
    </div>

  </div>
</div>

<div class="admin-toast" id="esignToast"></div>

<!-- PDF.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

const SESSION_ID  = '<%= session._id %>';
const CURRENT_PAGE_SETTING = <%- JSON.stringify(currentUserSigner ? currentUserSigner.position.page : 0) %>;
const MY_SIGNER_STATUS = '<%- currentUserSigner ? currentUserSigner.status : "none" %>';

const signersData = <%- JSON.stringify(session.signers.map(s => ({
  _id: s._id,
  userId: s.userId,
  name: s.name,
  status: s.status,
  isMe: s.userId.toString() === currentUser._id.toString(),
  position: s.position
}))) %>;

let pdfDoc = null, currentPage = 0, totalPages = 0, renderTask = null;
const canvas  = document.getElementById('pdfCanvas');
const ctx     = canvas.getContext('2d');
const pdfWrap = document.getElementById('pdfWrap');

// My draggable box
let myBox = null, isDragging = false, dragOffX = 0, dragOffY = 0;

function showToast(msg, ok) {
  const t = document.getElementById('esignToast');
  t.textContent = msg;
  t.className = 'admin-toast admin-toast-' + (ok ? 'success' : 'error') + ' admin-toast-show';
  setTimeout(() => t.className = 'admin-toast', 3500);
}

async function loadPDF() {
  try {
    const pdf = await pdfjsLib.getDocument('/e-sign/' + SESSION_ID + '/pdf').promise;
    pdfDoc    = pdf;
    totalPages = pdf.numPages;
    document.getElementById('totalPages').textContent = totalPages;
    currentPage = Math.min(CURRENT_PAGE_SETTING, totalPages - 1);
    await renderPage(currentPage);
  } catch (e) {
    pdfWrap.innerHTML = '<div style="padding:40px;text-align:center;color:#94a3b8;font-size:13px;">Gagal memuat PDF</div>';
  }
}

async function renderPage(pageNum) {
  if (renderTask) { renderTask.cancel(); renderTask = null; }
  const page     = await pdfDoc.getPage(pageNum + 1);
  const scale    = pdfWrap.clientWidth / page.getViewport({ scale: 1 }).width;
  const viewport = page.getViewport({ scale });
  canvas.width   = viewport.width;
  canvas.height  = viewport.height;

  renderTask = page.render({ canvasContext: ctx, viewport });
  await renderTask.promise;
  renderTask = null;

  document.getElementById('pageNum').textContent = pageNum + 1;
  updateSigBoxes();
}

function updateSigBoxes() {
  // Remove old boxes
  pdfWrap.querySelectorAll('.esign-box').forEach(el => el.remove());
  myBox = null;

  const W = canvas.width;
  const H = canvas.height;

  signersData.forEach(s => {
    if (s.position.page !== currentPage) return;

    const x = s.position.xPct * W;
    const y = s.position.yPct * H;
    const w = s.position.wPct * W;
    const h = s.position.hPct * H;

    const box = document.createElement('div');
    box.className = 'esign-box';
    box.dataset.signerId = s._id;
    box.style.cssText = `
      position:absolute;
      left:${x}px; top:${y}px;
      width:${w}px; height:${h}px;
      border:2px ${s.status === 'signed' ? 'solid' : 'dashed'} ${s.isMe ? '#2563eb' : '#64748b'};
      background:${s.isMe ? 'rgba(37,99,235,0.07)' : 'rgba(100,116,139,0.05)'};
      border-radius:4px;
      display:flex; align-items:flex-start; padding:4px 6px;
      box-sizing:border-box;
      ${s.isMe && s.status === 'pending' ? 'cursor:move;' : 'pointer-events:none;'}
      user-select:none;
      transition: box-shadow .15s;
    `;

    const label = document.createElement('div');
    label.style.cssText = `font-size:10px;font-weight:600;color:${s.isMe ? '#2563eb' : '#64748b'};line-height:1.3;pointer-events:none;`;
    label.innerHTML = (s.status === 'signed' ? '✓ ' : '○ ') + s.name.split(' ')[0];
    if (s.isMe && s.status === 'pending') {
      label.innerHTML += '<br><span style="font-size:9px;font-weight:400;opacity:.7;">seret untuk pindah</span>';
    }
    box.appendChild(label);
    pdfWrap.appendChild(box);

    if (s.isMe && s.status === 'pending') {
      myBox = box;
      setupDrag(box);
    }
  });
}

function setupDrag(box) {
  box.addEventListener('mousedown', e => {
    isDragging = true;
    const rect = pdfWrap.getBoundingClientRect();
    dragOffX = e.clientX - rect.left - box.offsetLeft;
    dragOffY = e.clientY - rect.top  - box.offsetTop;
    box.style.boxShadow = '0 4px 20px rgba(37,99,235,.25)';
    e.preventDefault();
  });
  box.addEventListener('touchstart', e => {
    isDragging = true;
    const rect = pdfWrap.getBoundingClientRect();
    const t = e.touches[0];
    dragOffX = t.clientX - rect.left - box.offsetLeft;
    dragOffY = t.clientY - rect.top  - box.offsetTop;
    e.preventDefault();
  }, { passive: false });
}

document.addEventListener('mousemove', e => {
  if (!isDragging || !myBox) return;
  const rect = pdfWrap.getBoundingClientRect();
  const maxX = canvas.width  - myBox.offsetWidth;
  const maxY = canvas.height - myBox.offsetHeight;
  const newX = Math.max(0, Math.min(maxX, e.clientX - rect.left - dragOffX));
  const newY = Math.max(0, Math.min(maxY, e.clientY - rect.top  - dragOffY));
  myBox.style.left = newX + 'px';
  myBox.style.top  = newY + 'px';
});
document.addEventListener('touchmove', e => {
  if (!isDragging || !myBox) return;
  const rect = pdfWrap.getBoundingClientRect();
  const t = e.touches[0];
  const maxX = canvas.width  - myBox.offsetWidth;
  const maxY = canvas.height - myBox.offsetHeight;
  const newX = Math.max(0, Math.min(maxX, t.clientX - rect.left - dragOffX));
  const newY = Math.max(0, Math.min(maxY, t.clientY - rect.top  - dragOffY));
  myBox.style.left = newX + 'px';
  myBox.style.top  = newY + 'px';
  e.preventDefault();
}, { passive: false });
document.addEventListener('mouseup', () => { isDragging = false; if (myBox) myBox.style.boxShadow = ''; });
document.addEventListener('touchend', () => { isDragging = false; if (myBox) myBox.style.boxShadow = ''; });

function getMyPosition() {
  if (!myBox) return null;
  return {
    page: currentPage,
    xPct: myBox.offsetLeft / canvas.width,
    yPct: myBox.offsetTop  / canvas.height,
    wPct: myBox.offsetWidth  / canvas.width,
    hPct: myBox.offsetHeight / canvas.height,
  };
}

async function signDocument() {
  if (MY_SIGNER_STATUS !== 'pending') { showToast('Anda sudah menandatangani dokumen ini.', false); return; }
  const pos = getMyPosition();
  if (!pos) { showToast('Tidak ada kotak tanda tangan untuk Anda.', false); return; }

  if (!await showConfirm('Tanda tangani dokumen ini sekarang? Tindakan tidak dapat dibatalkan.', {
    title: 'Konfirmasi Tanda Tangan', type: 'primary', confirmLabel: 'Tanda Tangani'
  })) return;

  const btns = document.querySelectorAll('#signBtn, #signBtnPanel');
  btns.forEach(b => { b.disabled = true; b.textContent = 'Memproses...'; });

  try {
    const r = await fetch('/e-sign/' + SESSION_ID + '/sign', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(pos)
    });
    const d = await r.json();
    if (d.ok) {
      showToast(d.allSigned ? 'Dokumen selesai ditandatangani oleh semua pihak!' : 'Berhasil ditandatangani!', true);
      setTimeout(() => location.reload(), 1200);
    } else {
      showToast(d.message || 'Gagal menandatangani.', false);
      btns.forEach(b => { b.disabled = false; b.textContent = 'Tanda Tangani'; });
    }
  } catch {
    showToast('Kesalahan koneksi.', false);
    btns.forEach(b => { b.disabled = false; b.textContent = 'Tanda Tangani'; });
  }
}

async function saveToPersonalDocs() {
  const r = await fetch('/e-sign/' + SESSION_ID + '/save', { method: 'POST' });
  const d = await r.json();
  if (d.ok) showToast('Disimpan ke Dokumen Pribadi!', true);
  else showToast(d.message || 'Gagal menyimpan.', false);
}

function toggleAddSigner() {
  const f = document.getElementById('addSignerForm');
  f.style.display = f.style.display === 'none' ? 'block' : 'none';
}

async function addCoSigner() {
  const sel = document.getElementById('coSignerSelect');
  const userId = sel.value;
  if (!userId) { showToast('Pilih pengguna terlebih dahulu.', false); return; }

  const r = await fetch('/e-sign/' + SESSION_ID + '/add-signer', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId })
  });
  const d = await r.json();
  if (d.ok) {
    showToast('Co-signer ditambahkan!', true);
    setTimeout(() => location.reload(), 800);
  } else {
    showToast(d.message || 'Gagal menambahkan.', false);
  }
}

async function removeSigner(sessionId, signerId) {
  if (!await showConfirm('Hapus penandatangan ini dari dokumen?', { title: 'Hapus Co-Signer', type: 'danger', confirmLabel: 'Hapus' })) return;
  const r = await fetch('/e-sign/' + sessionId + '/signers/' + signerId, { method: 'DELETE' });
  const d = await r.json();
  if (d.ok) { document.getElementById('sigrow-' + signerId)?.remove(); showToast('Co-signer dihapus.', true); }
  else showToast(d.message || 'Gagal.', false);
}

async function changePage(delta) {
  const newPage = currentPage + delta;
  if (newPage < 0 || newPage >= totalPages) return;
  currentPage = newPage;
  await renderPage(currentPage);
}

// Re-render on resize
let resizeTimer;
window.addEventListener('resize', () => {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(() => { if (pdfDoc) renderPage(currentPage); }, 200);
});

loadPDF();
</script>

<%- include('./partials/footer') %>
