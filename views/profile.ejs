<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Profil Saya</div>
    <h1 class="page-title">Profil Saya</h1>
    <p class="page-subtitle">Kelola informasi akun dan keamanan Anda</p>
  </div>
</div>

<% if (success) { %>
<div class="flash-msg flash-success">
  <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  <%= success %>
</div>
<% } %>
<% if (error) { %>
<div class="flash-msg flash-error">
  <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  <%= error %>
</div>
<% } %>

<div class="profile-layout">

  <!-- Left: Avatar card -->
  <div class="profile-sidebar">
    <div class="profile-avatar-card">
      <div class="profile-avatar-wrap">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" class="profile-avatar-img" alt="">
        <% } else { %>
          <div class="profile-avatar-initials"><%= user.getInitials() %></div>
        <% } %>
        <label class="profile-avatar-overlay" for="avatarFile" title="Ganti foto">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M14.5 3.5l2 2L7 15l-3 1 1-3 9.5-9.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </label>
      </div>
      <h3 class="profile-name"><%= user.name %></h3>
      <p class="profile-org"><%= user.organization %></p>
      <span class="profile-badge profile-badge-<%= user.role %>">
        <%= user.role === 'superadmin' ? 'Super Admin' : user.role === 'admin' ? 'Admin' : user.role === 'direktur' ? 'Direktur / Komisaris' : 'Pengguna' %>
      </span>
      <form action="/profile/avatar" method="POST" enctype="multipart/form-data" id="avatarForm">
        <input type="file" id="avatarFile" name="avatar" accept="image/*" style="display:none" onchange="document.getElementById('avatarForm').submit()">
      </form>
      <div class="profile-meta-list">
        <div class="profile-meta-item">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span><%= user.email %></span>
        </div>
        <% if (user.phone) { %>
        <div class="profile-meta-item">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M6.5 3h7A1.5 1.5 0 0115 4.5v11A1.5 1.5 0 0113.5 17h-7A1.5 1.5 0 015 15.5v-11A1.5 1.5 0 016.5 3z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="14" r="1" fill="currentColor"/></svg>
          <span><%= user.phone %></span>
        </div>
        <% } %>
        <div class="profile-meta-item">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span>Bergabung <%= new Date(user.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Right: Forms -->
  <div class="profile-main">

    <!-- Info form -->
    <div class="compose-card">
      <div class="compose-card-header">
        <span class="compose-card-title">Informasi Pribadi</span>
      </div>
      <form action="/profile" method="POST" class="compose-form">
        <div class="profile-form-row">
          <div class="form-group">
            <label class="form-label">Nama Lengkap <span class="req">*</span></label>
            <input type="text" name="name" class="form-control" value="<%= user.name %>" required placeholder="Masukkan nama lengkap">
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" value="<%= user.email %>" disabled>
            <small class="form-hint">Ubah email melalui bagian <a href="#emailSection" style="color:var(--brand-600);">Ubah Email</a> di bawah</small>
          </div>
        </div>
        <div class="profile-form-row">
          <div class="form-group">
            <label class="form-label">ENIK</label>
            <input type="text" name="enik" class="form-control" value="<%= user.enik || '' %>" placeholder="cth: 260403">
            <small class="form-hint">Nomor Induk Karyawan</small>
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" name="jabatan" class="form-control" value="<%= user.jabatan || '' %>" placeholder="Misal: Software Development Manager">
          </div>
        </div>
        <div class="profile-form-row">
          <div class="form-group">
            <label class="form-label">Instansi / Organisasi</label>
            <input type="text" name="organization" class="form-control" value="<%= user.organization || '' %>" placeholder="Nama instansi atau perusahaan">
          </div>
          <div class="form-group">
            <label class="form-label">Nomor Telepon</label>
            <input type="tel" name="phone" class="form-control" value="<%= user.phone || '' %>" placeholder="+62 8xx xxxx xxxx">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Bio</label>
          <textarea name="bio" class="form-control textarea" rows="3" placeholder="Ceritakan sedikit tentang Anda..."><%= user.bio || '' %></textarea>
        </div>
        <div class="compose-actions">
          <button type="submit" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Simpan Perubahan
          </button>
        </div>
      </form>
    </div>

    <!-- Password form -->
    <div class="compose-card" style="margin-top: 16px;">
      <div class="compose-card-header">
        <span class="compose-card-title">Ubah Kata Sandi</span>
      </div>
      <form action="/profile/password" method="POST" class="compose-form">
        <div class="form-group">
          <label class="form-label">Kata Sandi Saat Ini <span class="req">*</span></label>
          <div class="auth-input-group" style="position:relative;">
            <input type="password" id="curPass" name="currentPassword" class="form-control" placeholder="Masukkan kata sandi lama" required>
            <button type="button" class="auth-eye auth-eye-sm" onclick="toggleFieldPass('curPass','ce')" tabindex="-1">
              <svg id="ce" width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
        </div>
        <div class="profile-form-row">
          <div class="form-group">
            <label class="form-label">Kata Sandi Baru <span class="req">*</span></label>
            <div style="position:relative;">
              <input type="password" id="newPass" name="newPassword" class="form-control" placeholder="Min. 8 karakter" required>
              <button type="button" class="auth-eye auth-eye-sm" onclick="toggleFieldPass('newPass','ne')" tabindex="-1">
                <svg id="ne" width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
              </button>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Konfirmasi Kata Sandi Baru <span class="req">*</span></label>
            <input type="password" name="confirmPassword" class="form-control" placeholder="Ulangi kata sandi baru" required>
          </div>
        </div>
        <div class="compose-actions">
          <button type="submit" class="btn btn-secondary">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><rect x="5" y="13" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 13V9a2 2 0 014 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Ubah Kata Sandi
          </button>
        </div>
      </form>
    </div>

    <!-- Email form -->
    <div class="compose-card" style="margin-top:16px;" id="emailSection">
      <div class="compose-card-header">
        <span class="compose-card-title">Ubah Email</span>
      </div>
      <% if (locals.emailSuccess) { %>
      <div class="alert alert-success" style="margin:0 0 16px;padding:10px 14px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;font-size:13px;color:#166534;">
        <%= emailSuccess %>
      </div>
      <% } %>
      <% if (locals.emailError) { %>
      <div class="alert alert-error" style="margin:0 0 16px;padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;font-size:13px;color:#991b1b;">
        <%= emailError %>
      </div>
      <% } %>
      <form action="/profile/email" method="POST" class="compose-form">
        <div class="profile-form-row">
          <div class="form-group">
            <label class="form-label">Email Baru <span class="req">*</span></label>
            <input type="email" name="newEmail" class="form-control" placeholder="email@domain.com" required autocomplete="off">
          </div>
          <div class="form-group">
            <label class="form-label">Konfirmasi Email Baru <span class="req">*</span></label>
            <input type="email" name="confirmEmail" class="form-control" placeholder="Ulangi email baru" required autocomplete="off">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Kata Sandi Saat Ini <span class="req">*</span></label>
          <div style="position:relative;">
            <input type="password" id="emailPassInput" name="password" class="form-control" placeholder="Konfirmasi dengan kata sandi" required autocomplete="current-password">
            <button type="button" class="auth-eye auth-eye-sm" onclick="toggleFieldPass('emailPassInput','epIcon')" tabindex="-1" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--gray-400);">
              <svg id="epIcon" width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            </button>
          </div>
          <small class="form-hint">Diperlukan untuk memverifikasi perubahan email</small>
        </div>
        <div class="compose-actions">
          <button type="submit" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Simpan Email Baru
          </button>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
function toggleFieldPass(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M3 3l14 14M9.88 9.88A3 3 0 0110 7a3 3 0 013 3 3 3 0 01-.12.88M10.73 14.95A7 7 0 013 10s2-5 7-5a7 7 0 013.27.79M17 10s-2 5-7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>';
  }
}
</script>

<%- include('./partials/footer') %>
