<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Surat Masuk — <%= surat.perihal %></title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
body { font-family:'DM Sans',sans-serif; background:#0f172a; color:#1e293b; min-height:100vh; }

/* TOOLBAR */
.pdf-toolbar {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:54px; background:#071840;
  display:flex; align-items:center; gap:12px; padding:0 20px;
  box-shadow:0 1px 0 rgba(255,255,255,.08);
}
.toolbar-back {
  display:flex; align-items:center; gap:6px;
  color:rgba(255,255,255,.6); font-size:13px; text-decoration:none;
  padding:5px 10px; border-radius:6px; transition:background .15s;
}
.toolbar-back:hover { background:rgba(255,255,255,.08); color:#fff; }
.toolbar-sep { width:1px; height:20px; background:rgba(255,255,255,.12); }
.toolbar-title { font-size:13.5px; font-weight:500; color:#fff; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.btn-toolbar {
  display:flex; align-items:center; gap:6px;
  background:rgba(255,255,255,.1); color:rgba(255,255,255,.8); border:none; border-radius:7px;
  padding:7px 14px; font-size:13px; font-weight:500; cursor:pointer; transition:background .15s; white-space:nowrap;
}
.btn-toolbar:hover { background:rgba(255,255,255,.15); }
.btn-toolbar.danger { background:rgba(239,68,68,.2); color:#fca5a5; }
.btn-toolbar.danger:hover { background:rgba(239,68,68,.3); }

/* SHELL */
.pdf-shell { display:flex; height:100vh; padding-top:54px; }
.pdf-canvas-area {
  flex:1; overflow:auto; background:#1e293b;
  display:flex; align-items:flex-start; justify-content:center; padding:40px 24px;
}

/* A4 */
.a4-page {
  position:relative; width:794px; min-height:1123px;
  background:#fff; box-shadow:0 8px 40px rgba(0,0,0,.5); flex-shrink:0; overflow:hidden;
  font-family:'Times New Roman',serif; font-size:12pt; color:#000;
}

/* KOP */
.doc-header { padding:20px 96px 16px 96px; display:flex; align-items:center; }
.doc-header-logo { width:100px; height:auto; object-fit:contain; }
.doc-header-spacer { flex:1; }
.doc-header-contacts { display:grid; grid-template-columns:auto auto; gap:5px 28px; font-size:10.5px; color:#374151; }
.doc-contact-row { display:flex; align-items:center; gap:6px; white-space:nowrap; }
.doc-contact-icon { color:#1a56a8; flex-shrink:0; }
.doc-header-line {
  height:2px;
  background:linear-gradient(to right,transparent 0%,#2E6DA4 15%,#1F4E79 50%,#2E6DA4 85%,transparent 100%);
  margin:0; border:none;
}

/* BODY */
.doc-body { padding:28px 96px 40px; }
.doc-title-block { margin-bottom:24px; }
.doc-label { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#6b7280; margin-bottom:2px; }
.doc-val { font-size:12pt; color:#111827; }

.doc-meta-table { width:100%; border-collapse:collapse; margin-bottom:24px; }
.doc-meta-table td { padding:5px 0; font-size:11pt; vertical-align:top; }
.doc-meta-table td:first-child { width:150px; color:#374151; font-weight:500; }
.doc-meta-table td:nth-child(2) { width:10px; color:#6b7280; }
.doc-meta-table td:last-child { color:#111827; }

.doc-section-line { border:none; border-top:1px solid #e5e7eb; margin:20px 0; }

.doc-body-text { font-size:11.5pt; line-height:1.8; color:#1f2937; }

.doc-disposisi-box {
  margin-top:32px; border:1.5px solid #1d4ed8; border-radius:4px; padding:16px 20px;
}
.doc-disposisi-title { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#1d4ed8; margin-bottom:10px; }
.doc-disposisi-row { display:flex; gap:24px; margin-bottom:8px; }
.doc-disposisi-item { display:flex; align-items:flex-start; gap:8px; font-size:10.5pt; }
.doc-disposisi-item input[type=checkbox] { margin-top:2px; accent-color:#1d4ed8; }

/* SIDE PANEL */
.sm-panel {
  width:300px; flex-shrink:0; background:#f8fafc; border-left:1px solid #e2e8f0;
  overflow-y:auto; padding:20px 16px; display:flex; flex-direction:column; gap:16px;
  height:100%; box-sizing:border-box; align-content:flex-start;
}
.sm-panel-card {
  background:#fff; border:1px solid #e2e8f0;
  border-radius:10px; padding:16px; box-shadow:0 1px 3px rgba(0,0,0,.04);
}
.sm-panel-title { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; color:#94a3b8; margin-bottom:12px; }
.sm-info-row { display:flex; flex-direction:column; gap:2px; margin-bottom:10px; }
.sm-info-row:last-child { margin-bottom:0; }
.sm-info-key { font-size:11px; color:#94a3b8; }
.sm-info-val { font-size:13px; color:#1e293b; font-weight:500; }
.sm-select { width:100%; background:#fff; border:1px solid #cbd5e1; color:#1e293b; border-radius:6px; padding:7px 10px; font-size:13px; outline:none; margin-bottom:10px; }
.sm-select option { background:#fff; }
.sm-btn { width:100%; padding:8px; border-radius:6px; font-size:13px; font-weight:500; cursor:pointer; border:none; transition:background .15s; }
.sm-btn-primary { background:#1a56a8; color:#fff; }
.sm-btn-primary:hover { background:#1d63c0; }
.sm-btn-danger { background:#fef2f2; color:#dc2626; margin-top:8px; border:1px solid #fecaca; }
.sm-btn-danger:hover { background:#fee2e2; }
.sm-textarea { width:100%; background:#fff; border:1px solid #cbd5e1; color:#1e293b; border-radius:6px; padding:8px 10px; font-size:13px; outline:none; resize:vertical; min-height:70px; font-family:inherit; }
.sm-textarea::placeholder { color:#94a3b8; }
.sm-user-opt { display:flex; flex-direction:column; gap:6px; max-height:160px; overflow-y:auto; }
.sm-user-chip {
  display:flex; align-items:center; gap:8px; padding:7px 10px;
  border-radius:6px; background:#f8fafc; border:1px solid #e2e8f0;
  cursor:pointer; transition:background .15s; font-size:12.5px; color:#475569;
}
.sm-user-chip:hover,.sm-user-chip.selected { background:#eff6ff; border-color:#bfdbfe; color:#1e40af; }
.sm-user-chip input[type=checkbox] { accent-color:#1a56a8; flex-shrink:0; }

/* STATUS BADGE */
.status-badge {
  display:inline-block; font-size:11.5px; font-weight:600; padding:3px 10px; border-radius:20px;
}
.st-baru { background:#dbeafe; color:#1d4ed8; }
.st-dibaca { background:#f1f5f9; color:#64748b; }
.st-ditindaklanjuti { background:#fef3c7; color:#92400e; }
.st-selesai { background:#dcfce7; color:#15803d; }

/* FILE EMBED */
.file-embed { width:794px; min-height:1123px; display:block; border:none; }

@media print {
  .pdf-toolbar,.sm-panel { display:none !important; }
  .pdf-shell { padding-top:0; display:block; }
  .pdf-canvas-area { background:#fff; padding:0; }
  .a4-page { box-shadow:none; }
}
</style>
</head>
<body>

<%
const stLabel = { baru:'Baru', dibaca:'Dibaca', ditindaklanjuti:'Ditindaklanjuti', selesai:'Selesai' };
const stCls   = { baru:'st-baru', dibaca:'st-dibaca', ditindaklanjuti:'st-ditindaklanjuti', selesai:'st-selesai' };
const isImg   = surat.file && surat.file.mimetype && surat.file.mimetype.startsWith('image/');
const isPdf   = surat.file && surat.file.mimetype === 'application/pdf';
%>

<!-- TOOLBAR -->
<div class="pdf-toolbar">
  <a href="/surat-masuk" class="toolbar-back">
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Surat Masuk
  </a>
  <div class="toolbar-sep"></div>
  <div class="toolbar-title"><%= surat.perihal %></div>
  <span class="status-badge <%= stCls[surat.status] %>" id="toolbarStatus"><%= stLabel[surat.status] %></span>
  <div class="toolbar-sep"></div>
  <% if (surat.file) { %>
  <a href="<%= surat.file.path %>" target="_blank" class="btn-toolbar">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M6 9l4 4 4-4M3 17h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Unduh
  </a>
  <% } %>
  <button class="btn-toolbar" onclick="window.print()">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M5 7V3h10v4M5 15H3V9h14v6h-2M5 13h10v4H5v-4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Cetak
  </button>
  <button class="btn-toolbar danger" onclick="deleteSurat()">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    Hapus
  </button>
</div>

<div class="pdf-shell">
  <!-- A4 AREA -->
  <div class="pdf-canvas-area">
    <% if (isPdf) { %>
    <!-- PDF embed langsung -->
    <iframe src="<%= surat.file.path %>" class="file-embed" style="box-shadow:0 8px 40px rgba(0,0,0,.5);"></iframe>

    <% } else if (isImg) { %>
    <!-- Gambar scan -->
    <div class="a4-page">
      <img src="<%= surat.file.path %>" style="width:100%;height:auto;display:block;" alt="Scan Surat">
    </div>

    <% } else { %>
    <!-- Tidak ada scan — tampilkan lembar penerimaan A4 -->
    <div class="a4-page">
      <!-- KOP -->
      <div class="doc-header">
        <div><img src="/img/Group 1597880519.png" class="doc-header-logo" alt="INSPIRA" onerror="this.style.display='none'"></div>
        <div class="doc-header-spacer"></div>
        <div class="doc-header-contacts">
          <div class="doc-contact-row"><svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M6.5 3C5.1 3 4 4.1 4 5.5c0 6.9 5.6 12.5 12.5 12.5 1.4 0 2.5-1.1 2.5-2.5v-1.3c0-.4-.2-.7-.5-.9l-3-1.5c-.3-.2-.7-.1-1 .1l-1.3 1.3a9.6 9.6 0 01-4.4-4.4l1.3-1.3c.3-.3.3-.7.1-1l-1.5-3C8.5 3.2 8.2 3 7.8 3H6.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>+62 851 1163 6633</div>
          <div class="doc-contact-row"><svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 10h15M10 2.5c-2 2-3 4.5-3 7.5s1 5.5 3 7.5M10 2.5c2 2 3 4.5 3 7.5s-1 5.5-3 7.5" stroke="currentColor" stroke-width="1.4"/></svg>inspiratekno.com</div>
          <div class="doc-contact-row"><svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M3 5l7 5 7-5M3 5v10h14V5H3z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>nusainspirateknologi@gmail.com</div>
        </div>
      </div>
      <hr class="doc-header-line">

      <div class="doc-body">
        <!-- Judul -->
        <div style="text-align:center;margin-bottom:28px;">
          <div style="font-size:13pt;font-weight:700;letter-spacing:.5px;text-transform:uppercase;">Lembar Penerimaan Surat</div>
          <div style="font-size:10.5pt;color:#6b7280;margin-top:4px;">Surat Masuk — Agenda Internal</div>
        </div>

        <!-- Meta surat -->
        <table class="doc-meta-table">
          <tr>
            <td>No. Agenda</td><td>:</td>
            <td style="font-weight:700;color:#1d4ed8;font-family:monospace;"><%= surat.nomorSurat || '—' %></td>
          </tr>
          <tr>
            <td>Dari / Pengirim</td><td>:</td>
            <td style="font-weight:600;"><%= surat.dariInstansi %></td>
          </tr>
          <tr>
            <td>Perihal</td><td>:</td>
            <td><%= surat.perihal %></td>
          </tr>
          <tr>
            <td>Nomor Surat</td><td>:</td>
            <td><%= surat.nomorSurat || '—' %></td>
          </tr>
          <tr>
            <td>Tanggal Surat</td><td>:</td>
            <td><%= surat.tanggalSurat ? new Date(surat.tanggalSurat).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) : '—' %></td>
          </tr>
          <tr>
            <td>Tanggal Diterima</td><td>:</td>
            <td style="font-weight:500;"><%= new Date(surat.tanggalTerima).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) %></td>
          </tr>
          <tr>
            <td>Klasifikasi</td><td>:</td>
            <td><%= surat.klasifikasi %></td>
          </tr>
          <tr>
            <td>Dicatat Oleh</td><td>:</td>
            <td><%= surat.dicatatOleh?.name || '—' %></td>
          </tr>
        </table>

        <hr class="doc-section-line">

        <!-- Catatan / disposisi -->
        <% if (surat.catatan) { %>
        <div style="margin-bottom:24px;">
          <div class="doc-label" style="margin-bottom:8px;">Catatan / Disposisi</div>
          <div class="doc-body-text"><%= surat.catatan %></div>
        </div>
        <% } %>

        <!-- Kotak disposisi -->
        <div class="doc-disposisi-box">
          <div class="doc-disposisi-title">Lembar Disposisi</div>
          <div class="doc-disposisi-row">
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Untuk Diketahui</div>
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Untuk Ditindaklanjuti</div>
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Untuk Dibalas</div>
          </div>
          <div class="doc-disposisi-row">
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Untuk Diarsipkan</div>
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Untuk Didiskusikan</div>
            <div class="doc-disposisi-item"><input type="checkbox" disabled> Lain-lain</div>
          </div>
          <div style="margin-top:14px;font-size:10.5pt;">
            <div style="font-weight:600;margin-bottom:4px;">Diteruskan Kepada :</div>
            <% if (surat.disposisi && surat.disposisi.length > 0) { %>
              <% surat.disposisi.forEach(function(d) { %>
              <div style="margin-bottom:2px;">• <%= d.nama %> (<%= d.jabatan || d.role || '' %>)</div>
              <% }) %>
            <% } else { %>
            <div style="border-bottom:1px solid #d1d5db;margin-bottom:12px;padding-bottom:2px;">&nbsp;</div>
            <div style="border-bottom:1px solid #d1d5db;margin-bottom:12px;padding-bottom:2px;">&nbsp;</div>
            <% } %>
          </div>
          <% if (surat.disposisiCatatan) { %>
          <div style="margin-top:10px;font-size:10.5pt;">
            <div style="font-weight:600;margin-bottom:4px;">Instruksi / Catatan Disposisi :</div>
            <div><%= surat.disposisiCatatan %></div>
          </div>
          <% } else { %>
          <div style="margin-top:10px;font-size:10.5pt;">
            <div style="font-weight:600;margin-bottom:4px;">Instruksi / Catatan Disposisi :</div>
            <div style="border-bottom:1px solid #d1d5db;margin-bottom:12px;padding-bottom:2px;">&nbsp;</div>
            <div style="border-bottom:1px solid #d1d5db;padding-bottom:2px;">&nbsp;</div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- SIDE PANEL -->
  <div class="sm-panel">

    <!-- Info -->
    <div class="sm-panel-card">
      <div class="sm-panel-title">Info Surat</div>
      <div class="sm-info-row">
        <span class="sm-info-key">Dari</span>
        <span class="sm-info-val"><%= surat.dariInstansi %></span>
      </div>
      <div class="sm-info-row">
        <span class="sm-info-key">Perihal</span>
        <span class="sm-info-val"><%= surat.perihal %></span>
      </div>
      <% if (surat.nomorSurat) { %>
      <div class="sm-info-row">
        <span class="sm-info-key">Nomor</span>
        <span class="sm-info-val" style="font-family:monospace;color:#93c5fd;"><%= surat.nomorSurat %></span>
      </div>
      <% } %>
      <div class="sm-info-row">
        <span class="sm-info-key">Tgl Terima</span>
        <span class="sm-info-val"><%= new Date(surat.tanggalTerima).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}) %></span>
      </div>
      <div class="sm-info-row" style="margin-bottom:0;">
        <span class="sm-info-key">Klasifikasi</span>
        <span class="sm-info-val"><%= surat.klasifikasi %></span>
      </div>
    </div>

    <!-- Status -->
    <div class="sm-panel-card">
      <div class="sm-panel-title">Ubah Status</div>
      <select id="newStatus" class="sm-select">
        <% ['baru','dibaca','ditindaklanjuti','selesai'].forEach(function(s) { %>
        <option value="<%= s %>" <%= surat.status===s?'selected':'' %>><%= stLabel[s] %></option>
        <% }) %>
      </select>
      <button class="sm-btn sm-btn-primary" onclick="updateStatus()">Simpan Status</button>
    </div>

    <!-- Disposisi -->
    <div class="sm-panel-card">
      <div class="sm-panel-title">Disposisi</div>
      <div style="font-size:11.5px;color:#64748b;margin-bottom:10px;margin-top:-8px;">Teruskan ke</div>
      <div id="disposisiUserList" style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;padding-right:2px;">
        <%
          const savedDIds = (surat.disposisi||[]).map(d=>d.userId?.toString());
          const smGrouped = {};
          users.forEach(function(u) {
            const k = u.kodeDir || '__lain__';
            if (!smGrouped[k]) smGrouped[k] = [];
            smGrouped[k].push(u);
          });
          const smDirMap = {};
          direktorats.forEach(function(d){ smDirMap[d.kode] = d.nama; });
          const smKeys = [...direktorats.map(d=>d.kode), '__lain__'].filter(k => smGrouped[k]);
        %>
        <% smKeys.forEach(function(k) { %>
        <div style="border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;background:#fff;">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:7px 10px;background:#f1f5f9;border-bottom:1px solid #e2e8f0;cursor:pointer;"
               onclick="toggleSmGroup(this)">
            <span style="font-size:11px;font-weight:700;color:#1a56a8;letter-spacing:.2px;">
              <% if(k==='__lain__'){ %>Lainnya<% } else { %><%= k %> &mdash; <%= smDirMap[k]||k %><% } %>
            </span>
            <div style="display:flex;align-items:center;gap:8px;">
              <button type="button"
                style="font-size:10.5px;background:#dbeafe;border:none;color:#1a56a8;cursor:pointer;padding:2px 8px;border-radius:4px;font-weight:500;line-height:1.6;"
                onclick="event.stopPropagation();selectSmGroup(this)">Pilih semua</button>
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" class="sm-chevron" style="color:#94a3b8;"><path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
          </div>
          <div class="sm-group-members" style="display:flex;flex-direction:column;gap:1px;padding:4px 6px;">
            <% (smGrouped[k]||[]).forEach(function(u) { %>
            <label style="display:flex;align-items:center;gap:9px;padding:6px 6px;border-radius:6px;cursor:pointer;transition:background .12s;"
                   onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
              <input type="checkbox" value="<%= u._id %>" data-name="<%= u.name %>" data-jabatan="<%= u.jabatan||'' %>"
                style="accent-color:#1a56a8;width:14px;height:14px;flex-shrink:0;"
                <% if(savedDIds.includes(u._id?.toString())){ %>checked<% } %>>
              <div style="min-width:0;">
                <div style="font-size:12.5px;font-weight:500;color:#1e293b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= u.name %></div>
                <% if(u.jabatan){ %><div style="font-size:10.5px;color:#94a3b8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= u.jabatan %></div><% } %>
              </div>
            </label>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
      <div style="margin-top:10px;">
        <div class="sm-panel-title" style="margin-bottom:5px;">Instruksi / Catatan</div>
        <textarea id="disposisiCatatan" class="sm-textarea" placeholder="Instruksi / catatan..."><%= surat.disposisiCatatan||'' %></textarea>
      </div>
      <button class="sm-btn sm-btn-primary" style="margin-top:10px;" onclick="simpanDisposisi()">Simpan Disposisi</button>
    </div>

    <!-- Hapus -->
    <div class="sm-panel-card" style="background:rgba(239,68,68,.05);border-color:rgba(239,68,68,.15);">
      <button class="sm-btn sm-btn-danger" style="margin-top:0;" onclick="deleteSurat()">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none" style="display:inline;margin-right:4px;"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Hapus Surat Ini
      </button>
    </div>

  </div>
</div>

<script>
const SURAT_ID = '<%= surat._id %>';

function toggleSmGroup(header) {
  const members = header.nextElementSibling;
  const chevron = header.querySelector('.sm-chevron');
  const open = members.style.display !== 'none';
  members.style.display = open ? 'none' : 'flex';
  chevron.style.transform = open ? 'rotate(-90deg)' : '';
}
function selectSmGroup(btn) {
  const members = btn.closest('div').parentElement.nextElementSibling;
  const checkboxes = members.querySelectorAll('input[type=checkbox]');
  const allChecked = [...checkboxes].every(cb => cb.checked);
  checkboxes.forEach(cb => cb.checked = !allChecked);
}

function showToast(msg, ok) {
  const existing = document.getElementById('smToast');
  if (existing) existing.remove();
  const t = document.createElement('div');
  t.id = 'smToast';
  t.textContent = msg;
  t.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:500;color:#fff;background:${ok?'#15803d':'#dc2626'};box-shadow:0 4px 16px rgba(0,0,0,.4);`;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

async function updateStatus() {
  const status = document.getElementById('newStatus').value;
  const res  = await fetch('/surat-masuk/' + SURAT_ID + '/status', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ status })
  });
  const data = await res.json();
  if (data.ok) {
    showToast('Status diperbarui.', true);
    const stLabel = { baru:'Baru', dibaca:'Dibaca', ditindaklanjuti:'Ditindaklanjuti', selesai:'Selesai' };
    const stCls   = { baru:'st-baru', dibaca:'st-dibaca', ditindaklanjuti:'st-ditindaklanjuti', selesai:'st-selesai' };
    const badge = document.getElementById('toolbarStatus');
    badge.textContent = stLabel[status];
    badge.className = 'status-badge ' + stCls[status];
  } else showToast('Gagal mengubah status.', false);
}

async function simpanDisposisi() {
  const selected = [...document.querySelectorAll('#disposisiUserList input:checked')].map(cb => ({
    userId: cb.value, nama: cb.dataset.name, jabatan: cb.dataset.jabatan
  }));
  const catatan = document.getElementById('disposisiCatatan').value.trim();
  if (!selected.length && !catatan) { showToast('Pilih penerima atau isi catatan disposisi.', false); return; }
  const res = await fetch('/surat-masuk/' + SURAT_ID + '/disposisi', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ disposisi: selected, disposisiCatatan: catatan })
  });
  const data = await res.json();
  if (data.ok) { showToast('Disposisi berhasil disimpan.', true); setTimeout(() => location.reload(), 1000); }
  else showToast('Gagal menyimpan disposisi.', false);
}

async function deleteSurat() {
  if (!confirm('Yakin ingin menghapus surat masuk ini?')) return;
  const res  = await fetch('/surat-masuk/' + SURAT_ID, { method:'DELETE' });
  const data = await res.json();
  if (data.ok) window.location.href = '/surat-masuk';
  else showToast('Gagal menghapus.', false);
}

// Pre-select disposisi users jika sudah ada
<% if (surat.disposisi && surat.disposisi.length > 0) { %>
document.addEventListener('DOMContentLoaded', function() {
  const ids = <%- JSON.stringify((surat.disposisi||[]).map(d=>d.userId?.toString())) %>;
  document.querySelectorAll('#disposisiUserList input').forEach(cb => {
    if (ids.includes(cb.value)) { cb.checked = true; cb.closest('label').classList.add('selected'); }
  });
});
<% } %>
</script>
</body>
</html>
