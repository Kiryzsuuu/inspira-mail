<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Preview Surat — <%= email.subject %></title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: #0f172a; color: #1e293b; min-height: 100vh; }

.pdf-toolbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: 54px; background: #071840;
  display: flex; align-items: center; gap: 12px; padding: 0 20px;
  box-shadow: 0 1px 0 rgba(255,255,255,.08);
}
.toolbar-back {
  display: flex; align-items: center; gap: 6px;
  color: rgba(255,255,255,.6); font-size: 13px; text-decoration: none;
  padding: 5px 10px; border-radius: 6px; transition: background .15s;
}
.toolbar-back:hover { background: rgba(255,255,255,.08); color: #fff; }
.toolbar-sep { width: 1px; height: 20px; background: rgba(255,255,255,.12); }
.toolbar-title { font-size: 13.5px; font-weight: 500; color: #fff; flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.toolbar-hint { font-size: 12px; color: rgba(255,255,255,.4); }
.btn-dl {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,.1); color: rgba(255,255,255,.8); border: none; border-radius: 7px;
  padding: 7px 14px; font-size: 13px; font-weight: 500; cursor: pointer; transition: background .15s; white-space: nowrap;
}
.btn-dl:hover { background: rgba(255,255,255,.15); }
.btn-send {
  display: flex; align-items: center; gap: 6px;
  background: #1a56a8; color: #fff; border: none; border-radius: 7px;
  padding: 7px 16px; font-size: 13px; font-weight: 500; cursor: pointer; transition: background .15s; white-space: nowrap;
}
.btn-send:hover { background: #1d63c0; }
.btn-send:disabled { background: #334155; color: rgba(255,255,255,.35); cursor: not-allowed; }

.pdf-shell { display: flex; height: 100vh; padding-top: 54px; }
.pdf-canvas-area {
  flex: 1; overflow: auto; background: #1e293b;
  display: flex; align-items: flex-start; justify-content: center; padding: 40px 24px;
}

/* A4 */
.a4-page {
  position: relative; width: 794px; min-height: 1123px;
  background: #fff; box-shadow: 0 8px 40px rgba(0,0,0,.5); flex-shrink: 0; overflow: hidden;
  font-family: 'Times New Roman', serif; font-size: 12pt; color: #000;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}
.a4-page * { color: #000 !important; }

/* KOP SURAT */
.doc-header {
  padding: 20px 96px 16px 96px;
  display: flex; align-items: center;
}
.doc-header-logo-area { display: flex; align-items: center; flex-shrink: 0; }
.doc-header-logo { width: 100px; height: auto; object-fit: contain; }
.doc-header-spacer { flex: 1; }
.doc-header-contacts { display: grid; grid-template-columns: auto auto; gap: 5px 28px; font-size: 10.5px; color: #374151; }
.doc-contact-row { display: flex; align-items: center; gap: 6px; white-space: nowrap; }
.doc-contact-icon { color: #1a56a8; flex-shrink: 0; }
.doc-header-line {
  height: 2px;
  background: linear-gradient(to right, transparent 0%, #2E6DA4 15%, #1F4E79 50%, #2E6DA4 85%, transparent 100%);
  margin: 0; border: none;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}

/* Watermark */
.doc-watermark {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  opacity: 0.045; pointer-events: none; z-index: 0;
  display: flex; flex-direction: column; align-items: center; gap: 0; user-select: none;
}
.doc-watermark img { width: 260px; height: auto; }
.doc-watermark-text { font-size: 64px; font-weight: 900; color: #1a56a8; letter-spacing: 10px; margin-top: -10px; }

/* Classification banner */
.doc-class-banner {
  text-align: center; font-size: 11px; font-weight: 800; letter-spacing: 3px;
  padding: 5px 0; margin: 8px 40px 0;
  border: 2px solid #ef4444; color: #ef4444; border-radius: 3px;
}
.doc-class-banner.konfidensial { border-color: #d97706; color: #d97706; }
/* KLS — classification box inside body (sesuai template) */
.kls { text-align:center; font-weight:bold; border:2px solid #000; padding:4px; margin:8px 0 14px; letter-spacing:2px; font-size:12pt; }

/* Doc meta bar */
.doc-meta {
  padding: 10px 40px;
  background: #f9fafb; border-bottom: 1px solid #e5e7eb;
  display: flex; align-items: center; justify-content: space-between;
}
.doc-nomor { font-size: 11.5px; font-weight: 600; color: #374151; }
.doc-meta-right { display: flex; gap: 6px; align-items: center; }
.doc-pill { font-size: 10px; font-weight: 600; padding: 2px 9px; border-radius: 3px; border: 1px solid #d1d5db; color: #374151; background: #fff; }
.doc-pill.tipe { background: #eff6ff; border-color: #bfdbfe; color: #1d4ed8; }

/* Body container — margin: 2.54cm (1 inch) semua sisi */
.doc-body { padding: 20px 96px 96px 96px; position: relative; z-index: 1; line-height: 1.6; }
.doc-title {
  font-size: 13pt; font-weight: bold; color: #000; margin: 14px 0 4px;
  text-align: center; text-transform: uppercase;
  text-decoration: underline;
}
.doc-para { margin-bottom: 10px; text-align: justify; font-size: 12pt; line-height: 1.6; }
.doc-subtitle { font-size: 12pt; font-weight: bold; color: #000; text-align: center; margin-bottom: 4px; text-decoration: underline; }
.doc-nomor-center { font-size: 12pt; text-align: center; color: #000; margin-bottom: 18px; }

/* Standard info table */
.doc-info-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
.doc-info-table td {
  padding: 5px 0; vertical-align: top; font-size: 12pt;
  border-bottom: 1px solid #000;
}
.doc-info-table td:first-child {
  width: 120px; font-weight: 600; font-size: 12pt; padding-right: 12px;
}
.doc-colon { padding-right: 6px; }

/* Body content */
.doc-body-content {
  border: 1px solid #000; padding: 16px 18px;
  font-size: 12pt; line-height: 1.9; min-height: 120px;
  position: relative; z-index: 1;
}

/* SPPD Table */
.sppd-table { width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 12pt; }
.sppd-table th, .sppd-table td { border: 1px solid #000; padding: 7px 10px; }
.sppd-table th { background: #fff; font-weight: 700; font-size: 12pt; }
.sppd-table td:first-child { width: 40px; text-align: center; font-weight: 600; }
.sppd-table td:nth-child(2) { width: 220px; font-weight: 600; color: #374151; }

/* Memo header table */
.memo-header-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
.memo-header-table td { padding: 5px 0; font-size: 12pt; border-bottom: 1px solid #000; }
.memo-header-table td:first-child { width: 110px; font-weight: 600; font-size: 12pt; }
.memo-header-line { border-top: 2px solid #374151; margin: 14px 0 14px; }

/* Structured sections (SK, Surat Tugas, etc.) */
.doc-section { margin-bottom: 14px; }
.doc-section-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #374151; margin-bottom: 6px; }
.doc-section-list { padding-left: 0; list-style: none; }
.doc-section-list li { font-size: 12.5px; color: #1f2937; padding: 3px 0 3px 20px; position: relative; line-height: 1.7; }
.doc-section-list li::before { content: attr(data-prefix); position: absolute; left: 0; font-weight: 600; color: #6b7280; }

/* Task info block */
.task-info-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
.task-info-table td { padding: 6px 0; font-size: 12.5px; color: #222; border-bottom: 1px solid #f3f4f6; }
.task-info-table td:first-child { width: 160px; font-weight: 600; color: #374151; font-size: 12.5px; padding-right: 10px; }

/* Surat field table — format sesuai template kv() */
.surat-field-table { border-collapse: collapse; margin-bottom: 3px; }
.surat-field-table tr { display: flex; margin-bottom: 3px; font-size: 12pt; line-height: 1.6; }
.surat-field-table td { display: block; border: none; padding: 0; }
.surat-field-table td:nth-child(1) { min-width: 150px; padding-left: 20px; }
.surat-field-table td:nth-child(2) { min-width: 16px; padding: 0 4px; }
.surat-field-table td:nth-child(3) { flex: 1; }

/* Undangan event table */
.und-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; font-size: 12pt; }
.und-table td { padding: 7px 12px; border: 1px solid #000; }
.und-table td:first-child { width: 140px; font-weight: 600; background: #fff; }

/* Pengantar doc list */
.peng-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; font-size: 12pt; }
.peng-table th, .peng-table td { border: 1px solid #000; padding: 6px 10px; }
.peng-table th { background: #fff; font-weight: 700; font-size: 12pt; text-align: left; }

/* Statuta */
.statuta-table { width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 12pt; }
.statuta-table th, .statuta-table td { border: 1px solid #000; padding: 7px 10px; }
.statuta-table th { background: #fff; font-weight: 700; font-size: 12pt; text-align: left; }
.statuta-table td:first-child { width: 40px; text-align: center; }

/* Signature area */
.doc-sig-area { padding: 20px 96px 96px 96px; border-top: none; position: relative; z-index: 1; }
.doc-sig-hint { font-size: 12px; color: #9ca3af; font-style: italic; text-align: center; padding: 20px 0; }

/* QR Stamp */
.qr-stamp {
  position: absolute; cursor: move; user-select: none;
  z-index: 50;
  border: none; outline: 2px dashed transparent; outline-offset: 3px; border-radius: 4px; transition: outline-color .15s;
  display: flex; flex-direction: column; align-items: center;
  padding: 0; text-align: center;
  overflow: visible;
}
.qr-stamp-date { font-size: 11pt; font-family: 'Times New Roman', serif; color: #000; margin-bottom: 6px; white-space: nowrap; text-align: left; width: 100%; }
.qr-stamp:hover, .qr-stamp.active { outline-color: #1a56a8; }
.qr-stamp img { width: 100%; flex: 1; min-height: 0; object-fit: contain; display: block; }
.qr-stamp-sig { width: 95%; border-top: 1.5px solid #111; margin: 5px 0 3px; flex-shrink: 0; }
.qr-stamp-name { font-size: 9.5px; font-weight: 700; color: #111; text-align: center; padding: 0 4px; line-height: 1.5; flex-shrink: 0; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
.qr-stamp-role { font-size: 8.5px; font-weight: 400; color: #111; text-align: center; padding: 1px 4px 3px; flex-shrink: 0; white-space: nowrap; max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
.qr-resize { position: absolute; bottom: 0; right: 0; width: 12px; height: 12px; cursor: se-resize; background: #1a56a8; border-radius: 2px 0 0 0; opacity: 0; transition: opacity .15s; }
.qr-stamp:hover .qr-resize, .qr-stamp.active .qr-resize { opacity: 1; }
.qr-delete { position: absolute; top: -10px; right: -10px; width: 20px; height: 20px; border-radius: 50%; background: #ef4444; color: #fff; border: none; cursor: pointer; font-size: 12px; opacity: 0; transition: opacity .15s; display: flex; align-items: center; justify-content: center; }
.qr-stamp:hover .qr-delete, .qr-stamp.active .qr-delete { opacity: 1; }

/* Right panel */
.pdf-panel {
  width: 290px; flex-shrink: 0; background: #0f172a;
  border-left: 1px solid rgba(255,255,255,.06); overflow-y: auto; display: flex; flex-direction: column;
}
.panel-section { padding: 16px 18px; border-bottom: 1px solid rgba(255,255,255,.06); }
.panel-title { font-size: 10.5px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,.35); margin-bottom: 10px; }
.panel-hint { font-size: 12px; color: rgba(255,255,255,.4); line-height: 1.6; margin-bottom: 10px; }
.btn-add-self {
  width: 100%; padding: 9px; border-radius: 8px; background: #1a56a8; color: #fff; border: none;
  cursor: pointer; font-size: 13px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background .15s;
}
.btn-add-self:hover { background: #1d63c0; }
.btn-add-self:disabled { background: #334155; color: rgba(255,255,255,.35); cursor: not-allowed; }
.cosign-toggle { display: flex; align-items: center; gap: 10px; cursor: pointer; padding: 10px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.04); color: rgba(255,255,255,.75); font-size: 13px; transition: background .15s; }
.cosign-toggle input { accent-color: #1a56a8; width: 15px; height: 15px; }
.cosign-panel { margin-top: 12px; display: none; }
.cosign-panel.open { display: block; }
.panel-select { width: 100%; padding: 8px 10px; border-radius: 6px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #fff; font-size: 13px; margin-bottom: 8px; outline: none; }
.panel-select option { background: #1e293b; color: #fff; }
.btn-add-cosign { width: 100%; padding: 8px; border-radius: 6px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); color: rgba(255,255,255,.8); font-size: 13px; cursor: pointer; transition: background .15s; }
.btn-add-cosign:hover { background: rgba(255,255,255,.14); }
.signer-list { display: flex; flex-direction: column; gap: 8px; }
.signer-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); }
.signer-av { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg,#0f3270,#1a56a8); color: #fff; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.signer-info { flex: 1; min-width: 0; }
.signer-name { font-size: 12.5px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.signer-role { font-size: 11px; color: rgba(255,255,255,.4); margin-top: 1px; }
.signer-del { width: 24px; height: 24px; border-radius: 5px; background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.2); color: #ef4444; font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background .15s; }
.signer-del:hover { background: rgba(239,68,68,.3); }
.empty-signers { text-align: center; padding: 16px 0; color: rgba(255,255,255,.25); font-size: 12px; line-height: 1.7; }
.signer-av-pending { background: rgba(255,255,255,.12) !important; }
.j-hidden { display: none; }
.jabatan-input { width: 100%; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #fff; border-radius: 5px; padding: 5px 8px; font-size: 11.5px; outline: none; }

/* Display mode toggles */
.display-mode-row { display: flex; gap: 6px; margin-top: 8px; }
.dm-btn {
  flex: 1; padding: 5px 4px; border-radius: 5px; border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.04); color: rgba(255,255,255,.5); font-size: 10.5px; font-weight: 600;
  cursor: pointer; text-align: center; transition: all .15s; line-height: 1.3;
}
.dm-btn:hover { background: rgba(255,255,255,.1); color: rgba(255,255,255,.8); }
.dm-btn.active { background: #1a56a8; color: #fff; border-color: #1a56a8; }

@media print {
  @page { size: A4; margin: 0; }
  html, body { margin: 0; padding: 0; background: #fff !important; }
  .pdf-toolbar, .pdf-panel { display: none !important; }
  .pdf-shell { display: block !important; padding-top: 0 !important; }
  .pdf-canvas-area { display: block !important; padding: 0 !important; background: #fff !important; overflow: visible !important; }
  .a4-page { width: 210mm !important; min-height: 297mm !important; box-shadow: none !important; overflow: hidden !important; }
  .doc-meta { display: none !important; }
  .qr-resize, .qr-delete { display: none !important; }
  .qr-stamp { outline: none !important; cursor: default !important; }
}
</style>
</head>
<body>

<%
  const sd = email.suratData || {};
  const tipe = email.tipeSurat || 'Surat';
  function fmtDate(d) {
    if (!d) return '—';
    const dt = new Date(d);
    const bln = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    return `${dt.getDate()} ${bln[dt.getMonth()]} ${dt.getFullYear()}`;
  }
  function fmtDateSimple(str) {
    if (!str) return '—';
    const dt = new Date(str);
    if (isNaN(dt)) return str;
    const bln = ['Januari','Februari','Maret','Oktober','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    const bl2 = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    return `${dt.getDate()} ${bl2[dt.getMonth()]} ${dt.getFullYear()}`;
  }
%>

<div class="pdf-toolbar">
  <a href="/compose" class="toolbar-back">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M12 4l-8 8 8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Kembali
  </a>
  <div class="toolbar-sep"></div>
  <div class="toolbar-title">Preview — <%= tipe %>: <%= email.subject %></div>
  <span class="toolbar-hint">Tanda tangan, lalu kirim</span>
  <button class="btn-dl" onclick="window.print()">
    <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M6 9l4 4 4-4M3 17h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Download PDF
  </button>
  <button class="btn-send" id="btnKirim" onclick="kirimSurat()">
    <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Kirim Surat
  </button>
</div>

<div class="pdf-shell">
  <div class="pdf-canvas-area">
    <div class="a4-page" id="a4Page">

      <!-- KOP SURAT INSPIRA -->
      <div class="doc-header">
        <div class="doc-header-logo-area">
          <img src="/img/Group 1597880519.png" class="doc-header-logo" alt="INSPIRA" onerror="this.style.display='none'">
        </div>
        <div class="doc-header-spacer"></div>
        <div class="doc-header-contacts">
          <div class="doc-contact-row">
            <svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M6.5 3C5.1 3 4 4.1 4 5.5c0 6.9 5.6 12.5 12.5 12.5 1.4 0 2.5-1.1 2.5-2.5v-1.3c0-.4-.2-.7-.5-.9l-3-1.5c-.3-.2-.7-.1-1 .1l-1.3 1.3a9.6 9.6 0 01-4.4-4.4l1.3-1.3c.3-.3.3-.7.1-1l-1.5-3C8.5 3.2 8.2 3 7.8 3H6.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            +62 851 1163 6633
          </div>
          <div class="doc-contact-row">
            <svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 10h15M10 2.5c-2 2-3 4.5-3 7.5s1 5.5 3 7.5M10 2.5c2 2 3 4.5 3 7.5s-1 5.5-3 7.5" stroke="currentColor" stroke-width="1.4"/></svg>
            inspiratekno.com
          </div>
          <div class="doc-contact-row">
            <svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M3 5l7 5 7-5M3 5v10h14V5H3z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            nusainspirateknologi@gmail.com
          </div>
          <div class="doc-contact-row">
            <svg class="doc-contact-icon" width="12" height="12" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.4"/><circle cx="14.5" cy="5.5" r=".8" fill="currentColor"/></svg>
            inspira.teknologi
          </div>
        </div>
      </div>

      <div class="doc-header-line"></div>

      <!-- Watermark -->
      <div class="doc-watermark" aria-hidden="true">
        <img src="/img/Group 1597880519.png" alt="">
        <div class="doc-watermark-text">INSPIRA</div>
      </div>

      <!-- Classification Banner -->
      <% if (tipe === 'Surat Rahasia') { %>
      <div class="doc-class-banner">[ RAHASIA ]</div>
      <% } else if (tipe === 'Surat Konfidensial') { %>
      <div class="doc-class-banner konfidensial">[ KONFIDENSIAL ]</div>
      <% } %>

      <!-- Meta bar -->
      <div class="doc-meta">
        <div class="doc-nomor">Nomor: <strong><%= email.nomorSurat %></strong></div>
        <div class="doc-meta-right">
          <span class="doc-pill tipe"><%= tipe %></span>
          <span class="doc-pill"><%= email.sifat %></span>
          <span class="doc-pill"><%= email.jenis === 'internal' ? 'Internal' : 'Eksternal' %></span>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- DOCUMENT BODY — rendered per type                      -->
      <!-- ═══════════════════════════════════════════════════════ -->

      <%
        const recipients = email.jenis === 'internal'
          ? email.to.map(r=>r.name)
          : (email.toExternal||[]).map(r=>r.name);
        const hasBody = email.body && email.body.trim() && email.body.trim() !== '<p><br></p>';
      %>

      <% if (tipe === 'Memo') { %>
      <!-- ── MEMO ── -->
      <div class="doc-body">
        <div class="doc-title">MEMO</div>
        <p style="text-align:center;margin-bottom:14px;">INTERNAL PT NUSA INSPIRA TEKNOLOGI</p>
        <table class="surat-field-table">
          <tr><td>Kepada</td><td>:</td><td><strong><%= sd.kepada || recipients.join(', ') || '—' %></strong></td></tr>
          <tr><td>Dari</td><td>:</td><td><%= email.from.name %></td></tr>
          <tr><td>Perihal</td><td>:</td><td><strong><%= email.subject %></strong></td></tr>
          <tr><td>Tanggal</td><td>:</td><td><%= fmtDate(email.createdAt) %></td></tr>
          <% if (sd.klasifikasi) { %><tr><td>Klasifikasi</td><td>:</td><td><strong><%= sd.klasifikasi %></strong></td></tr><% } %>
        </table>
        <hr style="border:none;border-top:1px solid #000;margin:12px 0;">
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
      </div>

      <% } else if (tipe === 'Nota Dinas') { %>
      <!-- ── NOTA DINAS ── -->
      <div class="doc-body">
        <div class="doc-title">NOTA DINAS</div>
        <p style="text-align:center;margin-bottom:14px;">INTERNAL — PT NUSA INSPIRA TEKNOLOGI</p>
        <table class="surat-field-table">
          <tr><td>Kepada</td><td>:</td><td><strong><%= sd.kepada || recipients.join(', ') || '—' %></strong></td></tr>
          <tr><td>Dari</td><td>:</td><td><%= email.from.name %></td></tr>
          <tr><td>Nomor</td><td>:</td><td><%= email.nomorSurat %></td></tr>
          <tr><td>Tanggal</td><td>:</td><td><%= fmtDate(email.createdAt) %></td></tr>
          <tr><td>Perihal</td><td>:</td><td><strong><%= email.subject %></strong></td></tr>
        </table>
        <hr style="border:none;border-top:1px solid #000;margin:12px 0;">
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <% if (sd.budgetRows && sd.budgetRows.length > 0) { %>
        <table class="sppd-table" style="margin-top:10px;">
          <thead><tr><th>No.</th><th>Uraian Kebutuhan</th><th>Jumlah (Rp)</th></tr></thead>
          <tbody>
          <% sd.budgetRows.forEach((r,i) => { %>
          <tr><td><%= i+1 %></td><td><%= r.uraian %></td><td><%= r.jumlah %></td></tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
        <p class="doc-para" style="margin-top:10px;">Atas perhatian dan tindak lanjutnya, kami ucapkan terima kasih.</p>
      </div>

      <% } else if (tipe === 'SPPD') { %>
      <!-- ── SPPD ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT PERINTAH PERJALANAN DINAS (SPPD)</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <table class="sppd-table">
          <thead><tr><th>No.</th><th>Keterangan</th><th>Isian</th></tr></thead>
          <tbody>
            <tr><td>1</td><td>Pejabat yang memberikan perintah</td><td><strong><%= email.from.name %></strong> — Direktur Utama</td></tr>
            <tr><td>2</td><td>Nama pegawai yang diperintahkan</td><td><strong><%= sd.namaPegawai || '—' %></strong></td></tr>
            <tr><td>3</td><td>Jabatan</td><td><%= sd.jabatanPegawai || '—' %></td></tr>
            <tr><td>4</td><td>Tingkat / Golongan</td><td><%= sd.golongan || '—' %></td></tr>
            <tr><td>5</td><td>Maksud perjalanan dinas</td><td><%= sd.maksudPerjalanan || email.subject || '—' %></td></tr>
            <tr><td>6</td><td>Alat angkutan yang digunakan</td><td><%= sd.alatAngkutan || '—' %></td></tr>
            <tr><td>7</td><td>Tempat berangkat</td><td><%= sd.tempatBerangkat || '—' %></td></tr>
            <tr><td>8</td><td>Tempat tujuan</td><td><%= sd.tempatTujuan || '—' %></td></tr>
            <tr><td>9</td><td>Tanggal berangkat</td><td><%= fmtDateSimple(sd.tanggalBerangkat) %></td></tr>
            <tr><td>10</td><td>Tanggal kembali</td><td><%= fmtDateSimple(sd.tanggalKembali) %></td></tr>
            <tr><td>11</td><td>Lama perjalanan dinas</td><td><% if(sd.tanggalBerangkat&&sd.tanggalKembali){const d1=new Date(sd.tanggalBerangkat),d2=new Date(sd.tanggalKembali);const diff=Math.round((d2-d1)/(1000*60*60*24))+1;%><%=diff%> (<%=diff===1?'satu':diff%>) hari<%}else{%>—<%}%></td></tr>
            <tr><td>12</td><td>Pembebanan anggaran</td><td>PT Nusa Inspira Teknologi / <%= sd.mataPenggunaan || 'Biaya Operasional' %></td></tr>
          </tbody>
        </table>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:10px;"><%- email.body %></div><% } %>
        <table class="sppd-table" style="margin-top:16px;">
          <thead><tr><th>Keterangan</th><th>Tanggal</th><th>Tanda Tangan &amp; Cap</th></tr></thead>
          <tbody>
            <tr><td>Tiba di tempat tujuan</td><td style="width:140px;"></td><td style="width:160px;"></td></tr>
            <tr><td>Berangkat dari tempat tujuan</td><td></td><td></td></tr>
            <tr><td>Tiba kembali di tempat asal</td><td></td><td></td></tr>
          </tbody>
        </table>
      </div>

      <% } else if (tipe === 'Surat Tugas') { %>
      <!-- ── SURAT TUGAS ── -->
      <%
        const tugasPelaksana = sd.pelaksana && sd.pelaksana.length > 0
          ? sd.pelaksana
          : (sd.namaPelaksana ? [{ nama: sd.namaPelaksana, jabatan: sd.jabatanPelaksana }] : []);
      %>
      <div class="doc-body">
        <div class="doc-title">SURAT TUGAS</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPemberiTugas || email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPemberiTugas || 'Direktur Utama' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Dengan ini menugaskan kepada:</p>
        <% if (tugasPelaksana.length === 1) { %>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= tugasPelaksana[0].nama %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= tugasPelaksana[0].jabatan || '—' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <% } else if (tugasPelaksana.length > 1) { %>
        <table class="sppd-table" style="margin-bottom:10px;">
          <thead><tr><th style="width:36px;">No.</th><th>Nama</th><th>Jabatan</th></tr></thead>
          <tbody>
          <% tugasPelaksana.forEach((p, i) => { %>
          <tr><td style="text-align:center;"><%= i+1 %></td><td><strong><%= p.nama %></strong></td><td><%= p.jabatan || '—' %></td></tr>
          <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong>—</strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>—</td></tr>
        </table>
        <% } %>
        <p class="doc-para" style="margin-top:10px;">Untuk melaksanakan tugas dengan rincian sebagai berikut:</p>
        <table class="surat-field-table">
          <tr><td>Jenis Tugas</td><td>:</td><td><strong><%= sd.jenisTugas || email.subject || '—' %></strong></td></tr>
          <% if(sd.tujuanTugas){%><tr><td>Tujuan</td><td>:</td><td><%= sd.tujuanTugas %></td></tr><%}%>
          <% if(sd.lokasiTugas){%><tr><td>Lokasi</td><td>:</td><td><%= sd.lokasiTugas %></td></tr><%}%>
          <% if(sd.tanggalTugas){%><tr><td>Tanggal</td><td>:</td><td><%= fmtDateSimple(sd.tanggalTugas) %></td></tr><%}%>
          <% if(sd.waktuTugas){%><tr><td>Waktu</td><td>:</td><td><%= sd.waktuTugas %></td></tr><%}%>
        </table>
        <% if (hasBody) { %><p class="doc-para" style="margin-top:12px;"><%- email.body %></p><% } %>
        <p class="doc-para">Demikian surat tugas ini diberikan untuk dilaksanakan dengan penuh tanggung jawab dan profesionalisme.</p>
      </div>

      <% } else if (tipe === 'Surat Tugas Pendelegasian') { %>
      <!-- ── SURAT TUGAS PENDELEGASIAN ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT TUGAS PENDELEGASIAN</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Selanjutnya disebut PENDELEGASI, dengan ini mendelegasikan tugas dan wewenang kepada:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPenerima || '—' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPenerima || '—' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Selanjutnya disebut PELAKSANA DELEGASI.</p>
        <% if (sd.lingkupDelegasi && sd.lingkupDelegasi.length > 0) { %>
        <p><strong>Lingkup Pendelegasian:</strong></p>
        <% sd.lingkupDelegasi.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= i+1 %>. <%= item %></p>
        <% }) %>
        <% } %>
        <% if (sd.ketentuanDelegasi && sd.ketentuanDelegasi.length > 0) { %>
        <p style="margin-top:10px;"><strong>Ketentuan Pendelegasian:</strong></p>
        <% sd.ketentuanDelegasi.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= String.fromCharCode(97+i) %>. <%= item %>;</p>
        <% }) %>
        <% } %>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:10px;"><%- email.body %></div><% } %>
        <p class="doc-para">Pendelegasian ini berlaku selama pelaksanaan tugas yang dimaksud dan berakhir otomatis setelah laporan final diterima.</p>
      </div>

      <% } else if (tipe === 'Surat Keterangan') { %>
      <!-- ── SURAT KETERANGAN ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT KETERANGAN</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:12px;">Dengan ini menerangkan bahwa:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaDiterangkan || '—' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanDiterangkan || '—' %></td></tr>
          <% if(sd.timDiterangkan){%><tr><td>Tim / Unit</td><td>:</td><td><%= sd.timDiterangkan %></td></tr><%}%>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:12px;"><% if(hasBody){%><%- email.body %><%}else{%>Adalah benar merupakan anggota aktif PT Nusa Inspira Teknologi<% if(sd.keperluan){ %> dan ditugaskan untuk <%= sd.keperluan %><% }%><% if(sd.lokasiTugas){ %> di <%= sd.lokasiTugas %><% }%><% if(sd.tanggalTugas){ %> pada tanggal <%= fmtDateSimple(sd.tanggalTugas) %><% }%>.<%}%></p>
        <p class="doc-para">Surat keterangan ini dibuat untuk digunakan sebagaimana mestinya.</p>
      </div>

      <% } else if (tipe === 'Surat Pernyataan') { %>
      <!-- ── SURAT PERNYATAAN ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT PERNYATAAN</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPenyataan || '—' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPernyataan || '—' %></td></tr>
          <% if(sd.timPernyataan){%><tr><td>Tim</td><td>:</td><td><%= sd.timPernyataan %></td></tr><%}%>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:12px;">Dengan ini menyatakan dengan sesungguhnya bahwa:</p>
        <% if (sd.poinPernyataan && sd.poinPernyataan.length > 0) { %>
        <% sd.poinPernyataan.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:8px;text-align:justify;"><%= i+1 %>. <%= item %></p>
        <% }) %>
        <% } %>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <p class="doc-para">Demikian surat pernyataan ini dibuat dengan sesungguhnya dan dapat digunakan sebagai alat bukti yang sah.</p>
      </div>

      <% } else if (tipe === 'Surat Kuasa') { %>
      <!-- ── SURAT KUASA ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT KUASA</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <p><strong><u>PEMBERI KUASA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Selanjutnya disebut PEMBERI KUASA, memberikan kuasa penuh kepada:</p>
        <p><strong><u>PENERIMA KUASA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPenerima || '—' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPenerima || '—' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Untuk bertindak dalam hal-hal berikut:</p>
        <% if (sd.ruangLingkup && sd.ruangLingkup.length > 0) { %>
        <% sd.ruangLingkup.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= i+1 %>. <%= item %></p>
        <% }) %>
        <% } %>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <p class="doc-para">Surat Kuasa ini berlaku sampai selesainya pelaksanaan tugas yang dimaksud.</p>
      </div>

      <% } else if (tipe === 'Surat Pengantar') { %>
      <!-- ── SURAT PENGANTAR ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT PENGANTAR</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth.</p>
        <p><strong><%= sd.kepada || recipients.join(', ') || '—' %></strong></p>
        <% if (sd.alamatPenerima) { %><p><%= sd.alamatPenerima %></p><% } %>
        <br>
        <p class="doc-para">Dengan hormat, bersama surat pengantar ini kami sampaikan kepada Bapak/Ibu:</p>
        <% if (sd.dokumenList && sd.dokumenList.length > 0) { %>
        <table class="peng-table">
          <thead><tr><th>No.</th><th>Dokumen / Barang</th><th>Jumlah</th><th>Keterangan</th></tr></thead>
          <tbody>
          <% sd.dokumenList.forEach((doc,i) => { %>
          <tr><td style="text-align:center;"><%= i+1 %></td><td><%= doc.nama %></td><td><%= doc.jumlah||'—' %></td><td><%= doc.keterangan||'—' %></td></tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
        <br>
        <% if (hasBody) { %><p class="doc-para"><%- email.body %></p><% } %>
        <p class="doc-para">Atas perhatian dan kerja sama Bapak/Ibu, kami ucapkan terima kasih.</p>
      </div>

      <% } else if (tipe === 'Surat Keputusan') { %>
      <!-- ── SURAT KEPUTUSAN ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT KEPUTUSAN</div>
        <p class="doc-title" style="font-size:12pt;">DIREKTUR UTAMA PT NUSA INSPIRA TEKNOLOGI</p>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p style="text-align:center;margin-bottom:4px;">Tentang</p>
        <p class="doc-title" style="font-size:12pt;"><%= email.subject.toUpperCase() %></p><br>
        <p><strong><u>DIREKTUR UTAMA PT NUSA INSPIRA TEKNOLOGI</u></strong></p><br>
        <% if (sd.menimbang && sd.menimbang.length > 0) { %>
        <p style="margin-bottom:6px;"><strong>Menimbang :</strong></p>
        <% sd.menimbang.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= String.fromCharCode(97+i) %>. <%= item %></p>
        <% }) %>
        <% } %>
        <% if (sd.mengingat && sd.mengingat.length > 0) { %>
        <p style="margin-top:10px;margin-bottom:6px;"><strong>Mengingat :</strong></p>
        <% sd.mengingat.forEach((item,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= i+1 %>. <%= item %></p>
        <% }) %>
        <% } %>
        <br><p><strong><u>MEMUTUSKAN:</u></strong></p><br>
        <p style="font-weight:bold;text-align:center;margin-bottom:8px;">Menetapkan :</p>
        <% if (sd.memutuskan && sd.memutuskan.length > 0) { %>
        <% const prefixes=['PERTAMA','KEDUA','KETIGA','KEEMPAT','KELIMA','KEENAM','KETUJUH','KEDELAPAN']; %>
        <% sd.memutuskan.forEach((item,i) => { %>
        <p style="font-weight:bold;margin-bottom:3px;"><%= prefixes[i]||('POIN '+(i+1)) %> :</p>
        <p class="doc-para"><%= item %></p>
        <% }) %>
        <% } %>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:10px;"><%- email.body %></div><% } %>
      </div>

      <% } else if (tipe === 'Surat Undangan Dinas') { %>
      <!-- ── SURAT UNDANGAN DINAS ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT UNDANGAN DINAS</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth.</p>
        <% recipients.forEach(r => { %><p><strong><%= r %></strong></p><% }) %>
        <p>di Tempat</p><br>
        <p class="doc-para">Dengan hormat, dalam rangka koordinasi dan pelaksanaan tugas, dengan ini kami mengundang Saudara/i untuk hadir:</p>
        <table class="sppd-table">
          <thead><tr><th>Keterangan</th><th>Detail</th></tr></thead>
          <tbody>
            <% if(sd.tanggalUndangan){%><tr><td>Hari / Tanggal</td><td><%= fmtDateSimple(sd.tanggalUndangan) %></td></tr><%}%>
            <% if(sd.waktuUndangan){%><tr><td>Waktu</td><td><%= sd.waktuUndangan %></td></tr><%}%>
            <% if(sd.tempatUndangan){%><tr><td>Tempat</td><td><%= sd.tempatUndangan %></td></tr><%}%>
            <% if(sd.agendaUndangan){%><tr><td>Agenda</td><td><strong><%= sd.agendaUndangan %></strong></td></tr><%}%>
            <% if(sd.pakaianUndangan){%><tr><td>Pakaian</td><td><%= sd.pakaianUndangan %></td></tr><%}%>
          </tbody>
        </table>
        <br>
        <p class="doc-para">Kehadiran Saudara/i sangat kami harapkan. Atas perhatian dan kehadiran Saudara/i, kami ucapkan terima kasih.</p>
      </div>

      <% } else if (tipe === 'Surat Statuta') { %>
      <!-- ── SURAT STATUTA ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT STATUTA</div>
        <div class="doc-nomor-center">PT NUSA INSPIRA TEKNOLOGI</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-title" style="font-size:12pt;">STATUTA <%= (sd.namaOrganisasi || email.subject).toUpperCase() %></p><br>
        <p><strong>BAB I – VISI DAN MISI</strong></p>
        <% if (sd.visi) { %><p class="doc-para"><em>Visi:</em> <%= sd.visi %></p><% } %>
        <% if (sd.misi && sd.misi.length > 0) { %>
        <p class="doc-para"><em>Misi:</em></p>
        <% sd.misi.forEach((m,i) => { %>
        <p style="margin-left:30px;margin-bottom:6px;text-align:justify;"><%= String.fromCharCode(97+i) %>. <%= m %></p>
        <% }) %>
        <% } %>
        <% if (sd.anggota && sd.anggota.length > 0) { %>
        <p style="margin-top:12px;"><strong>BAB II – KEANGGOTAAN</strong></p>
        <table class="statuta-table">
          <thead><tr><th>No.</th><th>Nama</th><th>Jabatan dalam Tim</th></tr></thead>
          <tbody>
          <% sd.anggota.forEach((a,i) => { %>
          <tr><td><%= i+1 %></td><td><%= a.nama %></td><td><%= a.jabatan %></td></tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
        <br><p><strong>BAB III – PENUTUP</strong></p>
        <p class="doc-para">Statuta ini berlaku sejak ditetapkan dan mengikat seluruh anggota tim selama menjalankan tugas yang dimandatkan.</p>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:10px;"><%- email.body %></div><% } %>
      </div>

      <% } else if (tipe === 'MOU') { %>
      <!-- ── MOU ── -->
      <div class="doc-body">
        <div class="doc-title">MEMORANDUM OF UNDERSTANDING (MOU)</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">MOU ini dibuat dan ditandatangani pada <%= fmtDate(email.createdAt) %>, di Jakarta, oleh dan antara:</p>
        <p style="margin-bottom:4px;"><strong>1. PT NUSA INSPIRA TEKNOLOGI</strong></p>
        <p class="doc-para" style="margin-left:20px;">Diwakili oleh <strong><%= email.from.name %></strong> selaku Direktur Utama, selanjutnya disebut <strong>PIHAK PERTAMA</strong>.</p>
        <p style="margin-bottom:4px;"><strong>2. <%= (sd.instansiPihakKedua||'[NAMA INSTANSI]').toUpperCase() %></strong></p>
        <p class="doc-para" style="margin-left:20px;">Diwakili oleh <strong><%= sd.namaPihakKedua||'[Nama Perwakilan]' %></strong> selaku <%= sd.jabatanPihakKedua||'[Jabatan]' %>, selanjutnya disebut <strong>PIHAK KEDUA</strong>.</p>
        <% if (hasBody) { %>
        <div class="doc-para" style="margin-top:10px;"><%- email.body %></div>
        <% } else { %>
        <p style="font-weight:bold;margin-top:12px;margin-bottom:4px;">Pasal 1 – Ruang Lingkup</p>
        <p class="doc-para">Para Pihak sepakat untuk mengadakan kerja sama dalam bidang audit, investigasi, dan peningkatan kualitas tata kelola operasional.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 2 – Jangka Waktu</p>
        <p class="doc-para">MOU ini berlaku selama 2 (dua) tahun sejak ditandatangani dan dapat diperpanjang atas kesepakatan Para Pihak.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 3 – Kerahasiaan</p>
        <p class="doc-para">Para Pihak wajib menjaga kerahasiaan seluruh informasi yang diperoleh dan tidak akan mengungkapkan kepada pihak ketiga tanpa persetujuan tertulis.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 4 – Penutup</p>
        <p class="doc-para">MOU ini dibuat dalam 2 (dua) rangkap asli, bermaterai cukup, masing-masing mempunyai kekuatan hukum yang sama.</p>
        <% } %>
      </div>

      <% } else if (tipe === 'PKS') { %>
      <!-- ── PKS ── -->
      <div class="doc-body">
        <div class="doc-title">PERJANJIAN KERJASAMA (PKS)</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">PKS ini dibuat pada <%= fmtDate(email.createdAt) %>, di Jakarta, oleh dan antara:</p>
        <p><strong><u>PIHAK PERTAMA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:8px;">Selanjutnya disebut <strong>PIHAK PERTAMA</strong>.</p>
        <p><strong><u>PIHAK KEDUA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPihakKedua||'[Nama]' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPihakKedua||'[Jabatan]' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td><%= sd.instansiPihakKedua||'[Instansi]' %></td></tr>
          <% if(sd.alamatPihakKedua){%><tr><td>Alamat</td><td>:</td><td><%= sd.alamatPihakKedua %></td></tr><%}%>
        </table>
        <p class="doc-para" style="margin-top:8px;">Selanjutnya disebut <strong>PIHAK KEDUA</strong>.</p>
        <% if (hasBody) { %>
        <div class="doc-para" style="margin-top:10px;"><%- email.body %></div>
        <% } else { %>
        <p style="font-weight:bold;margin-top:12px;margin-bottom:4px;">Pasal 1 — Objek Kerjasama</p>
        <p class="doc-para">Para Pihak sepakat mengadakan kerjasama dalam pelaksanaan audit, investigasi, dan peningkatan kualitas tata kelola operasional.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 2 — Hak dan Kewajiban</p>
        <p class="doc-para">(1) Pihak Pertama berhak mendapatkan akses penuh dan laporan yang akurat dari Pihak Kedua.</p>
        <p class="doc-para">(2) Pihak Kedua wajib menyediakan fasilitas, dokumen, dan personel yang diperlukan.</p>
        <p class="doc-para">(3) Kedua pihak wajib menjaga kerahasiaan informasi selama dan setelah berakhirnya perjanjian.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 3 — Jangka Waktu</p>
        <p class="doc-para">Perjanjian berlaku selama 1 (satu) tahun sejak ditandatangani dan dapat diperpanjang atas kesepakatan Para Pihak.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 4 — Penutup</p>
        <p class="doc-para">PKS ini dibuat dalam 2 (dua) rangkap asli, bermaterai cukup, dan mempunyai kekuatan hukum yang sama.</p>
        <% } %>
      </div>

      <% } else if (tipe === 'Kontrak') { %>
      <!-- ── KONTRAK ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT KONTRAK</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Kontrak ini dibuat pada <%= fmtDate(email.createdAt) %>, di Jakarta, oleh dan antara:</p>
        <p><strong><u>PIHAK PERTAMA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:8px;">Selanjutnya disebut <strong>PIHAK PERTAMA</strong>.</p>
        <p><strong><u>PIHAK KEDUA</u></strong></p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= sd.namaPihakKedua||'[Nama]' %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td><%= sd.jabatanPihakKedua||'[Jabatan]' %></td></tr>
          <tr><td>Instansi</td><td>:</td><td><%= sd.instansiPihakKedua||'[Instansi]' %></td></tr>
        </table>
        <p class="doc-para" style="margin-top:8px;">Selanjutnya disebut <strong>PIHAK KEDUA</strong>.</p>
        <% if (hasBody) { %>
        <div class="doc-para" style="margin-top:10px;"><%- email.body %></div>
        <% } else { %>
        <p style="font-weight:bold;margin-top:12px;margin-bottom:4px;">Pasal 1 — Objek Kontrak</p>
        <p class="doc-para">Pihak Kedua setuju melaksanakan pekerjaan sesuai spesifikasi yang ditetapkan Pihak Pertama.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 2 — Nilai Kontrak</p>
        <p class="doc-para">Nilai kontrak sebesar Rp. <%= sd.nilaiKontrak||'[Nilai Kontrak]' %>, sudah termasuk pajak yang berlaku.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 3 — Jangka Waktu</p>
        <p class="doc-para">Pekerjaan diselesaikan dalam 30 (tiga puluh) hari kalender sejak penandatanganan kontrak.</p>
        <p style="font-weight:bold;margin-bottom:4px;">Pasal 4 — Penutup</p>
        <p class="doc-para">Kontrak ini dibuat dalam 2 (dua) rangkap asli, bermaterai cukup, dan mempunyai kekuatan hukum yang sama.</p>
        <% } %>
      </div>

      <% } else if (tipe === 'SPK') { %>
      <!-- ── SPK ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT PERINTAH KERJA (SPK)</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p class="doc-para">Yang bertanda tangan di bawah ini:</p>
        <table class="surat-field-table">
          <tr><td>Nama</td><td>:</td><td><strong><%= email.from.name %></strong></td></tr>
          <tr><td>Jabatan</td><td>:</td><td>Direktur Utama</td></tr>
          <tr><td>Instansi</td><td>:</td><td>PT Nusa Inspira Teknologi</td></tr>
        </table>
        <p class="doc-para" style="margin-top:10px;">Selanjutnya disebut PEMBERI KERJA, dengan ini memerintahkan kepada:</p>
        <table class="surat-field-table">
          <% if(sd.namaTim){%><tr><td>Nama Tim</td><td>:</td><td><strong><%= sd.namaTim %></strong></td></tr><%}%>
          <% if(sd.ketuaTim){%><tr><td>Ketua Tim</td><td>:</td><td><strong><%= sd.ketuaTim %></strong></td></tr><%}%>
          <% if(sd.anggotaTim){%><tr><td>Anggota</td><td>:</td><td><%= sd.anggotaTim %></td></tr><%}%>
        </table>
        <p class="doc-para" style="margin-top:10px;">Untuk melaksanakan pekerjaan sebagai berikut:</p>
        <% if (sd.pekerjaanSPK && sd.pekerjaanSPK.length > 0) { %>
        <table class="sppd-table" style="margin-bottom:14px;">
          <thead><tr><th>No.</th><th>Uraian Pekerjaan</th><th>Keterangan</th></tr></thead>
          <tbody>
          <% sd.pekerjaanSPK.forEach((p,i) => { %>
          <tr><td style="text-align:center;"><%= i+1 %></td><td><%= p.uraian %></td><td><%= p.keterangan||'—' %></td></tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
        <% if (sd.lokasiSPK||sd.tanggalSPK||sd.waktuSPK) { %>
        <p><strong>Ketentuan Pelaksanaan:</strong></p>
        <table class="surat-field-table">
          <% if(sd.lokasiSPK){%><tr><td>Lokasi</td><td>:</td><td><%= sd.lokasiSPK %></td></tr><%}%>
          <% if(sd.tanggalSPK){%><tr><td>Tanggal</td><td>:</td><td><%= fmtDateSimple(sd.tanggalSPK) %></td></tr><%}%>
          <% if(sd.waktuSPK){%><tr><td>Waktu</td><td>:</td><td><%= sd.waktuSPK %></td></tr><%}%>
        </table>
        <% } %>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:12px;"><%- email.body %></div><% } %>
        <p class="doc-para">Demikian Surat Perintah Kerja ini diberikan untuk dilaksanakan dengan penuh tanggung jawab dan profesionalisme.</p>
      </div>

      <% } else if (tipe === 'Surat Instruksi') { %>
      <!-- ── SURAT INSTRUKSI ── -->
      <div class="doc-body">
        <div class="doc-title">SURAT INSTRUKSI</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth.</p>
        <p><strong><%= recipients.join(', ') || '—' %></strong></p><br>
        <p class="doc-para">Dalam rangka pelaksanaan tugas, dengan ini disampaikan instruksi sebagai berikut:</p>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <p class="doc-para">Seluruh instruksi ini wajib dilaksanakan dengan penuh dedikasi dan profesionalisme.</p>
      </div>

      <% } else if (tipe === 'Surat Rahasia') { %>
      <!-- ── SURAT RAHASIA ── -->
      <div class="doc-body">
        <div class="kls">[ RAHASIA ]</div>
        <div class="doc-title">SURAT RAHASIA</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth. <em>(Sangat Terbatas)</em></p>
        <p><strong><%= recipients.join(', ') || '—' %></strong></p><br>
        <table class="surat-field-table"><tr><td>Perihal</td><td>:</td><td><strong><%= email.subject %></strong></td></tr></table>
        <br><p>Yang Terhormat,</p><br>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <p style="text-align:center;font-weight:bold;font-size:10pt;margin-top:20px;">[ Dokumen ini bersifat RAHASIA — Tidak untuk disebarluaskan ]</p>
      </div>

      <% } else if (tipe === 'Surat Konfidensial') { %>
      <!-- ── SURAT KONFIDENSIAL ── -->
      <div class="doc-body">
        <div class="kls">[ KONFIDENSIAL ]</div>
        <div class="doc-title">SURAT KONFIDENSIAL</div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth. <em>(Terbatas)</em></p>
        <p><strong><%= recipients.join(', ') || '—' %></strong></p><br>
        <table class="surat-field-table"><tr><td>Perihal</td><td>:</td><td><strong><%= email.subject %></strong></td></tr></table>
        <br><p>Dengan hormat,</p><br>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <p style="text-align:center;font-weight:bold;font-size:10pt;margin-top:20px;">[ Dokumen ini bersifat KONFIDENSIAL — Harap dijaga dengan ketat ]</p>
      </div>

      <% } else if (tipe === 'Invoice') { %>
      <!-- ── INVOICE ── -->
      <%
        const invItems  = sd.invItems || [];
        const invPajak  = sd.invPajak || 0;
        const invDiskon = sd.invDiskon || 0;
        const invSubtotal = invItems.reduce((s, it) => s + (it.qty * it.harga), 0);
        const invPajakAmt = invSubtotal * invPajak / 100;
        const invTotal    = invSubtotal + invPajakAmt - invDiskon;
        const fmtRpPrev = n => 'Rp ' + Math.round(n).toLocaleString('id-ID');
      %>
      <div class="doc-body">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;">
          <div>
            <div style="font-size:22pt;font-weight:800;color:#071840;letter-spacing:-0.5px;">INVOICE</div>
            <div style="font-size:10pt;color:#555;margin-top:2px;">No: <strong><%= email.nomorSurat %></strong></div>
            <div style="font-size:10pt;color:#555;">Tanggal: <strong><%= fmtDate(email.createdAt) %></strong></div>
            <% if (sd.invJatuhTempo) { %><div style="font-size:10pt;color:#c00;">Jatuh Tempo: <strong><%= fmtDateSimple(sd.invJatuhTempo) %></strong></div><% } %>
          </div>
          <div style="text-align:right;">
            <div style="font-weight:700;font-size:11pt;">PT Nusa Inspira Teknologi</div>
            <div style="font-size:9pt;color:#555;"><%= email.from.email %></div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;background:#f8f9fb;border-radius:6px;padding:12px 14px;">
          <div>
            <div style="font-size:9pt;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Dari</div>
            <div style="font-weight:600;font-size:11pt;"><%= email.from.name %></div>
            <div style="font-size:9.5pt;color:#555;">PT Nusa Inspira Teknologi</div>
          </div>
          <div>
            <div style="font-size:9pt;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Tagihan Kepada</div>
            <div style="font-weight:600;font-size:11pt;"><%= sd.invKepada || '—' %></div>
            <% if (sd.invAlamat) { %><div style="font-size:9.5pt;color:#555;"><%= sd.invAlamat %></div><% } %>
          </div>
        </div>
        <% if (invItems.length > 0) { %>
        <table style="width:100%;border-collapse:collapse;font-size:10pt;margin-bottom:0;">
          <thead>
            <tr style="background:#071840;color:#fff;">
              <th style="padding:8px 10px;text-align:left;width:36px;">No.</th>
              <th style="padding:8px 10px;text-align:left;">Deskripsi</th>
              <th style="padding:8px 10px;text-align:center;width:60px;">Qty</th>
              <th style="padding:8px 10px;text-align:left;width:70px;">Satuan</th>
              <th style="padding:8px 10px;text-align:right;width:130px;">Harga Satuan</th>
              <th style="padding:8px 10px;text-align:right;width:130px;">Jumlah</th>
            </tr>
          </thead>
          <tbody>
          <% invItems.forEach((it, i) => { %>
          <tr style="border-bottom:1px solid #e5e7eb;<%= i%2===1?'background:#f9fafb;':'' %>">
            <td style="padding:7px 10px;text-align:center;color:#888;"><%= i+1 %></td>
            <td style="padding:7px 10px;"><%= it.deskripsi %></td>
            <td style="padding:7px 10px;text-align:center;"><%= it.qty %></td>
            <td style="padding:7px 10px;"><%= it.satuan || '—' %></td>
            <td style="padding:7px 10px;text-align:right;"><%= fmtRpPrev(it.harga) %></td>
            <td style="padding:7px 10px;text-align:right;font-weight:500;"><%= fmtRpPrev(it.qty * it.harga) %></td>
          </tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
        <div style="display:flex;justify-content:flex-end;margin-top:8px;">
          <table style="font-size:10pt;border-collapse:collapse;min-width:260px;">
            <tr><td style="padding:4px 16px 4px 0;color:#555;">Subtotal</td><td style="text-align:right;"><%= fmtRpPrev(invSubtotal) %></td></tr>
            <% if (invPajak > 0) { %><tr><td style="padding:4px 16px 4px 0;color:#555;">Pajak (<%= invPajak %>%)</td><td style="text-align:right;"><%= fmtRpPrev(invPajakAmt) %></td></tr><% } %>
            <% if (invDiskon > 0) { %><tr><td style="padding:4px 16px 4px 0;color:#555;">Diskon</td><td style="text-align:right;color:#c00;">- <%= fmtRpPrev(invDiskon) %></td></tr><% } %>
            <tr style="border-top:2px solid #071840;">
              <td style="padding:8px 16px 4px 0;font-weight:700;font-size:12pt;">TOTAL</td>
              <td style="padding:8px 0 4px 0;font-weight:700;font-size:12pt;text-align:right;color:#071840;"><%= fmtRpPrev(invTotal < 0 ? 0 : invTotal) %></td>
            </tr>
          </table>
        </div>
        <% if (sd.invMetode) { %>
        <div style="margin-top:14px;padding:10px 14px;background:#f0f4ff;border-radius:6px;font-size:9.5pt;">
          <strong>Metode Pembayaran:</strong> <%= sd.invMetode %>
        </div>
        <% } %>
        <% if (sd.invCatatan) { %><p class="doc-para" style="margin-top:10px;font-size:9.5pt;color:#555;"><%= sd.invCatatan %></p><% } %>
        <% if (hasBody) { %><div class="doc-para" style="margin-top:12px;"><%- email.body %></div><% } %>
      </div>

      <% } else { %>
      <!-- ── STANDARD LETTERS (Surat, Surat Resmi, Surat Formal, Surat Edaran, Surat Biasa, dll) ── -->
      <div class="doc-body">
        <div class="doc-title"><%= tipe.toUpperCase() %></div>
        <div class="doc-nomor-center">Nomor: <%= email.nomorSurat %></div>
        <p>Kepada Yth.</p>
        <% if (sd.jabatanPenerima) { %><p><strong><%= sd.jabatanPenerima %></strong></p><% } %>
        <% if (email.jenis === 'internal') { %>
          <% email.to.forEach(r => { %><p><strong><%= r.name %></strong></p><% }) %>
        <% } else { %>
          <% (email.toExternal||[]).forEach(r => { %><p><strong><%= r.name %></strong></p><% }) %>
        <% } %>
        <% if (sd.instansiPenerima) { %><p><%= sd.instansiPenerima %></p><% } %>
        <% if (sd.alamatPenerima) { %><p><%= sd.alamatPenerima %></p><% } %>
        <% if (tipe === 'Surat Edaran') { %><p>di Tempat</p><% } %>
        <br>
        <% if (tipe !== 'Surat Edaran') { %>
        <% if (email.subject) { %><table class="surat-field-table"><tr><td>Perihal</td><td>:</td><td><strong><%= email.subject %></strong></td></tr><% if(email.berkas){%><tr><td>Klasifikasi</td><td>:</td><td><%= email.berkas %></td></tr><%}%>
<%if(email.lampiran&&email.lampiranNama){%><tr><td>Lampiran</td><td>:</td><td><a href="<%= email.lampiran %>" target="_blank" style="color:inherit;"><%= email.lampiranNama %></a></td></tr><%}%></table><% } %>
        <br><p>Dengan hormat,</p><br>
        <% } %>
        <% if (hasBody) { %><div class="doc-para"><%- email.body %></div><% } %>
        <% if (tipe === 'Surat Edaran') { %>
        <p class="doc-para">Demikian Surat Edaran ini disampaikan untuk menjadi perhatian dan dilaksanakan dengan penuh tanggung jawab.</p>
        <% } %>
        <% if (email.cc && email.cc.length > 0) { %>
        <p style="margin-top:14px;font-size:10pt;">Tembusan: <%= email.cc.map(r=>r.name).join(', ') %></p>
        <% } %>
      </div>
      <% } %>

      <!-- SIGNATURE AREA -->
      <div class="doc-sig-area">
        <div id="sigHint" class="doc-sig-hint" style="<%= docSig.signers.length > 0 ? 'display:none' : '' %>">
          Tambahkan tanda tangan dari panel kanan. Seret untuk memindahkan posisi.
        </div>
      </div>

      <!-- QR Stamps -->
      <% docSig.signers.forEach(function(s) {
        const rl = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
        const jabatan = s.jabatanDisplay || (s.userRole ? rl[s.userRole]||s.userRole : (s.userOrg||''));
        const dm = s.displayMode || 'full';
      %>
      <div class="qr-stamp" id="stamp-<%= s._id %>" data-id="<%= s._id %>"
        data-dm="<%= dm %>"
        data-show-date="<%= s.showDate === false ? '0' : '1' %>"
        data-date-str="<%= fmtDate(email.createdAt) %>"
        style="left:<%= s.position.x %>px;top:<%= s.position.y %>px;width:<%= s.position.width %>px;height:<%= s.position.height %>px;">
        <div class="qr-stamp-date">Jakarta, <%= fmtDate(email.createdAt) %></div>
        <% if (s.qrDataUrl) { %>
        <img src="<%= s.qrDataUrl %>" alt="QR" draggable="false">
        <% } else { %>
        <div style="flex:1;width:100%;min-height:0;border:1px dashed #000;display:flex;align-items:center;justify-content:center;font-size:8px;">Menunggu tanda tangan</div>
        <% } %>
        <% if (dm !== 'qr_only') { %>
        <div class="qr-stamp-sig"></div>
        <div class="qr-stamp-name"><%= s.userName %></div>
        <% if (dm === 'full') { %><div class="qr-stamp-role"><%= jabatan %></div><% } %>
        <% } %>
        <div class="qr-resize"></div>
        <button class="qr-delete" onclick="removeSigner('<%= s._id %>',event)" title="Hapus tanda tangan">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>
      <% }) %>

    </div>
  </div>

  <!-- Right panel: hanya tampil jika draft atau co-signer pending -->
  <% if (email.status === 'draft' || isPendingCosigner) { %>
  <div class="pdf-panel">
    <%
      const mySig = docSig.signers.find(s => s.userId.toString() === currentUser._id.toString());
      const isSigned = mySig && mySig.status === 'signed';
      const isPending = mySig && mySig.status === 'pending';
    %>

    <div class="panel-section">
      <div class="panel-title">Tanda Tangan Saya</div>
      <div class="panel-hint">
        <% if (isSender) { %>QR unik per surat per penandatangan.
        <% } else if (isPendingCosigner) { %>Anda diundang sebagai co-signer.
        <% } %>
      </div>
      <% if (isSigned) { %>
      <button class="btn-add-self" disabled>
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sudah Ditandatangani
      </button>
      <% } else { %>
      <button class="btn-add-self" id="btnAddSelf" onclick="addSelf()">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <%= isPending ? 'Tandatangani Sekarang' : 'Tambah Tanda Tangan Saya' %>
      </button>
      <% } %>
    </div>

    <% if (isSender) { %>
    <div class="panel-section">
      <div class="panel-title">Undang Co-Signer</div>
      <label class="cosign-toggle">
        <input type="checkbox" id="coSignCheck" onchange="toggleCoSign(this)">
        Aktifkan Co-Sign
      </label>
      <div class="cosign-panel" id="coSignPanel">
        <div style="margin-top:12px;">
          <select class="panel-select" id="coSignSelect">
            <option value="">— Pilih pengguna —</option>
            <% users.forEach(u => {
              if (u._id.toString() !== currentUser._id.toString() &&
                  !docSig.signers.some(s => s.userId.toString() === u._id.toString())) { %>
            <option value="<%= u._id %>"><%= u.name %> (<%= u.email %>)</option>
            <% } }) %>
          </select>
          <button class="btn-add-cosign" onclick="inviteCosigner()">+ Undang Co-Signer</button>
        </div>
      </div>
    </div>
    <% } %>

    <div class="panel-section" style="flex:1;">
      <div class="panel-title">Penandatangan (<span id="signerCount"><%= docSig.signers.length %></span>)</div>
      <div class="signer-list" id="signerList">
        <% if (docSig.signers.length === 0) { %>
        <div class="empty-signers" id="emptySig">Belum ada penandatangan.</div>
        <% } %>
        <% docSig.signers.forEach(function(s) {
          const inits = s.userName.split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase();
          const rl = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
          const signed = s.status === 'signed';
          const jabatanNow = s.jabatanDisplay || (s.userRole ? rl[s.userRole]||s.userRole : (s.userOrg||''));
          const isCustom = !['Direktur','Staff','Administrator'].includes(jabatanNow);
          const dm = s.displayMode || 'full';
        %>
        <div class="signer-item" id="si-<%= s._id %>" style="flex-direction:column;align-items:stretch;gap:8px;">
          <div style="display:flex;align-items:center;gap:10px;">
            <div class="signer-av<%= signed ? '' : ' signer-av-pending' %>"><%= inits %></div>
            <div class="signer-info">
              <div class="signer-name"><%= s.userName %></div>
              <div class="signer-role" id="jlbl-<%= s._id %>"><%= jabatanNow %></div>
            </div>
            <% if (signed) { %>
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" style="color:#22c55e;flex-shrink:0;"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <% } else { %>
            <span style="font-size:9px;color:rgba(255,200,0,.7);font-weight:600;flex-shrink:0;">MENUNGGU</span>
            <% } %>
            <% if (isSender) { %>
            <button class="signer-del" onclick="removeSigner('<%= s._id %>',event)" title="Hapus">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </button>
            <% } %>
          </div>
          <!-- Jabatan (dari profil, read-only) -->
          <div style="font-size:11px;color:rgba(255,255,255,.35);padding:4px 0 0;">Jabatan: <span style="color:rgba(255,255,255,.6);font-weight:500;"><%= jabatanNow || '—' %></span></div>
          <!-- Display mode toggle -->
          <div>
            <div style="font-size:10px;color:rgba(255,255,255,.3);margin-bottom:4px;">Tampilan:</div>
            <div class="display-mode-row" id="dm-<%= s._id %>">
              <button type="button" class="dm-btn <%= dm==='full'?'active':'' %>" onclick="setDisplayMode('<%= s._id %>','full',this.closest('.display-mode-row'))">Semua</button>
              <button type="button" class="dm-btn <%= dm==='name_only'?'active':'' %>" onclick="setDisplayMode('<%= s._id %>','name_only',this.closest('.display-mode-row'))">+Nama</button>
              <button type="button" class="dm-btn <%= dm==='qr_only'?'active':'' %>" onclick="setDisplayMode('<%= s._id %>','qr_only',this.closest('.display-mode-row'))">QR Saja</button>
            </div>
            <div style="font-size:10px;color:rgba(255,255,255,.3);margin-top:6px;margin-bottom:4px;">Opsi:</div>
            <div class="display-mode-row">
              <button type="button" class="dm-btn <%= !s.showDate || s.showDate !== false ? 'active' : '' %>" id="btnDate-<%= s._id %>" onclick="toggleDate('<%= s._id %>',this)">Tanggal</button>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="panel-section" style="border-bottom:none;">
      <div style="font-size:11px;color:rgba(255,255,255,.25);line-height:1.9;">
        • Seret QR untuk pindahkan posisi<br>
        • Tarik sudut kanan bawah untuk resize<br>
        • Pilih tampilan: QR saja / + Nama / + Jabatan<br>
        • Setiap QR unik per surat &amp; penandatangan<br>
        • Scan QR = verifikasi dokumen + info surat
      </div>
    </div>
  </div>
  <% } %>
</div>

<script src="/js/app.js"></script>
<script>
const EMAIL_ID = '<%= email._id %>';
const CURRENT_USER_ID = '<%= currentUser._id %>';

// Auto-print jika parameter ?print=1 ada di URL
if (new URLSearchParams(window.location.search).get('print') === '1') {
  window.addEventListener('load', () => setTimeout(() => window.print(), 800));
}
let dragState = null;

function initStamp(el) {
  const page = document.getElementById('a4Page');

  // ── DRAG (stamp body) ──
  el.addEventListener('pointerdown', e => {
    if (e.target.classList.contains('qr-resize') || e.target.closest('.qr-delete')) return;
    e.preventDefault();
    el.setPointerCapture(e.pointerId);
    el.classList.add('active');
    dragState = { type:'drag', el, startX:e.clientX, startY:e.clientY,
      origX: parseInt(el.style.left)||0, origY: parseInt(el.style.top)||0, page };
  });
  el.addEventListener('pointermove', e => {
    if (!dragState || dragState.el !== el || dragState.type !== 'drag') return;
    const dx = e.clientX - dragState.startX, dy = e.clientY - dragState.startY;
    const rect = page.getBoundingClientRect();
    el.style.left = Math.max(0, Math.min(dragState.origX + dx, rect.width  - el.offsetWidth))  + 'px';
    el.style.top  = Math.max(0, Math.min(dragState.origY + dy, page.scrollHeight - el.offsetHeight)) + 'px';
  });
  el.addEventListener('pointerup', e => {
    if (!dragState || dragState.el !== el) return;
    el.classList.remove('active');
    savePosition(el.dataset.id, el);
    dragState = null;
  });
  el.addEventListener('pointercancel', () => { dragState = null; });

  // ── RESIZE (bottom-right handle) ──
  const handle = el.querySelector('.qr-resize');
  if (handle) {
    handle.addEventListener('pointerdown', e => {
      e.preventDefault(); e.stopPropagation();
      handle.setPointerCapture(e.pointerId);
      el.classList.add('active');
      dragState = { type:'resize', el, startX:e.clientX, startY:e.clientY,
        origX: parseInt(el.style.left)||0, origY: parseInt(el.style.top)||0,
        origW: el.offsetWidth, origH: el.offsetHeight, page };
    });
    handle.addEventListener('pointermove', e => {
      if (!dragState || dragState.type !== 'resize' || dragState.el !== el) return;
      el.style.width  = Math.max(60, dragState.origW + (e.clientX - dragState.startX)) + 'px';
      el.style.height = Math.max(60, dragState.origH + (e.clientY - dragState.startY)) + 'px';
    });
    handle.addEventListener('pointerup', e => {
      if (!dragState || dragState.el !== el) return;
      el.classList.remove('active');
      savePosition(el.dataset.id, el);
      dragState = null;
    });
    handle.addEventListener('pointercancel', () => { dragState = null; });
  }
}
document.querySelectorAll('.qr-stamp').forEach(initStamp);

async function savePosition(id, el) {
  await fetch(`/email/${EMAIL_ID}/sign/update-position`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ signerId:id, x:parseInt(el.style.left)||0, y:parseInt(el.style.top)||0, width:el.offsetWidth, height:el.offsetHeight })
  });
}

async function addSelf() {
  const btn = document.getElementById('btnAddSelf');
  btn.disabled = true; btn.textContent = 'Memproses...';
  try {
    const res  = await fetch(`/email/${EMAIL_ID}/sign/add-self`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId: CURRENT_USER_ID })
    });
    const data = await res.json();
    if (data.ok) {
      if (data.action === 'updated') {
        const stamp = document.getElementById('stamp-' + data.signer._id);
        if (stamp) {
          const img = stamp.querySelector('img');
          if (img) img.src = data.signer.qrDataUrl;
          const wait = stamp.querySelector('div[style*="border:1px dashed"]');
          if (wait) { const newImg = document.createElement('img'); newImg.src = data.signer.qrDataUrl; newImg.draggable = false; wait.replaceWith(newImg); }
        }
      } else {
        addStampToPage(data.signer);
        addSignerToPanel(data.signer);
      }
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Sudah Ditandatangani`;
    } else {
      await showAlert(data.message || 'Gagal menambahkan tanda tangan.', { title: 'Gagal', type: 'warn' });
      btn.disabled = false;
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Tambah Tanda Tangan Saya`;
    }
  } catch (err) {
    console.error(err);
    await showAlert('Terjadi kesalahan jaringan.', { title: 'Error', type: 'danger' });
    btn.disabled = false;
    btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Tambah Tanda Tangan Saya`;
  }
}

function addStampToPage(s, dm) {
  document.getElementById('sigHint').style.display = 'none';
  const page = document.getElementById('a4Page');
  const rl = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
  const jabatan = s.jabatanDisplay || (s.userRole ? (rl[s.userRole]||s.userRole) : (s.userOrg||''));
  const mode = dm || s.displayMode || 'full';
  const dateStr = '<%= fmtDate(email.createdAt) %>';
  const showDate = s.showDate !== false;
  const showName = mode !== 'qr_only';
  const showRole = mode === 'full';

  const qrHtml = s.qrDataUrl
    ? `<img src="${s.qrDataUrl}" draggable="false">`
    : `<div style="flex:1;width:100%;min-height:0;border:1px dashed #000;display:flex;align-items:center;justify-content:center;font-size:8px;">Menunggu</div>`;
  const dateHtml  = showDate ? `<div class="qr-stamp-date">Jakarta, ${dateStr}</div>` : '';
  const nameHtml  = showName ? `<div class="qr-stamp-sig"></div><div class="qr-stamp-name">${s.userName}</div>` : '';
  const roleHtml  = showRole ? `<div class="qr-stamp-role">${jabatan}</div>` : '';

  const div = document.createElement('div');
  div.className = 'qr-stamp'; div.id = `stamp-${s._id}`; div.dataset.id = s._id;
  div.dataset.dm = mode;
  div.dataset.showDate = showDate ? '1' : '0';
  div.dataset.dateStr = dateStr;
  div.style.cssText = `left:${s.position.x}px;top:${s.position.y}px;width:${s.position.width}px;height:${s.position.height}px;`;
  div.innerHTML = `${dateHtml}${qrHtml}${nameHtml}${roleHtml}
    <div class="qr-resize"></div>
    <button class="qr-delete" onclick="removeSigner('${s._id}',event)" title="Hapus">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </button>`;
  page.appendChild(div); initStamp(div);
}

function addSignerToPanel(s) {
  document.getElementById('emptySig')?.remove();
  const rl = { admin:'Administrator', direktur:'Direktur', user:'Pengguna' };
  const jabatan = s.jabatanDisplay || (s.userRole ? (rl[s.userRole]||s.userRole) : (s.userOrg||''));
  const ini = s.userName.split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase();
  const dm = s.displayMode || 'full';
  const item = document.createElement('div');
  item.className = 'signer-item'; item.id = `si-${s._id}`;
  item.style.cssText = 'flex-direction:column;align-items:stretch;gap:8px;';
  item.innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;">
      <div class="signer-av">${ini}</div>
      <div class="signer-info"><div class="signer-name">${s.userName}</div><div class="signer-role" id="jlbl-${s._id}">${jabatan}</div></div>
      <span style="font-size:9px;color:rgba(255,200,0,.7);font-weight:600;flex-shrink:0;">MENUNGGU</span>
      <button class="signer-del" onclick="removeSigner('${s._id}',event)">
        <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div style="font-size:11px;color:rgba(255,255,255,.35);padding:4px 0 0;">Jabatan: <span style="color:rgba(255,255,255,.6);font-weight:500;">${jabatan || '—'}</span></div>
    <div>
      <div style="font-size:10px;color:rgba(255,255,255,.3);margin-bottom:4px;">Tampilan Tanda Tangan:</div>
      <div class="display-mode-row" id="dm-${s._id}">
        <button type="button" class="dm-btn ${dm==='full'?'active':''}" onclick="setDisplayMode('${s._id}','full',this.closest('.display-mode-row'))">QR + Nama<br>+ Jabatan</button>
        <button type="button" class="dm-btn ${dm==='name_only'?'active':''}" onclick="setDisplayMode('${s._id}','name_only',this.closest('.display-mode-row'))">QR +<br>Nama</button>
        <button type="button" class="dm-btn ${dm==='qr_only'?'active':''}" onclick="setDisplayMode('${s._id}','qr_only',this.closest('.display-mode-row'))">QR<br>Saja</button>
      </div>
      <div style="font-size:10px;color:rgba(255,255,255,.3);margin-top:6px;margin-bottom:4px;">Opsi:</div>
      <div class="display-mode-row">
        <button type="button" class="dm-btn ${s.showDate !== false ? 'active' : ''}" id="btnDate-${s._id}" onclick="toggleDate('${s._id}',this)">Tanggal</button>
      </div>
    </div>`;
  document.getElementById('signerList').appendChild(item);
  document.getElementById('signerCount').textContent = parseInt(document.getElementById('signerCount').textContent)+1;
}

// ── DISPLAY MODE ──
function rebuildStamp(id) {
  const stamp = document.getElementById('stamp-' + id);
  if (!stamp) return;
  const img = stamp.querySelector('img');
  const noQr = stamp.querySelector('div[style*="border:1px"]');
  const qrEl = img ? img.outerHTML : (noQr ? noQr.outerHTML : '');
  const jabEl = document.getElementById('jlbl-' + id);
  const jabatan = jabEl ? jabEl.textContent : '';
  const nameEl = jabEl?.closest('.signer-item')?.querySelector('.signer-name');
  const signerName = nameEl ? nameEl.textContent : '';
  const mode = stamp.dataset.dm || 'full';
  const showDate = stamp.dataset.showDate !== '0';
  const dateStr = stamp.dataset.dateStr || '';
  const dateHtml = showDate && dateStr ? `<div class="qr-stamp-date">Jakarta, ${dateStr}</div>` : '';
  const nameHtml = mode !== 'qr_only' ? `<div class="qr-stamp-sig"></div><div class="qr-stamp-name">${signerName}</div>` : '';
  const roleHtml = mode === 'full' ? `<div class="qr-stamp-role">${jabatan}</div>` : '';
  const delHtml = `<button class="qr-delete" onclick="removeSigner('${id}',event)" title="Hapus"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 2l8 8M10 2L2 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></button>`;
  stamp.innerHTML = `${dateHtml}${qrEl}${nameHtml}${roleHtml}<div class="qr-resize"></div>${delHtml}`;
  initStamp(stamp);
}

async function setDisplayMode(id, mode, row) {
  row.querySelectorAll('.dm-btn').forEach(b => b.classList.remove('active'));
  row.querySelector(`.dm-btn:nth-child(${mode==='full'?1:mode==='name_only'?2:3})`).classList.add('active');
  const stamp = document.getElementById('stamp-' + id);
  if (stamp) { stamp.dataset.dm = mode; rebuildStamp(id); }
  await fetch(`/email/${EMAIL_ID}/sign/update-display-mode`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ signerId: id, displayMode: mode })
  });
}

function toggleDate(id, btn) {
  const stamp = document.getElementById('stamp-' + id);
  if (!stamp) return;
  const isOn = stamp.dataset.showDate !== '0';
  stamp.dataset.showDate = isOn ? '0' : '1';
  btn.classList.toggle('active', !isOn);
  rebuildStamp(id);
}

// ── JABATAN EDIT ──
function toggleCoSign(cb) { document.getElementById('coSignPanel').classList.toggle('open', cb.checked); }

async function inviteCosigner() {
  const sel = document.getElementById('coSignSelect');
  if (!sel.value) { await showAlert('Pilih pengguna terlebih dahulu.', { title: 'Pilih Pengguna', type: 'warn' }); return; }
  try {
    const res  = await fetch(`/email/${EMAIL_ID}/sign/invite-cosigner`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId: sel.value })
    });
    const data = await res.json();
    if (data.ok) {
      addStampToPage(data.signer);
      addSignerToPanel(data.signer);
      sel.querySelector(`option[value="${sel.value}"]`)?.remove();
      sel.value = '';
    } else {
      await showAlert(data.message || 'Gagal mengundang co-signer.', { title: 'Gagal', type: 'warn' });
    }
  } catch (err) {
    await showAlert('Terjadi kesalahan jaringan.', { title: 'Error', type: 'danger' });
  }
}

function onJabatanSelect(id, sel) {
  const inputDiv = document.getElementById('jinput-' + id);
  if (sel.value === '__custom__') {
    inputDiv.classList.remove('j-hidden');
    document.getElementById('jtext-' + id).focus();
  } else {
    inputDiv.classList.add('j-hidden');
    saveJabatan(id, sel.value);
  }
}

let jabatanTimer = {};
function updateJabatanText(id, val) {
  clearTimeout(jabatanTimer[id]);
  jabatanTimer[id] = setTimeout(() => saveJabatan(id, val), 600);
}

async function saveJabatan(id, jabatan) {
  const res = await fetch(`/email/${EMAIL_ID}/sign/update-jabatan`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ signerId: id, jabatan })
  });
  const data = await res.json();
  if (data.ok) {
    const lbl = document.getElementById('jlbl-' + id);
    if (lbl) lbl.textContent = jabatan;
    const stamp = document.getElementById('stamp-' + id);
    if (stamp) { const roleEl = stamp.querySelector('.qr-stamp-role'); if (roleEl) roleEl.textContent = jabatan; }
  }
}

async function removeSigner(id, e) {
  if (e) { e.preventDefault(); e.stopPropagation(); }
  if (!await showConfirm('Hapus penandatangan ini dari dokumen?', { title:'Hapus Penandatangan', type:'danger', confirmLabel:'Hapus' })) return;
  const res  = await fetch(`/email/${EMAIL_ID}/sign/signers/${id}`, { method:'DELETE' });
  const data = await res.json();
  if (data.ok) {
    document.getElementById(`stamp-${id}`)?.remove();
    document.getElementById(`si-${id}`)?.remove();
    const cnt = document.getElementById('signerCount');
    cnt.textContent = Math.max(0, parseInt(cnt.textContent)-1);
    if (!document.querySelector('.signer-item')) {
      const e2 = document.createElement('div'); e2.className='empty-signers'; e2.id='emptySig'; e2.textContent='Belum ada penandatangan.';
      document.getElementById('signerList').appendChild(e2);
      document.getElementById('sigHint').style.display='';
    }
    if (data.wasCurrentUser) {
      const b = document.getElementById('btnAddSelf');
      if(b){ b.disabled=false; b.innerHTML=`<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Tambah Tanda Tangan Saya`; }
    }
  }
}

async function kirimSurat() {
  const btn = document.getElementById('btnKirim');
  btn.disabled = true; btn.textContent = 'Mengirim...';
  try {
    const res  = await fetch(`/email/${EMAIL_ID}/send`, { method:'POST', headers:{'Content-Type':'application/json'} });
    const data = await res.json();
    if (data.ok) { window.location.href = '/sent'; }
    else { alert(data.message||'Gagal mengirim surat.'); btn.disabled=false; btn.textContent='Kirim Surat'; }
  } catch { alert('Terjadi kesalahan.'); btn.disabled=false; btn.textContent='Kirim Surat'; }
}
</script>
</body>
</html>
