<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lupa Kata Sandi — Inspira Mailer</title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">

<div class="auth-wrap auth-wrap-center">
  <div class="auth-panel auth-panel-sm">
    <div class="auth-brand">
      <img src="/img/Group 1597880519.png" alt="Inspira Logo" class="auth-logo">
      <div>
        <div class="auth-brand-name">Inspira Mailer</div>
        <div class="auth-brand-sub">Sistem Surat Dinas Digital</div>
      </div>
    </div>

    <div class="auth-icon-wrap">
      <div class="auth-icon-circle">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="13" width="18" height="12" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M9 13V9a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="14" cy="19" r="1.5" fill="currentColor"/></svg>
      </div>
    </div>

    <h1 class="auth-title">Lupa Kata Sandi?</h1>
    <p class="auth-desc">Masukkan alamat email Anda dan kami akan mengirimkan link untuk mereset kata sandi.</p>

    <% if (error) { %>
    <div class="auth-alert auth-alert-error">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <%= error %>
    </div>
    <% } %>
    <% if (success) { %>
    <div class="auth-alert auth-alert-success">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= success %>
    </div>
    <% } %>

    <% if (!success) { %>
    <form action="/forgot-password" method="POST" class="auth-form">
      <div class="auth-field">
        <label class="auth-label" for="email">Alamat Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="auth-input"
          placeholder="nama@perusahaan.com"
          required
          autofocus
          autocomplete="email"
        >
      </div>
      <button type="submit" class="auth-btn">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Kirim Link Reset
      </button>
    </form>
    <% } %>

    <p class="auth-footer-text">
      <a href="/login" class="auth-link auth-back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Kembali ke halaman masuk
      </a>
    </p>
  </div>
</div>

</body>
</html>
