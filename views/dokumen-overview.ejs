<%- include('./partials/header') %>

<style>
.dok-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px; }
@media(max-width:700px){ .dok-stats{ grid-template-columns:repeat(2,1fr); } }
.dok-stat-card { background:#fff; border:1px solid var(--gray-200); border-radius:12px; padding:14px 18px; display:flex; align-items:center; gap:12px; }
.dok-stat-icon { width:38px; height:38px; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.dok-stat-label { font-size:11.5px; color:var(--gray-400); font-weight:500; }
.dok-stat-val { font-size:22px; font-weight:700; color:var(--gray-800); line-height:1.1; }

/* TABS */
.dok-tabs { display:flex; gap:0; border-bottom:2px solid var(--gray-100); margin-bottom:0; overflow-x:auto; overflow-y:hidden; scrollbar-width:none; }
.dok-tabs::-webkit-scrollbar { display:none; }
.dok-tab { padding:12px 18px; font-size:13px; font-weight:500; color:var(--gray-500); cursor:pointer; white-space:nowrap; border-bottom:2px solid transparent; margin-bottom:-2px; text-decoration:none; transition:color .15s; display:inline-flex; align-items:center; }
.dok-tab:hover { color:var(--gray-700); }
.dok-tab.active { color:var(--brand-600); border-bottom-color:var(--brand-600); font-weight:600; }
.dok-tab .tab-count { display:inline-block; background:var(--gray-100); color:var(--gray-500); font-size:10.5px; font-weight:600; padding:1px 6px; border-radius:10px; margin-left:5px; }
.dok-tab.active .tab-count { background:#dbeafe; color:#1d4ed8; }

/* TABLE */
.dok-table { width:100%; border-collapse:collapse; font-size:13px; }
.dok-table th { padding:10px 14px; text-align:left; font-size:11.5px; font-weight:600; color:var(--gray-500); background:var(--gray-50); border-bottom:1px solid var(--gray-200); text-transform:uppercase; letter-spacing:.4px; }
.dok-table td { padding:11px 14px; border-bottom:1px solid var(--gray-100); color:var(--gray-700); vertical-align:middle; }
.dok-table tr:last-child td { border-bottom:none; }
.dok-table tbody tr { cursor:pointer; transition:background .1s; }
.dok-table tbody tr:hover { background:var(--gray-50); }

.dok-tipe-badge { font-size:11px; font-weight:600; padding:2px 8px; border-radius:4px; white-space:nowrap; }
.tipe-nota { background:#f0fdf4; color:#15803d; }
.tipe-surat { background:#eff6ff; color:#1d4ed8; }
.tipe-mou,.tipe-moa { background:#fdf4ff; color:#7e22ce; }
.tipe-contract,.tipe-ia { background:#fff7ed; color:#c2410c; }
.tipe-pks,.tipe-spk { background:#fef3c7; color:#92400e; }
.tipe-lain { background:var(--gray-100); color:var(--gray-600); }

.dok-status { font-size:11px; font-weight:600; padding:2px 9px; border-radius:20px; display:inline-block; }
.dok-status.draft { background:var(--gray-100); color:var(--gray-500); }
.dok-status.sent { background:#dcfce7; color:#15803d; }

.dok-search { display:flex; gap:8px; padding:12px 16px; border-bottom:1px solid var(--gray-100); }
.dok-search input { flex:1; }
</style>

<%
  const TIPE_KHUSUS_OV = ['MoU','MoA','Contract','IA','PKS','SPK'];
  const isPriv = user && (['superadmin','admin','direktur'].includes(user.role));

  // Count per tab dari docs (semua, sebelum filter tab)
  const allDocs = docs; // sudah difilter q dari server
  function countTab(t) {
    if (t === 'all')        return allDocs.length;
    if (t === 'nota')       return allDocs.filter(d=>d.tipeSurat==='Nota Dinas').length;
    if (t === 'surat')      return allDocs.filter(d=>d.tipeSurat==='Surat Dinas').length;
    if (t === 'khusus')     return allDocs.filter(d=>TIPE_KHUSUS_OV.includes(d.tipeSurat)).length;
    if (t === 'draft')      return allDocs.filter(d=>d.status==='draft').length;
    return 0;
  }

  // Terapkan filter tab
  let displayDocs = allDocs;
  if (tipe === 'Nota Dinas')  displayDocs = allDocs.filter(d=>d.tipeSurat==='Nota Dinas');
  else if (tipe === 'Surat Dinas') displayDocs = allDocs.filter(d=>d.tipeSurat==='Surat Dinas');
  else if (tipe === 'khusus') displayDocs = allDocs.filter(d=>TIPE_KHUSUS_OV.includes(d.tipeSurat));
  else if (status === 'draft') displayDocs = allDocs.filter(d=>d.status==='draft');

  function tipeCls(t) {
    if (t==='Nota Dinas') return 'tipe-nota';
    if (t==='Surat Dinas') return 'tipe-surat';
    if (t==='MoU') return 'tipe-mou';
    if (t==='MoA') return 'tipe-moa';
    if (t==='Contract'||t==='IA') return 'tipe-contract';
    if (t==='PKS') return 'tipe-pks';
    if (t==='SPK') return 'tipe-spk';
    return 'tipe-lain';
  }
%>

<div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Manajemen Dokumen</div>
    <h1 class="page-title">Manajemen Dokumen</h1>
    <p class="page-subtitle">Draf dan dokumen aktif Anda<% if(isPriv){ %> — Nota Dinas, Surat Eksternal, MoU, MoA, PKS, SPK, SK<% } %></p>
  </div>
</div>

<!-- STATS -->
<div class="dok-stats">
  <div class="dok-stat-card">
    <div class="dok-stat-icon" style="background:#eff6ff;"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 4h12a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="#3b82f6" stroke-width="1.5"/><path d="M7 8h6M7 11h4" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/></svg></div>
    <div><div class="dok-stat-label">Total</div><div class="dok-stat-val"><%= totalAll %></div></div>
  </div>
  <div class="dok-stat-card">
    <div class="dok-stat-icon" style="background:#f0fdf4;"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#22c55e" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    <div><div class="dok-stat-label">Terkirim</div><div class="dok-stat-val"><%= totalSent %></div></div>
  </div>
  <div class="dok-stat-card">
    <div class="dok-stat-icon" style="background:#fef9c3;"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h5" stroke="#ca8a04" stroke-width="1.5" stroke-linecap="round"/><path d="M14 13l1.5 1.5L18 12" stroke="#ca8a04" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    <div><div class="dok-stat-label">Draf</div><div class="dok-stat-val"><%= totalDraft %></div></div>
  </div>
  <div class="dok-stat-card">
    <div class="dok-stat-icon" style="background:#fdf4ff;"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 2h8l4 4v12H2V2h4z" stroke="#a855f7" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 2v4h4M6 9h8M6 13h5" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round"/></svg></div>
    <div><div class="dok-stat-label">Nota Dinas</div><div class="dok-stat-val"><%= allDocs.filter(d=>d.tipeSurat==='Nota Dinas').length %></div></div>
  </div>
</div>

<!-- CARD DENGAN TABS + TABEL -->
<div class="mail-list-wrap">

  <!-- TABS -->
  <div class="dok-tabs" style="padding:0 16px;">
    <a href="/compose" class="dok-tab <%= (!tipe&&!status)?'active':'' %>">Semua <span class="tab-count"><%= totalAll %></span></a>
    <a href="/compose?tipe=Nota+Dinas" class="dok-tab <%= tipe==='Nota Dinas'?'active':'' %>">Nota Dinas <span class="tab-count"><%= tabNota %></span></a>
    <a href="/compose?tipe=Surat+Dinas" class="dok-tab <%= tipe==='Surat Dinas'?'active':'' %>">Surat Dinas <span class="tab-count"><%= tabSurat %></span></a>
    <% if (isPriv) { %>
    <a href="/compose?tipe=khusus" class="dok-tab <%= tipe==='khusus'?'active':'' %>">MoU / PKS / Kontrak <span class="tab-count"><%= tabKhusus %></span></a>
    <% } %>
    <a href="/compose?status=draft" class="dok-tab <%= status==='draft'?'active':'' %>">Konsep / Draf <span class="tab-count"><%= totalDraft %></span></a>
  </div>

  <!-- SEARCH -->
  <div class="dok-search">
    <form method="GET" action="/compose" style="display:flex;gap:8px;flex:1;">
      <% if (tipe) { %><input type="hidden" name="tipe" value="<%= tipe %>"><% } %>
      <% if (status) { %><input type="hidden" name="status" value="<%= status %>"><% } %>
      <input type="text" name="q" value="<%= q %>" class="form-control" style="font-size:13px;" placeholder="Cari judul, nomor surat...">
      <button type="submit" class="btn btn-secondary" style="padding:7px 14px;font-size:13px;">Cari</button>
      <% if (q) { %><a href="/compose<%= tipe?'?tipe='+encodeURIComponent(tipe):status?'?status='+status:'' %>" class="btn btn-ghost" style="padding:7px 12px;font-size:13px;">Reset</a><% } %>
    </form>
  </div>

  <!-- TABEL -->
  <% if (displayDocs.length === 0) { %>
  <div class="empty-state" style="padding:40px;">
    <svg width="40" height="40" viewBox="0 0 48 48" fill="none"><path d="M10 8h28l8 8v28H2V8h8z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M30 8v8h8M16 24h16M16 32h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Belum ada dokumen<% if(q){ %> dengan kata kunci "<%= q %>"<% } %>.</p>
    <a href="/compose/internal" class="btn btn-primary" style="margin-top:8px;">+ Tulis Surat Baru</a>
  </div>
  <% } else { %>
  <div style="overflow-x:auto;">
    <table class="dok-table">
      <thead>
        <tr>
          <th style="width:120px;">Jenis</th>
          <th>Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:130px;">Penerima</th>
          <th style="width:90px;">Status</th>
          <th style="width:100px;">Tanggal</th>
        </tr>
      </thead>
      <tbody>
      <% displayDocs.forEach(d => { %>
      <tr onclick="location.href='<%= d.status==='draft' ? '/draft/'+d._id+'/edit' : '/email/'+d._id %>'">
        <td><span class="dok-tipe-badge <%= tipeCls(d.tipeSurat) %>"><%= d.tipeSurat || '—' %></span></td>
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;"><%= d.nomorSurat || '—' %></td>
        <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500;"><%= d.subject %></td>
        <td style="font-size:12px;color:var(--gray-500);">
          <% const rcpt = (d.to||[]).map(r=>r.name).filter(Boolean); %>
          <%= rcpt.length ? (rcpt[0] + (rcpt.length>1?' +'+( rcpt.length-1):'')) : ((d.toExternal||[]).map(r=>r.name||r.email)[0] || '—') %>
        </td>
        <td><span class="dok-status <%= d.status %>"><%= d.status==='sent'?'Terkirim':'Draf' %></span></td>
        <td style="font-size:12px;color:var(--gray-400);white-space:nowrap;"><%= formatDate(d.createdAt) %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('./partials/footer') %>
