<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Roster Dokumen</div>
    <h1 class="page-title">Roster Dokumen</h1>
    <p class="page-subtitle">Klasifikasi berkas dokumen yang telah ditandatangani</p>
  </div>
</div>

<%
const TIPE_DEF = [
  { key: 'Nota Dinas',      label: 'Nota Dinas',      color: '#e0f2fe', accent: '#0284c7' },
  { key: 'Surat Eksternal', label: 'Surat Eksternal', color: '#fef9c3', accent: '#b45309' },
  { key: 'MoU',             label: 'MoU',             color: '#f0fdf4', accent: '#16a34a' },
  { key: 'MoA',             label: 'MoA',             color: '#f0fdf4', accent: '#15803d' },
  { key: 'Contract',        label: 'Kontrak',         color: '#fdf4ff', accent: '#9333ea' },
  { key: 'IA',              label: 'IA',              color: '#fff7ed', accent: '#ea580c' },
  { key: 'PKS',             label: 'PKS',             color: '#fdf4ff', accent: '#7c3aed' },
  { key: 'SPK',             label: 'SPK',             color: '#fff1f2', accent: '#e11d48' },
  { key: 'SK',              label: 'SK',              color: '#f0f9ff', accent: '#0369a1' },
];
// Tipe lain yang tidak ada di daftar di atas
const knownKeys = TIPE_DEF.map(t => t.key);
const otherKeys = Object.keys(grouped).filter(k => !knownKeys.includes(k));
otherKeys.forEach(k => TIPE_DEF.push({ key: k, label: k, color: '#f8fafc', accent: '#64748b' }));
%>

<!-- CARD GRID VIEW -->
<div id="cardGrid">
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;">
    <% TIPE_DEF.forEach(function(td) { %>
    <% const docs = grouped[td.key] || []; %>
    <div class="roster-card" onclick="showDetail('<%= td.key %>')"
      style="background:<%= td.color %>;border:1.5px solid <%= docs.length>0 ? td.accent+'33' : '#e2e8f0' %>;border-radius:12px;padding:20px 18px;cursor:pointer;transition:box-shadow .15s,transform .15s;user-select:none;"
      onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.1)';this.style.transform='translateY(-2px)'"
      onmouseout="this.style.boxShadow='';this.style.transform=''">
      <div style="font-size:22px;font-weight:800;color:<%= td.accent %>;margin-bottom:6px;font-family:'DM Mono',monospace;">
        <%= docs.length %>
      </div>
      <div style="font-size:13px;font-weight:600;color:<%= td.accent %>;margin-bottom:2px;"><%= td.label %></div>
      <div style="font-size:11px;color:var(--gray-400);">dokumen</div>
    </div>
    <% }) %>
  </div>
</div>

<!-- DETAIL VIEW (hidden by default) -->
<div id="detailView" style="display:none;">
  <div style="margin-bottom:16px;">
    <button onclick="showGrid()" class="btn btn-secondary" style="font-size:13px;display:inline-flex;align-items:center;gap:6px;">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Kembali ke Klasifikasi
    </button>
    <span id="detailTitle" style="margin-left:14px;font-size:15px;font-weight:600;color:var(--gray-800);"></span>
  </div>

  <!-- Empty state -->
  <div id="detailEmpty" style="display:none;">
    <div class="compose-card" style="padding:48px;text-align:center;">
      <svg width="40" height="40" viewBox="0 0 48 48" fill="none" style="margin:0 auto 14px;display:block;color:var(--gray-300)"><rect x="8" y="6" width="32" height="36" rx="3" stroke="currentColor" stroke-width="2"/><path d="M16 16h16M16 22h16M16 28h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      <p style="color:var(--gray-400);font-size:14px;margin-bottom:12px;">Belum ada dokumen jenis ini.</p>
      <button onclick="showGrid()" class="btn btn-secondary">Kembali</button>
    </div>
  </div>

  <!-- Table -->
  <div id="detailTable" style="display:none;">
    <div class="compose-card">
      <div style="overflow-x:auto;">
        <table class="dok-table">
          <thead>
            <tr>
              <th>Nomor Surat</th>
              <th>Perihal</th>
              <th style="width:90px;">Tujuan</th>
              <th style="width:140px;">Dari</th>
              <th style="width:120px;">Tanggal</th>
              <th style="width:80px;">Aksi</th>
            </tr>
          </thead>
          <tbody id="detailTbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Data JSON untuk JS -->
<script>
const GROUPED = <%- JSON.stringify(
  Object.fromEntries(
    Object.entries(grouped).map(([k, docs]) => [k, docs.map(d => ({
      _id: d._id,
      nomorSurat: d.nomorSurat || '',
      subject: d.subject || '',
      jenis: d.jenis || 'internal',
      fromName: d.from && d.from.name ? d.from.name : '—',
      createdAt: d.createdAt
    }))])
  )
) %>;

const TIPE_LABELS = <%- JSON.stringify(Object.fromEntries(TIPE_DEF.map(t => [t.key, t.label]))) %>;

function showDetail(tipe) {
  document.getElementById('cardGrid').style.display = 'none';
  document.getElementById('detailView').style.display = '';
  const label = TIPE_LABELS[tipe] || tipe;
  document.getElementById('detailTitle').textContent = label;
  const docs = GROUPED[tipe] || [];
  if (docs.length === 0) {
    document.getElementById('detailEmpty').style.display = '';
    document.getElementById('detailTable').style.display = 'none';
  } else {
    document.getElementById('detailEmpty').style.display = 'none';
    document.getElementById('detailTable').style.display = '';
    const tbody = document.getElementById('detailTbody');
    tbody.innerHTML = docs.map(d => `
      <tr style="cursor:pointer;" onclick="location.href='/email/${d._id}'">
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;white-space:nowrap;">${d.nomorSurat || '—'}</td>
        <td style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml(d.subject)}</td>
        <td><span style="font-size:11px;font-weight:500;padding:2px 7px;border-radius:10px;${d.jenis==='eksternal'?'background:#fff7ed;color:#c2410c':'background:#eff6ff;color:#1d4ed8'}">${d.jenis==='eksternal'?'Eksternal':'Internal'}</span></td>
        <td style="font-size:12px;color:var(--gray-500);">${escHtml(d.fromName)}</td>
        <td style="font-size:12px;color:var(--gray-400);white-space:nowrap;">${formatDate(d.createdAt)}</td>
        <td><a href="/email/${d._id}" class="btn btn-secondary" style="padding:3px 10px;font-size:11.5px;" onclick="event.stopPropagation()">Lihat</a></td>
      </tr>`).join('');
  }
}

function showGrid() {
  document.getElementById('detailView').style.display = 'none';
  document.getElementById('cardGrid').style.display = '';
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function formatDate(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' });
}
</script>

<%- include('./partials/footer') %>
