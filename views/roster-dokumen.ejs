<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Roster Dokumen</div>
    <h1 class="page-title">Roster Dokumen</h1>
    <p class="page-subtitle">Dokumen yang telah ditandatangani, dikelompokkan per jenis</p>
  </div>
</div>

<% const tipeOrder = ['Nota Dinas','Surat Eksternal','MoU','MoA','Contract','IA','PKS','SPK','SK']; %>
<% const allTipes = [...new Set([...tipeOrder.filter(t => grouped[t]), ...Object.keys(grouped).filter(t => !tipeOrder.includes(t))])]; %>

<% if (allTipes.length === 0) { %>
<div class="compose-card" style="padding:48px;text-align:center;">
  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="margin:0 auto 16px;display:block;color:var(--gray-300)"><rect x="8" y="6" width="32" height="36" rx="3" stroke="currentColor" stroke-width="2"/><path d="M16 16h16M16 22h16M16 28h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
  <p style="color:var(--gray-400);font-size:14px;">Belum ada dokumen bertanda tangan.</p>
</div>
<% } %>

<% allTipes.forEach(function(tipe) { %>
<% const docs = grouped[tipe] || []; %>
<div class="compose-card" style="margin-bottom:20px;">
  <div class="compose-card-header">
    <span class="compose-card-title" style="display:flex;align-items:center;gap:8px;">
      <span style="font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;background:#071840;color:#fff;letter-spacing:.5px;text-transform:uppercase;"><%= tipe %></span>
      <span><%= tipe %></span>
    </span>
    <span style="font-size:12px;color:var(--gray-400);">
      <svg width="12" height="12" viewBox="0 0 20 20" fill="none" style="vertical-align:middle;"><rect x="4" y="9" width="12" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <%= docs.length %> dokumen terkunci
    </span>
  </div>
  <div style="overflow-x:auto;">
    <table class="dok-table">
      <thead>
        <tr>
          <th>Nomor Surat</th>
          <th>Perihal</th>
          <th style="width:140px;">Dari</th>
          <th style="width:120px;">Tanggal</th>
          <th style="width:80px;">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% docs.forEach(function(doc) { %>
        <tr>
          <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;white-space:nowrap;"><%= doc.nomorSurat || '—' %></td>
          <td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= doc.subject %></td>
          <td style="font-size:12px;color:var(--gray-500);"><%= doc.from?.name || '—' %></td>
          <td style="font-size:12px;color:var(--gray-400);white-space:nowrap;"><%= formatDate(doc.createdAt) %></td>
          <td>
            <a href="/email/<%= doc._id %>" class="btn btn-secondary" style="padding:3px 10px;font-size:11.5px;">Lihat</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% }) %>

<%- include('./partials/footer') %>
