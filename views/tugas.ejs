<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Tugas</div>
    <h1 class="page-title">Manajemen Tugas</h1>
    <p class="page-subtitle">Buat, kelola, dan pantau progres tugas</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      Tugas Baru
    </button>
  </div>
</div>

<% const allTasks = [...myTasks, ...assignedTasks]; %>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M9 5H7a2 2 0 00-2 2v8a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h0a2 2 0 002-2M9 5a2 2 0 012-2h0a2 2 0 012 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Total Tugas</div><div class="stat-value"><%= allTasks.length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Sedang Dikerjakan</div><div class="stat-value"><%= allTasks.filter(t=>t.status==='dikerjakan').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Selesai</div><div class="stat-value"><%= allTasks.filter(t=>t.status==='selesai').length %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Urgent</div><div class="stat-value"><%= allTasks.filter(t=>t.priority==='urgent').length %></div></div>
  </div>
</div>

<%
const priorityClass = { urgent: 'tag-urgent', tinggi: 'tag-penting', normal: 'tag-normal', rendah: 'tag-info' };
const priorityLabel = { urgent: 'Urgent', tinggi: 'Tinggi', normal: 'Normal', rendah: 'Rendah' };
const statusClass = { pending: 'task-status-pending', dikerjakan: 'task-status-progress', selesai: 'task-status-done', dibatalkan: 'task-status-cancel' };
const statusLabel = { pending: 'Belum Dikerjakan', dikerjakan: 'Sedang Dikerjakan', selesai: 'Selesai', dibatalkan: 'Dibatalkan' };
%>

<!-- Filter tabs -->
<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:8px;">
    <span class="mail-list-title">Daftar Tugas</span>
    <div class="filter-tabs">
      <button class="filter-tab active" onclick="filterTask(this,'all')">Semua</button>
      <button class="filter-tab" onclick="filterTask(this,'pending')">Belum</button>
      <button class="filter-tab" onclick="filterTask(this,'dikerjakan')">Proses</button>
      <button class="filter-tab" onclick="filterTask(this,'selesai')">Selesai</button>
    </div>
  </div>

  <% if (allTasks.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M18 12h12M12 20h24M12 28h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M32 36l4 4 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p>Belum ada tugas. Klik "Tugas Baru" untuk memulai.</p>
  </div>
  <% } %>

  <% allTasks.forEach(function(t) {
    const isOwner = t.createdBy.userId.toString() === user._id.toString();
    const assigneeNames = (t.assignedTo || []).map(a => a.name).join(', ') || '—';
  %>
  <div class="task-item" data-status="<%= t.status %>">
    <div class="task-item-left">
      <button class="task-check-btn" onclick="cycleStatus('<%= t._id %>', '<%= t.status %>', this)" title="Ubah status">
        <% if (t.status === 'selesai') { %>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="var(--brand-500)"/><path d="M6 10l3 3 5-5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <% } else if (t.status === 'dikerjakan') { %>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" fill="var(--amber-500)"/><path d="M10 6v5l3 2" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/></svg>
        <% } else { %>
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="var(--gray-300)" stroke-width="1.5"/></svg>
        <% } %>
      </button>
    </div>
    <div class="task-item-body">
      <div class="task-title <%= t.status === 'selesai' ? 'task-done-text' : '' %>"><%= t.title %></div>
      <% if (t.description) { %>
        <div class="task-desc"><%= t.description %></div>
      <% } %>
      <div class="task-meta-row">
        <span class="mail-tag <%= priorityClass[t.priority] || 'tag-normal' %>"><%= priorityLabel[t.priority] || t.priority %></span>
        <span class="task-status-label <%= statusClass[t.status] %>"><%= statusLabel[t.status] || t.status %></span>
        <% if (!isOwner) { %>
          <span class="task-from-badge">dari: <%= t.createdBy.name %></span>
        <% } else if (t.assignedTo && t.assignedTo.length > 0) { %>
          <span class="task-assign-badge">ke: <%= assigneeNames %></span>
        <% } %>
        <% if (t.dueDateFmt) { %>
          <span class="task-due <%= new Date(t.dueDate) < new Date() && t.status !== 'selesai' ? 'task-due-late' : '' %>">
            <svg width="11" height="11" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <%= t.dueDateFmt %>
          </span>
        <% } %>
      </div>
    </div>
    <% if (isOwner) { %>
    <div class="task-item-actions">
      <button class="admin-btn admin-btn-delete" onclick="deleteTask('<%= t._id %>', this)" title="Hapus tugas">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
    <% } %>
  </div>
  <% }); %>
</div>

<!-- Modal: Tugas Baru -->
<div class="modal-overlay" id="taskModal" onclick="closeModal(event)">
  <div class="modal-card" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title">Buat Tugas Baru</h3>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form action="/tugas" method="POST" class="compose-form" style="padding:0;">
      <div class="form-group">
        <label class="form-label">Judul Tugas <span class="req">*</span></label>
        <input type="text" name="title" class="form-control" placeholder="Apa yang perlu dikerjakan?" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Deskripsi</label>
        <textarea name="description" class="form-control textarea" rows="3" placeholder="Detail atau catatan tambahan..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Prioritas</label>
          <div class="select-wrap">
            <select name="priority" class="form-control form-select">
              <option value="rendah">Rendah</option>
              <option value="normal" selected>Normal</option>
              <option value="tinggi">Tinggi</option>
              <option value="urgent">Urgent</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tenggat Waktu</label>
          <input type="date" name="dueDate" class="form-control">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Tugaskan Kepada</label>
        <div class="select-wrap">
          <select name="assignedTo" class="form-control form-select" multiple style="height:auto;min-height:42px;padding-right:12px;">
            <% users.forEach(function(u) { %>
            <option value="<%= u._id %>"><%= u.name %> — <%= u.email %></option>
            <% }); %>
          </select>
        </div>
        <small class="form-hint">Tahan Ctrl/Cmd untuk memilih lebih dari satu</small>
      </div>
      <div class="compose-actions" style="padding-top:8px;">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Batal</button>
        <button type="submit" class="btn btn-primary">Simpan Tugas</button>
      </div>
    </form>
  </div>
</div>

<div class="admin-toast" id="taskToast"></div>

<script>
function openModal() {
  document.getElementById('taskModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(e) {
  if (e && e.target !== document.getElementById('taskModal')) return;
  document.getElementById('taskModal').classList.remove('open');
  document.body.style.overflow = '';
}

function showToast(msg, ok) {
  const t = document.getElementById('taskToast');
  t.textContent = msg;
  t.className = 'admin-toast admin-toast-' + (ok ? 'success' : 'error') + ' admin-toast-show';
  setTimeout(() => t.className = 'admin-toast', 3000);
}

function filterTask(btn, status) {
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.task-item').forEach(item => {
    item.style.display = (status === 'all' || item.dataset.status === status) ? '' : 'none';
  });
}

const statusCycle = { pending: 'dikerjakan', dikerjakan: 'selesai', selesai: 'pending', dibatalkan: 'pending' };

async function cycleStatus(id, currentStatus, btn) {
  const next = statusCycle[currentStatus] || 'dikerjakan';
  try {
    const res = await fetch(`/tugas/${id}/status`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: next })
    });
    const data = await res.json();
    if (data.ok) location.reload();
    else showToast(data.message || 'Gagal.', false);
  } catch (e) {
    showToast('Terjadi kesalahan.', false);
  }
}

async function deleteTask(id, btn) {
  if (!confirm('Hapus tugas ini?')) return;
  const res = await fetch(`/tugas/${id}`, { method: 'DELETE' });
  const data = await res.json();
  if (data.ok) {
    btn.closest('.task-item').remove();
    showToast('Tugas dihapus.', true);
  } else {
    showToast(data.message || 'Gagal.', false);
  }
}
</script>

<%- include('./partials/footer') %>
