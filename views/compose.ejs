const ALL_SECS = ['sec-memo','sec-sppd','sec-tugas','sec-delegasi','sec-keterangan','sec-pernyataan','sec-kuasa','sec-pengantar','sec-keputusan','sec-undangan','sec-statuta','sec-surat-ext','sec-pihak-kedua','sec-spk','sec-invoice'];
const TIPE_SECS = {
  'Surat':['sec-surat-ext'],  'Surat Resmi':['sec-surat-ext'],  'Surat Formal':['sec-surat-ext'],
  'Surat Instruksi':['sec-surat-ext'],  'Surat Edaran':[],
  'Surat Rahasia':['sec-surat-ext'], 'Surat Konfidensial':['sec-surat-ext'],
  'Memo':['sec-memo'], 'Nota Dinas':['sec-memo'],
  'SPPD':['sec-sppd'],
  'Surat Tugas':['sec-tugas'],
  'Surat Tugas Pendelegasian':['sec-delegasi'],
  'Surat Keterangan':['sec-keterangan'],
  'Surat Pernyataan':['sec-pernyataan'],
  'Surat Kuasa':['sec-kuasa'],
  'Surat Pengantar':['sec-pengantar'],
  'Surat Keputusan':['sec-keputusan'],
  'Surat Undangan Dinas':['sec-undangan'],
  'Surat Statuta':['sec-statuta'],
  'MOU':['sec-pihak-kedua'],
  'PKS':['sec-pihak-kedua'],
  'Kontrak':['sec-pihak-kedua'],
  'SPK':['sec-spk'],
  'Invoice':['sec-invoice'],
};
const BODY_PLACEHOLDER = {
  'Surat': 'Tulis isi surat di sini...',
  'Surat Resmi': 'Tulis isi surat resmi di sini...',
  'Surat Formal': 'Tulis isi surat formal di sini...',
  'Surat Instruksi': 'Tulis instruksi-instruksi di sini...',
  'Surat Edaran': 'Tulis poin-poin edaran di sini...',
  'Surat Rahasia': 'Tulis isi surat rahasia di sini...',
  'Surat Konfidensial': 'Tulis isi surat konfidensial di sini...',
  'Memo': 'Tulis isi memo / pesan di sini...',
  'Nota Dinas': 'Tulis isi nota dinas / keterangan tambahan di sini...',
  'SPPD': 'Keterangan tambahan perjalanan dinas (opsional)...',
  'Surat Tugas': 'Instruksi atau keterangan tambahan (opsional)...',
  'Surat Tugas Pendelegasian': 'Keterangan tambahan pendelegasian (opsional)...',
  'Surat Keterangan': 'Keterangan tambahan (opsional)...',
  'Surat Pernyataan': 'Kalimat penutup pernyataan (opsional)...',
  'Surat Kuasa': 'Keterangan tambahan surat kuasa (opsional)...',
  'Surat Pengantar': 'Keterangan / pesan pengantar di sini...',
  'Surat Keputusan': 'Keterangan atau catatan tambahan keputusan (opsional)...',
  'Surat Undangan Dinas': 'Keterangan tambahan undangan (opsional)...',
  'Surat Statuta': 'Ketentuan atau pasal-pasal tambahan (opsional)...',
  'MOU': 'Tulis pasal-pasal MOU (Pasal 1, Pasal 2, dst.) di sini...',
  'PKS': 'Tulis pasal-pasal PKS (Pasal 1, Pasal 2, dst.) di sini...',
  'Kontrak': 'Tulis pasal-pasal kontrak (Pasal 1, Pasal 2, dst.) di sini...',
  'SPK': 'Keterangan tambahan SPK (opsional)...',
  'Invoice': 'Catatan atau keterangan tambahan invoice (opsional)...',
};
// Auto-suggest kodeDiv, kodeLay, berkas per tipe surat (sesuai Pedoman Kodifikasi NIT)
const TIPE_TO_KODE = {
  'Surat':                      { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Resmi':                { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Formal':               { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Instruksi':            { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Surat Edaran':               { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Rahasia':              { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Surat Konfidensial':         { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Memo':                       { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Nota Dinas':                 { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'SPPD':                       { div:'OPS', lay:'ST',  berkas:'OPS-ST'  },
  'Surat Tugas':                { div:'OPS', lay:'ST',  berkas:'OPS-ST'  },
  'Surat Tugas Pendelegasian':  { div:'OPS', lay:'ST',  berkas:'OPS-ST'  },
  'Surat Keterangan':           { div:'OPS', lay:'SRT', berkas:'OPS-SRT' },
  'Surat Pernyataan':           { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Surat Kuasa':                { div:'OPS', lay:'INT', berkas:'OPS-INT' },
  'Surat Pengantar':            { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Keputusan':            { div:'DIR', lay:'SK',  berkas:'DIR-SK'  },
  'Surat Undangan Dinas':       { div:'OPS', lay:'EXT', berkas:'OPS-EXT' },
  'Surat Statuta':              { div:'DIR', lay:'SK',  berkas:'DIR-SK'  },
  'MOU':                        { div:'BIS', lay:'PKS', berkas:'BIS-PKS' },
  'PKS':                        { div:'BIS', lay:'PKS', berkas:'BIS-PKS' },
  'Kontrak':                    { div:'BIS', lay:'SPK', berkas:'BIS-SPK' },
  'SPK':                        { div:'OPS', lay:'SPK', berkas:'BIS-SPK' },
  'Invoice':                    { div:'BIS', lay:'INV', berkas:'BIS-INV' },
};
function onTipeChange(val) {
  currentTipe = val;
  document.getElementById('tipeSuratHidden').value = val;
  document.getElementById('infoTipe').textContent = val;
  ALL_SECS.forEach(id => document.getElementById(id).style.display = 'none');
  (TIPE_SECS[val] || []).forEach(id => document.getElementById(id).style.display = '');
  // Show nota budget only for Nota Dinas
  const notaBudget = document.getElementById('sec-nota-budget');
  if (notaBudget) notaBudget.style.display = val === 'Nota Dinas' ? '' : 'none';
  const nilaiKontrak = document.getElementById('sec-nilai-kontrak');
  if (nilaiKontrak) nilaiKontrak.style.display = val === 'Kontrak' ? '' : 'none';
  // Auto-suggest kode divisi, jenis, dan berkas
  const kode = TIPE_TO_KODE[val];
  if (kode) {
    // auto-suggest kodeDir sudah tidak diperlukan — user pilih manual
  }
  // Tampilkan form Pihak Kedua untuk dokumen khusus
  const TIPE_KHUSUS_JS = ['MoU','MoA','Contract','IA','PKS','SPK'];
  const p2form = document.getElementById('sec-pihak-kedua-form');
