    <td><input type="text" id="pr_nama_${id}" class="form-control" placeholder="Nama dokumen..." style="min-width:180px;"></td>
    <td><input type="text" id="pr_jumlah_${id}" class="form-control" placeholder="cth: 1 berkas"></td>
    <td><input type="text" id="pr_ket_${id}" class="form-control" placeholder="Asli / Fotokopi"></td>
    <td><button type="button" class="dyn-row-del" onclick="delRow('row_${id}','pengantar','${id}')">×</button></td>`;
  document.getElementById('pengantarBody').appendChild(tr);
}

// Statuta anggota rows
