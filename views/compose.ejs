// Invoice rows
let invRows = [];
function addInvRow() {
  const id = 'inv_' + Date.now();
  invRows.push(id);
  const idx = invRows.length;
  const tr = document.createElement('tr');
  tr.id = 'invrow_' + id;
  tr.innerHTML = `
    <td style="text-align:center;padding:6px 4px;">${idx}</td>
    <td><input type="text" id="inv_desc_${id}" class="form-control" placeholder="Nama layanan / item..."></td>
    <td><input type="number" id="inv_qty_${id}" class="form-control" placeholder="1" min="0" step="any" oninput="recalcInv()"></td>
    <td><input type="text" id="inv_sat_${id}" class="form-control" placeholder="unit"></td>
    <td><input type="text" id="inv_harga_${id}" class="form-control" placeholder="0" oninput="recalcInv()"></td>
    <td id="inv_jml_${id}" style="padding:6px 8px;font-weight:500;font-size:13px;white-space:nowrap;">Rp 0</td>
    <td><button type="button" class="btn-del-row" onclick="delRow('invrow_${id}','invoice','${id}')">×</button></td>`;
  document.getElementById('invBody').appendChild(tr);
}
function parseRp(s) { return parseFloat(String(s).replace(/[^0-9.]/g,'')) || 0; }
function fmtRp(n) { return 'Rp ' + Math.round(n).toLocaleString('id-ID'); }
function recalcInv() {
  let subtotal = 0;
  invRows.forEach(id => {
    const qty   = parseFloat(document.getElementById('inv_qty_'+id)?.value) || 0;
    const harga = parseRp(document.getElementById('inv_harga_'+id)?.value);
    const jml   = qty * harga;
    const jmlEl = document.getElementById('inv_jml_'+id);
    if (jmlEl) jmlEl.textContent = fmtRp(jml);
    subtotal += jml;
  });
  const pajak   = parseFloat(document.getElementById('inv_pajak')?.value) || 0;
  const diskon  = parseRp(document.getElementById('inv_diskon')?.value);
  const pajakAmt = subtotal * pajak / 100;
  const total   = subtotal + pajakAmt - diskon;
  document.getElementById('inv_subtotal_display').textContent = fmtRp(subtotal);
  document.getElementById('inv_pajak_display').textContent    = fmtRp(pajakAmt);
  document.getElementById('inv_diskon_display').textContent   = fmtRp(diskon);
  document.getElementById('inv_total_display').textContent    = fmtRp(total < 0 ? 0 : total);
}

// ── COLLECT SURAT DATA ──
function collectSuratData() {
  const sd = {};
  const t = currentTipe;

  if (t === 'Memo' || t === 'Nota Dinas') {
    sd.kepada = v('memo_kepada');
    sd.klasifikasi = v('memo_klasifikasi');
    if (t === 'Nota Dinas') {
      sd.budgetRows = budgetRows.map(id => ({
        uraian: v('br_uraian_'+id),
        jumlah: v('br_jumlah_'+id)
      })).filter(r => r.uraian);
    }
  }
  else if (t === 'SPPD') {
    sd.namaPegawai = v('sppd_nama'); sd.jabatanPegawai = v('sppd_jabatan');
    sd.golongan = v('sppd_golongan'); sd.maksudPerjalanan = v('sppd_maksud');
    sd.alatAngkutan = v('sppd_angkutan'); sd.tempatBerangkat = v('sppd_asal');
    sd.tempatTujuan = v('sppd_tujuan'); sd.tanggalBerangkat = v('sppd_tgl_berangkat');
    sd.tanggalKembali = v('sppd_tgl_kembali'); sd.mataPenggunaan = v('sppd_mata_anggaran');
  }
  else if (t === 'Surat Tugas') {
    const _pJabatan = v('tugas_pemberi_preset') === 'lainnya' ? v('tugas_pemberi_jabatan_custom') : v('tugas_pemberi_preset');
    sd.jabatanPemberiTugas = _pJabatan;
    sd.namaPemberiTugas = v('tugas_pemberi_nama');
    sd.pelaksana = tugasRows.map(id => ({
      nama    : v('tgs_nama_' + id),
      jabatan : v('tgs_jabatan_' + id)
    })).filter(r => r.nama);
    sd.jenisTugas  = v('tugas_jenis');
    sd.tujuanTugas = v('tugas_tujuan');
    sd.lokasiTugas = v('tugas_lokasi');
    sd.tanggalTugas = v('tugas_tanggal');
    sd.waktuTugas  = v('tugas_waktu');
  }
  else if (t === 'Surat Tugas Pendelegasian') {
    sd.namaPenerima = v('del_nama'); sd.jabatanPenerima = v('del_jabatan');
    sd.lingkupDelegasi = getListValues('del_lingkup_list');
    sd.ketentuanDelegasi = getListValues('del_ketentuan_list');
  }
  else if (t === 'Surat Keterangan') {
    sd.namaDiterangkan = v('ket_nama'); sd.jabatanDiterangkan = v('ket_jabatan');
    sd.timDiterangkan = v('ket_tim'); sd.keperluan = v('ket_keperluan');
    sd.lokasiTugas = v('ket_lokasi'); sd.tanggalTugas = v('ket_tanggal');
  }
  else if (t === 'Surat Pernyataan') {
    sd.namaPenyataan = v('pry_nama'); sd.jabatanPernyataan = v('pry_jabatan');
    sd.timPernyataan = v('pry_tim');
    sd.poinPernyataan = getListValues('pry_poin_list');
  }
  else if (t === 'Surat Kuasa') {
    sd.namaPenerima = v('kuasa_nama'); sd.jabatanPenerima = v('kuasa_jabatan');
    sd.ruangLingkup = getListValues('kuasa_lingkup_list');
  }
  else if (t === 'Surat Pengantar') {
    sd.kepada = v('peng_kepada');
    sd.dokumenList = pengantarRows.map(id => ({
      nama: v('pr_nama_'+id), jumlah: v('pr_jumlah_'+id), keterangan: v('pr_ket_'+id)
    })).filter(r => r.nama);
  }
  else if (t === 'Surat Keputusan') {
    sd.menimbang = getListValues('sk_menimbang_list');
    sd.mengingat  = getListValues('sk_mengingat_list');
    sd.memutuskan = getListValues('sk_memutuskan_list');
  }
  else if (t === 'Surat Undangan Dinas') {
    sd.tanggalUndangan = v('und_tanggal'); sd.waktuUndangan = v('und_waktu');
    sd.tempatUndangan = v('und_tempat'); sd.agendaUndangan = v('und_agenda');
    sd.pakaianUndangan = v('und_pakaian');
  }
  else if (t === 'Surat Statuta') {
    sd.namaOrganisasi = v('sta_nama_org'); sd.visi = v('sta_visi');
    sd.misi = getListValues('sta_misi_list');
    sd.anggota = staAnggotaRows.map(id => ({
      nama: v('sa_nama_'+id), jabatan: v('sa_jabatan_'+id)
    })).filter(r => r.nama);
  }
  else if (t === 'MOU' || t === 'PKS' || t === 'Kontrak') {
    sd.namaPihakKedua = v('p2_nama');
    sd.jabatanPihakKedua = v('p2_jabatan');
    sd.instansiPihakKedua = v('p2_instansi');
    sd.alamatPihakKedua = v('p2_alamat');
    if (t === 'Kontrak') sd.nilaiKontrak = v('p2_nilai');
  }
  else if (t === 'SPK') {
    sd.namaTim = v('spk_tim');
    sd.ketuaTim = v('spk_ketua');
    sd.anggotaTim = v('spk_anggota');
    sd.pekerjaanSPK = spkRows.map(id => ({
      uraian: v('spk_uraian_'+id),
      keterangan: v('spk_ket_'+id)
    })).filter(r => r.uraian);
    sd.lokasiSPK = v('spk_lokasi');
    sd.tanggalSPK = v('spk_tanggal');
    sd.waktuSPK = v('spk_waktu');
  }
  else if (['Surat','Surat Resmi','Surat Formal','Surat Instruksi','Surat Rahasia','Surat Konfidensial'].includes(t)) {
    sd.jabatanPenerima = v('std_jabatan');
    sd.instansiPenerima = v('std_instansi');
    sd.alamatPenerima = v('std_alamat');
  }
  else if (['MoU','MoA','Contract','IA','PKS','SPK'].includes(t)) {
    const p2 = document.querySelector('[name="pihak2"]');
    const nilaiEl = document.querySelector('[name="nilaiKontrak"]');
    const tglMulai = document.querySelector('[name="tglMulai"]');
    const tglBerakhir = document.querySelector('[name="tglBerakhir"]');
    const deskEl = document.querySelector('[name="deskripsiDok"]');
    sd.pihak2 = p2?.value.trim() || '';
    sd.nilaiKontrak = nilaiEl?.value.replace(/\./g,'') || '';
    sd.tglMulai = tglMulai?.value || '';
    sd.tglBerakhir = tglBerakhir?.value || '';
    sd.deskripsi = deskEl?.value.trim() || '';
  }
  else if (t === 'Invoice') {
    sd.invKepada    = v('inv_kepada');
    sd.invAlamat    = v('inv_alamat');
    sd.invJatuhTempo = v('inv_jatuh_tempo');
    sd.invMetode    = v('inv_metode');
    sd.invCatatan   = v('inv_catatan');
    sd.invPajak     = parseFloat(document.getElementById('inv_pajak')?.value) || 0;
    sd.invDiskon    = parseRp(document.getElementById('inv_diskon')?.value);
    sd.invItems     = invRows.map(id => ({
      deskripsi : v('inv_desc_'+id),
      qty       : parseFloat(document.getElementById('inv_qty_'+id)?.value) || 0,
      satuan    : v('inv_sat_'+id),
      harga     : parseRp(document.getElementById('inv_harga_'+id)?.value)
    })).filter(r => r.deskripsi);
  }
  return sd;
}
function v(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
function onPemberiPresetChange() {
  const sel = document.getElementById('tugas_pemberi_preset');
  const custom = document.getElementById('tugas_pemberi_jabatan_custom');
  if (!sel || !custom) return;
  custom.style.display = sel.value === 'lainnya' ? '' : 'none';
  if (sel.value === 'lainnya') custom.focus();
}
function getListValues(listId) {
  return Array.from(document.getElementById(listId)?.querySelectorAll('input') || [])
    .map(i => i.value.trim()).filter(Boolean);
}

// ── SUBMIT ──
function submitForm(action) {
  if (action === 'send' && currentJenis === 'eksternal' && extList.length === 0) {
    alert('Tambahkan minimal satu penerima eksternal.'); return;
  }
  document.getElementById('formAction').value = action;
  document.getElementById('bodyHidden').value = quill.root.innerHTML;
  document.getElementById('externalRecipientsHidden').value = JSON.stringify(extList);
  document.getElementById('tipeSuratHidden').value = currentTipe;
  document.getElementById('suratDataHidden').value = JSON.stringify(collectSuratData());
  document.getElementById('composeForm').submit();
}

// ── DROPDOWN HELPERS ──
function toggleDropdown(id) { document.getElementById(id+'Dropdown').classList.toggle('open'); }
function searchDropdown(id, q) {
  document.getElementById(id+'Dropdown').querySelectorAll('.dropdown-opt').forEach(o => {
    o.style.display = !q||(o.dataset.search||'').includes(q.toLowerCase()) ? '' : 'none';
  });
}
function toggleTag(id, cb, name) {
  const tags = document.getElementById(id+'Tags');
  const ph   = document.getElementById(id+'Placeholder');
  if (cb.checked) {
    const t = document.createElement('span'); t.className = 'selected-tag'; t.dataset.value = cb.value;
    t.textContent = name.length>20 ? name.substring(0,18)+'…' : name;
    const b = document.createElement('button'); b.type='button'; b.innerHTML='×';
    b.onclick = e => { e.stopPropagation(); t.remove(); cb.checked=false; updatePh(id); };
    t.appendChild(b); tags.appendChild(t);
  } else { tags.querySelector('[data-value="'+cb.value+'"]')?.remove(); }
  updatePh(id);
}
function updatePh(id) {
  const ph = document.getElementById(id+'Placeholder');
  if(ph) ph.style.display = document.getElementById(id+'Tags').children.length ? 'none' : '';
}
document.addEventListener('click', e => {
  ['tertuju','tembusan'].forEach(id => {
    const w = document.getElementById(id+'Wrap');
    if (w && !w.contains(e.target)) document.getElementById(id+'Dropdown')?.classList.remove('open');
  });
});
