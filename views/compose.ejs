</div>
</form>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
// ── DATE ──
const today = new Date();
const mns = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
document.getElementById('infoDate').textContent = `${today.getDate()} ${mns[today.getMonth()]} ${today.getFullYear()}`;

// ── QUILL ──
const SizeStyle = Quill.import('attributors/style/size');
SizeStyle.whitelist = ['10px','12px','14px','16px','18px','20px','24px','28px','32px'];
Quill.register(SizeStyle, true);
const FontStyle = Quill.import('formats/font');
FontStyle.whitelist = ['times-new-roman', 'sans-serif', 'serif', 'monospace'];
Quill.register(FontStyle, true);
const quill = new Quill('#quillEditor', {
  theme: 'snow',
  placeholder: 'Tulis isi surat / instruksi tambahan di sini...',
  modules: {
    toolbar: {
      container: [
        [{ font: ['', 'times-new-roman', 'sans-serif', 'serif', 'monospace'] }, { size: ['10px','12px','14px','16px','18px','20px','24px','28px','32px'] }],
        [{ header: [1,2,3,4,false] }],
        ['bold','italic','underline','strike'],
        [{ color: [] }, { background: [] }],
        ['blockquote','code-block'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ indent: '-1' }, { indent: '+1' }],
        [{ align: [] }],
        ['link','image','table'],
        ['clean']
      ],
      handlers: { image: imageHandler, table: tablePickerHandler }
    }
  }
});
function imageHandler() {
  const input = document.createElement('input');
  input.setAttribute('type','file'); input.setAttribute('accept','image/*'); input.click();
  input.onchange = () => {
    const file = input.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => { const r = quill.getSelection(true); quill.insertEmbed(r.index,'image',e.target.result); quill.setSelection(r.index+1); };
    reader.readAsDataURL(file);
  };
}

// ── QUILL TABLE PICKER ──
(function() {
  const style = document.createElement('style');
  style.textContent = `
  .ql-table::before { content: '⊞'; font-size: 15px; line-height: 1; }
  .tbl-picker { position:fixed; z-index:9999; background:#fff; border:1px solid var(--gray-200); border-radius:8px; padding:8px; box-shadow:0 4px 20px rgba(0,0,0,.15); }
  .tbl-picker-grid { display:grid; grid-template-columns:repeat(8,22px); gap:3px; }
  .tbl-picker-cell { width:22px; height:22px; border:1px solid var(--gray-300); border-radius:3px; cursor:pointer; background:#f9fafb; transition:background .1s,border-color .1s; }
  .tbl-picker-cell.hover { background:#dbeafe; border-color:#3b82f6; }
  .tbl-picker-label { text-align:center; font-size:11px; color:var(--gray-500); margin-top:5px; }
  `;
  document.head.appendChild(style);
})();

let _tblPicker = null;
function tablePickerHandler() {
  if (_tblPicker) { _tblPicker.remove(); _tblPicker = null; return; }
  const btn = document.querySelector('.ql-table');
  if (!btn) return;
  const rect = btn.getBoundingClientRect();
  const picker = document.createElement('div');
  picker.className = 'tbl-picker';
  picker.style.top  = (rect.bottom + 6 + window.scrollY) + 'px';
  picker.style.left = rect.left + 'px';
  const grid = document.createElement('div'); grid.className = 'tbl-picker-grid';
  const label = document.createElement('div'); label.className = 'tbl-picker-label'; label.textContent = '1 × 1';
  const ROWS = 6, COLS = 8;
  const cells = [];
  for (let r = 0; r < ROWS; r++) {
    for (let c = 0; c < COLS; c++) {
      const cell = document.createElement('div'); cell.className = 'tbl-picker-cell';
      cell.dataset.r = r; cell.dataset.c = c;
      cell.addEventListener('mouseover', () => {
        const cr = +cell.dataset.r, cc = +cell.dataset.c;
        label.textContent = `${cr+1} × ${cc+1}`;
        cells.forEach(x => {
          x.classList.toggle('hover', +x.dataset.r <= cr && +x.dataset.c <= cc);
        });
      });
      cell.addEventListener('click', () => {
        insertTable(+cell.dataset.r + 1, +cell.dataset.c + 1);
        picker.remove(); _tblPicker = null;
      });
      cells.push(cell); grid.appendChild(cell);
    }
  }
  picker.appendChild(grid); picker.appendChild(label);
  document.body.appendChild(picker); _tblPicker = picker;
  setTimeout(() => document.addEventListener('click', function _close(e) {
    if (!picker.contains(e.target) && !btn.contains(e.target)) { picker.remove(); _tblPicker = null; document.removeEventListener('click', _close); }
  }), 0);
}
function insertTable(rows, cols) {
  const cellStyle = 'border:1px solid #ccc;padding:6px 10px;min-width:60px;';
  let html = `<table style="border-collapse:collapse;width:100%;margin:8px 0;"><tbody>`;
  for (let r = 0; r < rows; r++) {
    html += '<tr>';
    for (let c = 0; c < cols; c++) {
      html += `<td style="${cellStyle}">&nbsp;</td>`;
    }
    html += '</tr>';
  }
  html += '</tbody></table><p><br></p>';
  const range = quill.getSelection(true);
  quill.clipboard.dangerouslyPasteHTML(range ? range.index : quill.getLength(), html);
}

// ── FORMAT NILAI KONTRAK ──
function formatNilai(el) {
  let v = el.value.replace(/\D/g,'');
  el.value = v ? parseInt(v).toLocaleString('id-ID') : '';
}

// ── SUMBER TEMPLATE ──
function toggleSumberTemplate(isExternal) {
  document.getElementById('sumberTemplateHidden').value = isExternal ? 'eksternal' : 'internal';
  // Sembunyikan semua section form jika eksternal (hanya perlu tipe + nomor surat)
  const formSecs = document.getElementById('mainFormSections');
  if (formSecs) formSecs.style.display = isExternal ? 'none' : '';
  const extInfo = document.getElementById('eksternalTemplateInfo');
  if (extInfo) extInfo.style.display = isExternal ? '' : 'none';
}

// ── SIFAT ──
function updateSifat(sel) {
  const v = sel.value;
  document.getElementById('infoSifat').textContent = v;
  const other = sel.id === 'sifatSelect' ? 'sifatSelect2' : 'sifatSelect';
  const otherEl = document.getElementById(other);
  if (otherEl && otherEl.value !== v) otherEl.value = v;
}

// ── TIPE SURAT ──
