function onTipeChange(val) {
  currentTipe = val;
  document.getElementById('tipeSuratHidden').value = val;
  document.getElementById('infoTipe').textContent = val;
  ALL_SECS.forEach(id => document.getElementById(id).style.display = 'none');
  (TIPE_SECS[val] || []).forEach(id => document.getElementById(id).style.display = '');
  // Show nota budget only for Nota Dinas
  const notaBudget = document.getElementById('sec-nota-budget');
  if (notaBudget) notaBudget.style.display = val === 'Nota Dinas' ? '' : 'none';
  const nilaiKontrak = document.getElementById('sec-nilai-kontrak');
  if (nilaiKontrak) nilaiKontrak.style.display = val === 'Kontrak' ? '' : 'none';
  // Update quill placeholder
  const ph = BODY_PLACEHOLDER[val] || 'Tulis isi surat di sini...';
  quill.root.dataset.placeholder = ph;
}

// ── JENIS ──
let currentJenis = 'internal';
function setJenis(j) {
  currentJenis = j;
  document.getElementById('jenisHidden').value = j;
  document.getElementById('tabInternal').classList.toggle('active', j === 'internal');
  document.getElementById('tabEksternal').classList.toggle('active', j === 'eksternal');
  document.getElementById('internalSection').style.display = j === 'internal' ? '' : 'none';
  document.getElementById('eksternalSection').style.display = j === 'eksternal' ? '' : 'none';
}

// ── EXTERNAL RECIPIENTS ──
let extList = [];
function addExt() {
  const n = document.getElementById('extName').value.trim();
  const e = document.getElementById('extEmail').value.trim();
  if (!e) { document.getElementById('extEmail').focus(); return; }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)) { alert('Format email tidak valid.'); return; }
  if (extList.find(r => r.email === e)) { alert('Email sudah ditambahkan.'); return; }
  extList.push({ name: n||e, email: e }); renderExtList();
  document.getElementById('extName').value = ''; document.getElementById('extEmail').value = '';
  document.getElementById('extName').focus();
}
function removeExt(email) { extList = extList.filter(r => r.email !== email); renderExtList(); }
function renderExtList() {
  const list = document.getElementById('extList');
  const empty = document.getElementById('extEmpty');
  list.innerHTML = ''; empty.style.display = extList.length ? 'none' : '';
  extList.forEach(r => {
    const d = document.createElement('div'); d.className = 'ext-item';
    d.innerHTML = `<span class="ext-item-name">${esc(r.name)}</span><span class="ext-item-email">&lt;${esc(r.email)}&gt;</span><button type="button" class="ext-item-del" onclick="removeExt('${esc(r.email)}')">&times;</button>`;
    list.appendChild(d);
  });
  document.getElementById('externalRecipientsHidden').value = JSON.stringify(extList);
}
function esc(s) { return String(s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
document.getElementById('extEmail').addEventListener('keydown', e => { if(e.key==='Enter'){e.preventDefault();addExt();} });

// ── DYNAMIC ROWS / LISTS ──

// Budget rows (Nota Dinas)
let budgetRows = [];
function addBudgetRow() {
  const idx = budgetRows.length + 1;
  const id = 'br_' + Date.now();
  budgetRows.push(id);
  const tr = document.createElement('tr'); tr.id = 'row_' + id;
  tr.innerHTML = `<td style="text-align:center;font-size:12px;color:var(--gray-500);">${idx}</td>
    <td><input type="text" id="br_uraian_${id}" class="form-control" placeholder="Uraian kebutuhan..." style="min-width:200px;"></td>
    <td><input type="text" id="br_jumlah_${id}" class="form-control" placeholder="Rp ..."></td>
    <td><button type="button" class="dyn-row-del" onclick="delRow('row_${id}','budget','${id}')">×</button></td>`;
  document.getElementById('budgetBody').appendChild(tr);
}
function delRow(rowId, type, id) {
  document.getElementById(rowId)?.remove();
  if (type === 'budget') budgetRows = budgetRows.filter(r => r !== id);
  else if (type === 'pengantar') pengantarRows = pengantarRows.filter(r => r !== id);
  else if (type === 'staAnggota') staAnggotaRows = staAnggotaRows.filter(r => r !== id);
  renumberRows(type);
}
function renumberRows(type) {
  const bodyId = type === 'budget' ? 'budgetBody' : type === 'pengantar' ? 'pengantarBody' : 'staAnggotaBody';
  const body = document.getElementById(bodyId);
  if (!body) return;
  Array.from(body.querySelectorAll('tr')).forEach((r, i) => { const numCell = r.querySelector('td:first-child'); if(numCell) numCell.textContent = i+1; });
}

// Pengantar rows
let pengantarRows = [];
