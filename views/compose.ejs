<%- include('./partials/header') %>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
.ql-snow .ql-picker.ql-size .ql-picker-label::before,
.ql-snow .ql-picker.ql-size .ql-picker-item::before { content: attr(data-value) !important; }
.ql-size-10px { font-size: 10px; } .ql-size-12px { font-size: 12px; }
.ql-size-14px { font-size: 14px; } .ql-size-16px { font-size: 16px; }
.ql-size-18px { font-size: 18px; } .ql-size-20px { font-size: 20px; }
.ql-size-24px { font-size: 24px; } .ql-size-28px { font-size: 28px; }
.ql-size-32px { font-size: 32px; }
.ql-editor img { max-width: 100%; height: auto; border-radius: 4px; }

.jenis-tabs { display:flex; gap:0; border:1px solid var(--gray-200); border-radius:8px; overflow:hidden; margin-top:2px; }
.jenis-tab {
  flex:1; padding:9px 0; font-size:13px; font-weight:500; text-align:center; cursor:pointer;
  background:var(--gray-50); color:var(--gray-500); border:none; transition:all .15s;
  display:flex; align-items:center; justify-content:center; gap:6px;
}
.jenis-tab.active { background:#071840; color:#fff; }
.jenis-tab:first-child { border-right:1px solid var(--gray-200); }

.ext-recipient-input { display:flex; gap:8px; margin-bottom:8px; }
.ext-recipient-input input { flex:1; }
.ext-list { display:flex; flex-direction:column; gap:6px; }
.ext-item {
  display:flex; align-items:center; gap:8px;
  padding:7px 12px; border-radius:7px;
  background:var(--gray-50); border:1px solid var(--gray-200); font-size:13px;
}
.ext-item-name { font-weight:600; color:var(--gray-800); }
.ext-item-email { color:var(--gray-500); }
.ext-item-del { margin-left:auto; background:none; border:none; cursor:pointer; color:var(--gray-400); font-size:16px; line-height:1; }
.ext-item-del:hover { color:var(--red-500); }

.ql-container { font-family:'Times New Roman',Times,serif; font-size:14px; border:1px solid var(--gray-200) !important; border-top:0 !important; border-radius:0 0 var(--radius-md) var(--radius-md) !important; }
.ql-toolbar { border:1px solid var(--gray-200) !important; border-radius:var(--radius-md) var(--radius-md) 0 0 !important; background:var(--gray-50); flex-wrap:wrap; }
.ql-editor { min-height:220px; line-height:1.8; color:var(--gray-800); padding:16px; }
.ql-editor.ql-blank::before { color:var(--gray-400); font-style:normal; font-size:13.5px; }
.ql-toolbar .ql-formats { margin-right:8px; margin-bottom:4px; }
.ql-snow .ql-picker { color:var(--gray-600); }
.ql-snow .ql-picker.ql-size { width:80px; }
.ql-snow .ql-picker.ql-font { width:140px; }
.ql-font-times-new-roman { font-family: 'Times New Roman', Times, serif; }
.ql-snow .ql-picker.ql-font .ql-picker-label[data-value='times-new-roman']::before,
.ql-snow .ql-picker.ql-font .ql-picker-item[data-value='times-new-roman']::before { content: 'Times New Roman'; font-family: 'Times New Roman', Times, serif; }
.ql-snow .ql-picker.ql-font .ql-picker-label[data-value='sans-serif']::before,
.ql-snow .ql-picker.ql-font .ql-picker-item[data-value='sans-serif']::before { content: 'Sans Serif'; }
.ql-snow .ql-picker.ql-font .ql-picker-label[data-value='serif']::before,
.ql-snow .ql-picker.ql-font .ql-picker-item[data-value='serif']::before { content: 'Serif'; font-family: Georgia, serif; }
.ql-snow .ql-picker.ql-font .ql-picker-label[data-value='monospace']::before,
.ql-snow .ql-picker.ql-font .ql-picker-item[data-value='monospace']::before { content: 'Monospace'; font-family: monospace; }
.ql-snow .ql-picker.ql-font .ql-picker-label:not([data-value])::before,
.ql-snow .ql-picker.ql-font .ql-picker-item:not([data-value])::before { content: 'Times New Roman'; font-family: 'Times New Roman', Times, serif; }

/* Tipe surat section badges */
.sec-header {
  display:flex; align-items:center; gap:8px; margin-bottom:12px;
  padding:8px 12px; background:var(--gray-50); border:1px solid var(--gray-200);
  border-radius:8px; font-size:13px; font-weight:600; color:var(--gray-600);
}
.sec-badge { font-size:10px; font-weight:700; padding:2px 7px; border-radius:4px; background:#071840; color:#fff; }

/* Dynamic row table */
.dyn-table { width:100%; border-collapse:collapse; margin-top:8px; }
.dyn-table th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--gray-500); padding:6px 8px; border-bottom:2px solid var(--gray-200); text-align:left; }
.dyn-table td { padding:5px 4px; vertical-align:middle; }
.dyn-table td input, .dyn-table td select { font-size:12.5px; padding:5px 8px; }
.dyn-row-del { background:none; border:none; cursor:pointer; color:var(--gray-400); font-size:16px; padding:2px 6px; }
.dyn-row-del:hover { color:var(--red-500); }
.btn-add-row { margin-top:6px; font-size:12px; padding:5px 12px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:6px; cursor:pointer; color:var(--gray-600); }
.btn-add-row:hover { background:var(--gray-100); }

/* Dynamic list */
.dyn-list { display:flex; flex-direction:column; gap:6px; margin-top:8px; }
.dyn-list-item { display:flex; gap:8px; align-items:center; }
.dyn-list-item input { flex:1; font-size:13px; }
.dyn-list-item .item-num { font-size:12px; font-weight:700; color:var(--gray-500); min-width:24px; text-align:right; }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / <a href="/compose">Manajemen Dokumen</a> / Buat Baru</div>
    <h1 class="page-title">Buat Dokumen Baru</h1>
    <p class="page-subtitle">Nota Dinas, Surat Dinas<% if(user && (['superadmin','admin','direktur'].includes(user.role))){ %>, MoU, MoA, PKS, SPK, dan dokumen khusus lainnya<% } %></p>
  </div>
</div>

<form action="/compose" method="POST" id="composeForm" enctype="multipart/form-data">
  <input type="hidden" name="action" id="formAction" value="send">
  <input type="hidden" name="body" id="bodyHidden">
  <input type="hidden" name="jenis" id="jenisHidden" value="internal">
  <input type="hidden" name="externalRecipients" id="externalRecipientsHidden" value="[]">
  <input type="hidden" name="tipeSurat" id="tipeSuratHidden" value="Surat">
  <input type="hidden" name="suratData" id="suratDataHidden" value="{}">

<div class="compose-layout">
  <div class="compose-card">
    <div class="compose-card-header">
      <span class="compose-card-title">Detail Dokumen</span>
      <div style="display:flex;align-items:center;gap:12px;">
        <label style="display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--gray-600);cursor:pointer;">
          <input type="checkbox" name="sumberTemplateCheck" id="sumberTemplateCheck" onchange="toggleSumberTemplate(this.checked)" style="width:14px;height:14px;">
          Template Eksternal
        </label>
        <span style="font-size:12px;color:var(--gray-400);">Sifat:</span>
        <select id="sifatSelect" class="admin-role-select" style="padding:5px 24px 5px 10px;font-size:12.5px;" onchange="updateSifat(this)">
          <% if(allowedSifat.includes('Biasa/Terbuka')){ %><option value="Biasa/Terbuka">Biasa / Terbuka</option><% } %>
          <% if(allowedSifat.includes('Segera')){ %><option value="Segera">Segera</option><% } %>
          <% if(allowedSifat.includes('Terbatas')){ %><option value="Terbatas">Terbatas</option><% } %>
          <% if(allowedSifat.includes('Rahasia')){ %><option value="Rahasia">Rahasia</option><% } %>
        </select>
      </div>
    </div>
    <input type="hidden" name="sumberTemplate" id="sumberTemplateHidden" value="internal">
    <div class="compose-form">

      <!-- TIPE DOKUMEN + KODE DIREKTORAT -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Jenis Dokumen <span class="req">*</span></label>
          <div class="select-wrap">
            <select id="tipeSuratSelect" class="form-control form-select" onchange="onTipeChange(this.value)">
              <optgroup label="— Semua Pengguna —">
                <option value="Nota Dinas" selected>Nota Dinas (Internal)</option>
                <option value="Surat Dinas">Surat Dinas (Eksternal)</option>
              </optgroup>
              <% if (user && (['superadmin','admin','direktur'].includes(user.role))) { %>
              <optgroup label="— Direktur &amp; Admin —">
                <option value="MoU">MoU (Memorandum of Understanding)</option>
                <option value="MoA">MoA (Memorandum of Agreement)</option>
                <option value="Contract">Contract (Kontrak)</option>
                <option value="IA">IA (Implementation Agreement)</option>
                <option value="PKS">PKS (Perjanjian Kerja Sama)</option>
                <option value="SPK">SPK (Surat Perintah Kerja)</option>
              </optgroup>
              <% } %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Kode Direktorat <span class="req">*</span></label>
          <div class="select-wrap">
            <select name="kodeDir" id="kodeDirSel" class="form-control form-select">
              <% const kodeDirOpts=[{v:'KOM',l:'KOM — Dewan Komisaris'},{v:'DIR',l:'DIR — Direktur Utama'},{v:'PLAN',l:'PLAN — Business Strategy &amp; Finance'},{v:'TECH',l:'TECH — Technical &amp; Operations'},{v:'MP',l:'MP — Marketing &amp; Partnership'}]; %>
              <% kodeDirOpts.forEach(function(o){ if(allowedKodeDir.includes(o.v)){ %>
              <option value="<%= o.v %>" <%= (user.kodeDir===o.v||(allowedKodeDir.length===1&&allowedKodeDir[0]===o.v))?'selected':'' %>><%- o.l %></option>
              <% }}); %>
            </select>
          </div>
        </div>
      </div>

      <!-- PENGIRIM RESMI -->
      <div class="form-group">
        <label class="form-label">Pengirim Resmi <span style="font-size:11px;color:var(--gray-400);font-weight:400;">(nama yang tertera di dokumen)</span></label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <input type="text" name="pengirimResmi" id="pengirimResmiInput" class="form-control" value="<%= user.name %>" placeholder="Nama pengirim resmi di surat">
          <select id="pengirimPicker" class="form-control form-select" onchange="document.getElementById('pengirimResmiInput').value=this.value;this.value=''">
            <option value="">— Pilih dari daftar karyawan —</option>
            <% users.forEach(u => { %><option value="<%= u.name %>"><%= u.enik ? u.enik + ' — ' : '' %><%= u.name %><%= u.jabatan ? ' (' + u.jabatan + ')' : '' %></option><% }) %>
          </select>
        </div>
        <small class="form-hint">Pembuat dokumen: <strong><%= user.name %></strong><%= user.enik ? ' (ENIK: ' + user.enik + ')' : '' %></small>
      </div>

      <!-- Info jika template eksternal -->
      <div id="eksternalTemplateInfo" style="display:none;padding:14px 16px;background:#eff6ff;border-radius:8px;border:1px solid #bfdbfe;margin-bottom:4px;">
        <div style="font-weight:600;color:#1d4ed8;font-size:13.5px;margin-bottom:4px;">Template Eksternal</div>
        <div style="font-size:13px;color:#3b82f6;">Isi perihal dan nomor surat akan di-generate otomatis. Tidak perlu mengisi form konten.</div>
      </div>

      <!-- FORM PIHAK KEDUA — hanya untuk direktur+admin & dok. khusus -->
      <% if (user && (['superadmin','admin','direktur'].includes(user.role))) { %>
      <div id="sec-pihak-kedua-form" style="display:none;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:16px;margin-bottom:4px;">
        <div class="sec-header" style="margin-bottom:12px;">
          <span class="sec-badge">PIHAK KEDUA</span>
          Data Pihak Eksternal / Mitra
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Pihak Pertama (Internal)</label>
            <input type="text" name="pihak1" class="form-control" value="PT Nusa Inspira Teknologi" readonly style="background:var(--gray-100);">
          </div>
          <div class="form-group">
            <label class="form-label">Pihak Kedua (Eksternal) <span class="req">*</span></label>
            <input type="text" name="pihak2" id="pihak2Input" class="form-control" placeholder="Nama mitra / vendor / instansi luar">
          </div>
          <div class="form-group">
            <label class="form-label">Nilai Kontrak (Rp)</label>
            <input type="text" name="nilaiKontrak" class="form-control" placeholder="0" oninput="formatNilai(this)">
            <small class="form-hint">Kosongkan jika tidak ada nilai</small>
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Mulai</label>
            <input type="date" name="tglMulai" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Berakhir</label>
            <input type="date" name="tglBerakhir" class="form-control">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Deskripsi / Ruang Lingkup</label>
          <textarea name="deskripsiDok" class="form-control textarea" rows="3" placeholder="Uraikan ruang lingkup, tujuan, atau klausul penting dari dokumen ini..."></textarea>
        </div>
      </div>
      <% } %>

      <div id="mainFormSections">
      <!-- SUBJEK / PERIHAL -->
      <div class="form-group">
        <label class="form-label" id="subjectLabel">Subjek / Perihal <span class="req">*</span></label>
        <input type="text" name="subject" id="subjectInput" class="form-control" placeholder="Perihal surat..." required>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Tag / Prioritas</label>
          <div class="select-wrap">
            <select name="tag" class="form-control form-select">
              <option value="Biasa">Biasa</option>
              <option value="Penting">Penting</option>
              <option value="Segera">Segera</option>
              <option value="Mendesak">Mendesak</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Sifat Surat</label>
          <div class="select-wrap">
            <select name="sifat" id="sifatSelect2" class="form-control form-select" onchange="updateSifat(this)">
              <% if(allowedSifat.includes('Biasa/Terbuka')){ %><option value="Biasa/Terbuka">Biasa / Terbuka</option><% } %>
              <% if(allowedSifat.includes('Segera')){ %><option value="Segera">Segera</option><% } %>
              <% if(allowedSifat.includes('Terbatas')){ %><option value="Terbatas">Terbatas</option><% } %>
              <% if(allowedSifat.includes('Rahasia')){ %><option value="Rahasia">Rahasia</option><% } %>
            </select>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: MEMO / NOTA DINAS                             -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-memo" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">MEMO / NOTA DINAS</span>
          Informasi Internal
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Kepada (Jabatan / Nama)</label>
            <input type="text" id="memo_kepada" class="form-control" placeholder="cth: Kepala Bagian Keuangan">
          </div>
          <div class="form-group">
            <label class="form-label">Klasifikasi</label>
            <div class="select-wrap">
              <select id="memo_klasifikasi" class="form-control form-select">
                <option value="">— Pilih —</option>
                <option value="RAHASIA">RAHASIA</option>
                <option value="TERBATAS">TERBATAS</option>
                <option value="BIASA">BIASA</option>
              </select>
            </div>
          </div>
        </div>
        <!-- Nota Dinas: tabel anggaran -->
        <div id="sec-nota-budget" style="display:none;">
          <label class="form-label" style="margin-top:4px;">Rincian Anggaran / Biaya Operasional</label>
          <table class="dyn-table" id="budgetTable">
            <thead>
              <tr>
                <th style="width:40px;">No.</th>
                <th>Uraian Kebutuhan</th>
                <th style="width:160px;">Jumlah (Rp)</th>
                <th style="width:36px;"></th>
              </tr>
            </thead>
            <tbody id="budgetBody"></tbody>
          </table>
          <button type="button" class="btn-add-row" onclick="addBudgetRow()">+ Tambah Baris</button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SPPD                                          -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-sppd" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SPPD</span>
          Data Perjalanan Dinas
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Pegawai</label>
            <input type="text" id="sppd_nama" class="form-control" placeholder="Nama lengkap pegawai">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="sppd_jabatan" class="form-control" placeholder="Jabatan pegawai">
          </div>
          <div class="form-group">
            <label class="form-label">Tingkat / Golongan</label>
            <input type="text" id="sppd_golongan" class="form-control" placeholder="cth: Senior">
          </div>
          <div class="form-group">
            <label class="form-label">Maksud Perjalanan</label>
            <input type="text" id="sppd_maksud" class="form-control" placeholder="cth: Audit & Investigasi Internal">
          </div>
          <div class="form-group">
            <label class="form-label">Alat Angkutan</label>
            <input type="text" id="sppd_angkutan" class="form-control" placeholder="cth: Kendaraan Dinas / Umum">
          </div>
          <div class="form-group">
            <label class="form-label">Tempat Berangkat</label>
            <input type="text" id="sppd_asal" class="form-control" placeholder="cth: Jakarta">
          </div>
          <div class="form-group">
            <label class="form-label">Tempat Tujuan</label>
            <input type="text" id="sppd_tujuan" class="form-control" placeholder="cth: PT Maju Bersama, Jakarta Selatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Berangkat</label>
            <input type="date" id="sppd_tgl_berangkat" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Kembali</label>
            <input type="date" id="sppd_tgl_kembali" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Mata Anggaran</label>
            <input type="text" id="sppd_mata_anggaran" class="form-control" placeholder="cth: Biaya Operasional 2026">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT TUGAS (PERORANGAN / TIM)               -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-tugas" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SURAT TUGAS</span>
          Data Pemberi & Pelaksana Tugas
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
          <div class="form-group">
            <label class="form-label">Jabatan Pemberi Tugas</label>
            <div class="select-wrap">
              <select id="tugas_pemberi_preset" class="form-control form-select" onchange="onPemberiPresetChange()">
                <option value="">— Pilih jabatan —</option>
                <option value="Direktur Utama">Direktur Utama</option>
                <option value="Manajer Operasional">Manajer Operasional</option>
                <option value="HRD / Kepala SDM">HRD / Kepala SDM</option>
                <option value="lainnya">Lainnya...</option>
              </select>
            </div>
            <input type="text" id="tugas_pemberi_jabatan_custom" class="form-control" placeholder="Ketik jabatan..." style="margin-top:8px;display:none;">
          </div>
          <div class="form-group">
            <label class="form-label">Nama Pemberi Tugas</label>
            <input type="text" id="tugas_pemberi_nama" class="form-control" placeholder="Nama lengkap pemberi tugas...">
          </div>
        </div>

        <label class="form-label">Pelaksana Tugas <span style="font-size:11px;color:var(--gray-400);font-weight:400;">(bisa lebih dari satu orang)</span></label>
        <table class="dyn-table" id="tugasTable" style="margin-bottom:8px;">
          <thead>
            <tr>
              <th style="width:36px;">No.</th>
              <th>Nama Lengkap</th>
              <th style="width:200px;">Jabatan</th>
              <th style="width:36px;"></th>
            </tr>
          </thead>
          <tbody id="tugasBody"></tbody>
        </table>
        <button type="button" class="btn-add-row" onclick="addTugasRow()">+ Tambah Pelaksana</button>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px;">
          <div class="form-group">
            <label class="form-label">Jenis Tugas</label>
            <input type="text" id="tugas_jenis" class="form-control" placeholder="cth: Audit & Investigasi Internal">
          </div>
          <div class="form-group">
            <label class="form-label">Tujuan</label>
            <input type="text" id="tugas_tujuan" class="form-control" placeholder="cth: Investigasi Kepatuhan Operasional">
          </div>
          <div class="form-group">
            <label class="form-label">Lokasi Penugasan</label>
            <input type="text" id="tugas_lokasi" class="form-control" placeholder="cth: PT Maju Bersama, Jakarta Selatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Pelaksanaan</label>
            <input type="date" id="tugas_tanggal" class="form-control">
          </div>
          <div class="form-group" style="grid-column:span 2;">
            <label class="form-label">Waktu Pelaksanaan</label>
            <input type="text" id="tugas_waktu" class="form-control" placeholder="cth: 08.00 WIB s.d. selesai" value="08.00 WIB s.d. selesai">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT TUGAS PENDELEGASIAN                     -->
