<%- include('./partials/header') %>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
.ql-snow .ql-picker.ql-size .ql-picker-label::before,
.ql-snow .ql-picker.ql-size .ql-picker-item::before { content: attr(data-value) !important; }
.ql-size-10px { font-size: 10px; } .ql-size-12px { font-size: 12px; }
.ql-size-14px { font-size: 14px; } .ql-size-16px { font-size: 16px; }
.ql-size-18px { font-size: 18px; } .ql-size-20px { font-size: 20px; }
.ql-size-24px { font-size: 24px; } .ql-size-28px { font-size: 28px; }
.ql-size-32px { font-size: 32px; }
.ql-editor img { max-width: 100%; height: auto; border-radius: 4px; }

.jenis-tabs { display:flex; gap:0; border:1px solid var(--gray-200); border-radius:8px; overflow:hidden; margin-top:2px; }
.jenis-tab {
  flex:1; padding:9px 0; font-size:13px; font-weight:500; text-align:center; cursor:pointer;
  background:var(--gray-50); color:var(--gray-500); border:none; transition:all .15s;
  display:flex; align-items:center; justify-content:center; gap:6px;
}
.jenis-tab.active { background:#071840; color:#fff; }
.jenis-tab:first-child { border-right:1px solid var(--gray-200); }

.ext-recipient-input { display:flex; gap:8px; margin-bottom:8px; }
.ext-recipient-input input { flex:1; }
.ext-list { display:flex; flex-direction:column; gap:6px; }
.ext-item {
  display:flex; align-items:center; gap:8px;
  padding:7px 12px; border-radius:7px;
  background:var(--gray-50); border:1px solid var(--gray-200); font-size:13px;
}
.ext-item-name { font-weight:600; color:var(--gray-800); }
.ext-item-email { color:var(--gray-500); }
.ext-item-del { margin-left:auto; background:none; border:none; cursor:pointer; color:var(--gray-400); font-size:16px; line-height:1; }
.ext-item-del:hover { color:var(--red-500); }

.ql-container { font-family:'DM Sans',sans-serif; font-size:14px; border:1px solid var(--gray-200) !important; border-top:0 !important; border-radius:0 0 var(--radius-md) var(--radius-md) !important; }
.ql-toolbar { border:1px solid var(--gray-200) !important; border-radius:var(--radius-md) var(--radius-md) 0 0 !important; background:var(--gray-50); flex-wrap:wrap; }
.ql-editor { min-height:220px; line-height:1.8; color:var(--gray-800); padding:16px; }
.ql-editor.ql-blank::before { color:var(--gray-400); font-style:normal; font-size:13.5px; }
.ql-toolbar .ql-formats { margin-right:8px; margin-bottom:4px; }
.ql-snow .ql-picker { color:var(--gray-600); }
.ql-snow .ql-picker.ql-size { width:80px; }
.ql-snow .ql-picker.ql-font { width:110px; }

/* Tipe surat section badges */
.sec-header {
  display:flex; align-items:center; gap:8px; margin-bottom:12px;
  padding:8px 12px; background:var(--gray-50); border:1px solid var(--gray-200);
  border-radius:8px; font-size:13px; font-weight:600; color:var(--gray-600);
}
.sec-badge { font-size:10px; font-weight:700; padding:2px 7px; border-radius:4px; background:#071840; color:#fff; }

/* Dynamic row table */
.dyn-table { width:100%; border-collapse:collapse; margin-top:8px; }
.dyn-table th { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:var(--gray-500); padding:6px 8px; border-bottom:2px solid var(--gray-200); text-align:left; }
.dyn-table td { padding:5px 4px; vertical-align:middle; }
.dyn-table td input, .dyn-table td select { font-size:12.5px; padding:5px 8px; }
.dyn-row-del { background:none; border:none; cursor:pointer; color:var(--gray-400); font-size:16px; padding:2px 6px; }
.dyn-row-del:hover { color:var(--red-500); }
.btn-add-row { margin-top:6px; font-size:12px; padding:5px 12px; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:6px; cursor:pointer; color:var(--gray-600); }
.btn-add-row:hover { background:var(--gray-100); }

/* Dynamic list */
.dyn-list { display:flex; flex-direction:column; gap:6px; margin-top:8px; }
.dyn-list-item { display:flex; gap:8px; align-items:center; }
.dyn-list-item input { flex:1; font-size:13px; }
.dyn-list-item .item-num { font-size:12px; font-weight:700; color:var(--gray-500); min-width:24px; text-align:right; }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Tulis Surat</div>
    <h1 class="page-title">Tulis Surat</h1>
    <p class="page-subtitle">Buat dan kirimkan surat dinas baru</p>
  </div>
</div>

<form action="/compose" method="POST" id="composeForm">
  <input type="hidden" name="action" id="formAction" value="send">
  <input type="hidden" name="body" id="bodyHidden">
  <input type="hidden" name="jenis" id="jenisHidden" value="internal">
  <input type="hidden" name="externalRecipients" id="externalRecipientsHidden" value="[]">
  <input type="hidden" name="tipeSurat" id="tipeSuratHidden" value="Surat">
  <input type="hidden" name="suratData" id="suratDataHidden" value="{}">

<div class="compose-layout">
  <div class="compose-card">
    <div class="compose-card-header">
      <span class="compose-card-title">Detail Surat</span>
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:12px;color:var(--gray-400);">Sifat:</span>
        <select name="sifat" id="sifatSelect" class="admin-role-select" style="padding:5px 24px 5px 10px;font-size:12.5px;" onchange="updateSifat(this)">
          <option value="Biasa/Terbuka">Biasa / Terbuka</option>
          <option value="Terbatas">Terbatas</option>
          <option value="Rahasia">Rahasia</option>
          <option value="Segera">Segera</option>
        </select>
      </div>
    </div>
    <div class="compose-form">

      <!-- TIPE SURAT -->
      <div class="form-group">
        <label class="form-label">Tipe Surat <span class="req">*</span></label>
        <div class="select-wrap">
          <select id="tipeSuratSelect" class="form-control form-select" onchange="onTipeChange(this.value)">
            <optgroup label="— Surat Umum —">
              <option value="Surat">Surat (Biasa)</option>
              <option value="Surat Resmi">Surat Resmi</option>
              <option value="Surat Formal">Surat Formal</option>
              <option value="Surat Instruksi">Surat Instruksi</option>
              <option value="Surat Edaran">Surat Edaran</option>
            </optgroup>
            <optgroup label="— Surat Khusus —">
              <option value="Surat Rahasia">Surat Rahasia</option>
              <option value="Surat Konfidensial">Surat Konfidensial</option>
              <option value="Memo">Memo</option>
              <option value="Nota Dinas">Nota Dinas</option>
            </optgroup>
            <optgroup label="— Surat Tugas —">
              <option value="Surat Tugas">Surat Tugas (Perorangan)</option>
              <option value="Surat Tugas Pendelegasian">Surat Tugas Pendelegasian</option>
              <option value="SPPD">SPPD (Perjalanan Dinas)</option>
            </optgroup>
            <optgroup label="— Surat Otoritas —">
              <option value="Surat Keterangan">Surat Keterangan</option>
              <option value="Surat Pernyataan">Surat Pernyataan</option>
              <option value="Surat Kuasa">Surat Kuasa</option>
              <option value="Surat Pengantar">Surat Pengantar</option>
            </optgroup>
            <optgroup label="— Dokumen Keputusan —">
              <option value="Surat Keputusan">Surat Keputusan (SK)</option>
              <option value="Surat Undangan Dinas">Surat Undangan Dinas</option>
              <option value="Surat Statuta">Surat Statuta</option>
            </optgroup>
            <optgroup label="— Dokumen Perjanjian —">
              <option value="MOU">MOU (Memorandum of Understanding)</option>
              <option value="PKS">PKS (Perjanjian Kerjasama)</option>
              <option value="Kontrak">Surat Kontrak</option>
              <option value="SPK">SPK (Surat Perintah Kerja)</option>
            </optgroup>
          </select>
        </div>
      </div>

      <!-- SUBJEK / PERIHAL -->
      <div class="form-group">
        <label class="form-label" id="subjectLabel">Subjek / Perihal <span class="req">*</span></label>
        <input type="text" name="subject" id="subjectInput" class="form-control" placeholder="Perihal surat..." required>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Klasifikasi / Berkas</label>
          <div class="select-wrap">
            <select name="berkas" class="form-control form-select">
              <option value="">— Pilih Berkas —</option>
              <option value="OPS.01.02">OPS.01.02 — On Time Performance</option>
              <option value="OPS.01.03">OPS.01.03 — Analisis Runway Capacity</option>
              <option value="OPS.01.04">OPS.01.04 — Pemantauan Delay</option>
              <option value="OPS.02">OPS.02 — Collaborative Decision Making</option>
              <option value="OPS.03">OPS.03 — Air Traffic System</option>
              <option value="OPS.03.02">OPS.03.02 — Pembinaan Penggunaan Peralatan ATS</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tag / Prioritas</label>
          <div class="select-wrap">
            <select name="tag" class="form-control form-select">
              <option value="Normal">Normal</option>
              <option value="Penting">Penting</option>
              <option value="Urgent">Urgent</option>
              <option value="Info">Info</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: MEMO / NOTA DINAS                             -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-memo" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">MEMO / NOTA DINAS</span>
          Informasi Internal
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Kepada (Jabatan / Nama)</label>
            <input type="text" id="memo_kepada" class="form-control" placeholder="cth: Kepala Bagian Keuangan">
          </div>
          <div class="form-group">
            <label class="form-label">Klasifikasi</label>
            <div class="select-wrap">
              <select id="memo_klasifikasi" class="form-control form-select">
                <option value="">— Pilih —</option>
                <option value="RAHASIA">RAHASIA</option>
                <option value="TERBATAS">TERBATAS</option>
                <option value="BIASA">BIASA</option>
              </select>
            </div>
          </div>
        </div>
        <!-- Nota Dinas: tabel anggaran -->
        <div id="sec-nota-budget" style="display:none;">
          <label class="form-label" style="margin-top:4px;">Rincian Anggaran / Biaya Operasional</label>
          <table class="dyn-table" id="budgetTable">
            <thead>
              <tr>
                <th style="width:40px;">No.</th>
                <th>Uraian Kebutuhan</th>
                <th style="width:160px;">Jumlah (Rp)</th>
                <th style="width:36px;"></th>
              </tr>
            </thead>
            <tbody id="budgetBody"></tbody>
          </table>
          <button type="button" class="btn-add-row" onclick="addBudgetRow()">+ Tambah Baris</button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SPPD                                          -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-sppd" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SPPD</span>
          Data Perjalanan Dinas
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Pegawai</label>
            <input type="text" id="sppd_nama" class="form-control" placeholder="Nama lengkap pegawai">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="sppd_jabatan" class="form-control" placeholder="Jabatan pegawai">
          </div>
          <div class="form-group">
            <label class="form-label">Tingkat / Golongan</label>
            <input type="text" id="sppd_golongan" class="form-control" placeholder="cth: Senior">
          </div>
          <div class="form-group">
            <label class="form-label">Maksud Perjalanan</label>
            <input type="text" id="sppd_maksud" class="form-control" placeholder="cth: Audit & Investigasi Internal">
          </div>
          <div class="form-group">
            <label class="form-label">Alat Angkutan</label>
            <input type="text" id="sppd_angkutan" class="form-control" placeholder="cth: Kendaraan Dinas / Umum">
          </div>
          <div class="form-group">
            <label class="form-label">Tempat Berangkat</label>
            <input type="text" id="sppd_asal" class="form-control" placeholder="cth: Jakarta">
          </div>
          <div class="form-group">
            <label class="form-label">Tempat Tujuan</label>
            <input type="text" id="sppd_tujuan" class="form-control" placeholder="cth: PT Maju Bersama, Jakarta Selatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Berangkat</label>
            <input type="date" id="sppd_tgl_berangkat" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Kembali</label>
            <input type="date" id="sppd_tgl_kembali" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Mata Anggaran</label>
            <input type="text" id="sppd_mata_anggaran" class="form-control" placeholder="cth: Biaya Operasional 2026">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT TUGAS (PERORANGAN)                      -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-tugas" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SURAT TUGAS</span>
          Data Pelaksana & Tugas
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
          <div class="form-group">
            <label class="form-label">Jabatan Pemberi Tugas</label>
            <div class="select-wrap">
              <select id="tugas_pemberi_preset" class="form-control form-select" onchange="onPemberiPresetChange()">
                <option value="">— Pilih jabatan —</option>
                <option value="Direktur Utama">Direktur Utama</option>
                <option value="Manajer Operasional">Manajer Operasional</option>
                <option value="HRD / Kepala SDM">HRD / Kepala SDM</option>
                <option value="lainnya">Lainnya...</option>
              </select>
            </div>
            <input type="text" id="tugas_pemberi_jabatan_custom" class="form-control" placeholder="Ketik jabatan..." style="margin-top:8px;display:none;">
          </div>
          <div class="form-group">
            <label class="form-label">Nama Pemberi Tugas</label>
            <input type="text" id="tugas_pemberi_nama" class="form-control" placeholder="Nama lengkap pemberi tugas...">
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Yang Ditugaskan</label>
            <input type="text" id="tugas_nama" class="form-control" placeholder="Nama lengkap pelaksana">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="tugas_jabatan" class="form-control" placeholder="Jabatan pelaksana">
          </div>
          <div class="form-group">
            <label class="form-label">Jenis Tugas</label>
            <input type="text" id="tugas_jenis" class="form-control" placeholder="cth: Audit & Investigasi Internal">
          </div>
          <div class="form-group">
            <label class="form-label">Tujuan</label>
            <input type="text" id="tugas_tujuan" class="form-control" placeholder="cth: Investigasi Kepatuhan Operasional">
          </div>
          <div class="form-group">
            <label class="form-label">Lokasi Penugasan</label>
            <input type="text" id="tugas_lokasi" class="form-control" placeholder="cth: PT Maju Bersama, Jakarta Selatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Pelaksanaan</label>
            <input type="date" id="tugas_tanggal" class="form-control">
          </div>
          <div class="form-group" style="grid-column:span 2;">
            <label class="form-label">Waktu Pelaksanaan</label>
            <input type="text" id="tugas_waktu" class="form-control" placeholder="cth: 08.00 WIB s.d. selesai" value="08.00 WIB s.d. selesai">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT TUGAS PENDELEGASIAN                     -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-delegasi" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">PENDELEGASIAN</span>
          Data Pelaksana Delegasi
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Pelaksana Delegasi</label>
            <input type="text" id="del_nama" class="form-control" placeholder="Nama yang menerima delegasi">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan Pelaksana</label>
            <input type="text" id="del_jabatan" class="form-control" placeholder="Jabatan pelaksana delegasi">
          </div>
        </div>
        <label class="form-label" style="margin-top:4px;">Lingkup Pendelegasian</label>
        <div class="dyn-list" id="del_lingkup_list"></div>
        <button type="button" class="btn-add-row" onclick="addDelLingkup()">+ Tambah Lingkup</button>
        <label class="form-label" style="margin-top:12px;">Ketentuan Pendelegasian <span style="font-weight:400;color:var(--gray-400);">(opsional)</span></label>
        <div class="dyn-list" id="del_ketentuan_list"></div>
        <button type="button" class="btn-add-row" onclick="addDelKetentuan()">+ Tambah Ketentuan</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT KETERANGAN                              -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-keterangan" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">KETERANGAN</span>
          Data Pihak Yang Diterangkan
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama</label>
            <input type="text" id="ket_nama" class="form-control" placeholder="Nama yang diterangkan">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan / Posisi</label>
            <input type="text" id="ket_jabatan" class="form-control" placeholder="Jabatan dalam tim/instansi">
          </div>
          <div class="form-group">
            <label class="form-label">Tim / Kelompok <span style="font-weight:400;color:var(--gray-400);">(opsional)</span></label>
            <input type="text" id="ket_tim" class="form-control" placeholder="cth: Tim Mawar">
          </div>
          <div class="form-group">
            <label class="form-label">Keperluan / Penugasan</label>
            <input type="text" id="ket_keperluan" class="form-control" placeholder="cth: Audit Internal di PT Maju Bersama">
          </div>
          <div class="form-group">
            <label class="form-label">Lokasi</label>
            <input type="text" id="ket_lokasi" class="form-control" placeholder="cth: PT Maju Bersama, Jakarta Selatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal Pelaksanaan</label>
            <input type="date" id="ket_tanggal" class="form-control">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT PERNYATAAN                              -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-pernyataan" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">PERNYATAAN</span>
          Data Pembuat Pernyataan
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Yang Menyatakan</label>
            <input type="text" id="pry_nama" class="form-control" placeholder="Nama pembuat pernyataan">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="pry_jabatan" class="form-control" placeholder="Jabatan">
          </div>
          <div class="form-group">
            <label class="form-label">Tim / Instansi <span style="font-weight:400;color:var(--gray-400);">(opsional)</span></label>
            <input type="text" id="pry_tim" class="form-control" placeholder="cth: Tim Mawar">
          </div>
        </div>
        <label class="form-label" style="margin-top:4px;">Poin Pernyataan</label>
        <div class="dyn-list" id="pry_poin_list"></div>
        <button type="button" class="btn-add-row" onclick="addPryPoin()">+ Tambah Poin</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT KUASA                                   -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-kuasa" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SURAT KUASA</span>
          Data Penerima Kuasa
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Penerima Kuasa</label>
            <input type="text" id="kuasa_nama" class="form-control" placeholder="Nama penerima kuasa">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="kuasa_jabatan" class="form-control" placeholder="Jabatan penerima kuasa">
          </div>
        </div>
        <label class="form-label" style="margin-top:4px;">Ruang Lingkup Kuasa</label>
        <div class="dyn-list" id="kuasa_lingkup_list"></div>
        <button type="button" class="btn-add-row" onclick="addKuasaLingkup()">+ Tambah Lingkup</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT PENGANTAR                               -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-pengantar" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">PENGANTAR</span>
          Daftar Dokumen / Barang yang Dikirim
        </div>
        <div class="form-group">
          <label class="form-label">Ditujukan Kepada</label>
          <input type="text" id="peng_kepada" class="form-control" placeholder="cth: Pimpinan PT Maju Bersama, Jakarta Selatan">
        </div>
        <table class="dyn-table" id="pengantarTable">
          <thead>
            <tr>
              <th style="width:36px;">No.</th>
              <th>Nama Dokumen / Barang</th>
              <th style="width:110px;">Jumlah</th>
              <th style="width:120px;">Keterangan</th>
              <th style="width:36px;"></th>
            </tr>
          </thead>
          <tbody id="pengantarBody"></tbody>
        </table>
        <button type="button" class="btn-add-row" onclick="addPengantarRow()">+ Tambah Dokumen</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT KEPUTUSAN                               -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-keputusan" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SK</span>
          Konsiderans &amp; Diktum
        </div>
        <label class="form-label">Menimbang</label>
        <div class="dyn-list" id="sk_menimbang_list"></div>
        <button type="button" class="btn-add-row" onclick="addSkItem('menimbang')">+ Tambah Poin Menimbang</button>

        <label class="form-label" style="margin-top:12px;">Mengingat</label>
        <div class="dyn-list" id="sk_mengingat_list"></div>
        <button type="button" class="btn-add-row" onclick="addSkItem('mengingat')">+ Tambah Poin Mengingat</button>

        <label class="form-label" style="margin-top:12px;">Memutuskan / Menetapkan</label>
        <div class="dyn-list" id="sk_memutuskan_list"></div>
        <button type="button" class="btn-add-row" onclick="addSkItem('memutuskan')">+ Tambah Poin Keputusan</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT UNDANGAN DINAS                          -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-undangan" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">UNDANGAN</span>
          Detail Acara / Rapat
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Hari / Tanggal</label>
            <input type="date" id="und_tanggal" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Waktu</label>
            <input type="text" id="und_waktu" class="form-control" placeholder="cth: 09.00 WIB s.d. selesai" value="09.00 WIB s.d. selesai">
          </div>
          <div class="form-group">
            <label class="form-label">Tempat</label>
            <input type="text" id="und_tempat" class="form-control" placeholder="cth: Ruang Rapat Lantai 3">
          </div>
          <div class="form-group">
            <label class="form-label">Pakaian</label>
            <input type="text" id="und_pakaian" class="form-control" placeholder="cth: Formal / Batik" value="Formal / Batik">
          </div>
          <div class="form-group" style="grid-column:span 2;">
            <label class="form-label">Agenda</label>
            <input type="text" id="und_agenda" class="form-control" placeholder="cth: Briefing & Koordinasi Tim">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SURAT STATUTA                                 -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-statuta" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">STATUTA</span>
          Data Organisasi / Tim
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group" style="grid-column:span 2;">
            <label class="form-label">Nama Organisasi / Tim</label>
            <input type="text" id="sta_nama_org" class="form-control" placeholder="cth: TIM MAWAR">
          </div>
          <div class="form-group" style="grid-column:span 2;">
            <label class="form-label">Visi <span style="font-weight:400;color:var(--gray-400);">(opsional)</span></label>
            <input type="text" id="sta_visi" class="form-control" placeholder="Pernyataan visi...">
          </div>
        </div>
        <label class="form-label" style="margin-top:4px;">Misi <span style="font-weight:400;color:var(--gray-400);">(opsional)</span></label>
        <div class="dyn-list" id="sta_misi_list"></div>
        <button type="button" class="btn-add-row" onclick="addStaMisi()">+ Tambah Misi</button>
        <label class="form-label" style="margin-top:12px;">Susunan Keanggotaan</label>
        <table class="dyn-table" id="staAnggotaTable">
          <thead>
            <tr>
              <th style="width:36px;">No.</th>
              <th>Nama</th>
              <th style="width:220px;">Jabatan dalam Tim</th>
              <th style="width:36px;"></th>
            </tr>
          </thead>
          <tbody id="staAnggotaBody"></tbody>
        </table>
        <button type="button" class="btn-add-row" onclick="addStaAnggota()">+ Tambah Anggota</button>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: STANDARD LETTER RECIPIENT                     -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-surat-ext" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">PENERIMA</span>
          Identitas Penerima Surat <span style="font-weight:400;color:var(--gray-400);font-size:12px;">(opsional, untuk surat eksternal)</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Jabatan Penerima</label>
            <input type="text" id="std_jabatan" class="form-control" placeholder="cth: Direktur Utama">
          </div>
          <div class="form-group">
            <label class="form-label">Instansi / Perusahaan</label>
            <input type="text" id="std_instansi" class="form-control" placeholder="cth: PT Maju Bersama">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Alamat Penerima</label>
          <input type="text" id="std_alamat" class="form-control" placeholder="cth: Jl. Gatot Subroto Kav. 51, Jakarta Selatan">
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: MOU / PKS / KONTRAK                           -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-pihak-kedua" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">PIHAK KEDUA</span>
          Data Pihak Kedua
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Perwakilan</label>
            <input type="text" id="p2_nama" class="form-control" placeholder="Nama perwakilan pihak kedua">
          </div>
          <div class="form-group">
            <label class="form-label">Jabatan</label>
            <input type="text" id="p2_jabatan" class="form-control" placeholder="Jabatan pihak kedua">
          </div>
          <div class="form-group">
            <label class="form-label">Instansi / Perusahaan</label>
            <input type="text" id="p2_instansi" class="form-control" placeholder="cth: PT Maju Bersama">
          </div>
          <div class="form-group">
            <label class="form-label">Alamat</label>
            <input type="text" id="p2_alamat" class="form-control" placeholder="Alamat instansi pihak kedua">
          </div>
        </div>
        <div id="sec-nilai-kontrak" style="display:none;">
          <div class="form-group">
            <label class="form-label">Nilai Kontrak (Rp)</label>
            <input type="text" id="p2_nilai" class="form-control" placeholder="cth: 50.000.000">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- SECTION: SPK                                           -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div id="sec-spk" style="display:none;">
        <div class="sec-header">
          <span class="sec-badge">SPK</span>
          Data Pelaksana &amp; Pekerjaan
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="form-group">
            <label class="form-label">Nama Tim</label>
            <input type="text" id="spk_tim" class="form-control" placeholder="cth: TIM MAWAR">
          </div>
          <div class="form-group">
            <label class="form-label">Ketua Tim</label>
            <input type="text" id="spk_ketua" class="form-control" placeholder="Nama ketua tim">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Anggota Tim</label>
          <input type="text" id="spk_anggota" class="form-control" placeholder="cth: Nama 1, Nama 2, Nama 3">
        </div>
        <label class="form-label" style="margin-top:4px;">Rincian Pekerjaan</label>
        <table class="dyn-table" id="spkTable">
          <thead>
            <tr>
              <th style="width:40px;">No.</th>
              <th>Uraian Pekerjaan</th>
              <th style="width:130px;">Keterangan</th>
              <th style="width:36px;"></th>
            </tr>
          </thead>
          <tbody id="spkBody"></tbody>
        </table>
        <button type="button" class="btn-add-row" onclick="addSpkRow()">+ Tambah Pekerjaan</button>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:12px;">
          <div class="form-group">
            <label class="form-label">Lokasi</label>
            <input type="text" id="spk_lokasi" class="form-control" placeholder="Alamat lokasi">
          </div>
          <div class="form-group">
            <label class="form-label">Tanggal</label>
            <input type="date" id="spk_tanggal" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Waktu</label>
            <input type="text" id="spk_waktu" class="form-control" placeholder="cth: 08.00 WIB s.d. selesai">
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════ -->
      <!-- JENIS SURAT (Internal / Eksternal)                     -->
      <!-- ═══════════════════════════════════════════════════════ -->
      <div class="form-group">
        <label class="form-label">Jenis Surat</label>
        <div class="jenis-tabs">
          <button type="button" class="jenis-tab active" id="tabInternal" onclick="setJenis('internal')">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 2a6 6 0 100 12A6 6 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M4 18c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Internal (Pengguna Terdaftar)
          </button>
          <button type="button" class="jenis-tab" id="tabEksternal" onclick="setJenis('eksternal')">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M2 10h16M10 2c-2 2.5-3 5-3 8s1 5.5 3 8M10 2c2 2.5 3 5 3 8s-1 5.5-3 8" stroke="currentColor" stroke-width="1.5"/></svg>
            Eksternal (Email Bebas)
          </button>
        </div>
      </div>

      <!-- INTERNAL section -->
      <div id="internalSection">
        <div class="form-group">
          <label class="form-label">Tertuju (Penerima Internal)</label>
          <div class="multi-select-wrap" id="tertujuWrap">
            <div class="multi-select-input" id="tertujuInput" onclick="toggleDropdown('tertuju')">
              <span class="multi-placeholder" id="tertujuPlaceholder">Pilih penerima...</span>
              <div class="selected-tags" id="tertujuTags"></div>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;color:var(--gray-400);margin-left:auto;"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="multi-dropdown" id="tertujuDropdown">
              <div style="padding:8px;border-bottom:1px solid var(--gray-100);">
                <input type="text" class="form-control" placeholder="Cari pengguna..." style="padding:7px 10px;font-size:13px;" oninput="searchDropdown('tertuju',this.value)">
              </div>
              <% if (users.length === 0) { %>
              <div style="padding:12px 14px;color:var(--gray-400);font-size:13px;">Belum ada pengguna lain terdaftar.</div>
              <% } else { %>
              <div class="dropdown-group-label">Pengguna Terdaftar</div>
              <% users.forEach(u => { %>
              <label class="dropdown-opt" data-search="<%= u.name.toLowerCase() %> <%= u.email.toLowerCase() %>">
                <input type="checkbox" name="to" value="<%= u._id %>" onchange="toggleTag('tertuju',this,'<%= u.name %>')">
                <div>
                  <div style="font-size:13.5px;color:var(--gray-800);"><%= u.name %></div>
                  <div style="font-size:11.5px;color:var(--gray-400);"><%= u.email %> · <%= u.organization %></div>
                </div>
              </label>
              <% }) %>
              <% } %>
            </div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Tembusan / CC</label>
          <div class="multi-select-wrap" id="tembusanWrap">
            <div class="multi-select-input" id="tembusanInput" onclick="toggleDropdown('tembusan')">
              <span class="multi-placeholder" id="tembusanPlaceholder">Pilih tembusan...</span>
              <div class="selected-tags" id="tembusanTags"></div>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;color:var(--gray-400);margin-left:auto;"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="multi-dropdown" id="tembusanDropdown">
              <div style="padding:8px;border-bottom:1px solid var(--gray-100);">
                <input type="text" class="form-control" placeholder="Cari pengguna..." style="padding:7px 10px;font-size:13px;" oninput="searchDropdown('tembusan',this.value)">
              </div>
              <% if (users.length === 0) { %>
              <div style="padding:12px 14px;color:var(--gray-400);font-size:13px;">Belum ada pengguna lain.</div>
              <% } else { %>
              <div class="dropdown-group-label">Pengguna Terdaftar</div>
              <% users.forEach(u => { %>
              <label class="dropdown-opt" data-search="<%= u.name.toLowerCase() %> <%= u.email.toLowerCase() %>">
                <input type="checkbox" name="cc" value="<%= u._id %>" onchange="toggleTag('tembusan',this,'<%= u.name %>')">
                <div>
                  <div style="font-size:13.5px;color:var(--gray-800);"><%= u.name %></div>
                  <div style="font-size:11.5px;color:var(--gray-400);"><%= u.email %> · <%= u.organization %></div>
                </div>
              </label>
              <% }) %>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- EKSTERNAL section -->
      <div id="eksternalSection" style="display:none;">
        <div class="form-group">
          <label class="form-label">Tambah Penerima Eksternal</label>
          <div class="ext-recipient-input">
            <input type="text" id="extName" class="form-control" placeholder="Nama penerima" style="max-width:220px;">
            <input type="email" id="extEmail" class="form-control" placeholder="email@domain.com">
            <button type="button" class="btn btn-secondary" onclick="addExt()" style="white-space:nowrap;padding:8px 16px;">+ Tambah</button>
          </div>
          <div class="ext-list" id="extList"></div>
          <div id="extEmpty" style="font-size:12.5px;color:var(--gray-400);padding:6px 0;">Belum ada penerima. Tambahkan di atas.</div>
        </div>
      </div>

      <!-- ISI SURAT (Quill) -->
      <div class="form-group" id="bodySection">
        <label class="form-label" id="bodyLabel">Isi Surat / Catatan Tambahan</label>
        <div id="quillEditor" style="min-height:200px;"></div>
      </div>

      <div class="compose-actions">
        <button type="button" class="btn btn-ghost" onclick="submitForm('draft')">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2h10v10H2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M4 5h6M4 7h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Simpan Draf
        </button>
        <button type="button" class="btn btn-primary" onclick="submitForm('send')">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M13 1L6 8M13 1l-4 11-3-5-5-3 12-3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Lanjut ke Preview &amp; Tanda Tangan
        </button>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="compose-sidebar">
    <div class="info-card">
      <div class="info-card-title">Info Naskah</div>
      <div class="info-item"><span class="info-key">Pengirim</span><span class="info-val"><%= user.name.split(' ')[0] %></span></div>
      <div class="info-item"><span class="info-key">Tipe</span><span class="info-val" id="infoTipe">Surat</span></div>
      <div class="info-item"><span class="info-key">Status</span><span class="info-val" style="color:var(--amber-600);">Konsep</span></div>
      <div class="info-item"><span class="info-key">Tanggal</span><span class="info-val" id="infoDate"></span></div>
      <div class="info-item"><span class="info-key">Sifat</span><span class="info-val" id="infoSifat">Biasa/Terbuka</span></div>
      <div class="info-item" style="border-bottom:none;"><span class="info-key">Penomoran</span><span class="info-val">Otomatis</span></div>
    </div>
    <div class="info-card">
      <div class="info-card-title">Tipe Surat Tersedia</div>
      <ul style="font-size:12px;color:var(--gray-500);line-height:2;padding-left:16px;">
        <li>Surat Biasa, Resmi, Formal</li>
        <li>Memo, Nota Dinas</li>
        <li>Surat Tugas, SPPD</li>
        <li>Surat Kuasa, Keterangan</li>
        <li>Surat Keputusan (SK)</li>
        <li>Undangan, Pengantar</li>
        <li>Rahasia, Konfidensial</li>
      </ul>
    </div>
    <div class="info-card">
      <div class="info-card-title">Petunjuk</div>
      <ul style="font-size:12.5px;color:var(--gray-600);line-height:1.9;padding-left:16px;">
        <li>Pilih tipe surat di bagian atas</li>
        <li>Field tambahan muncul otomatis</li>
        <li>Kolom wajib bertanda <span style="color:var(--red-500);">*</span></li>
        <li>Nomor surat dibuat otomatis</li>
      </ul>
    </div>
  </div>
</div>
</form>

<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
// ── DATE ──
const today = new Date();
const mns = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
document.getElementById('infoDate').textContent = `${today.getDate()} ${mns[today.getMonth()]} ${today.getFullYear()}`;

// ── QUILL ──
const SizeStyle = Quill.import('attributors/style/size');
SizeStyle.whitelist = ['10px','12px','14px','16px','18px','20px','24px','28px','32px'];
Quill.register(SizeStyle, true);
const quill = new Quill('#quillEditor', {
  theme: 'snow',
  placeholder: 'Tulis isi surat / instruksi tambahan di sini...',
  modules: {
    toolbar: {
      container: [
        [{ font: [] }, { size: ['10px','12px','14px','16px','18px','20px','24px','28px','32px'] }],
        [{ header: [1,2,3,4,false] }],
        ['bold','italic','underline','strike'],
        [{ color: [] }, { background: [] }],
        ['blockquote','code-block'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        [{ indent: '-1' }, { indent: '+1' }],
        [{ align: [] }],
        ['link','image'],
        ['clean']
      ],
      handlers: { image: imageHandler }
    }
  }
});
function imageHandler() {
  const input = document.createElement('input');
  input.setAttribute('type','file'); input.setAttribute('accept','image/*'); input.click();
  input.onchange = () => {
    const file = input.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = e => { const r = quill.getSelection(true); quill.insertEmbed(r.index,'image',e.target.result); quill.setSelection(r.index+1); };
    reader.readAsDataURL(file);
  };
}

// ── SIFAT ──
function updateSifat(sel) { document.getElementById('infoSifat').textContent = sel.value; }

// ── TIPE SURAT ──
let currentTipe = 'Surat';
const ALL_SECS = ['sec-memo','sec-sppd','sec-tugas','sec-delegasi','sec-keterangan','sec-pernyataan','sec-kuasa','sec-pengantar','sec-keputusan','sec-undangan','sec-statuta','sec-surat-ext','sec-pihak-kedua','sec-spk'];
const TIPE_SECS = {
  'Surat':['sec-surat-ext'],  'Surat Resmi':['sec-surat-ext'],  'Surat Formal':['sec-surat-ext'],
  'Surat Instruksi':['sec-surat-ext'],  'Surat Edaran':[],
  'Surat Rahasia':['sec-surat-ext'], 'Surat Konfidensial':['sec-surat-ext'],
  'Memo':['sec-memo'], 'Nota Dinas':['sec-memo'],
  'SPPD':['sec-sppd'],
  'Surat Tugas':['sec-tugas'],
  'Surat Tugas Pendelegasian':['sec-delegasi'],
  'Surat Keterangan':['sec-keterangan'],
  'Surat Pernyataan':['sec-pernyataan'],
  'Surat Kuasa':['sec-kuasa'],
  'Surat Pengantar':['sec-pengantar'],
  'Surat Keputusan':['sec-keputusan'],
  'Surat Undangan Dinas':['sec-undangan'],
  'Surat Statuta':['sec-statuta'],
  'MOU':['sec-pihak-kedua'],
  'PKS':['sec-pihak-kedua'],
  'Kontrak':['sec-pihak-kedua'],
  'SPK':['sec-spk'],
};
const BODY_PLACEHOLDER = {
  'Surat': 'Tulis isi surat di sini...',
  'Surat Resmi': 'Tulis isi surat resmi di sini...',
  'Surat Formal': 'Tulis isi surat formal di sini...',
  'Surat Instruksi': 'Tulis instruksi-instruksi di sini...',
  'Surat Edaran': 'Tulis poin-poin edaran di sini...',
