// Dynamic list helpers
function addListItem(listId, placeholder) {
  const list = document.getElementById(listId);
  const idx = list.children.length + 1;
  const div = document.createElement('div'); div.className = 'dyn-list-item';
  div.innerHTML = `<span class="item-num">${idx}.</span>
    <input type="text" class="form-control" placeholder="${placeholder}">
    <button type="button" class="dyn-row-del" onclick="this.parentElement.remove();renumberList('${listId}')">×</button>`;
  list.appendChild(div);
}
function renumberList(listId) {
  Array.from(document.getElementById(listId).children).forEach((item, i) => {
    const num = item.querySelector('.item-num'); if(num) num.textContent = (i+1)+'.';
  });
}
// Delegation lingkup
function addDelLingkup() { addListItem('del_lingkup_list','Lingkup pendelegasian...'); }
function addDelKetentuan() { addListItem('del_ketentuan_list','Ketentuan pendelegasian...'); }
// Pernyataan poin
function addPryPoin() { addListItem('pry_poin_list','Pernyataan nomor '+(document.getElementById('pry_poin_list').children.length+1)+'...'); }
// Kuasa lingkup
function addKuasaLingkup() { addListItem('kuasa_lingkup_list','Ruang lingkup kuasa...'); }
// SK items
function addSkItem(type) { addListItem('sk_'+type+'_list','Poin '+type+'...'); }
// Statuta misi
function addStaMisi() { addListItem('sta_misi_list','Pernyataan misi...'); }
// SPK rows
let spkRows = [];
function addSpkRow() {
  const id = 'spk_' + Date.now();
  spkRows.push(id);
  const idx = spkRows.length;
  const tr = document.createElement('tr');
  tr.id = 'spkrow_' + id;
  tr.innerHTML = `<td style="text-align:center;padding:6px 4px;">${idx}</td>
    <td><input type="text" id="spk_uraian_${id}" class="form-control" placeholder="Uraian pekerjaan..."></td>
