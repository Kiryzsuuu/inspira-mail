<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inspira Mailer — <%= title %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-shell">
  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="brand">
        <div class="brand-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <rect width="22" height="22" rx="7" fill="white"/>
            <path d="M4 7.5L11 12L18 7.5" stroke="#1a6b4a" stroke-width="1.8" stroke-linecap="round"/>
            <rect x="4" y="6" width="14" height="10" rx="2" stroke="#1a6b4a" stroke-width="1.8" fill="none"/>
          </svg>
        </div>
        <div class="brand-text">
          <span class="brand-name">Inspira</span>
          <span class="brand-sub">Mailer</span>
        </div>
      </div>
      <button class="sidebar-close" id="sidebarClose" aria-label="Tutup sidebar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="compose-btn-wrap">
      <a href="/compose" class="compose-btn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Tulis Surat
      </a>
    </div>

    <nav class="sidebar-nav">
      <a href="/inbox" class="nav-item <%= active === 'inbox' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Kotak Masuk
        <span class="badge">2</span>
      </a>
      <a href="/sent" class="nav-item <%= active === 'sent' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Terkirim
      </a>
      <a href="/draft" class="nav-item <%= active === 'draft' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 14l2-2 2 2-2 2-2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Draf
        <span class="badge badge-muted">1</span>
      </a>
      <div class="nav-divider"></div>
      <a href="#" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 8v4M10 14h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Digsig
      </a>
      <a href="#" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M10 3a7 7 0 100 14A7 7 0 0010 3z" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Short URL
      </a>
      <a href="#" class="nav-item">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none"><path d="M9 5H7a2 2 0 00-2 2v8a2 2 0 002 2h6a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h0a2 2 0 002-2M9 5a2 2 0 012-2h0a2 2 0 012 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Tugas
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="user-info">
        <div class="user-avatar">AZ</div>
        <div class="user-details">
          <span class="user-name">M. Azwar Zulmi</span>
          <span class="user-role">Inspira Tekno</span>
        </div>
        <button class="user-menu-btn" aria-label="Menu pengguna">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </aside>

  <!-- Overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- Main content -->
  <main class="main-content">
    <!-- Top bar -->
    <header class="topbar">
      <button class="hamburger" id="hamburger" aria-label="Buka menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
      <div class="topbar-search">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10.5 10.5L13 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <input type="text" placeholder="Cari naskah dinas..." class="search-input">
        <kbd class="search-kbd">⌘K</kbd>
      </div>
      <div class="topbar-actions">
        <button class="topbar-btn" aria-label="Notifikasi">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2a5.5 5.5 0 015.5 5.5c0 3 1.5 4.5 1.5 4.5H2s1.5-1.5 1.5-4.5A5.5 5.5 0 019 2z" stroke="currentColor" stroke-width="1.5"/><path d="M7.5 14.5a1.5 1.5 0 003 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="notif-dot"></span>
        </button>
        <div class="topbar-avatar">AZ</div>
      </div>
    </header>

    <!-- Page body -->
    <div class="page-body">
      <%- body %>
    </div>
  </main>
</div>

<script src="/js/app.js"></script>
</body>
</html>
