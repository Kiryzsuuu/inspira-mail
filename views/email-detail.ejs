<%- include('./partials/header') %>

<%
const tagClass = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
const sifatColor = { 'Biasa/Terbuka':'var(--green-600)','Rahasia':'#9333ea','Terbatas':'var(--amber-600)','Segera':'var(--red-600)' };
const sifatBg    = { 'Biasa/Terbuka':'var(--green-50)','Rahasia':'#faf5ff','Terbatas':'var(--amber-50)','Segera':'var(--red-50)' };
const roleLabel  = { superadmin:'Super Admin', admin:'Admin', direktur:'Direktur', user:'Pengguna' };
%>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb">
      <a href="/inbox">Dashboard</a> /
      <a href="<%= isSender ? '/sent' : '/inbox' %>"><%= isSender ? 'Terkirim' : 'Kotak Masuk' %></a> / Detail
    </div>
    <h1 class="page-title"><%= email.subject %></h1>
    <p class="page-subtitle">No. <%= email.nomorSurat %></p>
  </div>
  <div class="page-actions">
    <% if (isSender && email.status === 'draft') { %>
    <a href="/email/<%= email._id %>/preview" class="btn btn-primary">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M13 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Preview &amp; Kirim
    </a>
    <% } %>
    <span class="mail-tag <%= tagClass[email.tag] || 'tag-normal' %>" style="font-size:13px;padding:5px 14px;">
      <%= email.tag %>
    </span>
    <% if (currentUser && currentUser.role === 'superadmin') { %>
    <button class="btn btn-secondary" style="color:var(--red-500);" onclick="openAdminDelete()">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Hapus (Admin)
    </button>
    <% } %>
  </div>
</div>

<% if (currentUser && currentUser.role === 'superadmin') { %>
<!-- Modal Konfirmasi Delete Admin -->
<div id="adminDeleteOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:28px 32px;width:460px;max-width:95vw;box-shadow:0 20px 60px rgba(0,0,0,.2);">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:6px;">Hapus Dokumen</div>
    <div style="font-size:13px;color:var(--gray-500);margin-bottom:18px;">
      Isi surat akan dihapus permanen, namun <strong>nomor surat tetap dipertahankan</strong> sebagai rekam jejak. Tindakan ini tidak dapat dibatalkan.
    </div>
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:12px 14px;margin-bottom:18px;font-size:13px;color:#991b1b;">
      Ketik ulang nomor surat untuk konfirmasi:<br>
      <strong style="font-family:monospace;font-size:14px;"><%= email.nomorSurat || '(tanpa nomor)' %></strong>
    </div>
    <input type="text" id="deleteKonfirmasi" class="form-control" placeholder="Ketik nomor surat di sini..." autocomplete="off"
      style="font-family:monospace;font-size:14px;margin-bottom:16px;" oninput="checkDeleteMatch()">
    <div style="display:flex;justify-content:flex-end;gap:10px;">
      <button class="btn btn-ghost" onclick="document.getElementById('adminDeleteOverlay').style.display='none'">Batal</button>
      <button id="btnConfirmDelete" class="btn btn-primary" style="background:var(--red-500);opacity:.4;cursor:not-allowed;" disabled onclick="doAdminDelete()">
        Hapus Permanen
      </button>
    </div>
  </div>
</div>

<script>
function openAdminDelete() {
  document.getElementById('deleteKonfirmasi').value = '';
  document.getElementById('btnConfirmDelete').disabled = true;
  document.getElementById('btnConfirmDelete').style.opacity = '.4';
  document.getElementById('btnConfirmDelete').style.cursor = 'not-allowed';
  document.getElementById('adminDeleteOverlay').style.display = 'flex';
}
function checkDeleteMatch() {
  const val    = document.getElementById('deleteKonfirmasi').value.trim();
  const nomor  = '<%= (email.nomorSurat||"").replace(/'/g,"\\'") %>';
  const ok     = val === nomor;
  const btn    = document.getElementById('btnConfirmDelete');
  btn.disabled = !ok;
  btn.style.opacity = ok ? '1' : '.4';
  btn.style.cursor  = ok ? 'pointer' : 'not-allowed';
}
async function doAdminDelete() {
  const konfirmasi = document.getElementById('deleteKonfirmasi').value.trim();
  try {
    const res  = await fetch('/email/<%= email._id %>/admin-delete', {
      method: 'DELETE', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ konfirmasi })
    });
    const data = await res.json();
    if (data.ok) {
      document.getElementById('adminDeleteOverlay').style.display = 'none';
      alert(`Surat No. ${data.nomorSurat} berhasil dihapus. Nomor surat tetap tercatat dalam sistem.`);
      window.location.href = '/sent';
    } else {
      alert(data.message || 'Gagal menghapus.');
    }
  } catch(e) { alert('Terjadi kesalahan.'); }
}
// Klik overlay tutup modal
document.getElementById('adminDeleteOverlay').addEventListener('click', function(e) {
  if (e.target === this) this.style.display = 'none';
});
</script>
<% } %>

<div class="ag-detail-layout">

  <!-- Kiri: Isi surat -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <div class="compose-card">
      <div class="compose-card-header">
        <span class="compose-card-title">Isi Surat</span>
        <span style="font-size:11.5px;font-weight:600;padding:3px 12px;border-radius:20px;background:<%= sifatBg[email.sifat]||'var(--green-50)' %>;color:<%= sifatColor[email.sifat]||'var(--green-600)' %>;">
          <%= email.sifat %>
        </span>
      </div>
      <div style="padding:24px 28px;">

        <!-- Meta -->
        <%
          const jabatanMap = {};
          users.forEach(function(u){ jabatanMap[u._id.toString()] = u.jabatan || ''; });
          function renderPerson(r) {
            const key = r.userId ? r.userId.toString() : '';
            const jab = jabatanMap[key] || r.jabatan || '';
            return `<span style="font-weight:500;">${r.name}</span>${jab ? `<span style="color:var(--gray-400);font-size:12px;"> — ${jab}</span>` : ''}`;
          }
        %>
        <div style="display:grid;grid-template-columns:100px 1fr;gap:0;margin-bottom:20px;font-size:13px;">
          <div style="color:var(--gray-400);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:7px 0;border-bottom:1px solid var(--gray-100);">Dari</div>
          <div style="padding:7px 0;border-bottom:1px solid var(--gray-100);color:var(--gray-800);">
            <%- renderPerson(email.from) %>
          </div>

          <div style="color:var(--gray-400);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:7px 0;border-bottom:1px solid var(--gray-100);">Kepada</div>
          <div style="padding:7px 0;border-bottom:1px solid var(--gray-100);color:var(--gray-800);">
            <% if (email.jenis === 'eksternal' && email.toExternal && email.toExternal.length > 0) { %>
              <% email.toExternal.forEach(function(r, i) { %>
                <span style="font-weight:500;"><%= r.name %></span><% if(r.jabatan){ %><span style="color:var(--gray-400);font-size:12px;"> — <%= r.jabatan %></span><% } %><% if(i < email.toExternal.length-1){ %>, <% } %>
              <% }) %>
            <% } else { %>
              <% email.to.forEach(function(r, i) { %>
                <%- renderPerson(r) %><% if (i < email.to.length - 1) { %>, <% } %>
              <% }) %>
            <% } %>
          </div>

          <% if (email.cc && email.cc.length > 0) { %>
          <div style="color:var(--gray-400);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:7px 0;border-bottom:1px solid var(--gray-100);">CC</div>
          <div style="padding:7px 0;border-bottom:1px solid var(--gray-100);color:var(--gray-800);">
            <% email.cc.forEach(function(r, i) { %>
              <%- renderPerson(r) %><% if (i < email.cc.length - 1) { %>, <% } %>
            <% }) %>
          </div>
          <% } %>

          <div style="color:var(--gray-400);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:7px 0;border-bottom:1px solid var(--gray-100);">Tanggal</div>
          <div style="padding:7px 0;border-bottom:1px solid var(--gray-100);color:var(--gray-800);"><%= new Date(email.createdAt).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) %></div>

          <% if (email.berkas) { %>
          <div style="color:var(--gray-400);font-weight:600;font-size:11.5px;text-transform:uppercase;letter-spacing:.4px;padding:7px 0;">Berkas</div>
          <div style="padding:7px 0;color:var(--gray-800);"><%= email.berkas %></div>
          <% } %>
        </div>

        <!-- Body -->
        <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius-md);padding:20px 24px;font-size:14px;line-height:1.8;color:var(--gray-700);min-height:120px;">
          <%- email.body || '<em style="color:var(--gray-400);">Tidak ada isi surat.</em>' %>
        </div>
        <% if (email.lampiran) {
          const lamExt = (email.lampiranNama || email.lampiran).split('.').pop().toLowerCase();
          const isImg  = ['jpg','jpeg','png','gif','webp'].includes(lamExt);
          const isPdf  = lamExt === 'pdf';
        %>
        <div style="margin-top:12px;border:1px solid #dbeafe;border-radius:8px;overflow:hidden;">
          <!-- Header bar -->
          <div style="padding:10px 14px;background:#f8faff;display:flex;align-items:center;gap:10px;">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M13 2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7l-4-5z" stroke="#3b82f6" stroke-width="1.5" stroke-linejoin="round"/><path d="M13 2v5h5" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/></svg>
            <div style="flex:1;font-size:13px;color:var(--gray-700);"><strong>Lampiran:</strong> <%= email.lampiranNama || 'File terlampir' %></div>
            <a href="<%= email.lampiran %>" target="_blank" class="btn btn-secondary" style="padding:4px 12px;font-size:12px;">
              <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M5 9l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 17h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              Unduh
            </a>
            <a href="<%= email.lampiran %>" target="_blank" class="btn btn-primary" style="padding:4px 12px;font-size:12px;">
              <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
              Lihat
            </a>
          </div>
          <!-- Preview inline -->
          <% if (isImg) { %>
          <div style="padding:12px;background:#fff;text-align:center;">
            <img src="<%= email.lampiran %>" alt="<%= email.lampiranNama %>"
              style="max-width:100%;max-height:500px;border-radius:6px;object-fit:contain;cursor:pointer;"
              onclick="window.open(this.src,'_blank')">
          </div>
          <% } else if (isPdf) { %>
          <div style="background:#fff;">
            <iframe src="<%= email.lampiran %>" style="width:100%;height:480px;border:none;" title="<%= email.lampiranNama %>"></iframe>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- QR Tanda Tangan -->
    <% if (docSig && docSig.signers && docSig.signers.length > 0) { %>
    <div class="compose-card">
      <div class="compose-card-header">
        <span class="compose-card-title">Tanda Tangan Digital</span>
        <span style="font-size:12px;color:var(--green-600);font-weight:500;display:flex;align-items:center;gap:4px;">
          <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <%= docSig.signers.length %> penandatangan
        </span>
      </div>
      <div style="padding:16px 24px;display:flex;flex-wrap:wrap;gap:20px;">
        <% docSig.signers.forEach(function(s) {
          const inits = s.userName.split(' ').slice(0,2).map(w=>w[0]||'').join('').toUpperCase();
          const rl = roleLabel[s.userRole] || s.userOrg || '';
        %>
        <div style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px;border:1px solid var(--gray-200);border-radius:var(--radius-md);background:var(--gray-50);min-width:130px;">
          <img src="<%= s.qrDataUrl %>" style="width:90px;height:90px;" alt="QR <%= s.userName %>">
          <div style="width:90px;border-top:1.5px solid var(--gray-800);"></div>
          <div style="font-size:11.5px;font-weight:700;color:var(--gray-900);text-align:center;"><%= s.userName %></div>
          <% if (rl) { %><div style="font-size:10.5px;color:var(--gray-500);text-align:center;"><%= rl %></div><% } %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>

  <!-- Sidebar -->
  <div style="display:flex;flex-direction:column;gap:16px;">
    <div class="info-card">
      <div class="info-card-title">Info Surat</div>
      <div class="info-item"><span class="info-key">Nomor</span><span class="info-val" style="font-weight:600;font-size:12.5px;"><%= email.nomorSurat %></span></div>
      <div class="info-item"><span class="info-key">Status</span>
        <span class="info-val" style="color:<%= email.status==='sent'?'var(--green-600)':'var(--amber-600)' %>;font-weight:500;">
          <%= email.status === 'sent' ? 'Terkirim' : 'Draf' %>
        </span>
      </div>
      <div class="info-item"><span class="info-key">Jenis</span>
        <span class="info-val"><%= email.jenis === 'internal' ? 'Internal' : 'Eksternal' %></span>
      </div>
      <div class="info-item"><span class="info-key">Sifat</span><span class="info-val"><%= email.sifat %></span></div>
      <div class="info-item" style="border-bottom:none;">
        <span class="info-key">Penandatangan</span>
        <span class="info-val"><%= docSig?.signers?.length || 0 %></span>
      </div>
    </div>

    <!-- Tombol buka modal disposisi -->
    <% if (email.status === 'sent') { %>
    <div class="info-card">
      <div class="info-card-title">Disposisi</div>
      <% if (email.disposisi && email.disposisi.length > 0) { %>
      <div style="margin-bottom:10px;">
        <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;color:var(--gray-400);margin-bottom:6px;">Diteruskan ke</div>
        <% email.disposisi.forEach(function(d) { %>
        <div style="display:flex;align-items:center;gap:6px;padding:5px 0;border-bottom:1px solid var(--gray-100);font-size:12.5px;color:var(--gray-700);">
          <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M3 17c0-3.3 3.1-6 7-6s7 2.7 7 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span><%= d.nama %><% if(d.jabatan){ %> <span style="color:var(--gray-400);">· <%= d.jabatan %></span><% } %></span>
        </div>
        <% }) %>
      </div>
      <% } %>
      <button class="btn btn-secondary" style="width:100%;justify-content:center;font-size:13px;" onclick="bukaModalDisposisi()">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;"><path d="M13 6l4 4-4 4M3 10h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <%= (email.disposisi && email.disposisi.length > 0) ? 'Ubah Disposisi' : 'Buat Disposisi' %>
      </button>
    </div>
    <% } %>

    <!-- MODAL DISPOSISI -->
    <% if (email.status === 'sent') { %>
    <%
      const savedIds = (email.disposisi||[]).map(d=>d.userId?.toString());
      const grouped = {};
      users.forEach(function(u) {
        const k = u.kodeDir || '__lain__';
        if (!grouped[k]) grouped[k] = [];
        grouped[k].push(u);
      });
      const dirMap = {};
      direktorats.forEach(function(d){ dirMap[d.kode] = d.nama; });
      const DISP_TIER = ['KOM','DIR',...direktorats.map(d=>d.kode).filter(k=>k!=='KOM'&&k!=='DIR'),'__lain__'];
      const groupKeys = DISP_TIER.filter(k => grouped[k]);
    %>
    <div id="modalDisposisi" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,.45);backdrop-filter:blur(2px);align-items:center;justify-content:center;">
      <div style="background:#fff;border-radius:14px;width:480px;max-width:94vw;box-shadow:0 20px 60px rgba(0,0,0,.25);display:flex;flex-direction:column;max-height:90vh;overflow:hidden;">
        <!-- Modal header -->
        <div style="padding:18px 20px 14px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
          <div>
            <div style="font-size:15px;font-weight:700;color:#0f172a;">Disposisi Surat</div>
            <div style="font-size:12px;color:#94a3b8;margin-top:1px;">Teruskan ke</div>
          </div>
          <button onclick="tutupModalDisposisi()" style="background:none;border:none;cursor:pointer;padding:4px;color:#94a3b8;border-radius:6px;" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='none'">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </button>
        </div>

        <!-- Daftar nama — scrollable -->
        <div id="disposisiUserList" style="overflow-y:auto;flex:1;min-height:0;">
          <% groupKeys.forEach(function(k, ki) { %>
            <% if (ki > 0) { %><div style="height:1px;background:#f1f5f9;"></div><% } %>
            <!-- label grup -->
            <div style="padding:8px 16px 4px;background:#f8fafc;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:1;border-bottom:1px solid #f1f5f9;">
              <span style="font-size:9px;font-weight:700;letter-spacing:.7px;color:#64748b;text-transform:uppercase;">
                <% if(k==='KOM'){ %>Komisaris
                <% } else if(k==='DIR'){ %>Jajaran Direksi
                <% } else if(k==='__lain__'){ %>Lainnya
                <% } else { %><%= dirMap[k]||k %><% } %>
              </span>
              <button type="button" onclick="selectAllInGroup(this)"
                style="font-size:10px;background:none;border:none;color:var(--brand-600);cursor:pointer;padding:0;font-weight:600;">Pilih semua</button>
            </div>
            <!-- nama -->
            <div class="disp-group-body">
              <% (grouped[k]||[]).forEach(function(u, ui) { %>
              <label style="display:flex;align-items:center;gap:10px;padding:9px 16px;cursor:pointer;transition:background .1s;<%= ui>0?'border-top:1px solid #f8fafc;':'' %>"
                     onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background=''">
                <input type="checkbox" value="<%= u._id %>" data-name="<%= u.name %>" data-jabatan="<%= u.jabatan||'' %>"
                  style="accent-color:var(--brand-600);width:15px;height:15px;flex-shrink:0;"
                  <% if(savedIds.includes(u._id.toString())){ %>checked<% } %>>
                <div style="min-width:0;">
                  <div style="font-size:13px;font-weight:500;color:#1e293b;"><%= u.name %></div>
                  <% if(u.jabatan){ %><div style="font-size:11px;color:#94a3b8;"><%= u.jabatan %></div><% } %>
                </div>
              </label>
              <% }) %>
            </div>
          <% }); %>
        </div>

        <!-- Catatan + tombol simpan -->
        <div style="padding:14px 20px 18px;border-top:1px solid #e2e8f0;flex-shrink:0;">
          <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94a3b8;margin-bottom:6px;">Instruksi / Catatan</div>
          <textarea id="disposisiCatatan" class="form-control" style="font-size:13px;min-height:72px;resize:vertical;margin-bottom:10px;" placeholder="Instruksi / catatan..."><%= email.disposisiCatatan||'' %></textarea>
          <div style="display:flex;gap:8px;">
            <button class="btn btn-secondary" style="flex:1;justify-content:center;" onclick="tutupModalDisposisi()">Batal</button>
            <button class="btn btn-primary" style="flex:2;justify-content:center;" onclick="simpanDisposisi()">Simpan Disposisi</button>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="info-card">
      <div class="info-card-title">Aksi</div>
      <% if (isSender && email.status === 'draft') { %>
      <a href="/email/<%= email._id %>/preview" class="btn btn-primary" style="width:100%;margin-bottom:8px;justify-content:center;">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M13 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Buka Preview & Kirim
      </a>
      <% } %>
      <div style="display:flex;gap:8px;">
        <a href="/email/<%= email._id %>/preview?print=1" target="_blank" class="btn btn-secondary" style="flex:1;justify-content:center;font-size:12px;padding:5px 0;">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v10M6 9l4 4 4-4M3 17h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Unduh
        </a>
        <a href="/email/<%= email._id %>/preview" target="_blank" class="btn btn-primary" style="flex:1;justify-content:center;font-size:12px;padding:5px 0;">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          Lihat
        </a>
      </div>
    </div>
  </div>
</div>

<script>
function bukaModalDisposisi() {
  const m = document.getElementById('modalDisposisi');
  m.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function tutupModalDisposisi() {
  const m = document.getElementById('modalDisposisi');
  m.style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e){ if(e.key==='Escape') tutupModalDisposisi(); });
document.getElementById('modalDisposisi')?.addEventListener('click', function(e){ if(e.target===this) tutupModalDisposisi(); });

function selectAllInGroup(btn) {
  const body = btn.closest('div').nextElementSibling;
  const checkboxes = body.querySelectorAll('input[type=checkbox]');
  const allChecked = [...checkboxes].every(cb => cb.checked);
  checkboxes.forEach(cb => cb.checked = !allChecked);
}
function toggleGroup(header) {
  const members = header.nextElementSibling;
  const chevron = header.querySelector('.group-chevron');
  const open = members.style.display !== 'none';
  members.style.display = open ? 'none' : 'flex';
  chevron.style.transform = open ? 'rotate(-90deg)' : '';
}
function selectGroup(btn) {
  const body = btn.closest('div').nextElementSibling;
  const checkboxes = body.querySelectorAll('input[type=checkbox]');
  const allChecked = [...checkboxes].every(cb => cb.checked);
  checkboxes.forEach(cb => cb.checked = !allChecked);
}
async function simpanDisposisi() {
  const selected = [...document.querySelectorAll('#disposisiUserList input:checked')].map(cb => ({
    userId: cb.value, nama: cb.dataset.name, jabatan: cb.dataset.jabatan
  }));
  const catatan = (document.getElementById('disposisiCatatan').value || '').trim();
  if (!selected.length && !catatan) {
    alert('Pilih penerima atau isi catatan disposisi.');
    return;
  }
  const res  = await fetch('/email/<%= email._id %>/disposisi', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ disposisi: selected, disposisiCatatan: catatan })
  });
  const data = await res.json();
  if (data.ok) { location.reload(); }
  else alert('Gagal menyimpan disposisi.');
}
</script>

