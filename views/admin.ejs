<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Admin</div>
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Kelola pengguna, pantau statistik, dan lacak aktivitas sistem</p>
  </div>
</div>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 18c0-3.314 2.686-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="15" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 18c0-3.314 2.686-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Total Pengguna</div>
      <div class="stat-value"><%= stats.totalUsers %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Total Surat</div>
      <div class="stat-value"><%= stats.totalEmails %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Terkirim</div>
      <div class="stat-value"><%= stats.totalSent %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Draf</div>
      <div class="stat-value"><%= stats.totalDraft %></div>
    </div>
  </div>
</div>

<!-- Tab navigation -->
<div class="admin-tabs">
  <button class="admin-tab active" onclick="showTab(this,'tabUsers')" data-tab="users">
    <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 18c0-3.314 2.686-6 6-6s6 2.686 6 6M14 3h4v4M14 5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    Manajemen Pengguna (<%= users.length %>)
  </button>
  <button class="admin-tab" onclick="showTab(this,'tabLogs')" data-tab="logs">
    <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h12M4 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="15" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
    Log Aktivitas (<%= logs.length %><%= logs.length >= 50 ? '+' : '' %>)
  </button>
</div>

<!-- Tab: Users -->
<div id="tabUsers" class="admin-tab-panel">
  <div class="mail-list-wrap">
    <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
      <span class="mail-list-title">Daftar Pengguna</span>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input id="userSearchInput" type="text" class="search-input" placeholder="Cari nama / ENIK..." style="max-width:200px;padding:7px 12px;" oninput="filterUsers(this.value)">
        <select id="userRoleFilter" class="admin-role-select" onchange="filterByRole(this.value)" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Role</option>
          <option value="admin">Super Admin</option>
          <option value="direktur">Direktur / Komisaris</option>
          <option value="user">User</option>
        </select>
        <button class="btn btn-primary" style="padding:7px 14px;font-size:13px;" onclick="openAddUserModal()">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v14M3 10h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Tambah User
        </button>
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table" id="usersTable">
        <thead>
          <tr>
            <th style="width:80px;">ENIK</th>
            <th>Nama</th>
            <th>Jabatan</th>
            <th>Role</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) {
            const initials = u.name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
            const isCurrentUser = u._id.toString() === user._id.toString();
            const roleLabel = { admin: 'Administrator', direktur: 'Direktur', user: 'Pengguna' }[u.role] || 'Pengguna';
          %>
          <tr class="admin-user-row" data-name="<%= u.name.toLowerCase() %> <%= (u.enik||'').toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-role="<%= u.role %>">
            <td style="font-family:monospace;font-weight:600;font-size:13px;color:var(--brand-700);">
              <%= u.enik || '—' %>
            </td>
            <td>
              <div class="admin-user-cell">
                <% if (u.avatar) { %>
                  <img src="<%= u.avatar %>" class="admin-user-avatar admin-user-avatar-img" alt="">
                <% } else { %>
                  <div class="admin-user-avatar"><%= initials %></div>
                <% } %>
                <div>
                  <div class="admin-user-name">
                    <%= u.name %>
                    <% if (isCurrentUser) { %><span class="admin-you-tag">Anda</span><% } %>
                  </div>
                  <div class="admin-user-email"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td>
              <div style="font-size:13px;color:var(--gray-700);font-weight:500;"><%= u.jabatan || '-' %></div>
              <div style="font-size:11px;color:var(--gray-400);"><%= u.organization || '' %></div>
            </td>
            <td>
              <% if (!isCurrentUser) { %>
              <select class="admin-role-select" onchange="changeRole('<%= u._id %>', this.value, this)">
                <option value="user"     <%= u.role==='user'?'selected':'' %>>User</option>
                <option value="direktur" <%= u.role==='direktur'?'selected':'' %>>Direktur / Komisaris</option>
                <option value="admin"    <%= u.role==='admin'?'selected':'' %>>Super Admin</option>
              </select>
              <% } else { %>
              <span class="profile-badge profile-badge-<%= u.role %>"><%= roleLabel %></span>
              <% } %>
            </td>
            <td>
              <span class="admin-status-badge admin-status-<%= u.isActive ? 'active' : 'inactive' %>">
                <span class="admin-status-dot"></span>
                <%= u.isActive ? 'Aktif' : 'Nonaktif' %>
              </span>
            </td>
            <td>
              <div class="admin-actions" style="gap:6px;">
                <button class="admin-btn" style="color:var(--brand-600);" onclick="openEditModal('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>','<%= u.enik||'' %>','<%= u.jabatan||'' %>','<%= u.organization||'' %>','<%= u.email %>','<%= u.kodeDir||'' %>')" title="Edit">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M14 3l3 3L7 16H4v-3L14 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  Edit
                </button>
                <% if (!isCurrentUser) { %>
                <button class="admin-btn" style="color:var(--amber-600);" onclick="resetPwd('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>')" title="Reset Password">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><rect x="4" y="9" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Reset PW
                </button>
                <button class="admin-btn admin-btn-toggle" onclick="toggleUser('<%= u._id %>', this)" data-active="<%= u.isActive %>">
                  <%= u.isActive ? 'Nonaktifkan' : 'Aktifkan' %>
                </button>
                <button class="admin-btn admin-btn-delete" onclick="deleteUser('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>',this)">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (users.length === 0) { %>
      <div class="empty-state"><p>Belum ada pengguna terdaftar.</p></div>
      <% } %>
    </div>
  </div>

  <!-- Role hierarchy info -->
  <div class="role-hierarchy-card">
    <div class="role-hierarchy-title">Hierarki Role</div>
    <div class="role-hierarchy-items">
      <div class="role-hi-item role-hi-admin">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.4 4.8 5.3.8-3.85 3.75.91 5.3L10 14.25 5.2 16.65l.91-5.3L2.26 7.6l5.3-.8L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Administrator (Admin)</div>
          <div class="role-hi-desc">Akses penuh — kelola pengguna, lihat semua log, ubah role, hapus data</div>
        </div>
      </div>
      <div class="role-hi-separator"></div>
      <div class="role-hi-item role-hi-direktur">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Direktur</div>
          <div class="role-hi-desc">Lihat ringkasan organisasi, semua surat yang beredar, dan laporan</div>
        </div>
      </div>
      <div class="role-hi-separator"></div>
      <div class="role-hi-item role-hi-user">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Pengguna (User)</div>
          <div class="role-hi-desc">Kirim, terima, dan kelola surat dinas milik sendiri</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab: Logs -->
<div id="tabLogs" class="admin-tab-panel" style="display:none;">
  <div class="mail-list-wrap">
    <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
      <span class="mail-list-title">Log Aktivitas Terbaru</span>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <select class="admin-role-select" id="logCategoryFilter" onchange="filterLogs()" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Kategori</option>
          <option value="auth">Autentikasi</option>
          <option value="email">Surat</option>
          <option value="user_management">Manajemen Pengguna</option>
          <option value="profile">Profil</option>
        </select>
        <select class="admin-role-select" id="logStatusFilter" onchange="filterLogs()" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Status</option>
          <option value="success">Berhasil</option>
          <option value="failed">Gagal</option>
        </select>
        <input type="text" id="logSearch" class="search-input" placeholder="Cari log..." style="max-width:200px;padding:7px 12px;" oninput="filterLogs()">
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table" id="logsTable">
        <thead>
          <tr>
            <th>Waktu</th>
            <th>Pengguna</th>
            <th>Aksi</th>
            <th>Kategori</th>
            <th>Keterangan</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="logsBody">
          <% logs.forEach(function(l) {
            const actionLabels = {
              login: 'Masuk',
              logout: 'Keluar',
              login_failed: 'Login Gagal',
              register: 'Daftar',
              password_change: 'Ubah Password',
              password_reset_request: 'Reset Password',
              password_reset: 'Password Direset',
              profile_update: 'Update Profil',
              avatar_update: 'Update Avatar',
              email_sent: 'Surat Terkirim',
              email_draft: 'Simpan Draf',
              email_read: 'Baca Surat',
              email_deleted: 'Hapus Surat',
              user_created: 'Buat User',
              user_updated: 'Update User',
              user_deleted: 'Hapus User',
              user_role_changed: 'Ubah Role',
              user_toggled: 'Toggle Status',
              system: 'Sistem'
            };
            const catLabels = { auth: 'Auth', email: 'Surat', user_management: 'User', profile: 'Profil', system: 'Sistem' };
          %>
          <tr class="log-row" data-category="<%= l.category %>" data-status="<%= l.status %>" data-search="<%= (l.description || '').toLowerCase() %> <%= (l.userName || '').toLowerCase() %> <%= (l.userEmail || '').toLowerCase() %>">
            <td class="admin-date" style="white-space:nowrap;"><%= l.dateTime %></td>
            <td>
              <div style="font-size:13px;font-weight:500;color:var(--gray-800);"><%= l.userName || '-' %></div>
              <div style="font-size:11.5px;color:var(--gray-400);"><%= l.userEmail || '' %></div>
              <% if (l.userRole) { %>
              <span class="profile-badge profile-badge-<%= l.userRole %>" style="font-size:10px;padding:1px 6px;"><%= l.userRole %></span>
              <% } %>
            </td>
            <td><span class="log-action-badge log-action-<%= l.action %>"><%= actionLabels[l.action] || l.action %></span></td>
            <td><span class="log-cat-badge log-cat-<%= l.category %>"><%= catLabels[l.category] || l.category %></span></td>
            <td style="font-size:13px;color:var(--gray-600);max-width:300px;"><%= l.description %></td>
            <td>
              <span class="log-status-badge log-status-<%= l.status %>">
                <%= l.status === 'success' ? 'Berhasil' : l.status === 'failed' ? 'Gagal' : 'Peringatan' %>
              </span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (logs.length === 0) { %>
      <div class="empty-state"><p>Belum ada log aktivitas.</p></div>
      <% } %>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="admin-toast" id="adminToast"></div>

<!-- ── MODAL OVERLAY ── -->
<div id="modalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">

  <!-- Edit User Modal -->
  <div id="modalEdit" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:480px;max-width:95vw;position:relative;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:20px;">Edit Pengguna</div>
    <input type="hidden" id="editUserId">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">ENIK</label>
        <input id="editEnik" type="text" class="form-control" placeholder="Kode ENIK" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Jabatan</label>
        <input id="editJabatan" type="text" class="form-control" placeholder="Jabatan / posisi" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Organisasi / Divisi</label>
        <input id="editOrganization" type="text" class="form-control" placeholder="Nama organisasi" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Kode Direktorat</label>
        <select id="editKodeDir" class="form-control form-select" style="font-size:13px;">
          <option value="">— Belum ditugaskan —</option>
          <option value="KOM">KOM — Dewan Komisaris</option>
          <option value="DIR">DIR — Direktur Utama</option>
          <option value="PLAN">PLAN — Business Strategy & Finance</option>
          <option value="TECH">TECH — Technical & Operations</option>
          <option value="MP">MP — Marketing & Partnership</option>
        </select>
      </div>
    </div>
    <div style="margin-top:8px;">
      <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Email</label>
      <input id="editEmail" type="text" class="form-control" disabled style="font-size:13px;background:var(--gray-50);color:var(--gray-500);">
    </div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:22px;">
      <button class="btn btn-ghost" onclick="closeAllModals()">Batal</button>
      <button class="btn btn-primary" onclick="saveEdit()">Simpan</button>
    </div>
  </div>

  <!-- Reset Password Modal -->
  <div id="modalReset" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:400px;max-width:95vw;position:relative;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:6px;">Reset Kata Sandi</div>
    <div id="resetUserName" style="font-size:13px;color:var(--gray-500);margin-bottom:18px;"></div>
    <input type="hidden" id="resetUserId">
    <div>
      <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Kata Sandi Baru</label>
      <input id="resetPassword" type="password" class="form-control" placeholder="Minimal 8 karakter" style="font-size:13px;">
    </div>
    <div style="margin-top:10px;">
      <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Konfirmasi Kata Sandi</label>
      <input id="resetPassword2" type="password" class="form-control" placeholder="Ulangi kata sandi" style="font-size:13px;">
    </div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:22px;">
      <button class="btn btn-ghost" onclick="closeAllModals()">Batal</button>
      <button class="btn btn-primary" onclick="saveReset()">Simpan</button>
    </div>
  </div>

  <!-- Add User Modal -->
  <div id="modalAdd" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:520px;max-width:95vw;position:relative;max-height:90vh;overflow-y:auto;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:20px;">Tambah Pengguna Baru</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="grid-column:1/-1;">
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Nama Lengkap <span style="color:var(--red-500);">*</span></label>
        <input id="addName" type="text" class="form-control" placeholder="Nama lengkap" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Email <span style="color:var(--red-500);">*</span></label>
        <input id="addEmail" type="email" class="form-control" placeholder="email@domain.com" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">ENIK</label>
        <input id="addEnik" type="text" class="form-control" placeholder="Kode ENIK" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Jabatan</label>
        <input id="addJabatan" type="text" class="form-control" placeholder="Jabatan / posisi" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Organisasi / Divisi</label>
        <input id="addOrganization" type="text" class="form-control" placeholder="Inspira Tekno" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Role</label>
        <select id="addRole" class="form-control form-select" style="font-size:13px;">
          <option value="user">Pengguna</option>
          <option value="direktur">Direktur / Komisaris</option>
          <option value="admin">Super Admin</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Kode Direktorat</label>
        <select id="addKodeDir" class="form-control form-select" style="font-size:13px;">
          <option value="">— Belum ditugaskan —</option>
          <option value="KOM">KOM — Dewan Komisaris</option>
          <option value="DIR">DIR — Direktur Utama</option>
          <option value="PLAN">PLAN — Business Strategy & Finance</option>
          <option value="TECH">TECH — Technical & Operations</option>
          <option value="MP">MP — Marketing & Partnership</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Kata Sandi <span style="color:var(--red-500);">*</span></label>
        <input id="addPassword" type="password" class="form-control" placeholder="Min. 8 karakter" style="font-size:13px;">
      </div>
      <div>
        <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Konfirmasi Kata Sandi <span style="color:var(--red-500);">*</span></label>
        <input id="addPassword2" type="password" class="form-control" placeholder="Ulangi kata sandi" style="font-size:13px;">
      </div>
    </div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:22px;">
      <button class="btn btn-ghost" onclick="closeAllModals()">Batal</button>
      <button class="btn btn-primary" onclick="saveAddUser()">Tambah Pengguna</button>
    </div>
  </div>

</div>

<style>
.admin-modal { box-shadow: 0 20px 60px rgba(0,0,0,.18); }
#modalOverlay.show { display:flex !important; }
</style>

<script>
// Tab switching
function showTab(btn, panelId) {
  document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.admin-tab-panel').forEach(p => p.style.display = 'none');
  btn.classList.add('active');
  document.getElementById(panelId).style.display = '';
}

// Toast
function showToast(msg, ok) {
  const t = document.getElementById('adminToast');
  t.textContent = msg;
  t.className = 'admin-toast admin-toast-' + (ok ? 'success' : 'error') + ' admin-toast-show';
  setTimeout(() => t.className = 'admin-toast', 3500);
}

// Filter users
function filterUsers(q) {
  q = q.toLowerCase();
  applyUserFilters();
}
function filterByRole(role) {
  applyUserFilters();
}
function applyUserFilters() {
  const q = (document.getElementById('userSearchInput')?.value || '').toLowerCase();
  const role = (document.getElementById('userRoleFilter')?.value || '');
  document.querySelectorAll('.admin-user-row').forEach(row => {
    const matchQ = !q || (row.dataset.name || '').includes(q) || (row.dataset.email || '').includes(q);
    const matchRole = !role || row.dataset.role === role;
    row.style.display = (matchQ && matchRole) ? '' : 'none';
  });
}

// Filter logs
function filterLogs() {
  const category = document.getElementById('logCategoryFilter').value;
  const status = document.getElementById('logStatusFilter').value;
  const q = document.getElementById('logSearch').value.toLowerCase();
  document.querySelectorAll('.log-row').forEach(row => {
    const matchCat = !category || row.dataset.category === category;
    const matchStatus = !status || row.dataset.status === status;
    const matchQ = !q || (row.dataset.search || '').includes(q);
    row.style.display = (matchCat && matchStatus && matchQ) ? '' : 'none';
  });
}

// Change role
async function changeRole(id, role, sel) {
  const prev = sel.options[sel.selectedIndex === 0 ? 1 : 0].value;
  try {
    const res = await fetch(`/admin/users/${id}/role`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role })
    });
    const data = await res.json();
    if (data.ok) {
      showToast('Role berhasil diubah.', true);
      // update row data-role
      sel.closest('tr').dataset.role = role;
    } else {
      sel.value = prev;
      showToast(data.message || 'Gagal mengubah role.', false);
    }
  } catch (e) {
    sel.value = prev;
    showToast('Terjadi kesalahan.', false);
  }
}

// Toggle user active
async function toggleUser(id, btn) {
  try {
    const res = await fetch(`/admin/users/${id}/toggle`, { method: 'POST' });
    const data = await res.json();
    if (data.ok) {
      const row = btn.closest('tr');
      const badge = row.querySelector('.admin-status-badge');
      if (data.isActive) {
        badge.className = 'admin-status-badge admin-status-active';
        badge.innerHTML = '<span class="admin-status-dot"></span>Aktif';
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 10h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Nonaktifkan`;
      } else {
        badge.className = 'admin-status-badge admin-status-inactive';
        badge.innerHTML = '<span class="admin-status-dot"></span>Nonaktif';
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Aktifkan`;
      }
      showToast('Status pengguna diperbarui.', true);
    } else {
      showToast(data.message || 'Gagal.', false);
    }
  } catch (e) {
    showToast('Terjadi kesalahan.', false);
  }
}

// ── MODAL HELPERS ──
function openModal(id) {
  document.getElementById('modalOverlay').style.display = 'flex';
  document.getElementById(id).style.display = 'block';
}
function closeAllModals() {
  document.getElementById('modalOverlay').style.display = 'none';
  ['modalEdit','modalReset','modalAdd'].forEach(function(mid) {
    document.getElementById(mid).style.display = 'none';
  });
}
// Tutup hanya jika klik tepat di overlay (bukan di dalam modal)
document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeAllModals();
});

// ── EDIT USER ──
function openEditModal(id, name, enik, jabatan, org, email, kodeDir) {
  document.getElementById('editUserId').value = id;
  document.getElementById('editEnik').value = enik || '';
  document.getElementById('editJabatan').value = jabatan || '';
  document.getElementById('editOrganization').value = org || '';
  document.getElementById('editEmail').value = email || '';
  document.getElementById('editKodeDir').value = kodeDir || '';
  openModal('modalEdit');
}
async function saveEdit() {
  const id  = document.getElementById('editUserId').value;
  const payload = {
    enik:         document.getElementById('editEnik').value.trim(),
    jabatan:      document.getElementById('editJabatan').value.trim(),
    organization: document.getElementById('editOrganization').value.trim(),
    kodeDir:      document.getElementById('editKodeDir').value
  };
  try {
    const res  = await fetch(`/admin/users/${id}/enik`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.ok) {
      // Update row display
      const row = document.querySelector(`tr[data-name]`);
      document.querySelectorAll('.admin-user-row').forEach(r => {
        if (r.querySelector(`button[onclick*="${id}"]`)) {
          r.querySelector('td:nth-child(3) div:first-child').textContent = payload.jabatan || '-';
          r.querySelector('td:nth-child(3) div:last-child').textContent = payload.organization || '';
          r.querySelector('td:first-child').textContent = payload.enik || '—';
        }
      });
      closeAllModals();
      showToast('Data pengguna berhasil disimpan.', true);
    } else {
      showToast(data.message || 'Gagal menyimpan.', false);
    }
  } catch(e) { showToast('Terjadi kesalahan.', false); }
}

// ── RESET PASSWORD ──
function resetPwd(id, name) {
  document.getElementById('resetUserId').value = id;
  document.getElementById('resetUserName').textContent = 'Pengguna: ' + name;
  document.getElementById('resetPassword').value = '';
  document.getElementById('resetPassword2').value = '';
  openModal('modalReset');
}
async function saveReset() {
  const id  = document.getElementById('resetUserId').value;
  const pw  = document.getElementById('resetPassword').value;
  const pw2 = document.getElementById('resetPassword2').value;
  if (!pw || pw.length < 8) { showToast('Kata sandi minimal 8 karakter.', false); return; }
  if (pw !== pw2) { showToast('Konfirmasi kata sandi tidak cocok.', false); return; }
  try {
    const res  = await fetch(`/admin/users/${id}/reset-password`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pw })
    });
    const data = await res.json();
    if (data.ok) { closeAllModals(); showToast('Kata sandi berhasil direset.', true); }
    else showToast(data.message || 'Gagal reset.', false);
  } catch(e) { showToast('Terjadi kesalahan.', false); }
}

// ── ADD USER ──
function openAddUserModal() {
  ['addName','addEmail','addEnik','addJabatan','addOrganization','addPassword','addPassword2'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('addRole').value = 'user';
  document.getElementById('addKodeDir').value = '';
  openModal('modalAdd');
}
async function saveAddUser() {
  const name  = document.getElementById('addName').value.trim();
  const email = document.getElementById('addEmail').value.trim();
  const pw    = document.getElementById('addPassword').value;
  const pw2   = document.getElementById('addPassword2').value;
  if (!name || !email || !pw) { showToast('Nama, email, dan kata sandi wajib diisi.', false); return; }
  if (pw.length < 8) { showToast('Kata sandi minimal 8 karakter.', false); return; }
  if (pw !== pw2) { showToast('Konfirmasi kata sandi tidak cocok.', false); return; }
  const payload = {
    name, email, password: pw,
    role:         document.getElementById('addRole').value,
    enik:         document.getElementById('addEnik').value.trim(),
    jabatan:      document.getElementById('addJabatan').value.trim(),
    organization: document.getElementById('addOrganization').value.trim(),
    kodeDir:      document.getElementById('addKodeDir').value
  };
  try {
    const res  = await fetch('/admin/users', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.ok) {
      closeAllModals();
      showToast(`Pengguna "${name}" berhasil ditambahkan.`, true);
      setTimeout(() => location.reload(), 1200);
    } else showToast(data.message || 'Gagal menambahkan.', false);
  } catch(e) { showToast('Terjadi kesalahan.', false); }
}

// Delete user
async function deleteUser(id, name, btn) {
  if (!await showConfirm(`Hapus pengguna "<b>${name}</b>"? Tindakan ini tidak dapat dibatalkan.`, { title:'Hapus Pengguna', type:'danger', confirmLabel:'Hapus' })) return;
  try {
    const res = await fetch(`/admin/users/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.ok) {
      btn.closest('tr').remove();
      showToast(`Pengguna "${name}" dihapus.`, true);
    } else {
      showToast(data.message || 'Gagal menghapus.', false);
    }
  } catch (e) {
    showToast('Terjadi kesalahan.', false);
  }
}
</script>

<%- include('./partials/footer') %>
