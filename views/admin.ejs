<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Admin</div>
    <h1 class="page-title">Admin Dashboard</h1>
    <p class="page-subtitle">Kelola pengguna, pantau statistik, dan lacak aktivitas sistem</p>
  </div>
</div>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 18c0-3.314 2.686-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="15" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 18c0-3.314 2.686-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Total Pengguna</div>
      <div class="stat-value"><%= stats.totalUsers %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Total Surat</div>
      <div class="stat-value"><%= stats.totalEmails %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M18 2L9 11M18 2l-6 16-3-7-7-3 16-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Terkirim</div>
      <div class="stat-value"><%= stats.totalSent %></div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h8M4 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <div class="stat-label">Draf</div>
      <div class="stat-value"><%= stats.totalDraft %></div>
    </div>
  </div>
</div>

<!-- Tab navigation -->
<div class="admin-tabs">
  <button class="admin-tab active" onclick="showTab(this,'tabUsers')" data-tab="users">
    <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M2 18c0-3.314 2.686-6 6-6s6 2.686 6 6M14 3h4v4M14 5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    Manajemen Pengguna (<%= users.length %>)
  </button>
  <button class="admin-tab" onclick="showTab(this,'tabLogs')" data-tab="logs">
    <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M4 4h12M4 8h12M4 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="16" cy="15" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
    Log Aktivitas (<%= logs.length %><%= logs.length >= 50 ? '+' : '' %>)
  </button>
  <button class="admin-tab" onclick="showTab(this,'tabPenomoran')" data-tab="penomoran">
    <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 10h6M7 13h4M8 7h1v6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
    Penomoran (<%= counters.length %>)
  </button>
</div>

<!-- Tab: Users -->
<div id="tabUsers" class="admin-tab-panel">
  <div class="mail-list-wrap">
    <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
      <span class="mail-list-title">Daftar Pengguna</span>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input id="userSearchInput" type="text" class="search-input" placeholder="Cari nama / ENIK..." style="max-width:200px;padding:7px 12px;" oninput="filterUsers(this.value)" autocomplete="off">
        <select id="userRoleFilter" class="admin-role-select" onchange="filterByRole(this.value)" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Role</option>
          <option value="superadmin">Super Admin</option>
          <option value="admin">Admin</option>
          <option value="direktur">Direktur / Komisaris</option>
          <option value="user">User</option>
        </select>
        <button class="btn btn-primary" style="padding:7px 14px;font-size:13px;" onclick="openAddUserModal()">
          <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v14M3 10h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Tambah User
        </button>
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table" id="usersTable">
        <thead>
          <tr>
            <th style="width:80px;">ENIK</th>
            <th>Nama</th>
            <th>Jabatan</th>
            <th>Role</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u) {
            const initials = u.name.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
            const isCurrentUser = u._id.toString() === user._id.toString();
            const roleLabel = { superadmin: 'Super Admin', admin: 'Admin', direktur: 'Direktur', user: 'Pengguna' }[u.role] || 'Pengguna';
          %>
          <tr class="admin-user-row" data-name="<%= u.name.toLowerCase() %> <%= (u.enik||'').toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-role="<%= u.role %>">
            <td style="font-family:monospace;font-weight:600;font-size:13px;color:var(--brand-700);">
              <%= u.enik || '—' %>
            </td>
            <td>
              <div class="admin-user-cell">
                <% if (u.avatar) { %>
                  <img src="<%= u.avatar %>" class="admin-user-avatar admin-user-avatar-img" alt="">
                <% } else { %>
                  <div class="admin-user-avatar"><%= initials %></div>
                <% } %>
                <div>
                  <div class="admin-user-name">
                    <%= u.name %>
                    <% if (isCurrentUser) { %><span class="admin-you-tag">Anda</span><% } %>
                  </div>
                  <div class="admin-user-email"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td>
              <div style="font-size:13px;color:var(--gray-700);font-weight:500;"><%= u.jabatan || '-' %></div>
              <div style="font-size:11px;color:var(--gray-400);"><%= u.organization || '' %></div>
            </td>
            <td>
              <% if (!isCurrentUser) { %>
              <%
                const canEditThisUser = !(u.role === 'superadmin' && user.role !== 'superadmin');
              %>
              <% if (canEditThisUser) { %>
              <select class="admin-role-select" onchange="changeRole('<%= u._id %>', this.value, this)">
                <option value="user"       <%= u.role==='user'?'selected':'' %>>User</option>
                <option value="direktur"   <%= u.role==='direktur'?'selected':'' %>>Direktur / Komisaris</option>
                <option value="admin"      <%= u.role==='admin'?'selected':'' %>>Admin</option>
                <% if (user.role === 'superadmin') { %>
                <option value="superadmin" <%= u.role==='superadmin'?'selected':'' %>>Super Admin</option>
                <% } %>
              </select>
              <% } else { %>
              <span class="profile-badge profile-badge-<%= u.role %>">Super Admin</span>
              <% } %>
              <% } else { %>
              <span class="profile-badge profile-badge-<%= u.role %>"><%= roleLabel %></span>
              <% } %>
            </td>
            <td>
              <span class="admin-status-badge admin-status-<%= u.isActive ? 'active' : 'inactive' %>">
                <span class="admin-status-dot"></span>
                <%= u.isActive ? 'Aktif' : 'Nonaktif' %>
              </span>
            </td>
            <td>
              <div class="admin-actions" style="gap:6px;">
                <button class="admin-btn" style="color:var(--brand-600);" onclick="openEditModal('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>','<%= u.enik||'' %>','<%= u.jabatan||'' %>','<%= u.organization||'' %>','<%= u.email %>','<%= u.kodeDir||'' %>')" title="Edit">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M14 3l3 3L7 16H4v-3L14 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  Edit
                </button>
                <% if (!isCurrentUser) { %>
                <button class="admin-btn" style="color:var(--amber-600);" onclick="resetPwd('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>')" title="Reset Password">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><rect x="4" y="9" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Reset PW
                </button>
                <button class="admin-btn admin-btn-toggle" onclick="toggleUser('<%= u._id %>', this)" data-active="<%= u.isActive %>">
                  <%= u.isActive ? 'Nonaktifkan' : 'Aktifkan' %>
                </button>
                <button class="admin-btn admin-btn-delete" onclick="deleteUser('<%= u._id %>','<%= u.name.replace(/'/g,`\\'`) %>',this)">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (users.length === 0) { %>
      <div class="empty-state"><p>Belum ada pengguna terdaftar.</p></div>
      <% } %>
    </div>
  </div>

  <!-- Role hierarchy info -->
  <div class="role-hierarchy-card">
    <div class="role-hierarchy-title">Hierarki Role</div>
    <div class="role-hierarchy-items">
      <div class="role-hi-item role-hi-admin">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.4 4.8 5.3.8-3.85 3.75.91 5.3L10 14.25 5.2 16.65l.91-5.3L2.26 7.6l5.3-.8L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Administrator (Admin)</div>
          <div class="role-hi-desc">Akses penuh — kelola pengguna, lihat semua log, ubah role, hapus data</div>
        </div>
      </div>
      <div class="role-hi-separator"></div>
      <div class="role-hi-item role-hi-direktur">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 100 16A8 8 0 0010 2z" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Direktur</div>
          <div class="role-hi-desc">Lihat ringkasan organisasi, semua surat yang beredar, dan laporan</div>
        </div>
      </div>
      <div class="role-hi-separator"></div>
      <div class="role-hi-item role-hi-user">
        <div class="role-hi-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <div class="role-hi-name">Pengguna (User)</div>
          <div class="role-hi-desc">Kirim, terima, dan kelola surat dinas milik sendiri</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Tab: Logs -->
<div id="tabLogs" class="admin-tab-panel" style="display:none;">
  <div class="mail-list-wrap">
    <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
      <span class="mail-list-title">Log Aktivitas Terbaru</span>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <select class="admin-role-select" id="logCategoryFilter" onchange="filterLogs()" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Kategori</option>
          <option value="auth">Autentikasi</option>
          <option value="email">Surat</option>
          <option value="user_management">Manajemen Pengguna</option>
          <option value="profile">Profil</option>
        </select>
        <select class="admin-role-select" id="logStatusFilter" onchange="filterLogs()" style="padding:7px 28px 7px 10px;">
          <option value="">Semua Status</option>
          <option value="success">Berhasil</option>
          <option value="failed">Gagal</option>
        </select>
        <input type="text" id="logSearch" class="search-input" placeholder="Cari log..." style="max-width:200px;padding:7px 12px;" oninput="filterLogs()">
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table" id="logsTable">
        <thead>
          <tr>
            <th>Waktu</th>
            <th>Pengguna</th>
            <th>Aksi</th>
            <th>Kategori</th>
            <th>Keterangan</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="logsBody">
          <% logs.forEach(function(l) {
            const actionLabels = {
              login: 'Masuk',
              logout: 'Keluar',
              login_failed: 'Login Gagal',
              register: 'Daftar',
              password_change: 'Ubah Password',
              password_reset_request: 'Reset Password',
              password_reset: 'Password Direset',
              profile_update: 'Update Profil',
              avatar_update: 'Update Avatar',
              email_sent: 'Surat Terkirim',
              email_draft: 'Simpan Draf',
              email_read: 'Baca Surat',
              email_deleted: 'Hapus Surat',
              user_created: 'Buat User',
              user_updated: 'Update User',
              user_deleted: 'Hapus User',
              user_role_changed: 'Ubah Role',
              user_toggled: 'Toggle Status',
              system: 'Sistem'
            };
            const catLabels = { auth: 'Auth', email: 'Surat', user_management: 'User', profile: 'Profil', system: 'Sistem' };
          %>
          <tr class="log-row" data-category="<%= l.category %>" data-status="<%= l.status %>" data-search="<%= (l.description || '').toLowerCase() %> <%= (l.userName || '').toLowerCase() %> <%= (l.userEmail || '').toLowerCase() %>">
            <td class="admin-date" style="white-space:nowrap;"><%= l.dateTime %></td>
            <td>
              <div style="font-size:13px;font-weight:500;color:var(--gray-800);"><%= l.userName || '-' %></div>
              <div style="font-size:11.5px;color:var(--gray-400);"><%= l.userEmail || '' %></div>
              <% if (l.userRole) { %>
              <span class="profile-badge profile-badge-<%= l.userRole %>" style="font-size:10px;padding:1px 6px;"><%= l.userRole %></span>
              <% } %>
            </td>
            <td><span class="log-action-badge log-action-<%= l.action %>"><%= actionLabels[l.action] || l.action %></span></td>
            <td><span class="log-cat-badge log-cat-<%= l.category %>"><%= catLabels[l.category] || l.category %></span></td>
            <td style="font-size:13px;color:var(--gray-600);max-width:300px;"><%= l.description %></td>
            <td>
              <span class="log-status-badge log-status-<%= l.status %>">
                <%= l.status === 'success' ? 'Berhasil' : l.status === 'failed' ? 'Gagal' : 'Peringatan' %>
              </span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (logs.length === 0) { %>
      <div class="empty-state"><p>Belum ada log aktivitas.</p></div>
      <% } %>
    </div>
  </div>
</div>

<!-- Tab: Penomoran -->
<div id="tabPenomoran" class="admin-tab-panel" style="display:none;">
  <div class="mail-list-wrap">
    <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
      <span class="mail-list-title">Pengaturan Penomoran Surat</span>
      <button class="btn btn-primary" style="padding:7px 14px;font-size:13px;" onclick="openAddCounterModal()">
        <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M10 3v14M3 10h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Tambah / Atur Counter
      </button>
    </div>

    <div style="padding:14px 18px;background:#fffbeb;border:1px solid #fde68a;border-radius:8px;margin:0 0 16px;font-size:13px;color:#92400e;display:flex;align-items:flex-start;gap:10px;">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;margin-top:1px;"><path d="M10 2l8.66 15H1.34L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 8v4M10 14v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <span>Mengubah nomor counter akan mempengaruhi penomoran surat berikutnya. Format key: <strong>SURAT-{TAHUN}</strong> (contoh: <strong>SURAT-2026</strong>). Nomor yang diset adalah nomor <em>terakhir terpakai</em> — surat berikutnya akan memakai nomor ini +1.</span>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table" id="countersTable">
        <thead>
          <tr>
            <th>Key</th>
            <th>Kategori</th>
            <th>Tahun</th>
            <th style="text-align:center;">Nomor Terakhir</th>
            <th style="text-align:center;">Surat Berikutnya</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody id="countersBody">
          <% if (counters.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;color:var(--gray-400);padding:32px;font-size:13px;">Belum ada counter. Nomor pertama akan dibuat otomatis saat surat pertama dikirim.</td></tr>
          <% } %>
          <% counters.forEach(function(c) {
            const parts = c.key.split('-');
            const tahun = parts[parts.length - 1];
            const kategori = parts.slice(0, -1).join('-');
          %>
          <tr id="crow-<%= c.key.replace(/[^a-zA-Z0-9]/g,'-') %>">
            <td style="font-family:monospace;font-weight:700;font-size:13px;color:var(--brand-700);"><%= c.key %></td>
            <td style="font-size:13px;color:var(--gray-700);"><%= kategori %></td>
            <td style="font-size:13px;color:var(--gray-500);"><%= tahun %></td>
            <td style="text-align:center;">
              <span class="counter-seq" style="font-size:18px;font-weight:700;color:var(--gray-800);font-family:monospace;"><%= String(c.seq).padStart(3,'0') %></span>
            </td>
            <td style="text-align:center;">
              <span style="font-size:14px;font-weight:600;color:var(--brand-600);font-family:monospace;"><%= String(c.seq + 1).padStart(3,'0') %></span>
            </td>
            <td>
              <div style="display:flex;gap:6px;">
                <button class="admin-btn" style="color:var(--brand-600);" onclick="openEditCounterModal('<%= c.key %>',<%= c.seq %>)">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M14 3l3 3L7 16H4v-3L14 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                  Atur Nomor
                </button>
                <button class="admin-btn" style="color:var(--amber-600);" onclick="resetCounter('<%= c.key %>')">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M4 10a6 6 0 106-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M4 6v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Reset ke 0
                </button>
                <button class="admin-btn admin-btn-delete" onclick="deleteCounter('<%= c.key %>')">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M6 4h8M4 6h12M7 6v10h6V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="admin-toast" id="adminToast"></div>

<!-- ── MODAL OVERLAY ── -->
<div id="modalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">

  <!-- Edit Counter Modal -->
  <div id="modalEditCounter" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:420px;max-width:95vw;position:relative;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:6px;">Atur Nomor Counter</div>
    <div id="editCounterKeyLabel" style="font-size:13px;color:var(--gray-500);margin-bottom:18px;font-family:monospace;"></div>
    <input type="hidden" id="editCounterKey">
    <div style="margin-bottom:14px;">
      <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Nomor Terakhir Terpakai</label>
      <input id="editCounterSeq" type="number" min="0" class="form-control" placeholder="0" style="font-size:22px;font-weight:700;font-family:monospace;text-align:center;" autocomplete="off">
      <div style="font-size:11.5px;color:var(--gray-400);margin-top:5px;">Surat berikutnya akan bernomor <strong id="editCounterNext">001</strong></div>
    </div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px;">
      <button class="btn btn-ghost" onclick="closeAllModals()">Batal</button>
      <button class="btn btn-primary" onclick="saveCounterEdit()">Simpan</button>
    </div>
  </div>

  <!-- Add Counter Modal -->
  <div id="modalAddCounter" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:440px;max-width:95vw;position:relative;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:20px;">Tambah / Atur Counter Baru</div>
    <div style="margin-bottom:12px;">
      <label style="font-size:12px;font-weight:600;color:var(--gray-600);display:block;margin-bottom:4px;">Kategori</label>
