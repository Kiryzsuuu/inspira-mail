  <!-- Reset Password Modal -->
  <div id="modalReset" class="admin-modal" style="display:none;background:#fff;border-radius:12px;padding:28px 32px;width:400px;max-width:95vw;position:relative;">
    <div style="font-size:16px;font-weight:700;color:var(--gray-900);margin-bottom:6px;">Reset Kata Sandi</div>
    <div id="resetUserName" style="font-size:13px;color:var(--gray-500);margin-bottom:18px;"></div>
