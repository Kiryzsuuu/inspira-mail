<%- include('./partials/header') %>
<style>
.dok-table { width:100%; border-collapse:collapse; font-size:13px; }
.dok-table th { padding:10px 14px; text-align:left; font-size:11.5px; font-weight:600; color:var(--gray-500); background:var(--gray-50); border-bottom:1px solid var(--gray-200); text-transform:uppercase; letter-spacing:.4px; }
.dok-table td { padding:11px 14px; border-bottom:1px solid var(--gray-100); color:var(--gray-700); vertical-align:middle; }
.dok-table tr:last-child td { border-bottom:none; }
.dok-table tbody tr:hover { background:var(--gray-50); }
tr.unread td { background:#fafbff; }
</style>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Surat Masuk</div>
    <h1 class="page-title">Surat Masuk</h1>
    <p class="page-subtitle">Pencatatan surat masuk dari instansi / pihak eksternal</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      Catat Surat Masuk
    </button>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="flash-msg flash-error">
  <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  <%= error %>
</div>
<% } %>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Total Masuk</div><div class="stat-value"><%= stats.total || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Baru</div><div class="stat-value"><%= stats.baru || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Ditindaklanjuti</div><div class="stat-value"><%= stats.ditindaklanjuti || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Selesai</div><div class="stat-value"><%= stats.selesai || 0 %></div></div>
  </div>
</div>

<!-- List -->
<div class="mail-list-wrap">
  <div class="mail-list-header" style="flex-wrap:wrap;gap:10px;">
    <span class="mail-list-title"><%= surats.length %> surat tercatat</span>
    <form method="GET" id="smForm" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <input type="text" name="q" class="search-input" placeholder="Cari perihal, instansi, nomor..." value="<%= filter.q || '' %>" style="width:220px;padding:7px 12px;">
      <!-- hidden date fields, diisi dari dropdown -->
      <input type="hidden" name="klasifikasi" id="hKlasifikasi" value="<%= filter.klasifikasi || '' %>">
      <input type="hidden" name="status"      id="hStatus"      value="<%= filter.status || '' %>">
      <input type="hidden" name="dateFrom"    id="hDateFrom"    value="<%= filter.dateFrom || '' %>">
      <input type="hidden" name="dateTo"      id="hDateTo"      value="<%= filter.dateTo || '' %>">
      <input type="hidden" name="dateMonth"   id="hDateMonth"   value="<%= filter.dateMonth || '' %>">
      <input type="hidden" name="dateYear"    id="hDateYear"    value="<%= filter.dateYear || '' %>">
      <input type="hidden" name="sort"        id="hSort"        value="<%= filter.sort || 'newest' %>">
      <input type="hidden" name="dateYear"    id="hDateYear"    value="<%= filter.dateYear || '' %>">

      <% const hasFilter = filter.status || filter.klasifikasi || filter.q || filter.dateFrom || filter.dateTo || filter.dateMonth || filter.dateYear; %>
      <div id="smActiveChips" class="filter-active-chips">
        <% if (filter.klasifikasi) { %><div class="filter-active-chip"><%= filter.klasifikasi %><button type="button" onclick="clearField('hKlasifikasi','<%= filter.klasifikasi %>')">×</button></div><% } %>
        <% if (filter.status) { %><div class="filter-active-chip"><%= filter.status.charAt(0).toUpperCase()+filter.status.slice(1) %><button type="button" onclick="clearField('hStatus','<%= filter.status %>')">×</button></div><% } %>
        <% if (filter.dateFrom || filter.dateTo) { %><div class="filter-active-chip"><%= filter.dateFrom||'?' %> s/d <%= filter.dateTo||'?' %><button type="button" onclick="clearDate()">×</button></div><% } %>
        <% if ((filter.dateMonth || filter.dateYear) && !filter.dateFrom && !filter.dateTo) { %><div class="filter-active-chip"><%= filter.dateMonth ? ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][parseInt(filter.dateMonth)]||'' : '' %> <%= filter.dateYear||'' %><button type="button" onclick="clearDate()">×</button></div><% } %>
      </div>

      <div class="filter-wrap">
        <button type="button" class="filter-btn <%= hasFilter ? 'has-filter' : '' %>" id="filterBtn" onclick="toggleFilterDropdown()">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M3 5h14M6 10h8M9 15h2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          Filter
          <% let fc=0; if(filter.klasifikasi)fc++; if(filter.status)fc++; if(filter.dateFrom||filter.dateTo||filter.dateMonth||filter.dateYear)fc++; %>
          <% if(fc>0){%><span class="filter-badge"><%=fc%></span><%}%>
        </button>
        <div class="filter-dropdown" id="filterDropdown">
          <div class="filter-section">
            <div class="filter-section-label">Klasifikasi</div>
            <div class="filter-chips">
              <button type="button" class="filter-chip <%= !filter.klasifikasi ? 'active':'' %>" onclick="setHidden('hKlasifikasi','')">Semua</button>
              <% ['Biasa','Penting','Segera','Mendesak'].forEach(k => { %>
              <button type="button" class="filter-chip <%= filter.klasifikasi===k ? 'active':'' %>" onclick="setHidden('hKlasifikasi','<%= k %>')"><%= k %></button>
              <% }) %>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Status</div>
            <div class="filter-chips">
              <button type="button" class="filter-chip <%= !filter.status ? 'active':'' %>" onclick="setHidden('hStatus','')">Semua</button>
              <% ['baru','dibaca','ditindaklanjuti','selesai'].forEach(s => { %>
              <button type="button" class="filter-chip <%= filter.status===s ? 'active':'' %>" onclick="setHidden('hStatus','<%= s %>')"><%= s.charAt(0).toUpperCase()+s.slice(1) %></button>
              <% }) %>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Tanggal</div>
            <div class="filter-chips" style="margin-bottom:8px;">
              <button type="button" class="filter-chip <%= (!filter.dateFrom&&!filter.dateTo&&!filter.dateMonth&&!filter.dateYear)?'active':'' %>" onclick="pickDateMode(this,'all')">Semua</button>
              <button type="button" class="filter-chip <%= (filter.dateFrom||filter.dateTo)?'active':'' %>" onclick="pickDateMode(this,'range')">Rentang</button>
              <button type="button" class="filter-chip <%= (filter.dateMonth||filter.dateYear)?'active':'' %>" onclick="pickDateMode(this,'month')">Bulan/Tahun</button>
            </div>
            <div id="smDateRange" style="display:<%= (filter.dateFrom||filter.dateTo)?'':'none' %>;">
              <div class="filter-date-row">
                <input type="date" id="inDateFrom" value="<%= filter.dateFrom||'' %>" oninput="document.getElementById('hDateFrom').value=this.value">
                <span class="filter-date-sep">s/d</span>
                <input type="date" id="inDateTo"   value="<%= filter.dateTo||'' %>"   oninput="document.getElementById('hDateTo').value=this.value">
              </div>
            </div>
            <div id="smDateMonth" style="display:<%= (filter.dateMonth||filter.dateYear)?'':'none' %>;">
              <div class="filter-date-row">
                <select id="inDateMonth" onchange="document.getElementById('hDateMonth').value=this.value">
                  <option value="">-- Bulan --</option>
                  <% [['01','Januari'],['02','Februari'],['03','Maret'],['04','April'],['05','Mei'],['06','Juni'],['07','Juli'],['08','Agustus'],['09','September'],['10','Oktober'],['11','November'],['12','Desember']].forEach(([v,l]) => { %>
                  <option value="<%= v %>" <%= filter.dateMonth===v?'selected':'' %>><%= l %></option>
                  <% }) %>
                </select>
                <select id="inDateYear" onchange="document.getElementById('hDateYear').value=this.value">
                  <option value="">-- Tahun --</option>
                  <% for(let y=new Date().getFullYear();y>=2020;y--){ %>
                  <option value="<%= y %>" <%= filter.dateYear==y?'selected':'' %>><%= y %></option>
                  <% } %>
                </select>
              </div>
            </div>
          </div>
          <div class="filter-section">
            <div class="filter-section-label">Urutan</div>
            <div class="filter-chips">
              <button type="button" class="filter-chip <%= (filter.sort||'newest')==='newest' ? 'active':'' %>" onclick="setHidden('hSort','newest');this.closest('.filter-chips').querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));this.classList.add('active')">Terbaru</button>
              <button type="button" class="filter-chip <%= filter.sort==='oldest' ? 'active':'' %>" onclick="setHidden('hSort','oldest');this.closest('.filter-chips').querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('active'));this.classList.add('active')">Terlama</button>
            </div>
          </div>
          <div class="filter-actions">
            <button type="button" class="btn btn-ghost" style="font-size:12.5px;padding:6px 14px;" onclick="window.location='/surat-masuk'">Reset</button>
            <button type="submit" class="btn btn-primary" style="font-size:12.5px;padding:6px 14px;">Terapkan</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <% if (surats.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M6 10h36a2 2 0 012 2v24a2 2 0 01-2 2H6a2 2 0 01-2-2V12a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M4 14l20 14L44 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Belum ada surat masuk yang dicatat.</p>
    <button class="btn btn-primary" style="margin-top:12px;" onclick="openModal()">Catat Surat Pertama</button>
  </div>
  <% } else { %>
  <%
  const tagClass = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
  const stClass  = { baru:'sm-baru', dibaca:'sm-dibaca', ditindaklanjuti:'sm-tindak', selesai:'sm-selesai' };
  const stLabel  = { baru:'Baru', dibaca:'Dibaca', ditindaklanjuti:'Ditindaklanjuti', selesai:'Selesai' };
  %>
  <div class="admin-table-wrap" style="overflow-x:auto;">
    <table class="dok-table">
      <thead>
        <tr>
          <th style="width:100px;">Klasifikasi</th>
          <th style="width:170px;">Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:160px;">Dari Instansi</th>
          <th style="width:110px;">Tgl Terima</th>
          <th style="width:120px;">Status</th>
          <th style="width:50px;text-align:center;">Lamp.</th>
        </tr>
      </thead>
      <tbody>
      <% surats.forEach(function(s) { %>
      <tr class="mail-item <%= s.status==='baru'?'unread':'' %>"
          data-tag="<%= s.klasifikasi.toLowerCase() %>"
          data-read="<%= s.status!=='baru' %>"
          data-search="<%= (s.perihal+' '+s.dariInstansi+' '+(s.nomorSurat||'')).toLowerCase() %>"
          onclick="window.location='/surat-masuk/<%= s._id %>'"
          style="cursor:pointer;">
        <td><span class="mail-tag <%= tagClass[s.klasifikasi]||'tag-normal' %>" style="font-size:11px;"><%= s.klasifikasi %></span></td>
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;">
          <%= s.nomorSurat || '—' %>
          <% if(s.status==='baru'){%><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--brand-500);margin-left:5px;vertical-align:middle;"></span><%}%>
        </td>
        <td>
          <div style="font-weight:<%= s.status==='baru'?'600':'400' %>;color:var(--gray-900);"><%= s.perihal %></div>
        </td>
        <td style="color:var(--gray-600);font-size:12.5px;"><%= s.dariInstansi %></td>
        <td style="font-size:12.5px;color:var(--gray-500);white-space:nowrap;"><%= formatDate(s.tanggalTerima) %></td>
        <td><span class="sm-status-badge <%= stClass[s.status] %>"><%= stLabel[s.status] %></span></td>
        <td style="text-align:center;">
          <% if(s.file){%>
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" style="color:var(--brand-500);"><path d="M13 2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7l-4-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          <%}%>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Modal: Catat Surat Masuk -->
<div class="modal-overlay" id="smModal" onclick="closeModal(event)">
  <div class="modal-card modal-card-lg" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title">Catat Surat Masuk</h3>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form action="/surat-masuk" method="POST" enctype="multipart/form-data" class="compose-form" style="padding:16px 24px 24px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Dari Instansi / Pengirim <span class="req">*</span></label>
          <input type="text" name="dariInstansi" class="form-control" placeholder="Nama instansi atau organisasi pengirim" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Nomor Surat</label>
          <input type="text" name="nomorSurat" class="form-control" placeholder="Contoh: 001/BPJS/VI/2026">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Perihal <span class="req">*</span></label>
        <input type="text" name="perihal" class="form-control" placeholder="Isi pokok surat" required>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Tanggal Surat</label>
          <input type="date" name="tanggalSurat" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">Tanggal Diterima <span class="req">*</span></label>
          <input type="date" name="tanggalTerima" class="form-control"
            value="<%= new Date().toISOString().substring(0,10) %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Klasifikasi</label>
          <div class="select-wrap">
            <select name="klasifikasi" class="form-control form-select">
              <option value="Biasa">Biasa</option>
              <option value="Penting">Penting</option>
              <option value="Segera">Segera</option>
              <option value="Mendesak">Mendesak</option>
            </select>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Upload Scan Surat</label>
        <div class="sm-upload-area" onclick="document.getElementById('fileSurat').click()">
          <input type="file" id="fileSurat" name="fileSurat" accept=".pdf,.jpg,.jpeg,.png" style="display:none;" onchange="showFileName(this)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="display:block;margin:0 auto;"><path d="M12 5v10M8 9l4-4 4 4M5 18h14" stroke="var(--brand-500)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p id="uploadLabel" style="font-size:12.5px;color:var(--gray-500);text-align:center;margin-top:6px;">
            Klik untuk unggah scan surat<br>
            <span style="font-size:11px;color:var(--gray-400);">PDF, JPG, PNG — maks. 10MB</span>
          </p>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Catatan</label>
        <textarea name="catatan" class="form-control textarea" rows="2" placeholder="Disposisi, tindak lanjut, atau catatan tambahan..."></textarea>
      </div>
      <div class="compose-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Batal</button>
        <button type="submit" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Simpan Catatan
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// ── FILTER DROPDOWN (server-side form) ──
function toggleFilterDropdown() {
  document.getElementById('filterDropdown').classList.toggle('open');
}
document.addEventListener('click', e => {
  const wrap = document.querySelector('.filter-wrap');
  if (wrap && !wrap.contains(e.target)) document.getElementById('filterDropdown')?.classList.remove('open');
});
function setHidden(id, val) {
  document.getElementById(id).value = val;
  document.getElementById(id).closest('form').querySelector('.filter-chip.active')?.classList.remove('active');
  event.currentTarget.classList.add('active');
}
function pickDateMode(btn, mode) {
  btn.closest('.filter-chips').querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('smDateRange').style.display  = mode === 'range' ? '' : 'none';
  document.getElementById('smDateMonth').style.display  = mode === 'month' ? '' : 'none';
  if (mode === 'all') {
    ['hDateFrom','hDateTo','hDateMonth','hDateYear'].forEach(id => document.getElementById(id).value = '');
  }
}
function clearField(id, val) {
  document.getElementById(id).value = '';
  document.getElementById('smForm').submit();
}
function clearDate() {
  ['hDateFrom','hDateTo','hDateMonth','hDateYear'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('smForm').submit();
}

function openModal() {
  document.getElementById('smModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(e) {
  if (e && e.target !== document.getElementById('smModal')) return;
  document.getElementById('smModal').classList.remove('open');
  document.body.style.overflow = '';
}
function showFileName(input) {
  const label = document.getElementById('uploadLabel');
  if (input.files[0]) {
    const name = input.files[0].name;
    const size = (input.files[0].size / 1024).toFixed(0);
    label.innerHTML = `<strong>${name}</strong><br><span style="font-size:11px;color:var(--gray-400);">${size} KB</span>`;
  }
}
</script>

<%- include('./partials/footer') %>
