<%- include('./partials/header') %>

<div class="page-header">
  <div class="page-title-group">
    <div class="page-breadcrumb"><a href="/inbox">Dashboard</a> / Surat Masuk</div>
    <h1 class="page-title">Surat Masuk</h1>
    <p class="page-subtitle">Pencatatan surat masuk dari instansi / pihak eksternal</p>
  </div>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      Catat Surat Masuk
    </button>
  </div>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="flash-msg flash-error">
  <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  <%= error %>
</div>
<% } %>

<!-- Stats -->
<div class="stats-bar" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon blue">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 4h14a1 1 0 011 1v9a1 1 0 01-1 1H3a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/><path d="M2 7l8 5 8-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Total Masuk</div><div class="stat-value"><%= stats.total || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Baru</div><div class="stat-value"><%= stats.baru || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div><div class="stat-label">Ditindaklanjuti</div><div class="stat-value"><%= stats.ditindaklanjuti || 0 %></div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div><div class="stat-label">Selesai</div><div class="stat-value"><%= stats.selesai || 0 %></div></div>
  </div>
</div>

<!-- List -->
<div class="mail-list-wrap">
  <!-- TABS -->
  <div class="dok-tabs" style="padding:0 16px;">
    <a href="#" class="dok-tab active" onclick="filterTab('all',this)">Semua <span class="tab-count"><%= surats.length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('baru',this)">Baru <span class="tab-count"><%= surats.filter(s=>s.status==='baru').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('dibaca',this)">Dibaca <span class="tab-count"><%= surats.filter(s=>s.status==='dibaca').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('ditindaklanjuti',this)">Ditindaklanjuti <span class="tab-count"><%= surats.filter(s=>s.status==='ditindaklanjuti').length %></span></a>
    <a href="#" class="dok-tab" onclick="filterTab('selesai',this)">Selesai <span class="tab-count"><%= surats.filter(s=>s.status==='selesai').length %></span></a>
  </div>
  <!-- SEARCH -->
  <div class="dok-search">
    <input type="text" id="smSearchBox" class="form-control" style="font-size:13px;" placeholder="Cari perihal, instansi, nomor surat..." oninput="filterSearch()">
    <a href="/surat-masuk" class="btn btn-ghost" style="padding:7px 12px;font-size:13px;">Reset</a>
  </div>

  <% if (surats.length === 0) { %>
  <div class="empty-state">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M6 10h36a2 2 0 012 2v24a2 2 0 01-2 2H6a2 2 0 01-2-2V12a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M4 14l20 14L44 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <p>Belum ada surat masuk yang dicatat.</p>
    <button class="btn btn-primary" style="margin-top:12px;" onclick="openModal()">Catat Surat Pertama</button>
  </div>
  <% } else { %>
  <%
  const tagClass = { Biasa:'tag-normal', Penting:'tag-penting', Segera:'tag-info', Mendesak:'tag-urgent', Normal:'tag-normal', Urgent:'tag-urgent', Info:'tag-info' };
  const stClass  = { baru:'sm-baru', dibaca:'sm-dibaca', ditindaklanjuti:'sm-tindak', selesai:'sm-selesai' };
  const stLabel  = { baru:'Baru', dibaca:'Dibaca', ditindaklanjuti:'Ditindaklanjuti', selesai:'Selesai' };
  %>
  <div style="overflow-x:auto;">
    <table class="dok-table" id="smTable">
      <thead>
        <tr>
          <th style="width:100px;">Klasifikasi</th>
          <th style="width:170px;">Nomor Surat</th>
          <th>Perihal / Subjek</th>
          <th style="width:160px;">Dari Instansi</th>
          <th style="width:110px;">Tgl Terima</th>
          <th style="width:120px;">Status</th>
          <th style="width:50px;text-align:center;">Lamp.</th>
        </tr>
      </thead>
      <tbody>
      <% surats.forEach(function(s) { %>
      <tr class="mail-item <%= s.status==='baru'?'unread':'' %>"
          data-tag="<%= s.klasifikasi.toLowerCase() %>"
          data-status="<%= s.status %>"
          data-read="<%= s.status!=='baru' %>"
          data-search="<%= (s.perihal+' '+s.dariInstansi+' '+(s.nomorSurat||'')).toLowerCase() %>"
          onclick="window.location='/surat-masuk/<%= s._id %>'"
          style="cursor:pointer;">
        <td><span class="dok-tipe-badge tipe-lain" style="font-size:11px;"><%= s.klasifikasi %></span></td>
        <td style="font-family:monospace;font-size:12px;color:var(--brand-700);font-weight:600;">
          <% if(s.status==='baru'){%><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--brand-500);margin-right:5px;vertical-align:middle;"></span><%}%><%= s.nomorSurat || '—' %>
        </td>
        <td>
          <div style="font-weight:<%= s.status==='baru'?'600':'400' %>;color:var(--gray-900);"><%= s.perihal %></div>
        </td>
        <td style="color:var(--gray-600);font-size:12.5px;"><%= s.dariInstansi %></td>
        <td style="font-size:12.5px;color:var(--gray-500);white-space:nowrap;"><%= formatDate(s.tanggalTerima) %></td>
        <td>
          <% const stStyleMap = {baru:'background:#eff6ff;color:#1d4ed8',dibaca:'background:var(--gray-100);color:var(--gray-600)',ditindaklanjuti:'background:#fef3c7;color:#92400e',selesai:'background:#f0fdf4;color:#15803d'}; %>
          <span style="font-size:11px;font-weight:600;padding:2px 9px;border-radius:20px;display:inline-block;<%= stStyleMap[s.status]||'' %>"><%= stLabel[s.status] %></span>
        </td>
        <td style="text-align:center;">
          <% if(s.file){%>
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" style="color:var(--brand-500);"><path d="M13 2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7l-4-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          <%}%>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Modal: Catat Surat Masuk -->
<div class="modal-overlay" id="smModal" onclick="closeModal(event)">
  <div class="modal-card modal-card-lg" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3 class="modal-title">Catat Surat Masuk</h3>
      <button class="modal-close" onclick="closeModal()">&times;</button>
    </div>
    <form action="/surat-masuk" method="POST" enctype="multipart/form-data" class="compose-form" style="padding:16px 24px 24px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Dari Instansi / Pengirim <span class="req">*</span></label>
          <input type="text" name="dariInstansi" class="form-control" placeholder="Nama instansi atau organisasi pengirim" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Nomor Surat</label>
          <input type="text" name="nomorSurat" class="form-control" placeholder="Contoh: 001/BPJS/VI/2026">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Perihal <span class="req">*</span></label>
        <input type="text" name="perihal" class="form-control" placeholder="Isi pokok surat" required>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;">
        <div class="form-group">
          <label class="form-label">Tanggal Surat</label>
          <input type="date" name="tanggalSurat" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">Tanggal Diterima <span class="req">*</span></label>
          <input type="date" name="tanggalTerima" class="form-control"
            value="<%= new Date().toISOString().substring(0,10) %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Klasifikasi</label>
          <div class="select-wrap">
            <select name="klasifikasi" class="form-control form-select">
              <option value="Biasa">Biasa</option>
              <option value="Penting">Penting</option>
              <option value="Segera">Segera</option>
              <option value="Mendesak">Mendesak</option>
            </select>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Upload Scan Surat</label>
        <div class="sm-upload-area" onclick="document.getElementById('fileSurat').click()">
          <input type="file" id="fileSurat" name="fileSurat" accept=".pdf,.jpg,.jpeg,.png" style="display:none;" onchange="showFileName(this)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" style="display:block;margin:0 auto;"><path d="M12 5v10M8 9l4-4 4 4M5 18h14" stroke="var(--brand-500)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p id="uploadLabel" style="font-size:12.5px;color:var(--gray-500);text-align:center;margin-top:6px;">
            Klik untuk unggah scan surat<br>
            <span style="font-size:11px;color:var(--gray-400);">PDF, JPG, PNG — maks. 10MB</span>
          </p>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Catatan</label>
        <textarea name="catatan" class="form-control textarea" rows="2" placeholder="Disposisi, tindak lanjut, atau catatan tambahan..."></textarea>
      </div>
      <div class="compose-actions">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Batal</button>
        <button type="submit" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Simpan Catatan
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// ── FILTER TABS + SEARCH (client-side) ──
let activeTab = 'all';
function filterTab(tab, el) {
  activeTab = tab;
  document.querySelectorAll('.dok-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  filterSearch();
  return false;
}
function filterSearch() {
  const q = (document.getElementById('smSearchBox').value || '').toLowerCase();
  document.querySelectorAll('#smTable tbody tr').forEach(row => {
    const search = (row.dataset.search || '');
    const status = (row.dataset.status || '');
    let show = true;
    if (activeTab !== 'all') show = status === activeTab;
    if (show && q) show = search.includes(q);
    row.style.display = show ? '' : 'none';
  });
}

function openModal() {
  document.getElementById('smModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(e) {
  if (e && e.target !== document.getElementById('smModal')) return;
  document.getElementById('smModal').classList.remove('open');
  document.body.style.overflow = '';
}
function showFileName(input) {
  const label = document.getElementById('uploadLabel');
  if (input.files[0]) {
    const name = input.files[0].name;
    const size = (input.files[0].size / 1024).toFixed(0);
    label.innerHTML = `<strong>${name}</strong><br><span style="font-size:11px;color:var(--gray-400);">${size} KB</span>`;
  }
}
</script>

<%- include('./partials/footer') %>
