<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Kata Sandi — Inspira Mailer</title>
<link rel="icon" type="image/png" href="/img/Group 1597880519.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">

<div class="auth-wrap auth-wrap-center">
  <div class="auth-panel auth-panel-sm">
    <div class="auth-brand">
      <img src="/img/Group 1597880519.png" alt="Inspira Logo" class="auth-logo">
      <div>
        <div class="auth-brand-name">Inspira Mailer</div>
        <div class="auth-brand-sub">Sistem Surat Dinas Digital</div>
      </div>
    </div>

    <div class="auth-icon-wrap">
      <div class="auth-icon-circle">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M10 14l3 3 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.8"/></svg>
      </div>
    </div>

    <h1 class="auth-title">Buat Kata Sandi Baru</h1>
    <p class="auth-desc">Masukkan kata sandi baru Anda di bawah ini.</p>

    <% if (error) { %>
    <div class="auth-alert auth-alert-error">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 7v3M10 13h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <%= error %>
    </div>
    <% } %>
    <% if (success) { %>
    <div class="auth-alert auth-alert-success">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= success %>
    </div>
    <% } %>

    <% if (token && !success) { %>
    <form action="/reset-password/<%= token %>" method="POST" class="auth-form">
      <div class="auth-field">
        <label class="auth-label" for="password">Kata Sandi Baru <span class="auth-req">*</span></label>
        <div class="auth-input-group">
          <input
            type="password"
            id="password"
            name="password"
            class="auth-input"
            placeholder="Min. 8 karakter"
            required
            autofocus
            autocomplete="new-password"
          >
          <button type="button" class="auth-eye" onclick="toggleVisibility('password','eye1')" tabindex="-1">
            <svg id="eye1" width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          </button>
        </div>
      </div>
      <div class="auth-field">
        <label class="auth-label" for="password2">Konfirmasi Kata Sandi <span class="auth-req">*</span></label>
        <div class="auth-input-group">
          <input
            type="password"
            id="password2"
            name="password2"
            class="auth-input"
            placeholder="Ulangi kata sandi baru"
            required
            autocomplete="new-password"
          >
          <button type="button" class="auth-eye" onclick="toggleVisibility('password2','eye2')" tabindex="-1">
            <svg id="eye2" width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="auth-btn">Simpan Kata Sandi Baru</button>
    </form>
    <% } %>

    <p class="auth-footer-text">
      <a href="/login" class="auth-link auth-back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Kembali ke halaman masuk
      </a>
    </p>
  </div>
</div>

<script>
function toggleVisibility(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M3 3l14 14M9.88 9.88A3 3 0 0110 7a3 3 0 013 3 3 3 0 01-.12.88M10.73 14.95A7 7 0 013 10s2-5 7-5a7 7 0 013.27.79M17 10s-2 5-7 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M3 10s2-5 7-5 7 5 7 5-2 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>';
  }
}
</script>
</body>
</html>
